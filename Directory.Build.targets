<Project>
  <PropertyGroup>
    <!--
      Project-specific requirement:
      every deployed .NET project must carry the same deployment version shown
      on the Command Center System Status screen.

      Directory.Build.targets is imported after each .csproj, so these values
      intentionally override stale project-local <Version> values such as 2.0.0
      or 2.1.0.
    -->
    <ArgusEngineDeploymentVersion>2.2.0</ArgusEngineDeploymentVersion>
    <Version>$(ArgusEngineDeploymentVersion)</Version>
    <PackageVersion>$(ArgusEngineDeploymentVersion)</PackageVersion>
    <AssemblyVersion>2.2.0.0</AssemblyVersion>
    <FileVersion>2.2.0.0</FileVersion>
    <InformationalVersion>$(ArgusEngineDeploymentVersion)</InformationalVersion>
  </PropertyGroup>

  <Target Name="ValidateArgusEngineDeploymentVersion" BeforeTargets="GenerateAssemblyInfo">
    <Error
      Condition="'$(ArgusEngineDeploymentVersion)' == ''"
      Text="ArgusEngineDeploymentVersion must be set before deploying." />
    <Error
      Condition="'$(Version)' != '$(ArgusEngineDeploymentVersion)'"
      Text="Project version $(Version) does not match ArgusEngineDeploymentVersion $(ArgusEngineDeploymentVersion)." />
  </Target>
</Project>
