// Add this section to appsettings.json in both:
// src/ArgusEngine.CommandCenter.Web/appsettings.json
// src/ArgusEngine.CommandCenter.CloudDeploy.Api/appsettings.json
//
// Sensitive values (passwords, URLs with creds) go in appsettings.Local.json
// or user-secrets — never committed.
{
  "GcpDeploy": {
    "ProjectId": "your-gcp-project-id",
    "Region": "us-central1",
    "GarRepository": "argus-engine",

    // Leave blank to generate a pinned tag from VERSION + git short SHA.
    // Do not use "latest"; startup validation rejects it.
    "ImageTag": "",

    "WorkerProjectPaths": {
      "Enumeration": "src/ArgusEngine.Workers.Enumeration/ArgusEngine.Workers.Enumeration.csproj",
      "Spider": "src/ArgusEngine.Workers.Spider/ArgusEngine.Workers.Spider.csproj",
      "HttpRequester": "src/ArgusEngine.Workers.HttpRequester/ArgusEngine.Workers.HttpRequester.csproj",
      "PortScan": "src/ArgusEngine.Workers.PortScan/ArgusEngine.Workers.PortScan.csproj",
      "HighValue": "src/ArgusEngine.Workers.HighValue/ArgusEngine.Workers.HighValue.csproj",
      "TechnologyIdentification": "src/ArgusEngine.Workers.TechnologyIdentification/ArgusEngine.Workers.TechnologyIdentification.csproj"
    },

    "WorkerMinInstances": 2,
    "WorkerMaxInstances": 10,
    "WorkerConcurrency": 4,
    "WorkerCpu": "1",
    "WorkerMemory": "512Mi",

    // Set these to the public IP/hostname of the machine running core services
    "HostPublicAddress": "",
    "RabbitMqPublicUrl": "amqp://argus:CHANGE_ME@YOUR_HOST_IP:5672/argus",
    "PostgresPublicUrl": "Host=YOUR_HOST_IP;Port=5432;Database=argus;Username=argus;Password=CHANGE_ME",
    "RedisPublicUrl": "YOUR_HOST_IP:6379",
    "CommandCenterApiUrl": "http://YOUR_HOST_IP:8080",

    "CoreComposeFile": "deployment/docker-compose.yml"
  }
}

