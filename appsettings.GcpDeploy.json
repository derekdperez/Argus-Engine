// Add this section to appsettings.json in both:
//   src/ArgusEngine.CommandCenter.Web/appsettings.json
//   src/ArgusEngine.CommandCenter.CloudDeploy.Api/appsettings.json
//
// Sensitive values (passwords, URLs with creds) go in appsettings.Local.json
// or user-secrets — never committed.

{
  "GcpDeploy": {
    "ProjectId": "your-gcp-project-id",
    "Region": "us-central1",
    "GarRepository": "argus-engine",
    "ImageTag": "latest",

    "WorkerMinInstances": 0,
    "WorkerMaxInstances": 10,
    "WorkerConcurrency": 4,
    "WorkerCpu": "1",
    "WorkerMemory": "512Mi",

    // Set these to the public IP/hostname of the machine running core services
    "HostPublicAddress": "",
    "RabbitMqPublicUrl": "amqp://argus:CHANGE_ME@YOUR_HOST_IP:5672/argus",
    "PostgresPublicUrl": "Host=YOUR_HOST_IP;Port=5432;Database=argus;Username=argus;Password=CHANGE_ME",
    "RedisPublicUrl": "YOUR_HOST_IP:6379",
    "CommandCenterApiUrl": "http://YOUR_HOST_IP:8080",

    "CoreComposeFile": "deploy/docker-compose.core.yml"
  }
}

// ─── Registration in CommandCenter.Web Program.cs ────────────────────────────
//
// Add one line to the existing service registration:
//
//   builder.Services.AddGcpHybridDeploy(builder.Configuration);
//
// This makes IGcpHybridDeployService available for direct injection in Blazor
// pages (including CloudDeploy.razor).
//
