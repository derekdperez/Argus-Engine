# syntax=docker/dockerfile:1.7
# Zero-download recon tool image.
#
# Refresh the committed binaries with deploy/vendor-recon-tools.sh. Builds should
# fail fast if these artifacts are absent instead of compiling Go tools during
# deployment.
FROM scratch
COPY --chmod=0755 artifacts/recon-tools/linux-amd64/subfinder /subfinder
COPY --chmod=0755 artifacts/recon-tools/linux-amd64/amass /amass
