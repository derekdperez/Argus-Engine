# syntax=docker/dockerfile:1.7
# Build context: repository root. Optimized for incremental feedback-loop builds.

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build

WORKDIR /src

# Copy project files first so NuGet restore is cached when only .cs/.razor/css/js files change.
COPY Directory.Build.props Directory.Build.targets NightmareV2.slnx ./
COPY src/NightmareV2.Application/NightmareV2.Application.csproj src/NightmareV2.Application/
COPY src/NightmareV2.CommandCenter/NightmareV2.CommandCenter.csproj src/NightmareV2.CommandCenter/
COPY src/NightmareV2.Contracts/NightmareV2.Contracts.csproj src/NightmareV2.Contracts/
COPY src/NightmareV2.Domain/NightmareV2.Domain.csproj src/NightmareV2.Domain/
COPY src/NightmareV2.Infrastructure/NightmareV2.Infrastructure.csproj src/NightmareV2.Infrastructure/

RUN --mount=type=cache,id=nightmare-nuget,target=/root/.nuget/packages,sharing=locked \
    dotnet restore "src/NightmareV2.CommandCenter/NightmareV2.CommandCenter.csproj"

# Copy only the project dependency closure used by the web app. Unrelated worker edits no longer invalidate this layer.
COPY src/NightmareV2.Application/ src/NightmareV2.Application/
COPY src/NightmareV2.CommandCenter/ src/NightmareV2.CommandCenter/
COPY src/NightmareV2.Contracts/ src/NightmareV2.Contracts/
COPY src/NightmareV2.Domain/ src/NightmareV2.Domain/
COPY src/NightmareV2.Infrastructure/ src/NightmareV2.Infrastructure/
COPY src/Resources/ src/Resources/

ARG COMPONENT_VERSION=2.3.0

RUN --mount=type=cache,id=nightmare-nuget,target=/root/.nuget/packages,sharing=locked \
    dotnet publish "src/NightmareV2.CommandCenter/NightmareV2.CommandCenter.csproj" \
      -c Release -o /app/publish --no-restore /p:UseAppHost=false \
      /p:Version="${COMPONENT_VERSION}" \
      /p:AssemblyVersion="2.3.0.0" \
      /p:FileVersion="2.3.0.0" \
      /p:InformationalVersion="${COMPONENT_VERSION}" \
    && test -s /app/publish/wwwroot/_framework/blazor.web.js \
    && ! grep -q "^404: Not Found" /app/publish/wwwroot/_framework/blazor.web.js

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final

# Npgsql can dlopen Kerberos for Postgres auth negotiation; slim runtime image omits it by default.
# curl: Docker HEALTHCHECK + manual probes.
# docker.io: CLI used by /api/ops/docker-status for runtime container/image/log inspection.
RUN apt-get update \
    && apt-get install -y --no-install-recommends libgssapi-krb5-2 curl docker.io \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENV ASPNETCORE_URLS=http://+:8080
# Blazor Server components call this app's own JSON endpoints from inside the container.
ENV Nightmare__CommandCenterInternalBaseUrl=http://127.0.0.1:8080/
ENV Argus__CommandCenterInternalBaseUrl=http://127.0.0.1:8080/

# Avoid HTTPS redirect/HSTS when only HTTP is bound.
ENV Nightmare__ListenPlainHttp=true
ENV Argus__ListenPlainHttp=true

EXPOSE 8080

COPY --from=build /app/publish .

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD curl -fsS http://127.0.0.1:8080/health/ready >/dev/null || exit 1

ARG BUILD_SOURCE_STAMP=unknown
ARG COMPONENT_VERSION=2.3.0

LABEL org.opencontainers.image.title="Argus Engine Command Center"
LABEL org.opencontainers.image.description="Command Center for Argus Engine"
LABEL org.opencontainers.image.revision="${BUILD_SOURCE_STAMP}"
LABEL org.opencontainers.image.version="${COMPONENT_VERSION}"

ENV ARGUS_BUILD_STAMP=${BUILD_SOURCE_STAMP}
ENV NIGHTMARE_BUILD_STAMP=${BUILD_SOURCE_STAMP}
ENV ARGUS_COMPONENT_VERSION=${COMPONENT_VERSION}
ENV NIGHTMARE_COMPONENT_VERSION=${COMPONENT_VERSION}

ENTRYPOINT ["dotnet", "NightmareV2.CommandCenter.dll"]
