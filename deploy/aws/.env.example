AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
ECS_CLUSTER=nightmare-v2
IMAGE_TAG=latest

# One ECR repository per service. Create them once with create-ecr-repos.sh.
ECR_PREFIX=nightmare-v2

COMMAND_CENTER_SERVICE=nightmare-command-center
GATEKEEPER_SERVICE=nightmare-gatekeeper
WORKER_SPIDER_SERVICE=nightmare-worker-spider
WORKER_ENUM_SERVICE=nightmare-worker-enum
WORKER_PORTSCAN_SERVICE=nightmare-worker-portscan
WORKER_HIGHVALUE_SERVICE=nightmare-worker-highvalue
WORKER_TECHID_SERVICE=nightmare-worker-techid

# Public or private reachable Command Center URL for the autoscaler.
COMMAND_CENTER_URL=http://localhost:8080

# Queue-based scaling knobs.
HTTP_QUEUE_TARGET_BACKLOG_PER_TASK=100
HTTP_QUEUE_MIN_TASKS=1
HTTP_QUEUE_MAX_TASKS=50

# ECS service reconciliation. SERVICE_ENV_FILE must point at a non-committed env file
# copied from deploy/aws/service-env.example with production Postgres/Redis/RabbitMQ values.
SERVICE_ENV_FILE=deploy/aws/service-env
ECS_LAUNCH_TYPE=FARGATE
ECS_NETWORK_MODE=awsvpc
ECS_SUBNETS=subnet-aaaaaaaa,subnet-bbbbbbbb
ECS_SECURITY_GROUPS=sg-aaaaaaaa
ECS_ASSIGN_PUBLIC_IP=DISABLED
ECS_TASK_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/nightmare-v2-ecs-task-execution
ECS_TASK_ROLE_ARN=arn:aws:iam::123456789012:role/nightmare-v2-ecs-task
ECS_LOG_GROUP=/ecs/nightmare-v2
ECS_LOG_PREFIX=nightmare-v2
UPDATE_DESIRED_COUNTS=false

# Per-service initial desired counts and task resources used by deploy-ecs-services.sh.
ECS_DESIRED_COMMAND_CENTER=1
ECS_DESIRED_GATEKEEPER=1
ECS_DESIRED_WORKER_SPIDER=1
ECS_DESIRED_WORKER_ENUM=1
ECS_DESIRED_WORKER_PORTSCAN=1
ECS_DESIRED_WORKER_HIGHVALUE=1
ECS_DESIRED_WORKER_TECHID=1
ECS_CPU_COMMAND_CENTER=1024
ECS_MEMORY_COMMAND_CENTER=2048
ECS_CPU_WORKER_SPIDER=1024
ECS_MEMORY_WORKER_SPIDER=2048
ECS_CPU_WORKER_ENUM=1024
ECS_MEMORY_WORKER_ENUM=2048

# Queue-driven ECS autoscaling. Minimums default to 1 so each worker class stays warm.
ECS_MIN_WORKER_SPIDER=1
ECS_MAX_WORKER_SPIDER=50
ECS_TARGET_BACKLOG_PER_TASK_WORKER_SPIDER=100
ECS_MIN_WORKER_ENUM=1
ECS_MAX_WORKER_ENUM=20
ECS_TARGET_BACKLOG_PER_TASK_WORKER_ENUM=25
ECS_MIN_WORKER_PORTSCAN=1
ECS_MAX_WORKER_PORTSCAN=20
ECS_TARGET_BACKLOG_PER_TASK_WORKER_PORTSCAN=100
ECS_MIN_WORKER_HIGHVALUE=1
ECS_MAX_WORKER_HIGHVALUE=20
ECS_TARGET_BACKLOG_PER_TASK_WORKER_HIGHVALUE=100
ECS_MIN_WORKER_TECHID=1
ECS_MAX_WORKER_TECHID=20
ECS_TARGET_BACKLOG_PER_TASK_WORKER_TECHID=100
ECS_AUTOSCALER_UPDATE_TASK_DEFINITION=true

# EC2 Worker Scaling Configuration (for provision-ec2-workers.sh and deploy-worker-instances.sh)
# ===========================================
# EC2 instance configuration
WORKER_INSTANCE_TYPE=m7i-flex.large
WORKER_KEY_PAIR=kp1
WORKER_IAM_ROLE=ec2-iam
WORKER_SECURITY_GROUP=default

# Worker deployment
WORKER_COUNT=10
INSTANCE_COUNT=2
SSH_KEY_PATH=~/.ssh/kp1.pem
SSH_USER=ubuntu

# Optional: override the Go install package specs baked into worker images.
SUBFINDER_PACKAGE=github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest
AMASS_PACKAGE=github.com/owasp-amass/amass/v5/cmd/amass@main
