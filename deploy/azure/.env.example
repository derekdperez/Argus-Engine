# Azure deployment settings for Argus Engine.
# This file is copied to deploy/azure/.env on first run.
# The scripts prompt for any missing or placeholder values and write answers back to deploy/azure/.env.
#
# deploy/azure/.env is local machine config and should not be committed.

AZURE_SUBSCRIPTION_ID='CHANGE_ME'
AZURE_LOCATION='eastus'
AZURE_RESOURCE_GROUP='argus-engine-rg'
AZURE_CONTAINERAPPS_ENV='argus-engine-env'

# Must be globally unique across Azure, lowercase letters/numbers only, 5-50 chars.
AZURE_ACR_NAME='CHANGE_ME'

# Prefix used inside ACR: <acr>.azurecr.io/<prefix>/<service>:<tag>
AZURE_IMAGE_PREFIX='argus-engine'

# Usually match VERSION or ARGUS_ENGINE_VERSION.
IMAGE_TAG='latest'
ARGUS_ENGINE_VERSION='latest'
