# Google Cloud Run Worker Pools deployment settings for Argus workers.
# The scripts create this file automatically and prompt for required missing values.

# If this still says replace-with-project-id, the script will prompt for a real value.
GCP_PROJECT_ID=replace-with-project-id
GCP_REGION=us-central1

GCP_ARTIFACT_REPOSITORY=argus-engine
GCP_IMAGE_PREFIX=argus-engine
IMAGE_TAG=latest

# Non-committed runtime environment file with reachable Postgres/Redis/RabbitMQ endpoints.
# The deploy script will create this from service-env.example and ask you to edit placeholders.
SERVICE_ENV_FILE=deploy/gcp/service-env

# Optional Cloud Run service account for worker pools.
# GCP_SERVICE_ACCOUNT=argus-workers@replace-with-project-id.iam.gserviceaccount.com

# Optional private egress configuration.
# GCP_VPC_CONNECTOR=projects/PROJECT_ID/locations/REGION/connectors/CONNECTOR_NAME
# GCP_VPC_EGRESS=private-ranges-only
# GCP_VPC_EGRESS=all-traffic

# Optional: override services by space-delimited list.
# ARGUS_CLOUD_SERVICES="worker-spider worker-http-requester worker-enum worker-portscan worker-highvalue worker-techid"

# Default per-worker manual instance count for Worker Pools.
GCP_WORKER_INSTANCES=1

# Optional per-service overrides. Names use upper-case service keys with dashes replaced by underscores.
# GCP_WORKER_INSTANCES_WORKER_HTTP_REQUESTER=1
# GCP_CPU_WORKER_ENUM=1
# GCP_MEMORY_WORKER_ENUM=2Gi
