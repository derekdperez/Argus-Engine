    {
      "type": "timeseries",
      "title": "HTTP requests by status",
      "id": 5,
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "targets": [
        {
          "expr": "sum by (status_code) (rate(argus_http_requests_completed_total[5m]))",
