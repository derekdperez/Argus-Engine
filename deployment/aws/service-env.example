# Copy to deployment/aws/service-env and replace with production values.
# Use routable hostnames/IPs that resolve from ECS tasks in your VPC; the compose
# hostnames below are examples only.
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=argus_engine;Username=argus;Password=argus
ConnectionStrings__FileStore=Host=postgres;Port=5432;Database=argus_engine_files;Username=argus;Password=argus
Nightmare__Postgres__MaxPoolSize=8
Nightmare__FileStore__MaxPoolSize=4
ConnectionStrings__Redis=redis:6379
RabbitMq__Host=rabbitmq
RabbitMq__Username=nightmare
RabbitMq__Password=nightmare
RabbitMq__VirtualHost=/
RabbitMq__ManagementUrl=http://rabbitmq:15672
Nightmare__ListenPlainHttp=true

# Worker task definitions should set this to true. Let command-center perform schema bootstrap once.
# Nightmare__SkipStartupDatabase=true
# NIGHTMARE_SKIP_STARTUP_DATABASE=1


# Worker-enum subdomain enumeration defaults. Keep these in the worker-enum ECS task definition.
Enumeration__UseSubfinder=true
Enumeration__SubfinderPath=/usr/local/bin/subfinder
Enumeration__SubfinderAllSources=true
Enumeration__SubfinderRecursive=true
Enumeration__SubfinderTimeoutSeconds=180
Enumeration__UseAmass=true
Enumeration__AmassPath=/usr/local/bin/amass
Enumeration__AmassActive=true
Enumeration__AmassBruteForce=true
Enumeration__AmassTimeoutSeconds=900
Enumeration__UseDnsFallback=true
Enumeration__DnsFallbackMaxCandidates=300
Enumeration__SubdomainWordlistPath=/opt/nightmare/wordlists/subdomains.txt
