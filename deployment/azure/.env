# Azure deployment settings for Argus Engine.
# Generated from values provided in ChatGPT conversation.
# This file is local deployment config; deployment/azure/.env is intentionally gitignored by the helper scripts.

AZURE_SUBSCRIPTION_ID='0f86d6db-2b36-47e8-ab8e-9ba7591f4d30'
AZURE_LOCATION='eastus'
AZURE_RESOURCE_GROUP='argus-engine-rg'
AZURE_CONTAINERAPPS_ENV='argus-engine-env'

# Must be globally unique across Azure, lowercase letters/numbers only, 5-50 chars.
AZURE_ACR_NAME='argusengine0f86d6db'
AZURE_ACR_SKU='Basic'

# Prefix used inside ACR: <acr>.azurecr.io/<prefix>/<service>:<tag>
AZURE_IMAGE_PREFIX='argus-engine'

# Image/build version.
IMAGE_TAG='latest'
ARGUS_ENGINE_VERSION='latest'

# Runtime env file used by deploy-containerapps-workers.sh.
SERVICE_ENV_FILE='deployment/azure/service-env'

# Default worker scaling.
AZURE_MIN_REPLICAS='1'
AZURE_MAX_REPLICAS='3'

# Default worker resource sizing.
AZURE_CONTAINER_CPU='0.5'
AZURE_CONTAINER_MEMORY='1.0Gi'
