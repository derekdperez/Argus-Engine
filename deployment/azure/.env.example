# Azure Container Apps deployment settings for Argus workers.
# The scripts create this file automatically and prompt for required missing values.

AZURE_SUBSCRIPTION_ID=
AZURE_LOCATION=eastus
AZURE_RESOURCE_GROUP=argus-engine-rg
AZURE_CONTAINERAPPS_ENV=argus-engine-env

# Must be globally unique, 5-50 chars, lowercase alphanumeric only.
# If this still says argusengineacrreplace, the script will prompt for a real value.
AZURE_ACR_NAME=argusengineacrreplace
AZURE_ACR_SKU=Basic

AZURE_IMAGE_PREFIX=argus-engine
IMAGE_TAG=latest

# Non-committed runtime environment file with reachable Postgres/Redis/RabbitMQ endpoints.
# The deploy script will create this from service-env.example and ask you to edit placeholders.
SERVICE_ENV_FILE=deployment/azure/service-env

# Optional: override services by space-delimited list.
# ARGUS_CLOUD_SERVICES="worker-spider worker-http-requester worker-enum worker-portscan worker-highvalue worker-techid"

# Default per-worker capacity.
AZURE_MIN_REPLICAS=1
AZURE_MAX_REPLICAS=3

# Optional per-service overrides. Names use upper-case service keys with dashes replaced by underscores.
# AZURE_MIN_REPLICAS_WORKER_HTTP_REQUESTER=1
# AZURE_MAX_REPLICAS_WORKER_HTTP_REQUESTER=1
# AZURE_CPU_WORKER_ENUM=1.0
# AZURE_MEMORY_WORKER_ENUM=2.0Gi
