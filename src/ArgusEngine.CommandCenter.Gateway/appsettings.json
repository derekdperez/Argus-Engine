{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CommandCenter": {
    "Gateway": {
      "Services": {
        "Web": "http://command-center-web:8080/",
        "Discovery": "http://command-center-discovery-api:8080/",
        "Operations": "http://command-center-operations-api:8080/",
        "WorkerControl": "http://command-center-worker-control-api:8080/",
        "Maintenance": "http://command-center-maintenance-api:8080/",
        "Updates": "http://command-center-updates-api:8080/",
        "Realtime": "http://command-center-realtime:8080/"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "ops_and_status": {
        "ClusterId": "operations-api",
        "Match": {
          "Path": "/api/ops/{**catch-all}"
        }
      },
      "status_summary": {
        "ClusterId": "operations-api",
        "Match": {
          "Path": "/api/status/summary"
        }
      },
      "restarts": {
        "ClusterId": "worker-control-api",
        "Match": {
          "Path": "/api/ops/{tool}/restart"
        }
      },
      "discovery": {
        "ClusterId": "discovery-api",
        "Match": {
          "Path": "/api/{catch-all}",
          "Hosts": [ "targets", "assets", "tags", "technologies", "technology-identification", "http-request-queue", "high-value-findings", "asset-admission-decisions", "filestore", "events" ]
        }
      },
      "maintenance": {
        "ClusterId": "maintenance-api",
        "Match": {
          "Path": "/api/{catch-all}",
          "Hosts": [ "admin", "maintenance", "diagnostics", "bus" ]
        }
      },
      "workers": {
        "ClusterId": "worker-control-api",
        "Match": {
          "Path": "/api/workers/{**catch-all}"
        }
      },
      "ec2_workers": {
        "ClusterId": "worker-control-api",
        "Match": {
          "Path": "/api/ec2-workers/{**catch-all}"
        }
      },
      "updates": {
        "ClusterId": "updates-api",
        "Match": {
          "Path": "/api/development/components/{**catch-all}"
        }
      },
      "realtime": {
        "ClusterId": "realtime-host",
        "Match": {
          "Path": "/hubs/discovery"
        }
      },
      "web_shell": {
        "ClusterId": "web",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "web": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-web:8080/"
          }
        }
      },
      "discovery-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-discovery-api:8080/"
          }
        }
      },
      "operations-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-operations-api:8080/"
          }
        }
      },
      "worker-control-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-worker-control-api:8080/"
          }
        }
      },
      "maintenance-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-maintenance-api:8080/"
          }
        }
      },
      "updates-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-updates-api:8080/"
          }
        }
      },
      "realtime-host": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-realtime:8080/"
          }
        }
      }
    }
  }
}
