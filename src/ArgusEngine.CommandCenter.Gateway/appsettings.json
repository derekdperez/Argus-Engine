{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "ops_and_status": {
        "ClusterId": "operations-api",
        "Match": {
          "Path": "/api/ops/{**catch-all}"
        }
      },
      "status_summary": {
        "ClusterId": "operations-api",
        "Match": {
          "Path": "/api/status/{**catch-all}"
        }
      },
      "restarts": {
        "ClusterId": "worker-control-api",
        "Match": {
          "Path": "/api/ops/{tool}/restart"
        }
      },
      "targets": {
        "ClusterId": "discovery-api",
        "Match": {
          "Path": "/api/targets/{**catch-all}"
        }
      },
      "assets": {
        "ClusterId": "discovery-api",
        "Match": {
          "Path": "/api/assets/{**catch-all}"
        }
      },
      "tags": {
        "ClusterId": "discovery-api",
        "Match": {
          "Path": "/api/tags/{**catch-all}"
        }
      },
      "technologies": {
        "ClusterId": "discovery-api",
        "Match": {
          "Path": "/api/technologies/{**catch-all}"
        }
      },
      "technology_identification": {
        "ClusterId": "discovery-api",
        "Match": {
          "Path": "/api/technology-identification/{**catch-all}"
        }
      },
      "http_request_queue": {
        "ClusterId": "discovery-api",
        "Match": {
          "Path": "/api/http-request-queue/{**catch-all}"
        }
      },
      "high_value_findings": {
        "ClusterId": "discovery-api",
        "Match": {
          "Path": "/api/high-value-findings/{**catch-all}"
        }
      },
      "asset_admission_decisions": {
        "ClusterId": "discovery-api",
        "Match": {
          "Path": "/api/asset-admission-decisions/{**catch-all}"
        }
      },
      "filestore": {
        "ClusterId": "discovery-api",
        "Match": {
          "Path": "/api/filestore/{**catch-all}"
        }
      },
      "events": {
        "ClusterId": "discovery-api",
        "Match": {
          "Path": "/api/events/{**catch-all}"
        }
      },
      "admin": {
        "ClusterId": "maintenance-api",
        "Match": {
          "Path": "/api/admin/{**catch-all}"
        }
      },
      "maintenance": {
        "ClusterId": "maintenance-api",
        "Match": {
          "Path": "/api/maintenance/{**catch-all}"
        }
      },
      "diagnostics": {
        "ClusterId": "maintenance-api",
        "Match": {
          "Path": "/api/diagnostics/{**catch-all}"
        }
      },
      "bus": {
        "ClusterId": "maintenance-api",
        "Match": {
          "Path": "/api/bus/{**catch-all}"
        }
      },
      "ui_preferences": {
        "ClusterId": "maintenance-api",
        "Match": {
          "Path": "/api/ui-preferences/{**catch-all}"
        }
      },
      "workers": {
        "ClusterId": "worker-control-api",
        "Match": {
          "Path": "/api/workers/{**catch-all}"
        }
      },
      "ec2_workers": {
        "ClusterId": "worker-control-api",
        "Match": {
          "Path": "/api/ec2-workers/{**catch-all}"
        }
      },
      "updates": {
        "ClusterId": "updates-api",
        "Match": {
          "Path": "/api/development/components/{**catch-all}"
        }
      },
      "realtime": {
        "ClusterId": "realtime-host",
        "Match": {
          "Path": "/hubs/discovery"
        }
      },
      "web_shell": {
        "ClusterId": "web",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "web": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-web:8080/"
          }
        }
      },
      "discovery-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-discovery-api:8080/"
          }
        }
      },
      "operations-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-operations-api:8080/"
          }
        }
      },
      "worker-control-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-worker-control-api:8080/"
          }
        }
      },
      "maintenance-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-maintenance-api:8080/"
          }
        }
      },
      "updates-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-updates-api:8080/"
          }
        }
      },
      "realtime-host": {
        "Destinations": {
          "destination1": {
            "Address": "http://command-center-realtime:8080/"
          }
        }
      }
    }
  }
}
