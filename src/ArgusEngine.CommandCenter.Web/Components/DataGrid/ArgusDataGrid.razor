@typeparam TGridItem
@using Microsoft.AspNetCore.Components.QuickGrid
@using ArgusEngine.CommandCenter

<div @attributes="AdditionalAttributes"
     class="argus-dg @DensityCssClass @CssClass"
     aria-busy="@IsLoading"
     data-grid-key="@PersistKey">
    @if (ToolbarVisible)
    {
        <div class="argus-dg-toolbar">
            <div class="argus-dg-toolbar-main">
                @if (ShowSearch)
                {
                    <label class="argus-dg-search-wrap">
                        <span class="sr-only">@SearchPlaceholder</span>
                        <input type="search"
                               class="argus-dg-search ops-filter"
                               placeholder="@SearchPlaceholder"
                               value="@_searchInputText"
                               @oninput="OnSearchInput" />
                    </label>
                }

                @ToolbarTemplate

                @if (HasConfiguration)
                {
                    <details class="argus-dg-config">
                        <summary>
                            Configure
                            @if (ActiveFilterCount > 0)
                            {
                                <span class="argus-dg-badge">@ActiveFilterCount</span>
                            }
                        </summary>
                        <div class="argus-dg-config-body">
                            @ConfigurationTemplate
                        </div>
                    </details>
                }

                @if (ShowClearFiltersButton && (HasAnyActiveFilter || ClearFiltersRequested.HasDelegate))
                {
                    <button type="button" class="btn ghost small" @onclick="ClearAllFiltersAsync" disabled="@IsLoading">
                        Clear sorting / filtering
                    </button>
                }
            </div>

            <div class="argus-dg-toolbar-actions">
                @if (LastUpdatedUtc is not null)
                {
                    <span class="argus-dg-updated muted small">Updated @AppTimeFormat.Format(LastUpdatedUtc)</span>
                }
            </div>
        </div>
    }

    @if (IsLoading)
    {
        <div class="argus-dg-loading" role="status">
            @if (LoadingTemplate is null)
            {
                <span class="argus-dg-spinner" aria-hidden="true"></span>
                <span>@LoadingText</span>
            }
            else
            {
                @LoadingTemplate
            }
        </div>
    }

    @if (_visibleRowCount == 0 && !IsLoading)
    {
        <div class="@HostCssClasses argus-dg-empty" style="@EffectiveHostStyle" tabindex="@HostTabIndex">
            @if (EmptyTemplate is null)
            {
                @EmptyText
            }
            else
            {
                @EmptyTemplate
            }
        </div>
    }
    else if (GroupKeySelector is null)
    {
        <div class="@HostCssClasses" style="@EffectiveHostStyle" tabindex="@HostTabIndex">
            <QuickGrid Items="@EffectiveItems"
                       Class="@GridTableClass"
                       Theme="@Theme"
                       Virtualize="@EffectiveVirtualize"
                       ItemSize="@EffectiveItemSize"
                       ItemKey="@ItemKey"
                       OverscanCount="@OverscanCount"
                       Pagination="@EffectivePagination">
                @ChildContent
            </QuickGrid>
        </div>
    }
    else if (_groups is { Count: > 0 })
    {
        <div class="argus-dg-groups">
            @foreach (var group in _groups)
            {
                <details @key="group.Key" class="argus-dg-group" open="@GroupsInitiallyExpanded">
                    <summary class="argus-dg-group-summary">
                        <span>@group.Key</span>
                        <span class="muted">(@group.Items.Count.ToString("N0"))</span>
                    </summary>
                    <div class="@HostCssClasses" style="@EffectiveHostStyle">
                        <QuickGrid Items="@group.Query"
                                   Class="@GridTableClass"
                                   Theme="@Theme"
                                   Virtualize="false"
                                   ItemSize="@EffectiveItemSize"
                                   ItemKey="@ItemKey"
                                   OverscanCount="@OverscanCount">
                            @ChildContent
                        </QuickGrid>
                    </div>
                </details>
            }
        </div>
    }

    @if (CanPage)
    {
        <div class="argus-dg-bottom-bar">
            <span class="argus-dg-rowcount muted small">
                @if (_visibleRowCount == _totalRowCount)
                {
                    <span>@_visibleRowCount.ToString("N0") rows</span>
                }
                else
                {
                    <span>@_visibleRowCount.ToString("N0") of @_totalRowCount.ToString("N0") rows</span>
                }
            </span>
        </div>
    }
</div>
