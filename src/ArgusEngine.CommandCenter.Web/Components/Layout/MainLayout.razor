@inherits LayoutComponentBase

<PageTitle>Argus Engine Command Center</PageTitle>

<div class="page-shell">
    <header class="app-header">
        <a class="brand" href="/ops" aria-label="Argus Engine Command Center">
            <span class="brand-mark">AE</span>
            <span class="brand-title">Argus Engine Command Center</span>
        </a>

        <nav class="app-nav" aria-label="Primary">
            <NavLink href="/ops" Match="NavLinkMatch.Prefix">Ops</NavLink>
            <NavLink href="/admin" Match="NavLinkMatch.Prefix">Admin</NavLink>
            <NavLink href="/development" Match="NavLinkMatch.Prefix">Development</NavLink>
        </nav>
    </header>

    <main class="app-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">×</a>
</div>
