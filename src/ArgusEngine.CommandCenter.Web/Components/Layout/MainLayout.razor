@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="page">
    <aside class="sidebar">
        <a class="brand" href="/">
            <span class="brand-mark">AE</span>
            <span>
                <strong>Argus Engine</strong>
                <small>Command Center</small>
            </span>
        </a>

        <nav class="nav-menu" aria-label="Primary navigation">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Operations</NavLink>
            <NavLink class="nav-link" href="/ops">Operations Console</NavLink>
            <NavLink class="nav-link" href="/targets">Targets</NavLink>
            <NavLink class="nav-link" href="/asset-graph">Asset Graph</NavLink>
            <NavLink class="nav-link" href="/development">Development</NavLink>
        </nav>
    </aside>

    <main class="main-content">
        @Body

        @if (IsOperationsRoute)
        {
            <OpsBottomPanels />
        }
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">x</a>
</div>

@code {
    private bool IsOperationsRoute
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
            return string.IsNullOrWhiteSpace(path) || path.Equals("ops", StringComparison.OrdinalIgnoreCase);
        }
    }
}
