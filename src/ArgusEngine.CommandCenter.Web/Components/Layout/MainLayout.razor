@inherits LayoutComponentBase

@inject NavigationManager Navigation

<div class="page">
    <aside class="sidebar">
        <a class="brand" href="/">
            <span class="brand-mark">AE</span>
            <span>
                <strong>Argus Engine</strong>
                <small>Command Center</small>
            </span>
        </a>

        <nav class="nav-menu" aria-label="Primary navigation">
            <a class="nav-button @(IsActive("") ? "active" : "")" href="/">Command Center</a>
            <a class="nav-button @(IsActive("recon-orchestrator") ? "active" : "")" href="/recon-orchestrator">Recon Orchestrator</a>
            <a class="nav-button @(IsActive("status") ? "active" : "")" href="/status">Status</a>
        </nav>
    </aside>

    <main class="main-content">
        @Body
    </main>
</div>

@code {
    private bool IsActive(string path)
    {
        var current = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
        return string.IsNullOrWhiteSpace(path)
            ? current is "" or "ops" or "commandcenter"
            : string.Equals(current, path, StringComparison.OrdinalIgnoreCase);
    }
}

<div id="blazor-error-ui">
    An unhandled error has occurred.

    <a href="" class="reload">Reload</a>

    <a class="dismiss">x</a>
</div>

