@using System.Globalization
@using System.Net.Http.Json
@using ArgusEngine.CommandCenter.Contracts
@using ArgusEngine.CommandCenter.Web.Clients
@implements IDisposable
@inject WorkerControlApiClient WorkerApi

<section class="ops-bottom-panels" aria-label="Operations additional grids">
    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="append-alert">@_statusMessage</div>
    }

    <section class="append-panel">
        <div class="append-panel-title">
            <div>
                <p class="eyebrow">High Value</p>
                <h2>High Value Assets</h2>
                <p class="muted">Moved from the removed High Value page. Existing Operations controls above are unchanged.</p>
            </div>
            <div class="append-toolbar">
                <input placeholder="Search high value assets" @bind="_highValueSearch" @bind:event="oninput" />
                <select @bind="_highValueStatusFilter">
                    <option value="Active">Active</option>
                    <option value="">All statuses</option>
                    <option value="Pending">Pending</option>
                    <option value="In Process">In Process</option>
                    <option value="False Positive">False Positive</option>
                    <option value="Valid Finding">Valid Finding</option>
                </select>
                <button type="button" class="btn" disabled="@_highValueLoading" @onclick="ReloadHighValueAssetsAsync">
                    @(_highValueLoading ? "Refreshing..." : "Refresh")
                </button>
            </div>
        </div>

        <div class="append-mini-metrics">
            <span>@FormatNumber(_highValueRows.LongCount(r => r.IsHighValue)) high value</span>
            <span>@FormatNumber(ValidFindingCount) valid findings</span>
            <span>@FormatNumber(FalsePositiveCount) false positives</span>
            <span>@ActualFindingRate actual finding rate</span>
        </div>

        @if (_highValueLoading)
        {
            <p class="muted">Loading high value assets…</p>
        }
        else
        {
            <div class="append-table-wrap">
                <table class="append-table">
                    <thead>
                        <tr>
                            <th>Last seen</th>
                            <th>Status</th>
                            <th>Target</th>
                            <th>Kind</th>
                            <th>Category</th>
                            <th>URL / Asset</th>
                            <th>Finding</th>
                            <th>Severity</th>
                            <th>Pattern</th>
                            <th>Matched text</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in FilteredHighValueRows)
                        {
                            <tr>
                                <td>@FormatTime(row.LastSeenAtUtc)</td>
                                <td>
                                    <select value="@row.InvestigationStatus" @onchange="args => UpdateInvestigationStatusAsync(row, args.Value?.ToString())">
                                        @foreach (var status in InvestigationStatuses)
                                        {
                                            <option value="@status">@status</option>
                                        }
                                    </select>
                                </td>
                                <td>@DisplayOrDash(row.TargetRootDomain)</td>
                                <td>@DisplayOrDash(row.Kind)</td>
                                <td>@DisplayOrDash(row.Category)</td>
                                <td class="wrap">
                                    @{
                                        var finalUrl = BestAssetUrl(row);
                                        var href = TryHttpHref(finalUrl);
                                    }
                                    @if (href is null)
                                    {
                                        @DisplayOrDash(finalUrl)
                                    }
                                    else
                                    {
                                        <a href="@href" target="_blank" rel="noopener noreferrer">@finalUrl</a>
                                    }
                                </td>
                                <td>@DisplayOrDash(row.FindingType)</td>
                                <td>@DisplayOrDash(row.Severity)</td>
                                <td><code>@DisplayOrDash(row.PatternName)</code></td>
                                <td class="wrap">@DisplayOrDash(row.MatchedText)</td>
                                <td>
                                    <button type="button" class="btn small" @onclick="() => MarkFalsePositiveAsync(row)">False Positive</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="append-panel">
        <div class="append-panel-title">
            <div>
                <p class="eyebrow">Technology ID</p>
                <h2>Top 10 Technologies</h2>
                <p class="muted">Grouped by technology name regardless of version. Click a name for version usage.</p>
            </div>
            <div class="append-toolbar">
                <input placeholder="Search technologies" @bind="_technologySearch" @bind:event="oninput" />
                <button type="button" class="btn" disabled="@_technologiesLoading" @onclick="ReloadTechnologyDataAsync">
                    @(_technologiesLoading ? "Refreshing..." : "Refresh")
                </button>
            </div>
        </div>

        @if (_usageLoading)
        {
            <p class="muted">Loading technology usage…</p>
        }
        else
        {
            <ol class="top-tech-list">
                @foreach (var row in TopTechnologyRows.Take(10))
                {
                    <li>
                        <button type="button" class="link-button" @onclick="() => OpenTechnologyModal(row.Name)">
                            @row.Name
                        </button>
                        <span>(@FormatNumber(row.TargetCount) targets, @FormatNumber(row.SubdomainCount) subdomains)</span>
                    </li>
                }
            </ol>
        }

        <h3>Technologies</h3>
        @if (_technologiesLoading)
        {
            <p class="muted">Loading technologies…</p>
        }
        else
        {
            <div class="append-table-wrap">
                <table class="append-table">
                    <thead>
                        <tr>
                            <th>Last seen</th>
                            <th>Target</th>
                            <th>Subdomain</th>
                            <th>Technology</th>
                            <th>Version</th>
                            <th>Source</th>
                            <th>Mode</th>
                            <th>Evidence</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in FilteredTechnologyRows)
                        {
                            <tr>
                                <td>@FormatTime(row.LastSeenUtc)</td>
                                <td>@DisplayOrDash(row.TargetRootDomain)</td>
                                <td>@DisplayOrDash(row.Subdomain)</td>
                                <td>@DisplayOrDash(row.TechnologyName)</td>
                                <td>@DisplayOrDash(row.Version)</td>
                                <td>@DisplayOrDash(row.SourceType)</td>
                                <td>@DisplayOrDash(row.DetectionMode)</td>
                                <td class="wrap">@DisplayOrDash(row.EvidenceSummary)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</section>

@if (_selectedTechnologyName is not null)
{
    <div class="append-modal-backdrop" @onclick="CloseTechnologyModal">
        <section class="append-modal" @onclick:stopPropagation="true">
            <header class="append-modal-header">
                <div>
                    <p class="eyebrow">Version breakdown</p>
                    <h2>@_selectedTechnologyName</h2>
                </div>
                <button type="button" class="btn" @onclick="CloseTechnologyModal">Close</button>
            </header>

            <div class="append-table-wrap">
                <table class="append-table">
                    <thead>
                        <tr>
                            <th>Version</th>
                            <th>Targets</th>
                            <th>Subdomains</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in SelectedTechnologyVersionRows)
                        {
                            <tr>
                                <td>@DisplayOrDash(row.Version)</td>
                                <td>@FormatNumber(row.TargetCount)</td>
                                <td>@FormatNumber(row.SubdomainCount)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
}

@code {
    private readonly List<HighValueAssetRowDto> _highValueRows = [];
    private readonly List<TechnologyIdentificationRowDto> _technologyRows = [];
    private readonly List<TechnologyUsageDto> _technologyUsage = [];
    private readonly CancellationTokenSource _cts = new();

    private bool _highValueLoading = true;
    private bool _technologiesLoading = true;
    private bool _usageLoading = true;
    private string _highValueSearch = "";
    private string _highValueStatusFilter = "Active";
    private string _technologySearch = "";
    private string? _selectedTechnologyName;
    private string? _statusMessage;

    private static readonly IReadOnlyList<string> InvestigationStatuses = ["Pending", "In Process", "False Positive", "Valid Finding"];

    private long ValidFindingCount => _highValueRows.LongCount(r => r.InvestigationStatus == "Valid Finding");
    private long FalsePositiveCount => _highValueRows.LongCount(r => r.InvestigationStatus == "False Positive" || !r.IsHighValue);

    private string ActualFindingRate
    {
        get
        {
            var totalClassified = ValidFindingCount + FalsePositiveCount;
            return totalClassified == 0
                ? "0%"
                : $"{Math.Round((double)ValidFindingCount / totalClassified * 100, 1).ToString("0.0", CultureInfo.InvariantCulture)}%";
        }
    }

    private IReadOnlyList<HighValueAssetRowDto> FilteredHighValueRows => _highValueRows
        .Where(StatusMatches)
        .Where(row => HighValueAssetMatches(row, _highValueSearch))
        .OrderByDescending(row => row.LastSeenAtUtc ?? row.FindingDiscoveredAtUtc)
        .Take(500)
        .ToArray();

    private IReadOnlyList<TechnologyIdentificationRowDto> FilteredTechnologyRows => _technologyRows
        .Where(row => TechnologyMatches(row, _technologySearch))
        .OrderByDescending(row => row.LastSeenUtc)
        .Take(500)
        .ToArray();

    private IReadOnlyList<TopTechnologyRow> TopTechnologyRows => _technologyUsage
        .Where(u => !string.IsNullOrWhiteSpace(u.TechnologyName))
        .GroupBy(u => u.TechnologyName, StringComparer.OrdinalIgnoreCase)
        .Select(g =>
        {
            var locations = g.SelectMany(x => x.Locations).ToArray();
            return new TopTechnologyRow(
                g.Key,
                locations.Select(l => l.TargetId).Distinct().LongCount(),
                locations.Select(l => l.Subdomain).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount());
        })
        .OrderByDescending(x => x.SubdomainCount)
        .ThenByDescending(x => x.TargetCount)
        .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private IReadOnlyList<TechnologyVersionRow> SelectedTechnologyVersionRows => _selectedTechnologyName is null
        ? []
        : _technologyUsage
            .Where(u => string.Equals(u.TechnologyName, _selectedTechnologyName, StringComparison.OrdinalIgnoreCase))
            .GroupBy(u => string.IsNullOrWhiteSpace(u.Version) ? "" : u.Version, StringComparer.OrdinalIgnoreCase)
            .Select(g =>
            {
                var locations = g.SelectMany(x => x.Locations).ToArray();
                return new TechnologyVersionRow(
                    string.IsNullOrWhiteSpace(g.Key) ? "Unknown / unversioned" : g.Key,
                    locations.Select(l => l.TargetId).Distinct().LongCount(),
                    locations.Select(l => l.Subdomain).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount());
            })
            .OrderByDescending(x => x.SubdomainCount)
            .ThenByDescending(x => x.TargetCount)
            .ThenBy(x => x.Version, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            ReloadHighValueAssetsAsync(),
            ReloadTechnologyDataAsync()).ConfigureAwait(false);
    }

    private async Task ReloadHighValueAssetsAsync()
    {
        _highValueLoading = true;
        try
        {
            var rows = await WorkerApi.Client.GetFromJsonAsync<List<HighValueAssetRowDto>>(
                "/api/high-value-assets?includeResolved=true",
                _cts.Token).ConfigureAwait(false);

            _highValueRows.Clear();
            if (rows is not null)
            {
                _highValueRows.AddRange(rows);
            }
        }
        catch (Exception ex)
        {
            _statusMessage = $"High value assets could not be loaded: {ex.Message}";
        }
        finally
        {
            _highValueLoading = false;
        }
    }

    private async Task ReloadTechnologyDataAsync()
    {
        _technologiesLoading = true;
        _usageLoading = true;
        try
        {
            var technologiesTask = WorkerApi.Client.GetFromJsonAsync<List<TechnologyIdentificationRowDto>>(
                "/api/technology-identification/technologies",
                _cts.Token);

            var usageTask = WorkerApi.Client.GetFromJsonAsync<List<TechnologyUsageDto>>(
                "/api/technology-identification/usage",
                _cts.Token);

            var technologies = await technologiesTask.ConfigureAwait(false);
            var usage = await usageTask.ConfigureAwait(false);

            _technologyRows.Clear();
            if (technologies is not null)
            {
                _technologyRows.AddRange(technologies);
            }

            _technologyUsage.Clear();
            if (usage is not null)
            {
                _technologyUsage.AddRange(usage);
            }
        }
        catch (Exception ex)
        {
            _statusMessage = $"Technology data could not be loaded: {ex.Message}";
        }
        finally
        {
            _technologiesLoading = false;
            _usageLoading = false;
        }
    }

    private async Task MarkFalsePositiveAsync(HighValueAssetRowDto row)
    {
        try
        {
            using var response = await WorkerApi.Client.PostAsync(
                $"/api/high-value-assets/{row.AssetId}/false-positive",
                null,
                _cts.Token).ConfigureAwait(false);

            response.EnsureSuccessStatusCode();
            await ReloadHighValueAssetsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Could not mark asset as false positive: {ex.Message}";
        }
    }

    private async Task UpdateInvestigationStatusAsync(HighValueAssetRowDto row, string? status)
    {
        if (string.IsNullOrWhiteSpace(status) || status == row.InvestigationStatus)
        {
            return;
        }

        try
        {
            using var response = await WorkerApi.Client.PatchAsJsonAsync(
                $"/api/high-value-findings/{row.FindingId}/status",
                new HighValueFindingStatusPatch(status),
                _cts.Token).ConfigureAwait(false);

            response.EnsureSuccessStatusCode();
            await ReloadHighValueAssetsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Could not update investigation status: {ex.Message}";
        }
    }

    private bool StatusMatches(HighValueAssetRowDto row) => _highValueStatusFilter switch
    {
        "Active" => row.IsHighValue && row.InvestigationStatus is not ("False Positive" or "Valid Finding"),
        "" => true,
        _ => string.Equals(row.InvestigationStatus, _highValueStatusFilter, StringComparison.OrdinalIgnoreCase),
    };

    private static bool HighValueAssetMatches(HighValueAssetRowDto row, string search)
    {
        if (string.IsNullOrWhiteSpace(search))
        {
            return true;
        }

        return Matches(row.TargetRootDomain, search)
            || Matches(row.Kind, search)
            || Matches(row.Category, search)
            || Matches(row.FinalUrl, search)
            || Matches(row.RawValue, search)
            || Matches(row.DisplayName, search)
            || Matches(row.DiscoveredBy, search)
            || Matches(row.DiscoveryContext, search)
            || Matches(row.WorkerName, search)
            || Matches(row.FindingType, search)
            || Matches(row.Severity, search)
            || Matches(row.PatternName, search)
            || Matches(row.MatchedText, search)
            || Matches(row.InvestigationStatus, search);
    }

    private static bool TechnologyMatches(TechnologyIdentificationRowDto row, string search)
    {
        return string.IsNullOrWhiteSpace(search)
            || Matches(row.TargetRootDomain, search)
            || Matches(row.Subdomain, search)
            || Matches(row.AssetCanonicalKey, search)
            || Matches(row.TechnologyName, search)
            || Matches(row.Vendor, search)
            || Matches(row.Product, search)
            || Matches(row.Version, search)
            || Matches(row.SourceType, search)
            || Matches(row.DetectionMode, search)
            || Matches(row.EvidenceSummary, search);
    }

    private static bool Matches(string? value, string search) =>
        string.IsNullOrWhiteSpace(search) ||
        (!string.IsNullOrWhiteSpace(value) && value.Contains(search.Trim(), StringComparison.OrdinalIgnoreCase));

    private static string BestAssetUrl(HighValueAssetRowDto row) =>
        row.FinalUrl ?? row.DisplayName ?? row.RawValue;

    private static string FormatNumber(long value) =>
        value.ToString("N0", CultureInfo.InvariantCulture);

    private static string DisplayOrDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatTime(DateTimeOffset? value) =>
        value is null ? "-" : value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture);

    private static string? TryHttpHref(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return Uri.TryCreate(value.Trim(), UriKind.Absolute, out var uri) && uri.Scheme is "http" or "https"
            ? uri.ToString()
            : null;
    }

    private void OpenTechnologyModal(string technologyName) => _selectedTechnologyName = technologyName;
    private void CloseTechnologyModal() => _selectedTechnologyName = null;

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private sealed record TopTechnologyRow(string Name, long TargetCount, long SubdomainCount);
    private sealed record TechnologyVersionRow(string Version, long TargetCount, long SubdomainCount);
}
