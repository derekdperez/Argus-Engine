@using ArgusEngine.CommandCenter.Models
@using ArgusEngine.CommandCenter
@page "/admin"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using ArgusEngine.CommandCenter.Web.Clients
@inject MaintenanceApiClient MaintenanceApi

<PageTitle>Admin - Nightmare v2</PageTitle>

<div class="page-shell admin-page">
    <section class="page-hero">
        <div>
            <p class="eyebrow">Administration</p>
            <h1>Admin</h1>
            <p class="hero-copy">Cloud usage, worker-hour budget, and HTTP traffic totals for the current UTC billing month.</p>
        </div>
        <div class="hero-actions">
            @if (_snapshot is not null)
            {
                <span class="muted">Updated @AppTimeFormat.Format(_snapshot.AtUtc)</span>
            }
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert">@_error</div>
    }

    @if (_loading && _snapshot is null)
    {
        <section class="panel">
            <p class="muted">Loading usage snapshot...</p>
        </section>
    }
    else if (_snapshot is null)
    {
        <section class="panel">
            <p class="muted">Usage snapshot unavailable.</p>
        </section>
    }
    else
    {
        <section class="stat-grid">
            <div class="stat-card">
                <div class="stat-label">Cumulative ECS Worker Hours</div>
                <div class="stat-value">@_snapshot.EcsWorkerHoursMonthToDate.ToString("N2")</div>
                <div class="stat-note">@_snapshot.EcsWorkerHoursRemaining.ToString("N2") of @_snapshot.EcsWorkerFreeTierHours.ToString("N0") remaining</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Free Tier Used</div>
                <div class="stat-value">@_snapshot.EcsWorkerPercentUsed.ToString("N2")%</div>
                <div class="usage-meter" aria-label="ECS worker free tier usage">
                    <span style="width:@UsageBarWidth"></span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Cumulative EC2 Server Hours</div>
                <div class="stat-value">@_snapshot.Ec2ServerHoursMonthToDate.ToString("N2")</div>
                <div class="stat-note">Current UTC month</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">HTTP Traffic This Month</div>
                <div class="stat-value small">@FormatBytes(_snapshot.HttpTrafficBytesMonthToDate)</div>
                <div class="stat-note">@_snapshot.HttpRequestCountMonthToDate.ToString("N0") completed requests</div>
            </div>
        </section>

        <section class="panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Traffic</p>
                    <h2>HTTP bandwidth estimate</h2>
                </div>
                <span class="muted">Since @AppTimeFormat.Format(_snapshot.MonthStartUtc)</span>
            </div>
            <div class="admin-traffic-grid">
                <div>
                    <span class="muted">Request bytes</span>
                    <strong>@FormatBytes(_snapshot.HttpRequestBytesMonthToDate)</strong>
                </div>
                <div>
                    <span class="muted">Response bytes</span>
                    <strong>@FormatBytes(_snapshot.HttpResponseBytesMonthToDate)</strong>
                </div>
                <div>
                    <span class="muted">All-time recorded traffic</span>
                    <strong>@FormatBytes(_snapshot.HttpTrafficBytesAllTime)</strong>
                </div>
            </div>
            <p class="muted">Traffic is estimated from stored HTTP queue request/response headers, request bodies, and response content lengths.</p>
        </section>

        <section class="panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Storage</p>
                    <h2>Event Retention Cleanup</h2>
                </div>
                @if (_retentionStatus is not null)
                {
                    <span class="muted">
                        Last run @AppTimeFormat.Format(_retentionStatus.LastRunAtUtc)
                    </span>
                }
            </div>

            <p class="muted">
                Deletes old high-volume event telemetry rows (bus journal and outbox) to reduce database disk usage.
            </p>

            @if (!string.IsNullOrWhiteSpace(_retentionMessage))
            {
                <p class="muted">@_retentionMessage</p>
            }

            <div class="retention-grid">
                <label>
                    <span class="muted">Bus journal retention (hours)</span>
                    <input class="admin-number" type="number" min="1" max="720" @bind="_busJournalRetentionHours" />
                </label>
                <label>
                    <span class="muted">Succeeded outbox retention (hours)</span>
                    <input class="admin-number" type="number" min="1" max="720" @bind="_succeededOutboxRetentionHours" />
                </label>
                <label>
                    <span class="muted">Failed outbox retention (hours)</span>
                    <input class="admin-number" type="number" min="1" max="720" @bind="_failedOutboxRetentionHours" />
                </label>
                <label>
                    <span class="muted">Dead-letter outbox retention (hours)</span>
                    <input class="admin-number" type="number" min="1" max="720" @bind="_deadLetterOutboxRetentionHours" />
                </label>
                <label>
                    <span class="muted">Batch size per delete pass</span>
                    <input class="admin-number" type="number" min="100" max="20000" @bind="_retentionBatchSize" />
                </label>
                <label>
                    <span class="muted">Max batches this run</span>
                    <input class="admin-number" type="number" min="1" max="5000" @bind="_retentionMaxBatchesPerRun" />
                </label>
            </div>

            <label class="retention-toggle">
                <input type="checkbox" @bind="_archiveEventRowsBeforeDelete" />
                <span>Archive event rows before deleting (uses more storage)</span>
            </label>

            <div class="hero-actions">
                <button type="button" class="btn primary" disabled="@_retentionBusy" @onclick="RunDataRetentionNowAsync">
                    @(_retentionBusy ? "Running cleanup..." : "Run Event Cleanup Now")
                </button>
                <button type="button" class="btn secondary" disabled="@_retentionBusy" @onclick="ReloadRetentionStatusAsync">Refresh Status</button>
            </div>

            @if (_retentionStatus?.LastResult is not null)
            {
                var result = _retentionStatus.LastResult;
                var eventRowsDeleted = result.BusJournalDeleted + result.SucceededOutboxDeleted + result.FailedOutboxDeleted + result.DeadLetterOutboxDeleted + result.InboxDeleted;
                <div class="admin-traffic-grid">
                    <div>
                        <span class="muted">Event rows deleted</span>
                        <strong>@eventRowsDeleted.ToString("N0")</strong>
                    </div>
                    <div>
                        <span class="muted">Bus journal deleted</span>
                        <strong>@result.BusJournalDeleted.ToString("N0")</strong>
                    </div>
                    <div>
                        <span class="muted">Outbox deleted</span>
                        <strong>@(result.SucceededOutboxDeleted + result.FailedOutboxDeleted + result.DeadLetterOutboxDeleted).ToString("N0")</strong>
                    </div>
                </div>
            }
        </section>

        <section class="panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Cloud samples</p>
                    <h2>Resource-hour rollup</h2>
                </div>
                <span class="muted">Last sample @AppTimeFormat.Format(_snapshot.LastCloudUsageSampleAtUtc)</span>
            </div>
            <table class="admin-table">
                <thead>
                <tr>
                    <th>Kind</th>
                    <th>Resource</th>
                    <th>Running</th>
                    <th>Month hours</th>
                    <th>Last sample</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in _snapshot.CloudResources)
                {
                    <tr>
                        <td>@row.ResourceKind</td>
                        <td>
                            <strong>@row.ResourceName</strong>
                            <span class="muted mono">@row.ResourceId</span>
                        </td>
                        <td>@row.LastRunningCount</td>
                        <td>@row.HoursMonthToDate.ToString("N2")</td>
                        <td>@AppTimeFormat.Format(row.LastSampledAtUtc)</td>
                    </tr>
                }
                </tbody>
            </table>
        </section>

        <section class="panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">ECS scaling</p>
                    <h2>Worker autoscaling settings</h2>
                </div>
                @if (!string.IsNullOrWhiteSpace(_scalingMessage))
                {
                    <span class="muted">@_scalingMessage</span>
                }
            </div>
            <table class="admin-table">
                <thead>
                <tr>
                    <th>Worker</th>
                    <th>Min tasks</th>
                    <th>Max tasks</th>
                    <th>Target backlog/task</th>
                    <th>Updated</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in _scalingSettings)
                {
                    <tr>
                        <td>
                            <strong>@row.DisplayName</strong>
                            <span class="muted mono">@row.ScaleKey</span>
                        </td>
                        <td><input class="admin-number" type="number" min="0" @bind="row.MinTasks" /></td>
                        <td><input class="admin-number" type="number" min="0" @bind="row.MaxTasks" /></td>
                        <td><input class="admin-number" type="number" min="1" @bind="row.TargetBacklogPerTask" /></td>
                        <td>@AppTimeFormat.Format(row.UpdatedAtUtc == DateTimeOffset.UnixEpoch ? null : row.UpdatedAtUtc)</td>
                        <td><button type="button" class="btn small primary" disabled="@_scalingBusy" @onclick="@(() => SaveScalingAsync(row))">Save</button></td>
                    </tr>
                }
                </tbody>
            </table>
        </section>
    }
</div>

@code {
    private AdminUsageSnapshotDto? _snapshot;
    private readonly List<EditableWorkerScalingSetting> _scalingSettings = [];
    private string _error = string.Empty;
    private string _scalingMessage = string.Empty;
    private string _retentionMessage = string.Empty;
    private bool _initialLoadStarted;
    private bool _loading = true;
    private bool _scalingBusy;
    private bool _retentionBusy;
    private DataRetentionStatusResponse? _retentionStatus;
    private int _busJournalRetentionHours = 48;
    private int _succeededOutboxRetentionHours = 24;
    private int _failedOutboxRetentionHours = 168;
    private int _deadLetterOutboxRetentionHours = 720;
    private int _retentionBatchSize = 5000;
    private int _retentionMaxBatchesPerRun = 500;
    private bool _archiveEventRowsBeforeDelete;

    private string UsageBarWidth => $"{Math.Clamp(_snapshot?.EcsWorkerPercentUsed ?? 0, 0, 100):0.##}%";

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialLoadStarted)
        {
            _initialLoadStarted = true;
            _ = InvokeAsync(ReloadAndRefreshAsync);
        }

        return Task.CompletedTask;
    }

    private async Task ReloadAndRefreshAsync()
    {
        await ReloadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = string.Empty;
        try
        {
            _snapshot = await MaintenanceApi.Client.GetFromJsonAsync<AdminUsageSnapshotDto>("/api/admin/usage").ConfigureAwait(false);
            var settings = await MaintenanceApi.Client.GetFromJsonAsync<List<WorkerScalingSettingsDto>>("/api/workers/scaling-settings").ConfigureAwait(false);
            _retentionStatus = await MaintenanceApi.Client.GetFromJsonAsync<DataRetentionStatusResponse>("/api/admin/data-retention/status").ConfigureAwait(false);
            _scalingSettings.Clear();
            if (settings is not null)
                _scalingSettings.AddRange(settings.Select(EditableWorkerScalingSetting.FromDto));

            if (_retentionStatus?.Options is not null)
            {
                var opt = _retentionStatus.Options;
                _busJournalRetentionHours = ResolveHours(opt.BusJournalRetentionDays, opt.BusJournalRetentionHours, fallbackHours: 48);
                _succeededOutboxRetentionHours = ResolveHours(opt.SucceededOutboxRetentionDays, opt.SucceededOutboxRetentionHours, fallbackHours: 24);
                _failedOutboxRetentionHours = ResolveHours(opt.FailedOutboxRetentionDays, opt.FailedOutboxRetentionHours, fallbackHours: 7 * 24);
                _deadLetterOutboxRetentionHours = ResolveHours(opt.DeadLetterOutboxRetentionDays, opt.DeadLetterOutboxRetentionHours, fallbackHours: 30 * 24);
                _retentionBatchSize = opt.BatchSize > 0 ? opt.BatchSize : _retentionBatchSize;
                _retentionMaxBatchesPerRun = opt.MaxBatchesPerRun > 0 ? opt.MaxBatchesPerRun : _retentionMaxBatchesPerRun;
                _archiveEventRowsBeforeDelete = opt.ArchiveEventTablesBeforeDelete;
            }

            if (_snapshot is null)
                _error = "Usage payload was empty.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveScalingAsync(EditableWorkerScalingSetting row)
    {
        _scalingBusy = true;
        _scalingMessage = "";
        try
        {
            var response = await MaintenanceApi.Client.PutAsJsonAsync(
                    $"/api/workers/scaling-settings/{Uri.EscapeDataString(row.ScaleKey)}",
                    new WorkerScalingSettingsPatchDto(row.MinTasks, row.MaxTasks, row.TargetBacklogPerTask))
                .ConfigureAwait(false);
            if (response.IsSuccessStatusCode)
            {
                var updated = await response.Content.ReadFromJsonAsync<WorkerScalingSettingsDto>().ConfigureAwait(false);
                if (updated is not null)
                    row.Apply(updated);
                _scalingMessage = "Saved.";
            }
            else
            {
                _scalingMessage = await response.Content.ReadAsStringAsync().ConfigureAwait(false);
            }
        }
        catch (Exception ex)
        {
            _scalingMessage = ex.Message;
        }
        finally
        {
            _scalingBusy = false;
        }
    }

    private async Task ReloadRetentionStatusAsync()
    {
        try
        {
            _retentionStatus = await MaintenanceApi.Client.GetFromJsonAsync<DataRetentionStatusResponse>("/api/admin/data-retention/status").ConfigureAwait(false);
            _retentionMessage = "Retention status refreshed.";
        }
        catch (Exception ex)
        {
            _retentionMessage = ex.Message;
        }
    }

    private async Task RunDataRetentionNowAsync()
    {
        _retentionBusy = true;
        _retentionMessage = "";
        try
        {
            using var response = await MaintenanceApi.Client.PostAsJsonAsync(
                    "/api/admin/data-retention/run-now",
                    new DataRetentionRunRequest(
                        Confirmation: "RUN DATA RETENTION",
                        BusJournalRetentionHours: _busJournalRetentionHours,
                        SucceededOutboxRetentionHours: _succeededOutboxRetentionHours,
                        FailedOutboxRetentionHours: _failedOutboxRetentionHours,
                        DeadLetterOutboxRetentionHours: _deadLetterOutboxRetentionHours,
                        BatchSize: _retentionBatchSize,
                        MaxBatchesPerRun: _retentionMaxBatchesPerRun,
                        ArchiveEventTablesBeforeDelete: _archiveEventRowsBeforeDelete))
                .ConfigureAwait(false);

            if (!response.IsSuccessStatusCode)
            {
                _retentionMessage = await response.Content.ReadAsStringAsync().ConfigureAwait(false);
                return;
            }

            await ReloadRetentionStatusAsync().ConfigureAwait(false);
            if (_retentionStatus?.LastResult is DataRetentionRunResult result)
            {
                var eventRowsDeleted = result.BusJournalDeleted +
                                       result.SucceededOutboxDeleted +
                                       result.FailedOutboxDeleted +
                                       result.DeadLetterOutboxDeleted +
                                       result.InboxDeleted;
                _retentionMessage = $"Cleanup completed. Deleted {eventRowsDeleted:N0} event rows.";
            }
            else
            {
                _retentionMessage = "Cleanup completed.";
            }
        }
        catch (Exception ex)
        {
            _retentionMessage = ex.Message;
        }
        finally
        {
            _retentionBusy = false;
        }
    }

    private static int ResolveHours(int retentionDays, int retentionHours, int fallbackHours)
    {
        if (retentionHours > 0)
            return retentionHours;
        if (retentionDays > 0)
            return retentionDays * 24;
        return fallbackHours;
    }

    private static string FormatBytes(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        var value = (double)Math.Max(0, bytes);
        var unit = 0;
        while (value >= 1024 && unit < units.Length - 1)
        {
            value /= 1024;
            unit++;
        }

        return $"{value:N2} {units[unit]}";
    }

    private sealed class EditableWorkerScalingSetting
    {
        public string ScaleKey { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public int MinTasks { get; set; }
        public int MaxTasks { get; set; }
        public int TargetBacklogPerTask { get; set; }
        public DateTimeOffset UpdatedAtUtc { get; set; }

        public static EditableWorkerScalingSetting FromDto(WorkerScalingSettingsDto dto) =>
            new()
            {
                ScaleKey = dto.ScaleKey,
                DisplayName = dto.DisplayName,
                MinTasks = dto.MinTasks,
                MaxTasks = dto.MaxTasks,
                TargetBacklogPerTask = dto.TargetBacklogPerTask,
                UpdatedAtUtc = dto.UpdatedAtUtc,
            };

        public void Apply(WorkerScalingSettingsDto dto)
        {
            DisplayName = dto.DisplayName;
            MinTasks = dto.MinTasks;
            MaxTasks = dto.MaxTasks;
            TargetBacklogPerTask = dto.TargetBacklogPerTask;
            UpdatedAtUtc = dto.UpdatedAtUtc;
        }
    }

    private sealed record DataRetentionRunRequest(
        string Confirmation,
        int BusJournalRetentionHours,
        int SucceededOutboxRetentionHours,
        int FailedOutboxRetentionHours,
        int DeadLetterOutboxRetentionHours,
        int BatchSize,
        int MaxBatchesPerRun,
        bool ArchiveEventTablesBeforeDelete);

    private sealed class DataRetentionStatusResponse
    {
        public bool Enabled { get; set; }
        public DateTimeOffset? LastRunAtUtc { get; set; }
        public DataRetentionRunResult? LastResult { get; set; }
        public DataRetentionOptionsSummary? Options { get; set; }
    }

    private sealed class DataRetentionOptionsSummary
    {
        public int RunIntervalMinutes { get; set; }
        public int SucceededOutboxRetentionDays { get; set; }
        public int SucceededOutboxRetentionHours { get; set; }
        public int FailedOutboxRetentionDays { get; set; }
        public int FailedOutboxRetentionHours { get; set; }
        public int DeadLetterOutboxRetentionDays { get; set; }
        public int DeadLetterOutboxRetentionHours { get; set; }
        public int BusJournalRetentionDays { get; set; }
        public int BusJournalRetentionHours { get; set; }
        public int BatchSize { get; set; }
        public int MaxBatchesPerRun { get; set; }
        public bool ArchiveEventTablesBeforeDelete { get; set; }
    }
}

