@rendermode InteractiveServer
@using System.Linq
@using System.Net.Http.Json
@using ArgusEngine.CommandCenter.Models
@using ArgusEngine.CommandCenter.Realtime
@inject HttpClient Http
@inject DiscoveryRealtimeClient Realtime
@implements IDisposable

<PageTitle>Application Component State</PageTitle>

<div class="component-state-page">
    <header class="state-hero">
        <div>
            <p class="eyebrow">Architecture</p>
            <h1>Application Component State</h1>
            <p class="hero-copy">
                Live, at-a-glance topology view of the application pieces that must be healthy for Argus Engine to operate:
                the Command Center web application, realtime channel, runtime dependencies, queues, workers, Docker runtime,
                and ECS worker services.
            </p>
        </div>

        <div class="hero-actions">
            <span class="hero-badge @ColorClass(OverallColor)">@OverallStatusLabel</span>
            <span class="hero-badge hero-badge-neutral">Realtime: @Realtime.State</span>
            <button class="refresh-button" @onclick="ReloadAsync" disabled="@_loading">
                @(_loading ? "Refreshing…" : "Refresh now")
            </button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="banner banner-error">@_error</div>
    }

    @if (_snapshot is null && _loading)
    {
        <div class="loading-state">Loading application component state…</div>
    }
    else if (_snapshot is null)
    {
        <div class="banner banner-warning">Application state is unavailable right now.</div>
    }
    else
    {
        <section class="overview-grid" aria-label="Summary">
            <article class="overview-card">
                <span class="overview-label">Healthy</span>
                <strong class="overview-value">@_overview.Healthy.ToString("N0")</strong>
                <span class="overview-help">Components currently reporting healthy/online.</span>
            </article>
            <article class="overview-card overview-card-warning">
                <span class="overview-label">Warning</span>
                <strong class="overview-value">@_overview.Warning.ToString("N0")</strong>
                <span class="overview-help">Components degraded, lagging, or partially available.</span>
            </article>
            <article class="overview-card overview-card-critical">
                <span class="overview-label">Critical</span>
                <strong class="overview-value">@_overview.Critical.ToString("N0")</strong>
                <span class="overview-help">Components unavailable, stopped, or in an error state.</span>
            </article>
            <article class="overview-card overview-card-muted">
                <span class="overview-label">Snapshot</span>
                <strong class="overview-value overview-value-small">@AppTimeFormat.FormatCompact(_snapshot.AtUtc)</strong>
                <span class="overview-help">Version @_snapshot.Version · Build @_snapshot.BuildStamp</span>
            </article>
        </section>

        <section class="pipeline-strip" aria-label="Operational flow">
            <div class="pipeline-node">
                <span class="pipeline-step">1</span>
                <div>
                    <strong>Control Plane</strong>
                    <p>Command Center UI, status API, and realtime connection.</p>
                </div>
            </div>
            <div class="pipeline-arrow">→</div>
            <div class="pipeline-node">
                <span class="pipeline-step">2</span>
                <div>
                    <strong>Dependencies</strong>
                    <p>Redis, RabbitMQ/message bus, databases, and other runtime services.</p>
                </div>
            </div>
            <div class="pipeline-arrow">→</div>
            <div class="pipeline-node">
                <span class="pipeline-step">3</span>
                <div>
                    <strong>Queues & Orchestration</strong>
                    <p>Backlogs, queue age, and system flow pressure.</p>
                </div>
            </div>
            <div class="pipeline-arrow">→</div>
            <div class="pipeline-node">
                <span class="pipeline-step">4</span>
                <div>
                    <strong>Execution Runtime</strong>
                    <p>Workers, containers, and ECS services processing the work.</p>
                </div>
            </div>
        </section>

        <section class="map-grid" aria-label="Application component map">
            @foreach (var lane in _lanes)
            {
                <section class="map-lane">
                    <header class="lane-header">
                        <div>
                            <p class="lane-kicker">@lane.Kicker</p>
                            <h2>@lane.Title</h2>
                        </div>
                        <span class="lane-count">@lane.Cards.Count.ToString("N0")</span>
                    </header>
                    <p class="lane-copy">@lane.Description</p>

                    @if (lane.Cards.Count == 0)
                    {
                        <div class="empty-lane">No live components are currently reported in this lane.</div>
                    }
                    else
                    {
                        <div class="lane-cards">
                            @foreach (var card in lane.Cards)
                            {
                                <article class="state-card @ColorClass(card.Color)">
                                    <div class="state-card-top">
                                        <span class="source-chip">@card.Source</span>
                                        <span class="status-chip @ColorClass(card.Color)">@card.Status</span>
                                    </div>
                                    <h3>@card.Title</h3>
                                    @if (!string.IsNullOrWhiteSpace(card.Subtitle))
                                    {
                                        <p class="card-subtitle">@card.Subtitle</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(card.Detail))
                                    {
                                        <p class="card-detail">@card.Detail</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(card.Reason))
                                    {
                                        <p class="card-reason">@card.Reason</p>
                                    }
                                </article>
                            }
                        </div>
                    }
                </section>
            }
        </section>

        <section class="alerts-panel" aria-label="Operational alerts">
            <header class="alerts-header">
                <div>
                    <p class="lane-kicker">Attention</p>
                    <h2>Operational alerts</h2>
                </div>
                <span class="lane-count">@_snapshot.Alerts.Count.ToString("N0")</span>
            </header>

            @if (_snapshot.Alerts.Count == 0)
            {
                <div class="empty-lane">No active operational alerts.</div>
            }
            else
            {
                <div class="alerts-list">
                    @foreach (var alert in _snapshot.Alerts.OrderByDescending(x => x.AtUtc))
                    {
                        <article class="alert-card @ColorClass(alert.Color)">
                            <div class="state-card-top">
                                <span class="source-chip">@alert.Scope</span>
                                <span class="status-chip @ColorClass(alert.Color)">@alert.Severity</span>
                            </div>
                            <p class="card-reason">@alert.Message</p>
                            <p class="card-detail">@AppTimeFormat.FormatCompact(alert.AtUtc)</p>
                        </article>
                    }
                </div>
            }
        </section>
    }
</div>

@code {
    private readonly CancellationTokenSource _pollCts = new();
    private CommandCenterStatusSnapshot? _snapshot;
    private DockerRuntimeStatusDto? _dockerSnapshot;
    private EcsRuntimeStatusDto? _ecsSnapshot;
    private bool _loading = true;
    private bool _initialLoadStarted;
    private string? _error;
    private StateOverview _overview = new(0, 0, 0, 0);
    private IReadOnlyList<ComponentLane> _lanes = Array.Empty<ComponentLane>();

    private string OverallColor
        => NormalizeColor(_snapshot?.Color) switch
        {
            "green" => "green",
            "yellow" => "yellow",
            "red" => "red",
            _ => "gray"
        };

    private string OverallStatusLabel
        => _snapshot is null
            ? "Status unavailable"
            : $"Overall: {_snapshot.Status}";

    protected override Task OnInitializedAsync()
    {
        Realtime.DomainEventReceived += OnDomainEventReceived;
        Realtime.StatusChangedReceived += OnStatusChangedReceived;
        Realtime.ConnectionStateChanged += OnConnectionStateChanged;
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialLoadStarted)
        {
            return;
        }

        _initialLoadStarted = true;
        await LoadInitialAsync();
    }

    private async Task LoadInitialAsync()
    {
        await ReloadAsync();

        try
        {
            await Realtime.EnsureStartedAsync(_pollCts.Token);
        }
        catch (Exception ex)
        {
            _error = $"Realtime connection is unavailable. Falling back to periodic refresh. {ex.Message}";
        }

        _ = PollWhenDisconnectedAsync(_pollCts.Token);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _snapshot = await Http.GetFromJsonAsync<CommandCenterStatusSnapshot>("/api/status/summary", _pollCts.Token);

            try
            {
                _dockerSnapshot = await Http.GetFromJsonAsync<DockerRuntimeStatusDto>("/api/ops/docker-status", _pollCts.Token);
            }
            catch
            {
                _dockerSnapshot = null;
            }

            try
            {
                _ecsSnapshot = await Http.GetFromJsonAsync<EcsRuntimeStatusDto>("/api/ops/ecs-status", _pollCts.Token);
            }
            catch
            {
                _ecsSnapshot = null;
            }

            RebuildMap();
        }
        catch (Exception ex)
        {
            _error = $"Unable to load application component state. {ex.Message}";
            _lanes = Array.Empty<ComponentLane>();
            _overview = new StateOverview(0, 0, 0, 0);
        }
        finally
        {
            _loading = false;
        }
    }

    private void RebuildMap()
    {
        var controlCards = new List<ComponentCard>
        {
            new(
                "Application",
                "Command Center Web App",
                "The user-facing control plane currently serving this page.",
                _snapshot?.Status ?? "Unavailable",
                _snapshot?.Color ?? "red",
                _error is null ? "Status endpoint reachable." : _error,
                _snapshot is null ? "No snapshot loaded." : $"Version {_snapshot.Version} · Build {_snapshot.BuildStamp}")
        };

        controlCards.Add(new ComponentCard(
            "Realtime",
            "Realtime UI Channel",
            "SignalR/live updates used to push state changes into the UI.",
            Realtime.IsConnected ? "Connected" : "Disconnected",
            Realtime.IsConnected ? "green" : "yellow",
            Realtime.IsConnected ? "Live updates are flowing." : "Live updates are unavailable; page will poll periodically.",
            $"Connection state: {Realtime.State}"));

        if (_snapshot is not null)
        {
            foreach (var component in _snapshot.Components.OrderBy(x => x.DisplayName, StringComparer.OrdinalIgnoreCase))
            {
                controlCards.Add(new ComponentCard(
                    "Component",
                    component.DisplayName,
                    component.Key,
                    component.Status,
                    component.Color,
                    component.Reason,
                    string.IsNullOrWhiteSpace(component.Version) ? string.Empty : $"Version {component.Version}"));
            }
        }

        var dependencyCards = new List<ComponentCard>();
        if (_snapshot is not null)
        {
            foreach (var dependency in _snapshot.Dependencies.OrderBy(x => x.DisplayName, StringComparer.OrdinalIgnoreCase))
            {
                dependencyCards.Add(new ComponentCard(
                    "Dependency",
                    dependency.DisplayName,
                    dependency.Key,
                    dependency.Status,
                    dependency.Color,
                    dependency.Reason,
                    "Runtime service dependency"));
            }
        }

        if (_dockerSnapshot is not null)
        {
            dependencyCards.Add(new ComponentCard(
                "Docker Runtime",
                "Docker Runtime",
                _dockerSnapshot.DockerAvailable ? "Container runtime available." : "Container runtime unavailable.",
                _dockerSnapshot.Status,
                _dockerSnapshot.Color,
                _dockerSnapshot.Error ?? "Docker runtime probe completed.",
                $"Reported at {AppTimeFormat.FormatCompact(_dockerSnapshot.AtUtc)}"));

            foreach (var component in _dockerSnapshot.Components.OrderBy(x => x.DisplayName, StringComparer.OrdinalIgnoreCase))
            {
                dependencyCards.Add(new ComponentCard(
                    "Docker Component",
                    component.DisplayName,
                    component.Key,
                    component.Status,
                    component.Color,
                    component.Reason,
                    BuildDockerComponentDetail(component)));
            }
        }

        var queueCards = new List<ComponentCard>();
        if (_snapshot is not null)
        {
            foreach (var queue in _snapshot.Queues.OrderBy(x => x.DisplayName, StringComparer.OrdinalIgnoreCase))
            {
                queueCards.Add(new ComponentCard(
                    "Queue",
                    queue.DisplayName,
                    queue.Key,
                    queue.Status,
                    queue.Color,
                    queue.Reason,
                    $"Depth {FormatDepth(queue.Depth)} · Oldest {FormatAge(queue.OldestAgeSeconds)}"));
            }
        }

        var executionCards = new List<ComponentCard>();
        if (_snapshot is not null)
        {
            foreach (var worker in _snapshot.Workers.OrderBy(x => x.DisplayName, StringComparer.OrdinalIgnoreCase))
            {
                executionCards.Add(new ComponentCard(
                    "Worker",
                    worker.DisplayName,
                    worker.Key,
                    worker.Status,
                    worker.Color,
                    worker.Reason,
                    $"Desired {worker.DesiredCount:N0} · Running {worker.RunningCount:N0} · Pending {worker.PendingCount:N0}"));
            }
        }

        if (_ecsSnapshot is not null)
        {
            executionCards.Add(new ComponentCard(
                "ECS",
                string.IsNullOrWhiteSpace(_ecsSnapshot.ClusterName) ? "ECS Worker Services" : _ecsSnapshot.ClusterName,
                _ecsSnapshot.EcsAvailable ? "Worker deployment runtime." : "ECS runtime unavailable.",
                _ecsSnapshot.Status,
                _ecsSnapshot.Color,
                _ecsSnapshot.Error ?? "ECS status probe completed.",
                $"Reported at {AppTimeFormat.FormatCompact(_ecsSnapshot.AtUtc)}"));

            foreach (var service in _ecsSnapshot.Services.OrderBy(x => x.WorkerKey, StringComparer.OrdinalIgnoreCase))
            {
                executionCards.Add(new ComponentCard(
                    "ECS Service",
                    service.ServiceName,
                    service.WorkerKey,
                    service.ServiceStatus,
                    service.Color,
                    service.DeploymentStatus,
                    $"Version {service.Version} · Desired {service.DesiredCount:N0} · Running {service.RunningCount:N0} · Pending {service.PendingCount:N0}"));
            }
        }

        var containerCards = new List<ComponentCard>();
        if (_dockerSnapshot is not null)
        {
            foreach (var container in _dockerSnapshot.Containers.OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase))
            {
                containerCards.Add(new ComponentCard(
                    "Container",
                    container.Name,
                    container.Image,
                    container.Status,
                    container.Color,
                    $"Docker: {container.DockerStatusText} · Health: {container.HealthCheckStatus}",
                    $"Version {container.Version} · {TrimContainerId(container.Id)}"));
            }
        }

        _lanes = new[]
        {
            new ComponentLane("Control Plane", "What operators use to steer and observe the system.", "Layer 1", controlCards),
            new ComponentLane("Dependencies", "Backing services and runtime dependencies the application relies on.", "Layer 2", dependencyCards),
            new ComponentLane("Queues & Flow", "Current message flow pressure and queue health.", "Layer 3", queueCards),
            new ComponentLane("Workers & Services", "Worker health, worker scale, and orchestration state.", "Layer 4", executionCards),
            new ComponentLane("Containers", "Concrete running runtime instances inside the environment.", "Layer 5", containerCards)
        };

        var allCards = _lanes.SelectMany(x => x.Cards).ToList();
        _overview = new StateOverview(
            allCards.Count(card => SeverityRank(card.Color) == 0),
            allCards.Count(card => SeverityRank(card.Color) == 1),
            allCards.Count(card => SeverityRank(card.Color) == 2),
            allCards.Count(card => SeverityRank(card.Color) >= 3));
    }

    private async Task PollWhenDisconnectedAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(30), cancellationToken);
                if (!Realtime.IsConnected)
                {
                    await ReloadAsync();
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException)
            {
                return;
            }
        }
    }

    private void OnDomainEventReceived(object? sender, LiveUiEventDto evt)
    {
        if (evt.Scope is "workers" or "http" or "assets" or "targets" or "status" or "ops")
        {
            _ = InvokeAsync(async () =>
            {
                await ReloadAsync();
                StateHasChanged();
            });
        }
    }

    private void OnStatusChangedReceived(object? sender, CommandCenterStatusSnapshot snapshot)
    {
        _snapshot = snapshot;
        RebuildMap();
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnConnectionStateChanged(object? sender, EventArgs args)
    {
        RebuildMap();
        _ = InvokeAsync(StateHasChanged);
    }

    private static string BuildDockerComponentDetail(DockerComponentHealthDto component)
    {
        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(component.Version))
        {
            parts.Add($"Version {component.Version}");
        }

        if (component.FirstReleasedAtUtc is { } releasedAt)
        {
            parts.Add($"Released {AppTimeFormat.FormatCompact(releasedAt)}");
        }

        return parts.Count == 0 ? "Docker-reported component" : string.Join(" · ", parts);
    }

    private static string TrimContainerId(string? containerId)
    {
        if (string.IsNullOrWhiteSpace(containerId))
        {
            return "Container ID unavailable";
        }

        return containerId.Length <= 12
            ? $"Container {containerId}"
            : $"Container {containerId[..12]}";
    }

    private static string FormatAge(double? seconds)
        => seconds is null
            ? "—"
            : AppTimeFormat.FormatDuration(TimeSpan.FromSeconds(Math.Max(0d, seconds.Value)));

    private static string FormatDepth(long? depth)
        => depth?.ToString("N0") ?? "—";

    private static string NormalizeColor(string? color)
        => color?.Trim().ToLowerInvariant() switch
        {
            "green" => "green",
            "yellow" => "yellow",
            "red" => "red",
            _ => "gray"
        };

    private static int SeverityRank(string? color)
        => NormalizeColor(color) switch
        {
            "green" => 0,
            "yellow" => 1,
            "red" => 2,
            _ => 3
        };

    private static string ColorClass(string? color)
        => $"tone-{NormalizeColor(color)}";

    public void Dispose()
    {
        Realtime.DomainEventReceived -= OnDomainEventReceived;
        Realtime.StatusChangedReceived -= OnStatusChangedReceived;
        Realtime.ConnectionStateChanged -= OnConnectionStateChanged;
        _pollCts.Cancel();
        _pollCts.Dispose();
    }

    private sealed record ComponentCard(
        string Source,
        string Title,
        string Subtitle,
        string Status,
        string Color,
        string Reason,
        string Detail);

    private sealed record ComponentLane(
        string Title,
        string Description,
        string Kicker,
        IReadOnlyList<ComponentCard> Cards);

    private sealed record StateOverview(int Healthy, int Warning, int Critical, int Unknown);
}
