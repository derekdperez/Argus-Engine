@using ArgusEngine.Application.Assets
@using ArgusEngine.Application.TechnologyIdentification

<li class="asset-tree-node">
    <div class="asset-node-line">
        <span class="asset-kind">@Node.Asset.Kind</span>
        <strong>@(Node.Asset.DisplayName ?? Node.Asset.RawValue)</strong>
        @if (Node.IncomingRelationship is not null)
        {
            <small>@Node.IncomingRelationship.RelationshipType</small>
        }
        @if (AssetTags.TryGetValue(Node.Asset.Id, out var tags) && tags.Count > 0)
        {
            <span class="asset-tag-list">
                @foreach (var tag in tags.Take(4))
                {
                    <span class="asset-tag-pill" title="@tag.Slug">@tag.Name</span>
                }
                @if (tags.Count > 4)
                {
                    <span class="asset-tag-pill muted">+@(tags.Count - 4)</span>
                }
            </span>
        }
    </div>
    @if (Node.Children.Count > 0)
    {
        <ul>
            @foreach (var child in Node.Children)
            {
                <AssetTreeView Node="child" AssetTags="AssetTags" />
            }
        </ul>
    }
</li>

@code {
    [Parameter, EditorRequired] public AssetTreeNodeDto Node { get; set; } = default!;
    [Parameter] public IReadOnlyDictionary<Guid, IReadOnlyList<AssetTagDto>> AssetTags { get; set; } =
        new Dictionary<Guid, IReadOnlyList<AssetTagDto>>();
}

