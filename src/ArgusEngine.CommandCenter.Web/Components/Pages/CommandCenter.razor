    private async Task<JsonElement?> GetObjectAsync(string uri)
    {
        using var response = await WorkerApi.Client.GetAsync(uri, _cts.Token).ConfigureAwait(false);
        if (!response.IsSuccessStatusCode)
        {
            return null;
        }

        var json = await response.Content.ReadAsStringAsync(_cts.Token).ConfigureAwait(false);
        using var doc = JsonDocument.Parse(json);
        return doc.RootElement.ValueKind == JsonValueKind.Object ? doc.RootElement.Clone() : null;
    }

    private async Task<List<JsonElement>> GetArrayAsync(string uri)
    {
        using var response = await WorkerApi.Client.GetAsync(uri, _cts.Token).ConfigureAwait(false);
        if (!response.IsSuccessStatusCode)
        {
            return [];
        }

        var json = await response.Content.ReadAsStringAsync(_cts.Token).ConfigureAwait(false);
        using var doc = JsonDocument.Parse(json);

        if (doc.RootElement.ValueKind == JsonValueKind.Array)
        {
            return doc.RootElement.EnumerateArray().Select(x => x.Clone()).ToList();
        }

        if (doc.RootElement.ValueKind == JsonValueKind.Object)
        {
            if (doc.RootElement.TryGetProperty("items", out var items) && items.ValueKind == JsonValueKind.Array)
            {
                return items.EnumerateArray().Select(x => x.Clone()).ToList();
            }

            if (doc.RootElement.TryGetProperty("rows", out var rows) && rows.ValueKind == JsonValueKind.Array)
            {
                return rows.EnumerateArray().Select(x => x.Clone()).ToList();
            }
        }

        return [];
    }

    private static void Replace(List<JsonElement> target, IEnumerable<JsonElement> values)
    {
        target.Clear();
        target.AddRange(values.Select(v => v.Clone()));
    }

    private static JsonElement? Property(JsonElement element, params string[] names)
    {
        if (element.ValueKind != JsonValueKind.Object)
        {
            return null;
        }

        foreach (var name in names.Where(n => !string.IsNullOrWhiteSpace(n)))
        {
            if (element.TryGetProperty(name, out var value))
            {
                return value;
            }

            var camel = char.ToLowerInvariant(name[0]) + name[1..];
            if (element.TryGetProperty(camel, out value))
            {
                return value;
            }

            var pascal = char.ToUpperInvariant(name[0]) + name[1..];
            if (element.TryGetProperty(pascal, out value))
            {
                return value;
            }
        }

        return null;
    }

    private static IReadOnlyList<JsonElement> ArrayProperty(JsonElement element, params string[] names)
    {
        var value = Property(element, names);
        return value is { ValueKind: JsonValueKind.Array }
            ? value.Value.EnumerateArray().Select(x => x.Clone()).ToArray()
            : [];
    }

    private static string Text(JsonElement element, params string[] names)
    {
        var value = Property(element, names);
        if (value is null)
        {
            return "";
        }

        return value.Value.ValueKind switch
        {
            JsonValueKind.String => value.Value.GetString() ?? "",
            JsonValueKind.Number => value.Value.ToString(),
            JsonValueKind.True => "true",
            JsonValueKind.False => "false",
            JsonValueKind.Null => "",
            _ => value.Value.ToString()
        };
    }

    private static long Long(JsonElement element, params string[] names)
    {
        var value = Property(element, names);
        if (value is null)
        {
            return 0;
        }

        if (value.Value.ValueKind == JsonValueKind.Number && value.Value.TryGetInt64(out var number))
        {
            return number;
        }

        return long.TryParse(Text(element, names), NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed) ? parsed : 0;
    }

    private static bool Bool(JsonElement element, params string[] names)
    {
        var value = Property(element, names);
        if (value is null)
        {
            return false;
        }

        return value.Value.ValueKind switch
        {
            JsonValueKind.True => true,
            JsonValueKind.False => false,
            JsonValueKind.String => bool.TryParse(value.Value.GetString(), out var parsed) && parsed,
            _ => false
        };
    }

    private static string SubdomainKey(JsonElement asset)
    {
        var targetId = Text(asset, "targetId", "TargetId");
        var subdomain = SubdomainName(asset);
        return $"{targetId}|{subdomain}".Trim('|');
    }

    private static string SubdomainName(JsonElement asset)
    {
        foreach (var name in new[] { "displayName", "DisplayName", "rawValue", "RawValue", "canonicalKey", "CanonicalKey", "finalUrl", "FinalUrl" })
        {
            var value = Text(asset, name);
            if (!string.IsNullOrWhiteSpace(value))
            {
                if (Uri.TryCreate(value, UriKind.Absolute, out var uri))
                {
                    return uri.Host;
                }

                return value.Trim();
            }
        }

        return "";
    }

    private static string AssetValue(JsonElement asset)
    {
        var finalUrl = Text(asset, "finalUrl", "FinalUrl");
        if (!string.IsNullOrWhiteSpace(finalUrl))
        {
            return finalUrl;
        }

        return DisplayOrDash(Text(asset, "displayName", "DisplayName", "rawValue", "RawValue", "canonicalKey", "CanonicalKey"));
    }

    private static string ExtractHost(JsonElement asset)
    {
        var value = AssetValue(asset);
        if (Uri.TryCreate(value, UriKind.Absolute, out var uri))
        {
            return uri.Host.Trim().ToLowerInvariant();
        }

        return value.Trim().ToLowerInvariant();
    }

    private static string ExtractHostForScope(JsonElement row)
    {
        foreach (var name in new[] { "subdomain", "Subdomain", "domainKey", "DomainKey", "targetRootDomain", "TargetRootDomain", "requestUrl", "RequestUrl", "finalUrl", "FinalUrl", "displayName", "DisplayName", "rawValue", "RawValue" })
        {
            var value = Text(row, name);
            if (string.IsNullOrWhiteSpace(value))
            {
                continue;
            }

            if (Uri.TryCreate(value, UriKind.Absolute, out var uri))
            {
                return uri.Host.Trim().ToLowerInvariant();
            }

            return value.Trim().ToLowerInvariant();
        }

        return "";
    }

    private static string BestAssetUrl(JsonElement row)
    {
        foreach (var name in new[] { "finalUrl", "FinalUrl", "displayName", "DisplayName", "rawValue", "RawValue" })
        {
            var value = Text(row, name);
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "";
    }

    private static string HighValueKey(JsonElement row)
    {
        foreach (var name in new[] { "findingId", "FindingId", "assetId", "AssetId", "id", "Id" })
        {
            var value = Text(row, name);
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return string.Join("|", Text(row, "targetRootDomain", "TargetRootDomain"), BestAssetUrl(row), Text(row, "findingType", "FindingType"));
    }

    private static string TechnologyKey(JsonElement row)
    {
        foreach (var name in new[] { "id", "Id", "observationId", "ObservationId" })
        {
            var value = Text(row, name);
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return string.Join("|", Text(row, "targetId", "TargetId"), Text(row, "subdomain", "Subdomain"), Text(row, "technologyName", "TechnologyName"), Text(row, "version", "Version"));
    }

    private static bool MatchesAny(JsonElement element, string search, params string[] names) =>
        names.Any(name => Text(element, name).Contains(search, StringComparison.OrdinalIgnoreCase));

    private static string FormatNumber(long value) => value.ToString("N0", CultureInfo.InvariantCulture);

    private static string FormatStorageSize(long bytes)
    {
        if (bytes <= 0)
        {
            return "0 B";
        }

        string[] units = ["B", "KB", "MB", "GB", "TB"];
        var size = (double)bytes;
        var unit = 0;
        while (size >= 1024 && unit < units.Length - 1)
        {
            size /= 1024;
            unit++;
        }

        return $"{size:N1} {units[unit]}";
    }

    private static string DisplayOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatTime(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        return DateTimeOffset.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var parsed)
            ? parsed.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)
            : value;
    }

    private static string? TryHttpHref(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return Uri.TryCreate(value.Trim(), UriKind.Absolute, out var uri) && uri.Scheme is "http" or "https"
            ? uri.ToString()
            : null;
    }

    public void Dispose()
    {
        Realtime.DomainEventReceived -= OnRealtimeEvent;
        _cts.Cancel();
        _cts.Dispose();
    }

