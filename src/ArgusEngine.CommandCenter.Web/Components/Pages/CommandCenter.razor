    private async Task ReloadRabbitMqAsync()
    {
        _rmqLoading = true;
        _rmqError = null;
        try
        {
            var resp = await Http.GetFromJsonAsync<JsonElement>("/api/rabbitmq/status");
            if (resp.TryGetProperty("error", out var err))
            {
                _rmqError = err.GetString();
                return;
            }
            _rmqVersion = resp.TryGetProperty("version", out var v) ? v.GetString() ?? "" : "";
            _rmqTotalMessages = resp.TryGetProperty("totalMessages", out var tm) ? tm.GetInt64() : 0;
            _rmqConsumerGroups = resp.TryGetProperty("consumerCount", out var cc) ? cc.GetInt32() : 0;

            var queues = new List<RmqQueueInfo>();
            if (resp.TryGetProperty("queues", out var qList))
            {
                foreach (var q in qList.EnumerateArray())
                {
                    queues.Add(new RmqQueueInfo(
                        q.GetProperty("name").GetString() ?? "?",
                        q.TryGetProperty("messages", out var m) ? m.GetInt64() : 0,
                        q.TryGetProperty("ready", out var r) ? r.GetInt64() : 0,
                        q.TryGetProperty("unacked", out var u) ? u.GetInt64() : 0,
                        q.TryGetProperty("consumers", out var c) ? c.GetInt32() : 0
                    ));
                }
            }
            _rmqQueues = queues;

            _rmqConsumerTags.Clear();
            if (resp.TryGetProperty("consumers", out var cList))
            {
                foreach (var cg in cList.EnumerateArray())
                {
                    var qName = cg.TryGetProperty("queue", out var qn) ? qn.GetString() ?? "" : "";
                    var consumerList = cg.TryGetProperty("consumers", out var cl) ? cl : default;
                    if (!string.IsNullOrWhiteSpace(qName) && consumerList.ValueKind == JsonValueKind.Array)
                    {
                        var tags = consumerList.EnumerateArray()
                            .Select(ce => ce.TryGetProperty("tag", out var tag) ? tag.GetString() ?? "" : "")
                            .Where(t => !string.IsNullOrWhiteSpace(t))
                            .ToList();
                        if (tags.Count > 0)
                            _rmqConsumerTags[qName] = tags;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _rmqError = $"Failed to load RabbitMQ status: {ex.Message}";
        }
        finally
        {
            _rmqLoading = false;
        }
    }

    private async Task CreateTargetAsync()
    {
        if (!CanCreateTarget)
        {
            return;
        }

        _creatingTarget = true;
        ClearError();

        try
        {
            var rootDomain = _newTargetRootDomain?.Trim();
            using var response = await Http.PostAsJsonAsync(
                "/api/targets",
                new { rootDomain, globalMaxDepth = _newTargetDepth },
                _disposeCts.Token).ConfigureAwait(false);

            await EnsureSuccessAsync(response, "create target").ConfigureAwait(false);
            _newTargetRootDomain = null;
            _statusMessage = $"Target {rootDomain} created.";
            await Task.WhenAll(ReloadTargetsAsync(), ReloadOverviewAsync(showLoading: false)).ConfigureAwait(false);
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            SetError(ex, "Failed to create target.");
        }
        finally
        {
            _creatingTarget = false;
        }
    }


