    private async Task ReloadWorkersAsync()
    {
        _workersLoading = true;
        try
        {
            var rows = new List<WorkerRow>();

            // Local workers
            try
            {
                var local = await Http.GetFromJsonAsync<List<JsonElement>>("/api/workers");
                if (local is not null)
                {
                    foreach (var w in local)
                    {
                        var name = Text(w, "name", "Name", "displayName", "DisplayName", "id", "Id") ?? "unknown";
                        var status = Text(w, "overallState", "OverallState", "status", "Status", "state", "State") ?? "unknown";
                        rows.Add(new WorkerRow("Local", name, status, 0, 0, null));
                    }
                }
            }
            catch { }

            // Google Cloud workers
            try
            {
                var gcpJson = await Http.GetFromJsonAsync<JsonElement>("/api/gcp-workers/status");
                _gcpConfigured = gcpJson.TryGetProperty("configured", out var cfg) && cfg.GetBoolean();
                if (_gcpConfigured && gcpJson.TryGetProperty("workers", out var w))
                {
                    foreach (var gw in w.EnumerateArray())
                    {
                        var name = Text(gw, "name", "Name") ?? "unknown";
                        var status = Text(gw, "status", "Status") ?? "inactive";
                        var min = Int(gw, "minInstances", "MinInstances");
                        var max = Int(gw, "maxInstances", "MaxInstances");
                        var url = Text(gw, "url", "Url");
                        rows.Add(new WorkerRow("Google", name, status, min, max, url));
                    }
                }
            }
            catch { _gcpConfigured = false; }

            // AWS workers (static entries)
            rows.Add(new WorkerRow("AWS", "worker-spider", "not configured", 0, 0, null));
            rows.Add(new WorkerRow("AWS", "worker-enum", "not configured", 0, 0, null));
            rows.Add(new WorkerRow("AWS", "worker-http-requester", "not configured", 0, 0, null));
            rows.Add(new WorkerRow("AWS", "worker-portscan", "not configured", 0, 0, null));
            rows.Add(new WorkerRow("AWS", "worker-highvalue", "not configured", 0, 0, null));
            rows.Add(new WorkerRow("AWS", "worker-techid", "not configured", 0, 0, null));

            // Azure workers (static entries)
            rows.Add(new WorkerRow("Azure", "worker-spider", "not configured", 0, 0, null));
            rows.Add(new WorkerRow("Azure", "worker-enum", "not configured", 0, 0, null));
            rows.Add(new WorkerRow("Azure", "worker-http-requester", "not configured", 0, 0, null));
            rows.Add(new WorkerRow("Azure", "worker-portscan", "not configured", 0, 0, null));
            rows.Add(new WorkerRow("Azure", "worker-highvalue", "not configured", 0, 0, null));
            rows.Add(new WorkerRow("Azure", "worker-techid", "not configured", 0, 0, null));

            _allWorkerRows = rows;
            _workersRefreshedUtc = DateTimeOffset.UtcNow;
        }
        finally
        {
            _workersLoading = false;
        }
    }

    private async Task ApplyScaleProviderAsync(string provider)
    {
        if (!_providerSettings.TryGetValue(provider, out var ps)) return;

        if (provider == "Google" && _gcpConfigured)
        {
            try
            {
                await Http.PutAsJsonAsync("/api/gcp-workers/scale",
                    new { minInstances = ps.Min, maxInstances = ps.Max });
                await ReloadWorkersAsync();
            }
            catch { }
        }
    }

    private async Task ApplyScaleAllAsync()
    {
        foreach (var kvp in _providerSettings)
        {
            await ApplyScaleProviderAsync(kvp.Key);
        }
    }

