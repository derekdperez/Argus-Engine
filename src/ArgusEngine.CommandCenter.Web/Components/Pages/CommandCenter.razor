@page "/commandcenter"
@rendermode InteractiveServer

@using System.Globalization
@using System.Net
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web.Virtualization
@implements IDisposable
@inject HttpClient Http
@inject ILogger<CommandCenter> Logger

<PageTitle>Command Center - Argus Engine</PageTitle>

<div class="cc-page">
    <header class="cc-hero">
        <div>
            <p class="cc-eyebrow">Argus Engine</p>
            <h1>Command Center</h1>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="cc-status">@_statusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="cc-error">
            <strong>Command Center request failed.</strong>
            <span>@_errorMessage</span>
            <button class="cc-btn cc-btn-small" @onclick="ClearError">Dismiss</button>
        </div>
    }

    <section class="cc-summary-grid" aria-label="Command Center summary">
        <article class="cc-card">
            <span>Targets</span>
            <strong>@FormatNumber(TotalTargets)</strong>
            <small>Database total</small>
        </article>
        <article class="cc-card">
            <span>Confirmed assets</span>
            <strong>@FormatNumber(ConfirmedAssets)</strong>
            <small>Database total</small>
        </article>
        <article class="cc-card">
            <span>HTTP queue</span>
            <strong>@FormatNumber(HttpQueueCount)</strong>
            <small>Database total</small>
        </article>
        <article class="cc-card">
            <span>High value</span>
            <strong>@FormatNumber(HighValueCount)</strong>
            <small>Database total</small>
        </article>
        <article class="cc-card">
            <span>Technologies</span>
            <strong>@FormatNumber(TechnologyCount)</strong>
            <small>Database total</small>
        </article>
        <article class="cc-card">
            <span>Workers</span>
            <strong>@FormatNumber(WorkerCount)</strong>
            <small>Database total</small>
        </article>
    </section>

    <nav class="cc-tabs" aria-label="Command Center sections">
        <button class="@TabClass(CommandTab.Targets)" @onclick="@(() => SelectTabAsync(CommandTab.Targets))">Targets</button>
        <button class="@TabClass(CommandTab.Discovery)" @onclick="@(() => SelectTabAsync(CommandTab.Discovery))">Discovery</button>
        <button class="@TabClass(CommandTab.Workers)" @onclick="@(() => SelectTabAsync(CommandTab.Workers))">Workers</button>
    </nav>

    @if (_activeTab == CommandTab.Targets)
    {
        <section class="cc-panel">
            <div class="cc-panel-header">
                <div>
                    <h2>Targets</h2>
                    <p class="cc-muted">Loaded in a bounded request. Use the search box to filter only the loaded window.</p>
                </div>
                <div class="cc-toolbar">
                    <input class="cc-input" placeholder="example.com" @bind="_newTargetRootDomain" @bind:event="oninput" />
                    <label class="cc-inline-label">
                        Depth
                        <input class="cc-input cc-depth-input" type="number" min="0" max="10" @bind="_newTargetDepth" />
                    </label>
                    <button class="cc-btn cc-btn-primary" @onclick="CreateTargetAsync" disabled="@(!CanCreateTarget || _creatingTarget)">
                        @(_creatingTarget ? "Creating..." : "Create")
                    </button>
                    <input class="cc-input" placeholder="Filter targets" @bind="_targetSearch" @bind:event="oninput" />
                    <button class="cc-btn" @onclick="ReloadTargetsAsync" disabled="@_targetsLoading">Reload</button>
                    <button class="cc-btn" @onclick="EnumerateSelectedTargetsAsync" disabled="@(!_selectedTargetIds.Any() || _targetActionLoading)">Enumerate selected</button>
                    <button class="cc-btn" @onclick="SpiderSelectedTargetsAsync" disabled="@(!_selectedTargetIds.Any() || _targetActionLoading)">Spider selected</button>
                </div>
            </div>
            <div class="cc-two-column">
                <div class="cc-grid cc-grid-targets" role="table" aria-label="Targets">
                    <div class="cc-row cc-header" role="row">
                        <span></span><span>Root domain</span><span>Status</span><span>Depth</span><span>Created</span>
                    </div>
                    <Virtualize Items="TargetRows" Context="target" ItemSize="44" OverscanCount="8">
                        <ItemContent>
                            <div class="cc-row" role="row" @key="RowKey(target)" @onclick="@(() => ToggleTarget(target))">
                                <span><input type="checkbox" checked="@IsSelectedTarget(target)" @onchange="@(_ => ToggleTarget(target))" @onclick:stopPropagation="true" /></span>
                                <span class="cc-main-cell">@Display(Text(target, "rootDomain", "RootDomain", "domain", "Domain"))</span>
                                <span><span class="cc-pill">@Display(Text(target, "status", "Status", "state", "State"))</span></span>
                                <span>@Display(Text(target, "globalMaxDepth", "GlobalMaxDepth", "maxDepth", "MaxDepth"))</span>
                                <span>@FormatTime(Text(target, "createdAtUtc", "CreatedAtUtc", "createdAt", "CreatedAt"))</span>
                            </div>
                        </ItemContent>
                        <Placeholder>
                            <div class="cc-row cc-placeholder"><span></span><span>Loading target...</span><span></span><span></span><span></span></div>
                        </Placeholder>
                    </Virtualize>
                </div>

                <div class="cc-grid cc-grid-subdomains" role="table" aria-label="Subdomains">
                    <div class="cc-row cc-header" role="row">
                        <span>Target</span><span>Subdomain</span><span>Technologies</span><span>Last seen</span>
                    </div>
                    <Virtualize Items="SubdomainRows" Context="subdomain" ItemSize="44" OverscanCount="8">
                        <ItemContent>
                            <div class="cc-row" role="row" @key="RowKey(subdomain)">
                                <span>@Display(Text(subdomain, "rootDomain", "RootDomain", "target", "Target"))</span>
                                <span class="cc-main-cell">@Display(Text(subdomain, "subdomain", "Subdomain", "canonicalKey", "CanonicalKey", "rawValue", "RawValue"))</span>
                                <span>@Display(Text(subdomain, "technologyCount", "TechnologyCount"))</span>
                                <span>@FormatTime(Text(subdomain, "lastSeenUtc", "LastSeenUtc", "lastSeenAtUtc", "LastSeenAtUtc"))</span>
                            </div>
                        </ItemContent>
                        <Placeholder>
                            <div class="cc-row cc-placeholder"><span></span><span>Loading subdomain...</span><span></span><span></span></div>
                        </Placeholder>
                    </Virtualize>
                </div>
            </div>

            <div class="cc-panel-header">
                <div>
                    <h2>Assets</h2>
                    <p class="cc-muted">Recent confirmed assets only. This avoids the previous full-table hydration path.</p>
                </div>
                <div class="cc-toolbar">
                    <input class="cc-input" placeholder="Filter loaded assets" @bind="_assetSearch" @bind:event="oninput" />
                    <select class="cc-input" @bind="_assetKindFilter">
                        <option value="">All kinds</option>
                        @foreach (var kind in AssetKinds)
                        {
                            <option value="@kind">@kind</option>
                        }
                    </select>
                    <button class="cc-btn" @onclick="ReloadAssetsAsync" disabled="@_assetsLoading">Reload</button>
                </div>
            </div>
            <div class="cc-grid cc-grid-assets" role="table" aria-label="Assets">
                <div class="cc-row cc-header" role="row">
                    <span>Kind</span><span>Asset</span><span>Category</span><span>Seen</span>
                </div>
                <Virtualize Items="AssetRows" Context="asset" ItemSize="46" OverscanCount="8">
                    <ItemContent>
                        <div class="cc-row" role="row" @key="RowKey(asset)" @onclick="@(() => ToggleAsset(asset))">
                            <span><span class="cc-pill">@Display(Text(asset, "kind", "Kind"))</span></span>
                            <span class="cc-main-cell">
                                @{
                                    var assetText = Text(asset, "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue", "finalUrl", "FinalUrl");
                                    var assetHref = TryHttpHref(assetText);
                                }
                                @if (assetHref is null)
                                {
                                    @Display(assetText)
                                }
                                else
                                {
                                    <a href="@assetHref" target="_blank" rel="noopener noreferrer">@assetText</a>
                                }
                            </span>
                            <span>@Display(Text(asset, "category", "Category"))</span>
                            <span>@FormatTime(Text(asset, "lastSeenAtUtc", "LastSeenAtUtc", "discoveredAtUtc", "DiscoveredAtUtc"))</span>
                        </div>
                    </ItemContent>
                    <Placeholder>
                        <div class="cc-row cc-placeholder"><span>Loading</span><span>Asset...</span><span></span><span></span></div>
                    </Placeholder>
                </Virtualize>
            </div>
        </section>
    }

    @if (_activeTab == CommandTab.Discovery)
    {
        <section class="cc-panel">
            <div class="cc-panel-header">
                <div>
                    <h2>Discovery</h2>
                    <p class="cc-muted">High-value and technology identification in one workspace.</p>
                </div>
                <div class="cc-toolbar">
                    <input class="cc-input" placeholder="Filter findings" @bind="_highValueSearch" @bind:event="oninput" />
                    <input class="cc-input" placeholder="Filter technologies" @bind="_technologySearch" @bind:event="oninput" />
                    <button class="cc-btn" @onclick="ReloadHighValueAsync" disabled="@_highValueLoading">Reload high value</button>
                    <button class="cc-btn" @onclick="ReloadTechnologyAsync" disabled="@_technologyLoading">Reload tech ID</button>
                </div>
            </div>
            <div class="cc-grid cc-grid-high-value" role="table" aria-label="High-value assets">
                <div class="cc-row cc-header" role="row">
                    <span>Severity</span><span>Asset</span><span>Finding</span><span>Score</span><span>Seen</span>
                </div>
                <Virtualize Items="HighValueRows" Context="finding" ItemSize="48" OverscanCount="8">
                    <ItemContent>
                        <div class="cc-row" role="row" @key="RowKey(finding)">
                            <span><span class="cc-pill">@Display(Text(finding, "severity", "Severity"))</span></span>
                            <span class="cc-main-cell">@Display(Text(finding, "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue"))</span>
                            <span>@Display(Text(finding, "findingType", "FindingType", "patternName", "PatternName"))</span>
                            <span>@Display(Text(finding, "importanceScore", "ImportanceScore", "confidence", "Confidence"))</span>
                            <span>@FormatTime(Text(finding, "findingDiscoveredAtUtc", "FindingDiscoveredAtUtc", "discoveredAtUtc", "DiscoveredAtUtc"))</span>
                        </div>
                    </ItemContent>
                    <Placeholder>
                        <div class="cc-row cc-placeholder"><span>Loading</span><span>Finding...</span><span></span><span></span><span></span></div>
                    </Placeholder>
                </Virtualize>
            </div>

            <div class="cc-grid cc-grid-technology" role="table" aria-label="Technology observations">
                <div class="cc-row cc-header" role="row">
                    <span>Technology</span><span>Version</span><span>Evidence</span><span>Seen</span>
                </div>
                <Virtualize Items="TechnologyRows" Context="technology" ItemSize="46" OverscanCount="8">
                    <ItemContent>
                        <div class="cc-row" role="row" @key="RowKey(technology)">
                            <span class="cc-main-cell">@Display(Text(technology, "technologyName", "TechnologyName", "name", "Name", "technology", "Technology"))</span>
                            <span>@Display(Text(technology, "version", "Version"))</span>
                            <span>@Display(Text(technology, "evidence", "Evidence", "source", "Source", "category", "Category"))</span>
                            <span>@FormatTime(Text(technology, "lastSeenUtc", "LastSeenUtc", "observedAtUtc", "ObservedAtUtc"))</span>
                        </div>
                    </ItemContent>
                    <Placeholder>
                        <div class="cc-row cc-placeholder"><span>Loading technology...</span><span></span><span></span><span></span></div>
                    </Placeholder>
                </Virtualize>
            </div>
        </section>
    }

    @if (_activeTab == CommandTab.Workers)
    {
        <section class="cc-panel">
            <div class="cc-panel-header">
                <div>
                    <h2>Workers</h2>
                    <p class="cc-muted">Loaded from the worker-control API in a bounded refresh cycle.</p>
                </div>
                <div class="cc-toolbar">
                    <input class="cc-input" placeholder="Filter workers" @bind="_workerSearch" @bind:event="oninput" />
                    <button class="cc-btn" @onclick="ReloadWorkersAsync" disabled="@_workersLoading">Reload</button>
                    <button class="cc-btn" @onclick="ReloadCloudWorkersAsync" disabled="@_workersLoading">Refresh cloud</button>
                </div>
            </div>

            <h3>Local worker controls</h3>
            <div class="cc-grid cc-grid-workers" role="table" aria-label="Local workers">
                <div class="cc-row cc-header" role="row">
                    <span>Worker</span><span>State</span><span>Running</span><span>Total</span>
                </div>
                <Virtualize Items="WorkerRows" Context="worker" ItemSize="46" OverscanCount="8">
                    <ItemContent>
                        <div class="cc-row" role="row" @key="RowKey(worker)">
                            <span class="cc-main-cell">@Display(Text(worker, "displayName", "DisplayName", "serviceName", "ServiceName", "name", "Name", "id", "Id"))</span>
                            <span><span class="cc-pill">@Display(Text(worker, "overallState", "OverallState", "status", "Status", "state", "State"))</span></span>
                            <span>@Display(Text(worker, "runningCount", "RunningCount"))</span>
                            <span>@Display(Text(worker, "totalCount", "TotalCount"))</span>
                        </div>
                    </ItemContent>
                    <Placeholder>
                        <div class="cc-row cc-placeholder"><span>Loading worker...</span><span></span><span></span><span></span></div>
                    </Placeholder>
                </Virtualize>
            </div>

            <h3>Cloud worker controls</h3>
            <div class="cc-grid cc-grid-workers" role="table" aria-label="Cloud workers">
                <div class="cc-row cc-header" role="row">
                    <span>Service</span><span>Status</span><span>Running</span><span>Desired</span>
                </div>
                <Virtualize Items="CloudWorkerRows" Context="worker" ItemSize="46" OverscanCount="8">
                    <ItemContent>
                        <div class="cc-row" role="row" @key="RowKey(worker)">
                            <span class="cc-main-cell">@Display(Text(worker, "serviceName", "ServiceName", "scaleKey", "ScaleKey"))</span>
                            <span><span class="cc-pill">@Display(Text(worker, "status", "Status", "deploymentStatus", "DeploymentStatus"))</span></span>
                            <span>@Display(Text(worker, "runningCount", "RunningCount"))</span>
                            <span>@Display(Text(worker, "desiredCount", "DesiredCount"))</span>
                        </div>
                    </ItemContent>
                    <Placeholder>
                        <div class="cc-row cc-placeholder"><span>Loading cloud worker...</span><span></span><span></span><span></span></div>
                    </Placeholder>
                </Virtualize>
            </div>
        </section>
    }
</div>

@code {
    private const int TargetTake = 500;
    private const int AssetTake = 250;
    private const int HttpQueueTake = 200;
    private const int HighValueTake = 200;
    private const int TechnologyTake = 250;
    private const int WorkerTake = 250;

    private readonly CancellationTokenSource _disposeCts = new();
    private JsonElement? _overview;
    private readonly List<JsonElement> _targets = [];
    private readonly List<JsonElement> _subdomains = [];
    private readonly List<JsonElement> _assets = [];
    private readonly List<JsonElement> _httpQueue = [];
    private readonly List<JsonElement> _highValue = [];
    private readonly List<JsonElement> _technology = [];
    private readonly List<JsonElement> _workers = [];
    private readonly List<JsonElement> _cloudWorkers = [];
    private readonly HashSet<string> _selectedTargetIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedAssetIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedHttpIds = new(StringComparer.OrdinalIgnoreCase);

    private CommandTab _activeTab = CommandTab.Targets;
    private PeriodicTimer? _summaryTimer;
    private Task? _summaryPollingTask;
    private string? _errorMessage;
    private string? _statusMessage;
    private string? _targetSearch;
    private string? _assetSearch;
    private string? _assetKindFilter;
    private string _httpSearch = string.Empty;
    private string _httpStateFilter = string.Empty;
    private string? _highValueSearch;
    private string? _technologySearch;
    private string? _workerSearch;
    private string? _newTargetRootDomain;
    private int _newTargetDepth = 2;
    private bool _overviewLoading;
    private bool _targetsLoading;
    private bool _subdomainsLoading;
    private bool _assetsLoading;
    private bool _httpLoading;
    private bool _highValueLoading;
    private bool _technologyLoading;
    private bool _workersLoading;
    private bool _creatingTarget;
    private bool _targetActionLoading;
    private bool _queueMutationLoading;

    private bool _loadingAny => _overviewLoading
        || _targetsLoading
        || _subdomainsLoading
        || _assetsLoading
        || _httpLoading
        || _highValueLoading
        || _technologyLoading
        || _workersLoading
        || _creatingTarget
        || _targetActionLoading
        || _queueMutationLoading;

    private bool CanCreateTarget => !string.IsNullOrWhiteSpace(_newTargetRootDomain);

    private JsonElement[] TargetRows => _targets
        .Where(row => Matches(row, _targetSearch, "rootDomain", "RootDomain", "domain", "Domain", "status", "Status"))
        .ToArray();

    private JsonElement[] AssetRows => _assets
        .Where(row => string.IsNullOrWhiteSpace(_assetKindFilter)
            || string.Equals(Text(row, "kind", "Kind"), _assetKindFilter, StringComparison.OrdinalIgnoreCase))
        .Where(row => Matches(row, _assetSearch, "kind", "Kind", "category", "Category", "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue", "finalUrl", "FinalUrl"))
        .ToArray();

    private JsonElement[] SubdomainRows => _subdomains
        .Where(row => Matches(row, _targetSearch, "subdomain", "Subdomain", "rootDomain", "RootDomain", "target", "Target"))
        .ToArray();

    private JsonElement[] HttpRows => _httpQueue
        .Where(row => string.IsNullOrWhiteSpace(_httpStateFilter)
            || string.Equals(Text(row, "state", "State"), _httpStateFilter, StringComparison.OrdinalIgnoreCase))
        .Where(row => Matches(row, _httpSearch, "state", "State", "method", "Method", "requestMethod", "RequestMethod", "url", "Url", "requestUrl", "RequestUrl", "finalUrl", "FinalUrl"))
        .ToArray();

    private JsonElement[] HighValueRows => _highValue
        .Where(row => Matches(row, _highValueSearch, "severity", "Severity", "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue", "findingType", "FindingType", "patternName", "PatternName"))
        .ToArray();

    private JsonElement[] TechnologyRows => _technology
        .Where(row => Matches(row, _technologySearch, "technologyName", "TechnologyName", "name", "Name", "technology", "Technology", "version", "Version", "evidence", "Evidence", "category", "Category"))
        .ToArray();

    private JsonElement[] WorkerRows => _workers
        .Where(row => Matches(row, _workerSearch, "name", "Name", "workerName", "WorkerName", "id", "Id", "status", "Status", "state", "State", "type", "Type", "kind", "Kind"))
        .ToArray();

    private JsonElement[] CloudWorkerRows => _cloudWorkers
        .Where(row => Matches(row, _workerSearch, "serviceName", "ServiceName", "scaleKey", "ScaleKey", "status", "Status", "deploymentStatus", "DeploymentStatus"))
        .ToArray();

    private string[] AssetKinds => _assets
        .Select(row => Text(row, "kind", "Kind"))
        .Where(static value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(static value => value, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private long TotalTargets => OverviewLong("totalTargets", "TotalTargets", "targetCount", "TargetCount");
    private long ConfirmedAssets => OverviewLong("confirmedAssets", "ConfirmedAssets", "assetCount", "AssetCount", "totalAssets", "TotalAssets");
    private long HttpQueueCount => OverviewLong("httpQueueCount", "HttpQueueCount", "queuedHttpRequests", "QueuedHttpRequests");
    private long HighValueCount => OverviewLong("highValueCount", "HighValueCount", "highValueFindings", "HighValueFindings");
    private long TechnologyCount => OverviewLong("technologyCount", "TechnologyCount", "technologies", "Technologies");
    private long WorkerCount => OverviewLong("workerCount", "WorkerCount", "activeWorkers", "ActiveWorkers");

    protected override async Task OnInitializedAsync()
    {
        await LoadInitialWorkspaceAsync().ConfigureAwait(false);

        _summaryTimer = new PeriodicTimer(TimeSpan.FromSeconds(15));
        _summaryPollingTask = PollSummaryAsync();
    }

    private async Task LoadInitialWorkspaceAsync()
    {
        _statusMessage = "Loading recent workspace data...";
        try
        {
            await Task.WhenAll(
                ReloadOverviewAsync(),
                ReloadTargetsAsync(),
                ReloadSubdomainsAsync(),
                ReloadAssetsAsync(),
                ReloadWorkersAsync()).ConfigureAwait(false);
        }
        finally
        {
            _statusMessage = null;
        }
    }

    private async Task PollSummaryAsync()
    {
        if (_summaryTimer is null)
        {
            return;
        }

        try
        {
            while (await _summaryTimer.WaitForNextTickAsync(_disposeCts.Token).ConfigureAwait(false))
            {
                await ReloadOverviewAsync(showLoading: false).ConfigureAwait(false);

                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
            // Expected during component disposal.
        }
    }

    private async Task SelectTabAsync(CommandTab tab)
    {
        _activeTab = tab;

        switch (tab)
        {
            case CommandTab.Targets when _targets.Count == 0:
                await ReloadTargetsAsync().ConfigureAwait(false);
                break;
            case CommandTab.Discovery when _highValue.Count == 0 || _technology.Count == 0:
                await ReloadHighValueAsync().ConfigureAwait(false);
                await ReloadTechnologyAsync().ConfigureAwait(false);
                break;
            case CommandTab.Workers when _workers.Count == 0:
                await Task.WhenAll(ReloadWorkersAsync(), ReloadCloudWorkersAsync()).ConfigureAwait(false);
                break;
        }
    }

    private async Task RefreshActiveAsync()
    {
        switch (_activeTab)
        {
            case CommandTab.Targets:
                await Task.WhenAll(ReloadTargetsAsync(), ReloadSubdomainsAsync(), ReloadAssetsAsync()).ConfigureAwait(false);
                break;
            case CommandTab.Discovery:
                await Task.WhenAll(ReloadHighValueAsync(), ReloadTechnologyAsync()).ConfigureAwait(false);
                break;
            case CommandTab.Workers:
                await Task.WhenAll(ReloadWorkersAsync(), ReloadCloudWorkersAsync()).ConfigureAwait(false);
                break;
        }

        await ReloadOverviewAsync(showLoading: false).ConfigureAwait(false);
    }

    private async Task RefreshEverythingAsync()
    {
        await Task.WhenAll(
            ReloadOverviewAsync(),
            ReloadTargetsAsync(),
            ReloadSubdomainsAsync(),
            ReloadAssetsAsync(),
            ReloadWorkersAsync()).ConfigureAwait(false);
    }

    private async Task ReloadOverviewAsync(bool showLoading = true)
    {
        if (showLoading)
        {
            _overviewLoading = true;
        }

        try
        {
            _overview = await GetObjectAsync("/api/ops/overview").ConfigureAwait(false);
        }
        finally
        {
            if (showLoading)
            {
                _overviewLoading = false;
            }
        }
    }

    private async Task ReloadTargetsAsync()
    {
        _targetsLoading = true;
        try
        {
            Replace(_targets, await GetArrayAsync("/api/targets").ConfigureAwait(false));
            PruneSelection(_selectedTargetIds, _targets);
        }
        finally
        {
            _targetsLoading = false;
        }
    }

    private async Task ReloadSubdomainsAsync()
    {
        _subdomainsLoading = true;
        try
        {
            Replace(_subdomains, await GetArrayAsync("/api/technology-identification/subdomains").ConfigureAwait(false));
        }
        finally
        {
            _subdomainsLoading = false;
        }
    }

    private async Task ReloadAssetsAsync()
    {
        _assetsLoading = true;
        try
        {
            Replace(_assets, await GetArrayAsync($"/api/assets?take={AssetTake}").ConfigureAwait(false));
        }
        finally
        {
            _assetsLoading = false;
        }
    }

    private async Task ReloadHttpQueueAsync(bool showLoading = true)
    {
        if (showLoading)
        {
            _httpLoading = true;
        }

        try
        {
            var stateQuery = string.IsNullOrWhiteSpace(_httpStateFilter)
                ? ""
                : $"&state={WebUtility.UrlEncode(_httpStateFilter)}";

            Replace(_httpQueue, await GetArrayAsync($"/api/http-request-queue?take={HttpQueueTake}{stateQuery}").ConfigureAwait(false));
            PruneSelection(_selectedHttpIds, _httpQueue);
        }
        finally
        {
            if (showLoading)
            {
                _httpLoading = false;
            }
        }
    }

    private async Task ReloadHighValueAsync()
    {
        _highValueLoading = true;
        try
        {
            Replace(_highValue, await GetArrayAsync($"/api/high-value-assets?includeResolved=false&take={HighValueTake}").ConfigureAwait(false));
        }
        finally
        {
            _highValueLoading = false;
        }
    }

    private async Task ReloadTechnologyAsync()
    {
        _technologyLoading = true;
        try
        {
            Replace(_technology, await GetArrayAsync($"/api/technology-identification/technologies?take={TechnologyTake}").ConfigureAwait(false));
        }
        finally
        {
            _technologyLoading = false;
        }
    }

    private async Task ReloadWorkersAsync()
    {
        _workersLoading = true;
        try
        {
            Replace(_workers, await GetArrayAsync("/api/ops/docker-status").ConfigureAwait(false));
        }
        finally
        {
            _workersLoading = false;
        }
    }

    private async Task ReloadCloudWorkersAsync()
    {
        try
        {
            Replace(_cloudWorkers, await GetArrayAsync("/api/ops/ecs-status").ConfigureAwait(false));
        }
        catch
        {
            // best-effort: cloud status is optional in local-only deployments
        }
    }

    private async Task CreateTargetAsync()
    {
        if (!CanCreateTarget)
        {
            return;
        }

        _creatingTarget = true;
        ClearError();

        try
        {
            var rootDomain = _newTargetRootDomain?.Trim();
            using var response = await Http.PostAsJsonAsync(
                "/api/targets",
                new { rootDomain, globalMaxDepth = _newTargetDepth },
                _disposeCts.Token).ConfigureAwait(false);

            await EnsureSuccessAsync(response, "create target").ConfigureAwait(false);
            _newTargetRootDomain = null;
            _statusMessage = $"Target {rootDomain} created.";
            await Task.WhenAll(ReloadTargetsAsync(), ReloadOverviewAsync(showLoading: false)).ConfigureAwait(false);
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            SetError(ex, "Failed to create target.");
        }
        finally
        {
            _creatingTarget = false;
        }
    }


    private Task EnumerateSelectedTargetsAsync()
    {
        return QueueTargetWorkAsync("/api/ops/subdomain-enum/restart", "Enumeration", selectedOnly: true);
    }

    private Task SpiderSelectedTargetsAsync()
    {
        return QueueTargetWorkAsync("/api/ops/spider/restart", "Spider", selectedOnly: true);
    }

    private async Task QueueTargetWorkAsync(string endpoint, string label, bool selectedOnly)
    {
        var ids = selectedOnly
            ? _selectedTargetIds.ToArray()
            : TargetRows.Select(RowKey).Where(static value => !string.IsNullOrWhiteSpace(value)).ToArray();

        if (ids.Length == 0)
        {
            _statusMessage = "Select at least one target first.";
            return;
        }

        _targetActionLoading = true;
        ClearError();

        try
        {
            using var response = await Http.PostAsJsonAsync(
                endpoint,
                new { targetIds = ids, allTargets = false },
                _disposeCts.Token).ConfigureAwait(false);

            await EnsureSuccessAsync(response, label).ConfigureAwait(false);
            _statusMessage = $"{label} queued for {ids.Length:N0} target(s).";
            await ReloadOverviewAsync(showLoading: false).ConfigureAwait(false);
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            SetError(ex, $"Failed to queue {label.ToLowerInvariant()}.");
        }
        finally
        {
            _targetActionLoading = false;
        }
    }

