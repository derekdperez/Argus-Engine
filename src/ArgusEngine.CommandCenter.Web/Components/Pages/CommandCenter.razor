@page "/"
@page "/ops"
@page "/commandcenter"
@rendermode InteractiveServer

@using System.Globalization
@using System.Net
@using System.Net.Http.Json
@using System.Text
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web.Virtualization
@implements IDisposable
@inject HttpClient Http
@inject ILogger<CommandCenter> Logger

<PageTitle>Command Center - Argus Engine</PageTitle>

<div class="cc-page">
    <header class="cc-hero">
        <div>
            <p class="cc-eyebrow">Argus Engine</p>
            <h1>Command Center</h1>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="cc-status">@_statusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="cc-error">
            <strong>Command Center request failed.</strong>
            <span>@_errorMessage</span>
            <button class="cc-btn cc-btn-small" @onclick="ClearError">Dismiss</button>
        </div>
    }

    <section class="cc-summary-grid" aria-label="Command Center summary">
        <article class="cc-card">
            <span>Targets</span>
            <strong>@FormatNumber(TotalTargets)</strong>
            <small>Database total</small>
        </article>
        <article class="cc-card">
            <span>Confirmed assets</span>
            <strong>@FormatNumber(ConfirmedAssets)</strong>
            <small>Database total</small>
        </article>
        <article class="cc-card">
            <span>HTTP queue</span>
            <strong>@FormatNumber(HttpQueueCount)</strong>
            <small>Database total</small>
        </article>
        <article class="cc-card">
            <span>High value</span>
            <strong>@FormatNumber(HighValueCount)</strong>
            <small>Database total</small>
        </article>
        <article class="cc-card">
            <span>Technologies</span>
            <strong>@FormatNumber(TechnologyCount)</strong>
            <small>Database total</small>
        </article>
        <article class="cc-card">
            <span>Workers</span>
            <strong>@FormatNumber(WorkerCount)</strong>
            <small>Database total</small>
        </article>
    </section>

    <nav class="cc-tabs" aria-label="Command Center sections">
        <button class="@TabClass(CommandTab.Targets)" @onclick="@(() => SelectTabAsync(CommandTab.Targets))">Targets</button>
        <button class="@TabClass(CommandTab.Discovery)" @onclick="@(() => SelectTabAsync(CommandTab.Discovery))">Discovery</button>
        <button class="@TabClass(CommandTab.Workers)" @onclick="@(() => SelectTabAsync(CommandTab.Workers))">Workers</button>
    </nav>

    @if (_activeTab == CommandTab.Targets)
    {
        <section class="cc-panel">
            <div class="cc-panel-header">
                <div>
                    <h2>Targets</h2>
                    <p class="cc-muted">Loaded in a bounded request. Use the search box to filter only the loaded window.</p>
                </div>
                <div class="cc-toolbar">
                    <input class="cc-input" placeholder="example.com" @bind="_newTargetRootDomain" @bind:event="oninput" />
                    <label class="cc-inline-label">
                        Depth
                        <input class="cc-input cc-depth-input" type="number" min="0" max="10" @bind="_newTargetDepth" />
                    </label>
                    <button class="cc-btn cc-btn-primary" @onclick="CreateTargetAsync" disabled="@(!CanCreateTarget || _creatingTarget)">
                        @(_creatingTarget ? "Creating..." : "Create")
                    </button>
                    <button class="cc-btn" @onclick="ReloadTargetsAsync" disabled="@_targetsLoading">Reload</button>
                    <button class="cc-btn" @onclick="EnumerateSelectedTargetsAsync" disabled="@(!_selectedTargetIds.Any() || _targetActionLoading)">Enumerate selected</button>
                    <button class="cc-btn" @onclick="SpiderSelectedTargetsAsync" disabled="@(!_selectedTargetIds.Any() || _targetActionLoading)">Spider selected</button>
                </div>
            </div>
            <div class="cc-two-column">
                <ArgusDataGrid TGridItem="JsonElement"
                               Items="@TargetRows.AsQueryable()"
                               RowMatches="@JsonRowMatches"
                               SearchText="@_targetSearch"
                               SearchTextChanged="@((string value) => _targetSearch = value)"
                               SearchPlaceholder="Search targets..."
                               IsLoading="@_targetsLoading"
                               EmptyText="No targets found."
                               PersistKey="command-center-targets"
                               EnableCsvExport="true"
                               ExportFileName="targets.csv"
                               StickyFirstColumn="true"
                               VirtualizedHeightPixels="420"
                               ItemKey="@RowKeyObject">
                    <ConfigurationTemplate>
                        @ColumnPicker(TargetGridColumns)
                    </ConfigurationTemplate>
                    <ChildContent>
                        @if (ColumnVisible("targets.select"))
                        {
                            <TemplateColumn Title="" Context="target" Class="select-col">
                                <input type="checkbox" checked="@IsSelectedTarget(target)" @onchange="@(_ => ToggleTarget(target))" />
                            </TemplateColumn>
                        }
                        @if (ColumnVisible("targets.root"))
                        {
                            <TemplateColumn Title="Root domain" Context="target" SortBy="@SortTargetRoot" Class="wide-col">
                                <span class="argus-dg-clip" title="@Text(target, "rootDomain", "RootDomain", "domain", "Domain")">@Display(Text(target, "rootDomain", "RootDomain", "domain", "Domain"))</span>
                            </TemplateColumn>
                        }
                        @if (ColumnVisible("targets.status"))
                        {
                            <TemplateColumn Title="Status" Context="target" SortBy="@SortTargetStatus">
                                <span class="cc-pill">@Display(Text(target, "status", "Status", "state", "State"))</span>
                            </TemplateColumn>
                        }
                        @if (ColumnVisible("targets.depth"))
                        {
                            <TemplateColumn Title="Depth" Context="target" SortBy="@SortTargetDepth">@Display(Text(target, "globalMaxDepth", "GlobalMaxDepth", "maxDepth", "MaxDepth"))</TemplateColumn>
                        }
                        @if (ColumnVisible("targets.created"))
                        {
                            <TemplateColumn Title="Created" Context="target" SortBy="@SortTargetCreated">@FormatTime(Text(target, "createdAtUtc", "CreatedAtUtc", "createdAt", "CreatedAt"))</TemplateColumn>
                        }
                    </ChildContent>
                </ArgusDataGrid>

                <ArgusDataGrid TGridItem="JsonElement"
                               Items="@SubdomainRows.AsQueryable()"
                               RowMatches="@JsonRowMatches"
                               SearchText="@_subdomainSearch"
                               SearchTextChanged="@((string value) => _subdomainSearch = value)"
                               SearchPlaceholder="Search subdomains..."
                               IsLoading="@_subdomainsLoading"
                               EmptyText="No subdomains found."
                               PersistKey="command-center-subdomains"
                               EnableCsvExport="true"
                               ExportFileName="subdomains.csv"
                               VirtualizedHeightPixels="420"
                               ItemKey="@RowKeyObject">
                    <ConfigurationTemplate>
                        @ColumnPicker(SubdomainGridColumns)
                    </ConfigurationTemplate>
                    <ChildContent>
                        @if (ColumnVisible("subdomains.target"))
                        {
                            <TemplateColumn Title="Target" Context="subdomain" SortBy="@SortSubdomainTarget">@Display(Text(subdomain, "rootDomain", "RootDomain", "target", "Target"))</TemplateColumn>
                        }
                        @if (ColumnVisible("subdomains.name"))
                        {
                            <TemplateColumn Title="Subdomain" Context="subdomain" SortBy="@SortSubdomainName" Class="wide-col">
                                <span class="argus-dg-clip" title="@Text(subdomain, "subdomain", "Subdomain", "canonicalKey", "CanonicalKey", "rawValue", "RawValue")">@Display(Text(subdomain, "subdomain", "Subdomain", "canonicalKey", "CanonicalKey", "rawValue", "RawValue"))</span>
                            </TemplateColumn>
                        }
                        @if (ColumnVisible("subdomains.technologies"))
                        {
                            <TemplateColumn Title="Technologies" Context="subdomain" SortBy="@SortSubdomainTechnologyCount">@Display(Text(subdomain, "technologyCount", "TechnologyCount"))</TemplateColumn>
                        }
                        @if (ColumnVisible("subdomains.lastSeen"))
                        {
                            <TemplateColumn Title="Last seen" Context="subdomain" SortBy="@SortSubdomainLastSeen">@FormatTime(Text(subdomain, "lastSeenUtc", "LastSeenUtc", "lastSeenAtUtc", "LastSeenAtUtc"))</TemplateColumn>
                        }
                    </ChildContent>
                </ArgusDataGrid>
            </div>

            <div class="cc-panel-header">
                <div>
                    <h2>Assets</h2>
                    <p class="cc-muted">Recent confirmed assets only. This avoids the previous full-table hydration path.</p>
                </div>
                <div class="cc-toolbar">
                    <select class="cc-input" @bind="_assetKindFilter">
                        <option value="">All kinds</option>
                        @foreach (var kind in AssetKinds)
                        {
                            <option value="@kind">@kind</option>
                        }
                    </select>
                    <button class="cc-btn" @onclick="ReloadAssetsAsync" disabled="@_assetsLoading">Reload</button>
                </div>
            </div>
            <ArgusDataGrid TGridItem="JsonElement"
                           Items="@AssetRows.AsQueryable()"
                           RowMatches="@JsonRowMatches"
                           SearchText="@_assetSearch"
                           SearchTextChanged="@((string value) => _assetSearch = value)"
                           SearchPlaceholder="Search loaded assets..."
                           IsLoading="@_assetsLoading"
                           EmptyText="No assets match the current filters."
                           PersistKey="command-center-assets"
                           EnableCsvExport="true"
                           ExportFileName="assets.csv"
                           VirtualizedHeightPixels="520"
                           ItemKey="@RowKeyObject">
                <ConfigurationTemplate>
                    @ColumnPicker(AssetGridColumns)
                </ConfigurationTemplate>
                <ChildContent>
                    @if (ColumnVisible("assets.kind"))
                    {
                        <TemplateColumn Title="Kind" Context="asset" SortBy="@SortAssetKind"><span class="cc-pill">@Display(Text(asset, "kind", "Kind"))</span></TemplateColumn>
                    }
                    @if (ColumnVisible("assets.asset"))
                    {
                        <TemplateColumn Title="Asset" Context="asset" SortBy="@SortAssetText" Class="wide-col">
                            @{
                                var assetText = Text(asset, "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue", "finalUrl", "FinalUrl");
                                var assetHref = TryHttpHref(assetText);
                            }
                            @if (assetHref is null)
                            {
                                <span class="argus-dg-clip" title="@assetText">@Display(assetText)</span>
                            }
                            else
                            {
                                <a href="@assetHref" target="_blank" rel="noopener noreferrer" class="argus-dg-clip" title="@assetText">@assetText</a>
                            }
                        </TemplateColumn>
                    }
                    @if (ColumnVisible("assets.category"))
                    {
                        <TemplateColumn Title="Category" Context="asset" SortBy="@SortAssetCategory">@Display(Text(asset, "category", "Category"))</TemplateColumn>
                    }
                    @if (ColumnVisible("assets.seen"))
                    {
                        <TemplateColumn Title="Seen" Context="asset" SortBy="@SortAssetSeen">@FormatTime(Text(asset, "lastSeenAtUtc", "LastSeenAtUtc", "discoveredAtUtc", "DiscoveredAtUtc"))</TemplateColumn>
                    }
                </ChildContent>
            </ArgusDataGrid>
        </section>
    }

    @if (_activeTab == CommandTab.Discovery)
    {
        <section class="cc-panel">
            <div class="cc-panel-header">
                <div>
                    <h2>Discovery</h2>
                    <p class="cc-muted">High-value and technology identification in one workspace.</p>
                </div>
                <div class="cc-toolbar">
                    <button class="cc-btn" @onclick="ReloadHighValueAsync" disabled="@_highValueLoading">Reload high value</button>
                    <button class="cc-btn" @onclick="ReloadTechnologyAsync" disabled="@_technologyLoading">Reload tech ID</button>
                </div>
            </div>
            <ArgusDataGrid TGridItem="JsonElement"
                           Items="@HighValueRows.AsQueryable()"
                           RowMatches="@JsonRowMatches"
                           SearchText="@_highValueSearch"
                           SearchTextChanged="@((string value) => _highValueSearch = value)"
                           SearchPlaceholder="Search high-value findings..."
                           IsLoading="@_highValueLoading"
                           EmptyText="No high-value findings match the current filters."
                           PersistKey="command-center-high-value"
                           EnableCsvExport="true"
                           ExportFileName="high-value.csv"
                           VirtualizedHeightPixels="420"
                           ItemKey="@RowKeyObject">
                <ConfigurationTemplate>
                    @ColumnPicker(HighValueGridColumns)
                </ConfigurationTemplate>
                <ChildContent>
                    @if (ColumnVisible("highValue.severity"))
                    {
                        <TemplateColumn Title="Severity" Context="finding" SortBy="@SortHighValueSeverity"><span class="cc-pill">@Display(Text(finding, "severity", "Severity"))</span></TemplateColumn>
                    }
                    @if (ColumnVisible("highValue.asset"))
                    {
                        <TemplateColumn Title="Asset" Context="finding" SortBy="@SortHighValueAsset" Class="wide-col">
                            <span class="argus-dg-clip" title="@Text(finding, "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue")">@Display(Text(finding, "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue"))</span>
                        </TemplateColumn>
                    }
                    @if (ColumnVisible("highValue.finding"))
                    {
                        <TemplateColumn Title="Finding" Context="finding" SortBy="@SortHighValueFinding">@Display(Text(finding, "findingType", "FindingType", "patternName", "PatternName"))</TemplateColumn>
                    }
                    @if (ColumnVisible("highValue.score"))
                    {
                        <TemplateColumn Title="Score" Context="finding" SortBy="@SortHighValueScore">@Display(Text(finding, "importanceScore", "ImportanceScore", "confidence", "Confidence"))</TemplateColumn>
                    }
                    @if (ColumnVisible("highValue.seen"))
                    {
                        <TemplateColumn Title="Seen" Context="finding" SortBy="@SortHighValueSeen">@FormatTime(Text(finding, "findingDiscoveredAtUtc", "FindingDiscoveredAtUtc", "discoveredAtUtc", "DiscoveredAtUtc"))</TemplateColumn>
                    }
                </ChildContent>
            </ArgusDataGrid>

            <ArgusDataGrid TGridItem="JsonElement"
                           Items="@TechnologyRows.AsQueryable()"
                           RowMatches="@JsonRowMatches"
                           SearchText="@_technologySearch"
                           SearchTextChanged="@((string value) => _technologySearch = value)"
                           SearchPlaceholder="Search technologies..."
                           IsLoading="@_technologyLoading"
                           EmptyText="No technology observations match the current filters."
                           PersistKey="command-center-technologies"
                           EnableCsvExport="true"
                           ExportFileName="technologies.csv"
                           VirtualizedHeightPixels="420"
                           ItemKey="@RowKeyObject">
                <ConfigurationTemplate>
                    @ColumnPicker(TechnologyGridColumns)
                </ConfigurationTemplate>
                <ChildContent>
                    @if (ColumnVisible("technology.name"))
                    {
                        <TemplateColumn Title="Technology" Context="technology" SortBy="@SortTechnologyName" Class="wide-col">
                            <span class="argus-dg-clip" title="@Text(technology, "technologyName", "TechnologyName", "name", "Name", "technology", "Technology")">@Display(Text(technology, "technologyName", "TechnologyName", "name", "Name", "technology", "Technology"))</span>
                        </TemplateColumn>
                    }
                    @if (ColumnVisible("technology.version"))
                    {
                        <TemplateColumn Title="Version" Context="technology" SortBy="@SortTechnologyVersion">@Display(Text(technology, "version", "Version"))</TemplateColumn>
                    }
                    @if (ColumnVisible("technology.evidence"))
                    {
                        <TemplateColumn Title="Evidence" Context="technology" SortBy="@SortTechnologyEvidence">@Display(Text(technology, "evidence", "Evidence", "source", "Source", "category", "Category"))</TemplateColumn>
                    }
                    @if (ColumnVisible("technology.seen"))
                    {
                        <TemplateColumn Title="Seen" Context="technology" SortBy="@SortTechnologySeen">@FormatTime(Text(technology, "lastSeenUtc", "LastSeenUtc", "observedAtUtc", "ObservedAtUtc"))</TemplateColumn>
                    }
                </ChildContent>
            </ArgusDataGrid>
        </section>
    }

    @if (_activeTab == CommandTab.Workers)
    {
        <section class="cc-panel">
            <div class="cc-panel-header">
                <div>
                    <h2>Workers</h2>
                    <p class="cc-muted">Loaded from the worker-control API in a bounded refresh cycle.</p>
                </div>
                <div class="cc-toolbar">
                    <button class="cc-btn" @onclick="ReloadWorkersAsync" disabled="@_workersLoading">Reload</button>
                    <button class="cc-btn" @onclick="ReloadCloudWorkersAsync" disabled="@_workersLoading">Refresh cloud</button>
                </div>
            </div>

            <h3>Local worker controls</h3>
            <ArgusDataGrid TGridItem="JsonElement"
                           Items="@WorkerRows.AsQueryable()"
                           RowMatches="@JsonRowMatches"
                           SearchText="@_workerSearch"
                           SearchTextChanged="@((string value) => _workerSearch = value)"
                           SearchPlaceholder="Search workers..."
                           IsLoading="@_workersLoading"
                           EmptyText="No local workers found."
                           PersistKey="command-center-workers"
                           EnableCsvExport="true"
                           ExportFileName="workers.csv"
                           VirtualizedHeightPixels="420"
                           ItemKey="@RowKeyObject">
                <ConfigurationTemplate>
                    @ColumnPicker(WorkerGridColumns)
                </ConfigurationTemplate>
                <ChildContent>
                    @if (ColumnVisible("workers.name"))
                    {
                        <TemplateColumn Title="Worker" Context="worker" SortBy="@SortWorkerName" Class="wide-col">
                            <span class="argus-dg-clip" title="@Text(worker, "displayName", "DisplayName", "serviceName", "ServiceName", "name", "Name", "id", "Id")">@Display(Text(worker, "displayName", "DisplayName", "serviceName", "ServiceName", "name", "Name", "id", "Id"))</span>
                        </TemplateColumn>
                    }
                    @if (ColumnVisible("workers.state"))
                    {
                        <TemplateColumn Title="State" Context="worker" SortBy="@SortWorkerState"><span class="cc-pill">@Display(Text(worker, "overallState", "OverallState", "status", "Status", "state", "State"))</span></TemplateColumn>
                    }
                    @if (ColumnVisible("workers.running"))
                    {
                        <TemplateColumn Title="Running" Context="worker" SortBy="@SortWorkerRunning">@Display(Text(worker, "runningCount", "RunningCount"))</TemplateColumn>
                    }
                    @if (ColumnVisible("workers.total"))
                    {
                        <TemplateColumn Title="Total" Context="worker" SortBy="@SortWorkerTotal">@Display(Text(worker, "totalCount", "TotalCount"))</TemplateColumn>
                    }
                </ChildContent>
            </ArgusDataGrid>

            <h3>Cloud worker controls</h3>
            <ArgusDataGrid TGridItem="JsonElement"
                           Items="@CloudWorkerRows.AsQueryable()"
                           RowMatches="@JsonRowMatches"
                           SearchText="@_cloudWorkerSearch"
                           SearchTextChanged="@((string value) => _cloudWorkerSearch = value)"
                           SearchPlaceholder="Search cloud workers..."
                           IsLoading="@_workersLoading"
                           EmptyText="No cloud workers found."
                           PersistKey="command-center-cloud-workers"
                           EnableCsvExport="true"
                           ExportFileName="cloud-workers.csv"
                           VirtualizedHeightPixels="420"
                           ItemKey="@RowKeyObject">
                <ConfigurationTemplate>
                    @ColumnPicker(CloudWorkerGridColumns)
                </ConfigurationTemplate>
                <ChildContent>
                    @if (ColumnVisible("cloudWorkers.service"))
                    {
                        <TemplateColumn Title="Service" Context="worker" SortBy="@SortCloudWorkerService" Class="wide-col">
                            <span class="argus-dg-clip" title="@Text(worker, "serviceName", "ServiceName", "scaleKey", "ScaleKey")">@Display(Text(worker, "serviceName", "ServiceName", "scaleKey", "ScaleKey"))</span>
                        </TemplateColumn>
                    }
                    @if (ColumnVisible("cloudWorkers.status"))
                    {
                        <TemplateColumn Title="Status" Context="worker" SortBy="@SortCloudWorkerStatus"><span class="cc-pill">@Display(Text(worker, "status", "Status", "deploymentStatus", "DeploymentStatus"))</span></TemplateColumn>
                    }
                    @if (ColumnVisible("cloudWorkers.running"))
                    {
                        <TemplateColumn Title="Running" Context="worker" SortBy="@SortCloudWorkerRunning">@Display(Text(worker, "runningCount", "RunningCount"))</TemplateColumn>
                    }
                    @if (ColumnVisible("cloudWorkers.desired"))
                    {
                        <TemplateColumn Title="Desired" Context="worker" SortBy="@SortCloudWorkerDesired">@Display(Text(worker, "desiredCount", "DesiredCount"))</TemplateColumn>
                    }
                </ChildContent>
            </ArgusDataGrid>
        </section>
    }
</div>

@code {
    private const int TargetTake = 500;
    private const int AssetTake = 250;
    private const int HttpQueueTake = 200;
    private const int HighValueTake = 200;
    private const int TechnologyTake = 250;
    private const int WorkerTake = 250;

    private readonly CancellationTokenSource _disposeCts = new();
    private JsonElement? _overview;
    private readonly List<JsonElement> _targets = [];
    private readonly List<JsonElement> _subdomains = [];
    private readonly List<JsonElement> _assets = [];
    private readonly List<JsonElement> _httpQueue = [];
    private readonly List<JsonElement> _highValue = [];
    private readonly List<JsonElement> _technology = [];
    private readonly List<JsonElement> _workers = [];
    private readonly List<JsonElement> _cloudWorkers = [];
    private readonly HashSet<string> _selectedTargetIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedAssetIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedHttpIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _hiddenGridColumns = new(StringComparer.OrdinalIgnoreCase);

    private CommandTab _activeTab = CommandTab.Targets;
    private PeriodicTimer? _summaryTimer;
    private PeriodicTimer? _debugClockTimer;
    private Task? _summaryPollingTask;
    private Task? _debugClockTask;
    private DateTimeOffset _debugNowUtc = DateTimeOffset.UtcNow;
    private DateTimeOffset? _targetsRefreshedUtc;
    private DateTimeOffset? _subdomainsRefreshedUtc;
    private DateTimeOffset? _assetsRefreshedUtc;
    private DateTimeOffset? _highValueRefreshedUtc;
    private DateTimeOffset? _technologyRefreshedUtc;
    private DateTimeOffset? _workersRefreshedUtc;
    private DateTimeOffset? _cloudWorkersRefreshedUtc;
    private string? _errorMessage;
    private string? _statusMessage;
    private string? _targetSearch;
    private string? _subdomainSearch;
    private string? _assetSearch;
    private string? _assetKindFilter;
    private string _httpSearch = string.Empty;
    private string _httpStateFilter = string.Empty;
    private string? _highValueSearch;
    private string? _technologySearch;
    private string? _workerSearch;
    private string? _cloudWorkerSearch;
    private string? _newTargetRootDomain;
    private int _newTargetDepth = 2;
    private bool _overviewLoading;
    private bool _targetsLoading;
    private bool _subdomainsLoading;
    private bool _assetsLoading;
    private bool _httpLoading;
    private bool _highValueLoading;
    private bool _technologyLoading;
    private bool _workersLoading;
    private bool _creatingTarget;
    private bool _targetActionLoading;
    private bool _queueMutationLoading;

    private bool _loadingAny => _overviewLoading
        || _targetsLoading
        || _subdomainsLoading
        || _assetsLoading
        || _httpLoading
        || _highValueLoading
        || _technologyLoading
        || _workersLoading
        || _creatingTarget
        || _targetActionLoading
        || _queueMutationLoading;

    private bool CanCreateTarget => !string.IsNullOrWhiteSpace(_newTargetRootDomain);

    private JsonElement[] TargetRows => _targets
        .Where(row => Matches(row, _targetSearch, "rootDomain", "RootDomain", "domain", "Domain", "status", "Status"))
        .ToArray();

    private JsonElement[] AssetRows => _assets
        .Where(row => string.IsNullOrWhiteSpace(_assetKindFilter)
            || string.Equals(Text(row, "kind", "Kind"), _assetKindFilter, StringComparison.OrdinalIgnoreCase))
        .Where(row => Matches(row, _assetSearch, "kind", "Kind", "category", "Category", "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue", "finalUrl", "FinalUrl"))
        .ToArray();

    private JsonElement[] SubdomainRows => _subdomains
        .Where(row => Matches(row, _subdomainSearch, "subdomain", "Subdomain", "rootDomain", "RootDomain", "target", "Target"))
        .ToArray();

    private JsonElement[] HttpRows => _httpQueue
        .Where(row => string.IsNullOrWhiteSpace(_httpStateFilter)
            || string.Equals(Text(row, "state", "State"), _httpStateFilter, StringComparison.OrdinalIgnoreCase))
        .Where(row => Matches(row, _httpSearch, "state", "State", "method", "Method", "requestMethod", "RequestMethod", "url", "Url", "requestUrl", "RequestUrl", "finalUrl", "FinalUrl"))
        .ToArray();

    private JsonElement[] HighValueRows => _highValue
        .Where(row => Matches(row, _highValueSearch, "severity", "Severity", "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue", "findingType", "FindingType", "patternName", "PatternName"))
        .ToArray();

    private JsonElement[] TechnologyRows => _technology
        .Where(row => Matches(row, _technologySearch, "technologyName", "TechnologyName", "name", "Name", "technology", "Technology", "version", "Version", "evidence", "Evidence", "category", "Category"))
        .ToArray();

    private JsonElement[] WorkerRows => _workers
        .Where(row => Matches(row, _workerSearch, "name", "Name", "workerName", "WorkerName", "id", "Id", "status", "Status", "state", "State", "type", "Type", "kind", "Kind"))
        .ToArray();

    private JsonElement[] CloudWorkerRows => _cloudWorkers
        .Where(row => Matches(row, _cloudWorkerSearch, "serviceName", "ServiceName", "scaleKey", "ScaleKey", "status", "Status", "deploymentStatus", "DeploymentStatus"))
        .ToArray();

    private static readonly GridColumnChoice[] TargetGridColumns =
    [
        new("targets.select", "Select"),
        new("targets.root", "Root domain"),
        new("targets.status", "Status"),
        new("targets.depth", "Depth"),
        new("targets.created", "Created")
    ];

    private static readonly GridColumnChoice[] SubdomainGridColumns =
    [
        new("subdomains.target", "Target"),
        new("subdomains.name", "Subdomain"),
        new("subdomains.technologies", "Technologies"),
        new("subdomains.lastSeen", "Last seen")
    ];

    private static readonly GridColumnChoice[] AssetGridColumns =
    [
        new("assets.kind", "Kind"),
        new("assets.asset", "Asset"),
        new("assets.category", "Category"),
        new("assets.seen", "Seen")
    ];

    private static readonly GridColumnChoice[] HighValueGridColumns =
    [
        new("highValue.severity", "Severity"),
        new("highValue.asset", "Asset"),
        new("highValue.finding", "Finding"),
        new("highValue.score", "Score"),
        new("highValue.seen", "Seen")
    ];

    private static readonly GridColumnChoice[] TechnologyGridColumns =
    [
        new("technology.name", "Technology"),
        new("technology.version", "Version"),
        new("technology.evidence", "Evidence"),
        new("technology.seen", "Seen")
    ];

    private static readonly GridColumnChoice[] WorkerGridColumns =
    [
        new("workers.name", "Worker"),
        new("workers.state", "State"),
