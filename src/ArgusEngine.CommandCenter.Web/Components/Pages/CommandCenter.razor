    private async Task ReloadLogsAsync()
    {
        _logsLoading = true;
        try
        {
            var level = string.IsNullOrWhiteSpace(_logLevelFilter) ? "" : $"&level={WebUtility.UrlEncode(_logLevelFilter)}";
            var component = string.IsNullOrWhiteSpace(_logComponentFilter) ? "" : $"&component={WebUtility.UrlEncode(_logComponentFilter)}";
            Replace(_logs, await GetArrayAsync($"/api/logs?take=500{level}{component}").ConfigureAwait(false));

            if (_logLevels.Count == 0)
            {
                var levels = await GetArrayAsync("/api/logs/levels").ConfigureAwait(false);
                _logLevels = levels.Select(e => Text(e, "value")).Where(static v => !string.IsNullOrWhiteSpace(v)).ToList();
            }
            if (_logComponents.Count == 0)
            {
                var components = await GetArrayAsync("/api/logs/components").ConfigureAwait(false);
                _logComponents = components.Select(e => e.GetString() ?? "").Where(static v => !string.IsNullOrWhiteSpace(v)).ToList();
            }
        }
        finally
        {
            _logsLoading = false;
        }
    }

