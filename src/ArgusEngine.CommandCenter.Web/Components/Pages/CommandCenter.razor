    {
        foreach (var key in keys.Where(k => !string.IsNullOrWhiteSpace(k)).Distinct(StringComparer.OrdinalIgnoreCase))
        {
            if (selected)
            {
                set.Add(key);
            }
            else
            {
                set.Remove(key);
            }
        }
    }

