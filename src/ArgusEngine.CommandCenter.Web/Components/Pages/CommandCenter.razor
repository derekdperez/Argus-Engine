    private bool MatchesSelectedTargetsScope(JsonElement asset)
    {
        if (_selectedTargetIds.Count == 0)
        {
            return true;
        }

        var targetId = Text(asset, "targetId", "TargetId");
        return !string.IsNullOrWhiteSpace(targetId) && _selectedTargetIds.Contains(targetId);
    }

    private bool MatchesSelectedSubdomainsScope(JsonElement asset)
    {
        if (_selectedSubdomainKeys.Count == 0)
        {
            return true;
        }

        var targetId = Text(asset, "targetId", "TargetId");
        var host = ExtractHost(asset);
        if (string.IsNullOrWhiteSpace(targetId) || string.IsNullOrWhiteSpace(host))
        {
            return false;
        }

        return _selectedSubdomainKeys.Contains($"{targetId}|{host}");
    }

    private bool MatchesSelectedTargetsScopeForAnyRow(JsonElement row)
    {
        if (_selectedTargetIds.Count == 0)
        {
            return true;
        }

        var targetId = Text(row, "targetId", "TargetId");
        if (!string.IsNullOrWhiteSpace(targetId) && _selectedTargetIds.Contains(targetId))
        {
            return true;
        }

        var rowTargetRootDomain = Text(row, "targetRootDomain", "TargetRootDomain");
        if (string.IsNullOrWhiteSpace(rowTargetRootDomain))
        {
            return false;
        }

        return _targets
            .Where(t => _selectedTargetIds.Contains(Text(t, "id", "Id")))
            .Select(t => Text(t, "rootDomain", "RootDomain"))
            .Any(domain => !string.IsNullOrWhiteSpace(domain) && domain.Equals(rowTargetRootDomain, StringComparison.OrdinalIgnoreCase));
    }

    private bool MatchesSelectedSubdomainsScopeForAnyRow(JsonElement row)
    {
        if (_selectedSubdomainKeys.Count == 0)
        {
            return true;
        }

        var targetId = Text(row, "targetId", "TargetId");
        var host = ExtractHostForScope(row);
        if (string.IsNullOrWhiteSpace(host))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(targetId) && _selectedSubdomainKeys.Contains($"{targetId}|{host}"))
        {
            return true;
        }

        return _selectedSubdomainKeys.Any(key =>
        {
            var parts = key.Split('|', 2);
            return parts.Length == 2 && parts[1].Equals(host, StringComparison.OrdinalIgnoreCase);
        });
    }

    private bool MatchesSelectedWorkersScopeForHttp(JsonElement row)
    {
        if (_selectedWorkerServices.Count == 0)
        {
            return true;
        }

        var directWorker = Text(row, "worker", "Worker", "workerKey", "WorkerKey", "lockedBy", "LockedBy");
        if (_selectedWorkerServices.Contains(directWorker))
        {
            return true;
        }

        return _selectedWorkerServices.Any(service => directWorker.Contains(service, StringComparison.OrdinalIgnoreCase));
    }

