    private async Task<JsonElement?> GetObjectAsync(string uri)
    {
        try
        {
            using var response = await Http.GetAsync(uri, _disposeCts.Token).ConfigureAwait(false);
            await EnsureSuccessAsync(response, uri).ConfigureAwait(false);

            await using var stream = await response.Content.ReadAsStreamAsync(_disposeCts.Token).ConfigureAwait(false);
            using var document = await JsonDocument.ParseAsync(stream, cancellationToken: _disposeCts.Token).ConfigureAwait(false);
            return document.RootElement.Clone();
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            SetError(ex, $"GET {uri} failed.");
            return null;
        }
    }

    private async Task<IReadOnlyList<JsonElement>> GetArrayAsync(string uri)
    {
        var payload = await GetObjectAsync(uri).ConfigureAwait(false);
        if (payload is null)
        {
            return [];
        }

        var root = payload.Value;
        if (root.ValueKind == JsonValueKind.Array)
        {
            return root.EnumerateArray().Select(static item => item.Clone()).ToArray();
        }

        foreach (var propertyName in new[] { "rows", "Rows", "items", "Items", "data", "Data", "results", "Results", "services", "Services" })
        {
            if (root.TryGetProperty(propertyName, out var array) && array.ValueKind == JsonValueKind.Array)
            {
                return array.EnumerateArray().Select(static item => item.Clone()).ToArray();
            }
        }

        return [];
    }

    private async Task EnsureSuccessAsync(HttpResponseMessage response, string operation)
    {
        if (response.IsSuccessStatusCode)
        {
            return;
        }

        var body = await response.Content.ReadAsStringAsync(_disposeCts.Token).ConfigureAwait(false);
        throw new InvalidOperationException($"{operation} returned {(int)response.StatusCode} {response.ReasonPhrase}. {body}");
    }

    private static void Replace(List<JsonElement> target, IReadOnlyList<JsonElement> source)
    {
        target.Clear();
        target.AddRange(source);
    }

    private static void PruneSelection(HashSet<string> selectedIds, IReadOnlyList<JsonElement> availableRows)
    {
        var available = availableRows
            .Select(RowKey)
            .Where(static value => !string.IsNullOrWhiteSpace(value))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        selectedIds.RemoveWhere(id => !available.Contains(id));
    }

    private static string RowKey(JsonElement row)
    {
        return Text(row, "id", "Id", "assetId", "AssetId", "findingId", "FindingId", "targetId", "TargetId", "queueId", "QueueId");
    }

    private static object RowKeyObject(JsonElement row) => RowKey(row);

    private static bool JsonRowMatches(JsonElement row, string search)
    {
        return string.IsNullOrWhiteSpace(search)
            || row.GetRawText().Contains(search.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private bool ColumnVisible(string key) => !_hiddenGridColumns.Contains(key);

    private void ToggleColumn(string key, ChangeEventArgs args)
    {
        var visible = args.Value is bool boolValue
            ? boolValue
            : bool.TryParse(args.Value?.ToString(), out var parsed) && parsed;

        if (visible)
        {
            _hiddenGridColumns.Remove(key);
        }
        else
        {
            _hiddenGridColumns.Add(key);
        }
    }

    private RenderFragment ColumnPicker(IReadOnlyList<GridColumnChoice> columns) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "cc-column-picker");

        var sequence = 2;
        foreach (var column in columns)
        {
            builder.OpenElement(sequence++, "label");
            builder.OpenElement(sequence++, "input");
            builder.AddAttribute(sequence++, "type", "checkbox");
            builder.AddAttribute(sequence++, "checked", ColumnVisible(column.Key));
            builder.AddAttribute(sequence++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, args => ToggleColumn(column.Key, args)));
            builder.CloseElement();
            builder.OpenElement(sequence++, "span");
            builder.AddContent(sequence++, column.Label);
            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private static bool Matches(JsonElement row, string? query, params string[] fields)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return true;
        }

        var search = query.Trim();
        return fields.Any(field =>
            row.TryGetProperty(field, out var value)
            && ValueToString(value).Contains(search, StringComparison.OrdinalIgnoreCase));
    }

    private long OverviewLong(params string[] names)
    {
        if (_overview is null)
        {
            return 0;
        }

        return Long(_overview.Value, names);
    }

    private static long Long(JsonElement row, params string[] names)
    {
        foreach (var name in names)
        {
            if (!row.TryGetProperty(name, out var value))
            {
                continue;
            }

            if (value.ValueKind == JsonValueKind.Number && value.TryGetInt64(out var longValue))
            {
                return longValue;
            }

            if (long.TryParse(ValueToString(value), NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed))
            {
                return parsed;
            }
        }

        return 0;
    }

    private static string Text(JsonElement row, params string[] names)
    {
        foreach (var name in names)
        {
            if (row.TryGetProperty(name, out var value))
            {
                var text = ValueToString(value);
                if (!string.IsNullOrWhiteSpace(text))
                {
                    return text;
                }
            }
        }

        return string.Empty;
    }

    private static string ValueToString(JsonElement value)
    {
        return value.ValueKind switch
        {
            JsonValueKind.String => value.GetString() ?? string.Empty,
            JsonValueKind.Number => value.ToString(),
            JsonValueKind.True => "true",
            JsonValueKind.False => "false",
            JsonValueKind.Null => string.Empty,
            JsonValueKind.Undefined => string.Empty,
            _ => value.ToString()
        };
    }

    private static DateTimeOffset SortableTime(JsonElement row, params string[] names)
    {
        var value = Text(row, names);
        return DateTimeOffset.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var timestamp)
            ? timestamp
            : DateTimeOffset.MinValue;
    }

    private RenderFragment GridDebug(IReadOnlyCollection<JsonElement> visibleRows, IReadOnlyCollection<JsonElement> sourceRows, DateTimeOffset? refreshedUtc) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "cc-grid-debug");
        builder.AddAttribute(2, "aria-live", "polite");

        builder.OpenElement(3, "span");
        builder.AddContent(4, FormatGridRowCount(visibleRows.Count, sourceRows.Count));
        builder.CloseElement();

        builder.OpenElement(5, "span");
        builder.AddContent(6, $"{FormatDataSizeMb(sourceRows)} MB");
        builder.CloseElement();

        builder.OpenElement(7, "span");
        builder.AddContent(8, FormatRefreshAge(refreshedUtc));
        builder.CloseElement();

        builder.CloseElement();
    };

    private static string FormatGridRowCount(int visibleCount, int sourceCount)
    {
        return visibleCount == sourceCount
            ? $"{visibleCount.ToString("N0", CultureInfo.InvariantCulture)} rows"
            : $"{visibleCount.ToString("N0", CultureInfo.InvariantCulture)} of {sourceCount.ToString("N0", CultureInfo.InvariantCulture)} rows";
    }

    private static string FormatDataSizeMb(IReadOnlyCollection<JsonElement> rows)
    {
        var bytes = rows.Sum(row => Encoding.UTF8.GetByteCount(row.GetRawText()));
        var megabytes = bytes / 1024d / 1024d;
        return megabytes.ToString("0.000", CultureInfo.InvariantCulture);
    }

    private string FormatRefreshAge(DateTimeOffset? refreshedUtc)
    {
        if (refreshedUtc is null)
        {
            return "not refreshed yet";
        }

        var seconds = Math.Max(0, (int)Math.Floor((_debugNowUtc - refreshedUtc.Value).TotalSeconds));
        return $"refreshed {seconds.ToString("N0", CultureInfo.InvariantCulture)}s ago";
    }

    private static string FormatNumber(long value)
    {
        return value.ToString("N0", CultureInfo.InvariantCulture);
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "—" : value;
    }

    private static string FormatTime(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "—";
        }

        if (DateTimeOffset.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var timestamp))
        {
            return AppTimeFormat.Format(timestamp);
        }

        return value;
    }

    private static string? TryHttpHref(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return Uri.TryCreate(value.Trim(), UriKind.Absolute, out var uri) && uri.Scheme is "http" or "https"
            ? uri.ToString()
            : null;
    }

    private bool IsSelectedTarget(JsonElement row)
    {
        var id = RowKey(row);
        return !string.IsNullOrWhiteSpace(id) && _selectedTargetIds.Contains(id);
    }

    private void ToggleTarget(JsonElement row)
    {
        ToggleSelection(_selectedTargetIds, RowKey(row));
    }

    private bool IsSelectedHttp(JsonElement row)
    {
        var id = RowKey(row);
        return !string.IsNullOrWhiteSpace(id) && _selectedHttpIds.Contains(id);
    }

    private bool IsSelectedAsset(JsonElement row)
    {
        var id = RowKey(row);
        return !string.IsNullOrWhiteSpace(id) && _selectedAssetIds.Contains(id);
    }

    private void ToggleHttp(JsonElement row)
    {
        ToggleSelection(_selectedHttpIds, RowKey(row));
    }

    private void ToggleAsset(JsonElement row)
    {
        ToggleSelection(_selectedAssetIds, RowKey(row));
    }

    private static void ToggleSelection(HashSet<string> selected, string id)
    {
        if (string.IsNullOrWhiteSpace(id))
        {
            return;
        }

        if (!selected.Add(id))
        {
            selected.Remove(id);
        }
    }

    private string TabClass(CommandTab tab)
    {
        return _activeTab == tab ? "cc-tab cc-tab-active" : "cc-tab";
    }

    private void SetError(Exception ex, string message)
    {
        Logger.LogWarning(ex, "{Message}", message);
        _errorMessage = $"{message} {ex.Message}";
    }

    private void ClearError()
    {
        _errorMessage = null;
    }

    public void Dispose()
    {
        _disposeCts.Cancel();
        _summaryTimer?.Dispose();
        _debugClockTimer?.Dispose();
        _disposeCts.Dispose();
    }

    private enum CommandTab
    {
        Targets,
        Discovery,
        Workers
    }

    private sealed record GridColumnChoice(string Key, string Label);
}
