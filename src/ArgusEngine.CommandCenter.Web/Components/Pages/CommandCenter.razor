            var level = string.IsNullOrWhiteSpace(_workerLogLevelFilter) ? "" : $"&level={WebUtility.UrlEncode(_workerLogLevelFilter)}";
            var worker = string.IsNullOrWhiteSpace(_workerLogWorkerFilter) ? "" : $"&worker={WebUtility.UrlEncode(_workerLogWorkerFilter)}";
            Replace(_workerLogs, await GetArrayAsync($"/api/worker-logs?take=500{level}{worker}").ConfigureAwait(false));

