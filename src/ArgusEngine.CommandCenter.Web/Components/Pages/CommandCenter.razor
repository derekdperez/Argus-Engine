    }

    private async Task ReloadHttpQueueAsync(bool showLoading = true)
    {
        if (showLoading)
        {
            _httpLoading = true;
        }

        try
        {
            var stateQuery = string.IsNullOrWhiteSpace(_httpStateFilter)
                ? ""
                : $"&state={WebUtility.UrlEncode(_httpStateFilter)}";

            Replace(_httpQueue, await GetArrayAsync($"/api/http-request-queue?take={HttpQueueTake}{stateQuery}").ConfigureAwait(false));
            PruneSelection(_selectedHttpIds, _httpQueue);
        }
        finally
        {
            if (showLoading)
