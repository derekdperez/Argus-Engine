@page "/"
@page "/ops"
@page "/commandcenter"
@rendermode InteractiveServer

@using System.Globalization
@using System.Net
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.JSInterop
@implements IDisposable
@inject HttpClient Http
@inject ILogger<CommandCenter> Logger
@inject IJSRuntime JS

<PageTitle>Command Center - Argus Engine</PageTitle>

<div class="cc-page">
    <header class="cc-hero">
        <div class="cc-hero-top">
            <h1>Command Center</h1>
            <StatusDashboard Http="Http" />
        </div>
        <section class="cc-summary-grid" aria-label="Command Center summary">
            <article class="cc-card">
                <span>Targets</span>
                <strong>@(_overview is null ? "..." : FormatNumber(TotalTargets))</strong>
            </article>
            <article class="cc-card">
                <span>Confirmed assets</span>
                <strong>@(_overview is null ? "..." : FormatNumber(ConfirmedAssets))</strong>
            </article>
            <article class="cc-card">
                <span>HTTP queue</span>
                <strong>@(_overview is null ? "..." : FormatNumber(_httpQueueCount))</strong>
            </article>
            <article class="cc-card">
                <span>High value</span>
                <strong>@(_overview is null ? "..." : FormatNumber(HighValueCount))</strong>
            </article>
            <article class="cc-card">
                <span>Technologies</span>
                <strong>@(_overview is null ? "..." : FormatNumber(TechnologyCount))</strong>
            </article>
            <article class="cc-card">
                <span>Workers</span>
                <strong>@(_overview is null ? "..." : FormatNumber(WorkerCount))</strong>
            </article>
            <article class="cc-card">
                <span>Events</span>
                <strong>@(_overview is null ? "..." : FormatNumber(_publishedEvents))</strong>
            </article>
            <article class="cc-card">
                <span>Version</span>
                <strong>@_appVersion</strong>
            </article>
            <article class="cc-card">
                <span>Build</span>
                <strong>@_buildTime</strong>
            </article>
        </section>
    </header>

    <nav class="cc-tabs" aria-label="Command Center sections">
        <button class="@TabClass(CommandTab.Targets)" @onclick="@(() => SelectTabAsync(CommandTab.Targets))">Targets</button>
        <button class="@TabClass(CommandTab.Discovery)" @onclick="@(() => SelectTabAsync(CommandTab.Discovery))">Discovery</button>
        <button class="@TabClass(CommandTab.Workers)" @onclick="@(() => SelectTabAsync(CommandTab.Workers))">Workers</button>
        <button class="@TabClass(CommandTab.Logs)" @onclick="@(() => SelectTabAsync(CommandTab.Logs))">Logs</button>
    </nav>

    <div id="recon-action-results" class="recon-action-collapsed">
        <div class="recon-action-panel-header">
            <div class="recon-action-summary-area">
                <span id="recon-action-summary">Actions</span>
            </div>
            <div class="recon-action-header-btns">
                <button id="recon-action-clear" type="button" class="cc-btn cc-btn-small">Clear</button>
            </div>
        </div>
        <div id="recon-action-list" class="recon-action-list"></div>
    </div>

    @if (_activeTab == CommandTab.Targets)
    {
        <section class="cc-panel">
            <div class="cc-panel-header">
                <div>
                    <h2>Targets</h2>
                    <p class="cc-muted">Manage targets and monitor reconnaissance progress.</p>
                </div>
            </div>
            <div class="cc-two-column">
                <ArgusDataGrid TGridItem="JsonElement"
                               Items="@TargetRows.AsQueryable()"
                               RowMatches="@JsonRowMatches"
                               SearchText="@_targetSearch"
                               SearchTextChanged="@((string value) => _targetSearch = value)"
                               SearchPlaceholder="Search targets..."
                               IsLoading="@_targetsLoading"
                               EmptyText="No targets found."
                               PersistKey="command-center-targets"
                               StickyFirstColumn="true"
                               VirtualizedHeightPixels="140"
                               ItemKey="@RowKeyObject">
                    <ConfigurationTemplate>
                        @ColumnPicker(TargetGridColumns)
                    </ConfigurationTemplate>
                    <ChildContent>
                        @if (ColumnVisible("targets.select"))
                        {
                            <TemplateColumn Title="" Context="target" Class="select-col">
                                <input type="checkbox" checked="@IsSelectedTarget(target)" @onchange="@(_ => ToggleTarget(target))" />
                            </TemplateColumn>
                        }
                        @if (ColumnVisible("targets.root"))
                        {
                            <TemplateColumn Title="Root domain" Context="target" SortBy="@SortTargetRoot" Class="wide-col">
                                <span data-target-id="@RowKey(target)" class="argus-dg-clip" title="@Text(target, "rootDomain", "RootDomain", "domain", "Domain")">@Display(Text(target, "rootDomain", "RootDomain", "domain", "Domain"))</span>
                            </TemplateColumn>
                        }
                        @if (ColumnVisible("targets.status"))
                        {
                            <TemplateColumn Title="Status" Context="target" SortBy="@SortTargetStatus">
                                <span class="cc-pill">@Display(Text(target, "status", "Status", "state", "State"))</span>
                            </TemplateColumn>
                        }
                        @if (ColumnVisible("targets.depth"))
                        {
                            <TemplateColumn Title="Depth" Context="target" SortBy="@SortTargetDepth">@Display(Text(target, "globalMaxDepth", "GlobalMaxDepth", "maxDepth", "MaxDepth"))</TemplateColumn>
                        }
                        @if (ColumnVisible("targets.created"))
                        {
                            <TemplateColumn Title="Created" Context="target" SortBy="@SortTargetCreated">@FormatTime(Text(target, "createdAtUtc", "CreatedAtUtc", "createdAt", "CreatedAt"))</TemplateColumn>
                        }
                        @if (ColumnVisible("targets.subdomainCount"))
                        {
                            <TemplateColumn Title="Subdomains" Context="target" SortBy="@SortTargetSubdomainCount">@Display(Text(target, "subdomainCount", "SubdomainCount"))</TemplateColumn>
                        }
                        @if (ColumnVisible("targets.assetCount"))
                        {
                            <TemplateColumn Title="Assets" Context="target" SortBy="@SortTargetAssetCount">@Display(Text(target, "confirmedAssetCount", "ConfirmedAssetCount", "assetCount", "AssetCount"))</TemplateColumn>
                        }
                        @if (ColumnVisible("targets.orchestrator"))
                        {
                            <TemplateColumn Title="Orchestrator" Context="target">
                                @{
                                    var tid = RowKey(target);
                                    var enr = tid is not null && _targetEnrichment.TryGetValue(tid, out var e) ? e : null;
                                }
                                @if (enr is not null)
                                {
                                    <span class="cc-pill">@enr.OrchestratorStatus</span>
                                }
                            </TemplateColumn>
                        }
                        @if (ColumnVisible("targets.enumerated"))
                        {
                            <TemplateColumn Title="Enumerated" Context="target">
                                @{
                                    var eid = RowKey(target);
                                    var eenr = eid is not null && _targetEnrichment.TryGetValue(eid, out var ee) ? ee : null;
                                }
                                @if (eenr?.HasSubdomainsEnumerated == true) { <span style="color:#22c55e">Yes</span> }
                                else { <span style="color:#64748b">No</span> }
                            </TemplateColumn>
                        }
                        @if (ColumnVisible("targets.spidered"))
                        {
                            <TemplateColumn Title="Spidered" Context="target">
                                @{
                                    var sid = RowKey(target);
                                    var senr = sid is not null && _targetEnrichment.TryGetValue(sid, out var se) ? se : null;
                                }
                                @if (senr?.HasBeenSpidered == true) { <span style="color:#22c55e">Yes</span> }
                                else { <span style="color:#64748b">No</span> }
                            </TemplateColumn>
                        }
                        @if (ColumnVisible("targets.controls"))
                        {
                            <TemplateColumn Title="Controls" Context="target">
                                @{
                                    var ctlId = RowKey(target);
                                }
                                <button class="cc-btn cc-btn-small" @onclick="() => EnumerateTargetAsync(ctlId)">En</button>
                                <button class="cc-btn cc-btn-small" @onclick="() => SpiderTargetAsync(ctlId)">Sp</button>
                            </TemplateColumn>
                        }
                    </ChildContent>
                </ArgusDataGrid>

                <ArgusDataGrid TGridItem="JsonElement"
                               Items="@SubdomainRows.AsQueryable()"
                               RowMatches="@JsonRowMatches"
                               SearchText="@_subdomainSearch"
                               SearchTextChanged="@((string value) => _subdomainSearch = value)"
                               SearchPlaceholder="Search subdomains..."
                               IsLoading="@_subdomainsLoading"
                               EmptyText="No subdomains found."
                               PersistKey="command-center-subdomains"
                               VirtualizedHeightPixels="140"
                               ItemKey="@RowKeyObject">
                    <ConfigurationTemplate>
                        @ColumnPicker(SubdomainGridColumns)
                    </ConfigurationTemplate>
                    <ChildContent>
                        @if (ColumnVisible("subdomains.target"))
                        {
                            <TemplateColumn Title="Target" Context="subdomain" SortBy="@SortSubdomainTarget">@Display(Text(subdomain, "rootDomain", "RootDomain", "target", "Target"))</TemplateColumn>
                        }
                        @if (ColumnVisible("subdomains.name"))
                        {
                            <TemplateColumn Title="Subdomain" Context="subdomain" SortBy="@SortSubdomainName" Class="wide-col">
                                <span data-target-id="@Text(subdomain, "targetId", "TargetId", "id", "Id")" data-subdomain-key="@Text(subdomain, "subdomain", "Subdomain", "canonicalKey", "CanonicalKey", "rawValue", "RawValue")" class="argus-dg-clip" title="@Text(subdomain, "subdomain", "Subdomain", "canonicalKey", "CanonicalKey", "rawValue", "RawValue")">
                                    @Display(Text(subdomain, "subdomain", "Subdomain", "canonicalKey", "CanonicalKey", "rawValue", "RawValue"))
                                </span>
                            </TemplateColumn>
                        }
                        @if (ColumnVisible("subdomains.technologies"))
                        {
                            <TemplateColumn Title="Technologies" Context="subdomain" SortBy="@SortSubdomainTechnologyCount">@Display(Text(subdomain, "technologyCount", "TechnologyCount"))</TemplateColumn>
                        }
                        @if (ColumnVisible("subdomains.lastSeen"))
                        {
                            <TemplateColumn Title="Last seen" Context="subdomain" SortBy="@SortSubdomainLastSeen">@FormatTime(Text(subdomain, "lastSeenUtc", "LastSeenUtc", "lastSeenAtUtc", "LastSeenAtUtc"))</TemplateColumn>
                        }
                    </ChildContent>
                </ArgusDataGrid>
            </div>

            <div class="cc-panel-header">
                <div>
                    <h2>Assets</h2>
                </div>
                <div class="cc-toolbar">
                    <select class="cc-input" @bind="_assetKindFilter">
                        <option value="">All kinds</option>
                        @foreach (var kind in AssetKinds)
                        {
                            <option value="@kind">@kind</option>
                        }
                    </select>
                    <button class="cc-btn cc-btn-small" @onclick="ReloadAssetsAsync" disabled="@_assetsLoading">Reload</button>
                </div>
            </div>
            <ArgusDataGrid TGridItem="JsonElement"
                           Items="@AssetRows.AsQueryable()"
                           RowMatches="@JsonRowMatches"
                           SearchText="@_assetSearch"
                           SearchTextChanged="@((string value) => _assetSearch = value)"
                           SearchPlaceholder="Search loaded assets..."
                           IsLoading="@_assetsLoading"
                           EmptyText="No assets match the current filters."
                           PersistKey="command-center-assets"
                           VirtualizedHeightPixels="620"
                           ItemKey="@RowKeyObject">
                <ConfigurationTemplate>
                    @ColumnPicker(AssetGridColumns)
                </ConfigurationTemplate>
                <ChildContent>
                    @if (ColumnVisible("assets.kind"))
                    {
                        <TemplateColumn Title="Kind" Context="asset" SortBy="@SortAssetKind"><span class="cc-pill">@Display(Text(asset, "kind", "Kind"))</span></TemplateColumn>
                    }
                    @if (ColumnVisible("assets.asset"))
                    {
                        <TemplateColumn Title="Asset" Context="asset" SortBy="@SortAssetText" Class="wide-col">
                            @{
                                var assetText = Text(asset, "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue", "finalUrl", "FinalUrl");
                                var assetHref = TryHttpHref(assetText);
                            }
                            @if (assetHref is null)
                            {
                                <span class="argus-dg-clip" title="@assetText">@Display(assetText)</span>
                            }
                            else
                            {
                                <a href="@assetHref" target="_blank" rel="noopener noreferrer" class="argus-dg-clip" title="@assetText">@assetText</a>
                            }
                        </TemplateColumn>
                    }
                    @if (ColumnVisible("assets.category"))
                    {
                        <TemplateColumn Title="Category" Context="asset" SortBy="@SortAssetCategory">@Display(Text(asset, "category", "Category"))</TemplateColumn>
                    }
                    @if (ColumnVisible("assets.seen"))
                    {
                        <TemplateColumn Title="Seen" Context="asset" SortBy="@SortAssetSeen">@FormatTime(Text(asset, "lastSeenAtUtc", "LastSeenAtUtc", "discoveredAtUtc", "DiscoveredAtUtc"))</TemplateColumn>
                    }
                </ChildContent>
            </ArgusDataGrid>
        </section>
    }

    @if (_activeTab == CommandTab.Discovery)
    {
        <section class="cc-panel">
            <div class="cc-panel-header">
                <div>
                    <h2>Discovery</h2>
                    <p class="cc-muted">High-value and technology identification in one workspace.</p>
                </div>
                <div class="cc-toolbar">
                    <button class="cc-btn" @onclick="ReloadHighValueAsync" disabled="@_highValueLoading">Reload high value</button>
                    <button class="cc-btn" @onclick="ReloadTechnologyAsync" disabled="@_technologyLoading">Reload tech ID</button>
                </div>
            </div>
            <ArgusDataGrid TGridItem="JsonElement"
                           Items="@HighValueRows.AsQueryable()"
                           RowMatches="@JsonRowMatches"
                           SearchText="@_highValueSearch"
                           SearchTextChanged="@((string value) => _highValueSearch = value)"
                           SearchPlaceholder="Search high-value findings..."
                           IsLoading="@_highValueLoading"
                           EmptyText="No high-value findings match the current filters."
                           PersistKey="command-center-high-value"
                           VirtualizedHeightPixels="320"
                           ItemKey="@RowKeyObject">
                <ConfigurationTemplate>
                    @ColumnPicker(HighValueGridColumns)
                </ConfigurationTemplate>
                <ChildContent>
                    @if (ColumnVisible("highValue.severity"))
                    {
                        <TemplateColumn Title="Severity" Context="finding" SortBy="@SortHighValueSeverity"><span class="cc-pill">@Display(Text(finding, "severity", "Severity"))</span></TemplateColumn>
                    }
                    @if (ColumnVisible("highValue.asset"))
                    {
                        <TemplateColumn Title="Asset" Context="finding" SortBy="@SortHighValueAsset" Class="wide-col">
                            <span class="argus-dg-clip" title="@Text(finding, "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue")">@Display(Text(finding, "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue"))</span>
                        </TemplateColumn>
                    }
                    @if (ColumnVisible("highValue.finding"))
                    {
                        <TemplateColumn Title="Finding" Context="finding" SortBy="@SortHighValueFinding">@Display(Text(finding, "findingType", "FindingType", "patternName", "PatternName"))</TemplateColumn>
                    }
                    @if (ColumnVisible("highValue.score"))
                    {
                        <TemplateColumn Title="Score" Context="finding" SortBy="@SortHighValueScore">@Display(Text(finding, "importanceScore", "ImportanceScore", "confidence", "Confidence"))</TemplateColumn>
                    }
                    @if (ColumnVisible("highValue.seen"))
                    {
                        <TemplateColumn Title="Seen" Context="finding" SortBy="@SortHighValueSeen">@FormatTime(Text(finding, "findingDiscoveredAtUtc", "FindingDiscoveredAtUtc", "discoveredAtUtc", "DiscoveredAtUtc"))</TemplateColumn>
                    }
                </ChildContent>
            </ArgusDataGrid>

            <ArgusDataGrid TGridItem="JsonElement"
                           Items="@TechnologyRows.AsQueryable()"
                           RowMatches="@JsonRowMatches"
                           SearchText="@_technologySearch"
                           SearchTextChanged="@((string value) => _technologySearch = value)"
                           SearchPlaceholder="Search technologies..."
                           IsLoading="@_technologyLoading"
                           EmptyText="No technology observations match the current filters."
                           PersistKey="command-center-technologies"
                           VirtualizedHeightPixels="320"
                           ItemKey="@RowKeyObject">
                <ConfigurationTemplate>
                    @ColumnPicker(TechnologyGridColumns)
                </ConfigurationTemplate>
                <ChildContent>
                    @if (ColumnVisible("technology.name"))
                    {
                        <TemplateColumn Title="Technology" Context="technology" SortBy="@SortTechnologyName" Class="wide-col">
                            <span class="argus-dg-clip" title="@Text(technology, "technologyName", "TechnologyName", "name", "Name", "technology", "Technology")">@Display(Text(technology, "technologyName", "TechnologyName", "name", "Name", "technology", "Technology"))</span>
                        </TemplateColumn>
                    }
                    @if (ColumnVisible("technology.version"))
                    {
                        <TemplateColumn Title="Version" Context="technology" SortBy="@SortTechnologyVersion">@Display(Text(technology, "version", "Version"))</TemplateColumn>
                    }
                    @if (ColumnVisible("technology.evidence"))
                    {
                        <TemplateColumn Title="Evidence" Context="technology" SortBy="@SortTechnologyEvidence">@Display(Text(technology, "evidence", "Evidence", "source", "Source", "category", "Category"))</TemplateColumn>
                    }
                    @if (ColumnVisible("technology.seen"))
                    {
                        <TemplateColumn Title="Seen" Context="technology" SortBy="@SortTechnologySeen">@FormatTime(Text(technology, "lastSeenUtc", "LastSeenUtc", "observedAtUtc", "ObservedAtUtc"))</TemplateColumn>
                    }
                </ChildContent>
            </ArgusDataGrid>
        </section>
    }

    @if (_activeTab == CommandTab.Workers)
    {
        <section class="cc-panel">
            <div class="cc-panel-header">
                <div>
                    <h2>Workers</h2>
                    <p class="cc-muted">All workers grouped by provider. Set min/max per provider and apply.</p>
                </div>
                <div class="cc-toolbar">
                    <button class="cc-btn" @onclick="ReloadWorkersAsync" disabled="@_workersLoading">Reload</button>
                    <button class="cc-btn" @onclick="ApplyScaleAllAsync" disabled="@_workersLoading">Apply All</button>
                </div>
            </div>

            @if (_allWorkerRows.Count == 0 && !_workersLoading)
            {
                <p class="cc-muted">No workers found. Check your provider connections.</p>
            }
            else
            {
                <div class="ww-grid-wrap">
                    <table class="ww-table">
                        <thead>
                            <tr>
                                <th class="ww-col-provider">Provider</th>
                                <th class="ww-col-name">Worker</th>
                                <th class="ww-col-status">Status</th>
                                <th class="ww-col-min">Min</th>
                                <th class="ww-col-max">Max</th>
                                <th class="ww-col-url">URL</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                string? lastProvider = null;
                            }
                            @foreach (var row in _allWorkerRows)
                            {
                                @* Group header with provider controls *@
                                @if (row.Provider != lastProvider)
                                {
                                    lastProvider = row.Provider;
                                    var ps = _providerSettings.GetValueOrDefault(lastProvider);
                                    var workerCount = _allWorkerRows.Count(r => r.Provider == lastProvider);
                                    <tr class="ww-group-header">
                                        <td colspan="6">
                                            <div style="display:flex;align-items:center;justify-content:space-between;width:100%">
                                                <span>
                                                    <span class="ww-group-dot" style="background:@(row.Provider switch { "Google" => "#4285F4", "Local" => "#22c55e", "AWS" => "#FF9900", "Azure" => "#0078D4", _ => "#94a3b8" })"></span>
                                                    @row.Provider
                                                    <span style="color:#64748b;font-weight:400;font-size:0.72rem;margin-left:6px;text-transform:none">@workerCount workers</span>
                                                </span>
                                                @if (ps is not null)
                                                {
                                                    <span class="ww-provider-controls-row">
                                                        <label>Min <input class="cc-input cc-depth-input" type="number" min="0" max="50" @bind="ps.Min" style="width:50px" /></label>
                                                        <label>Max <input class="cc-input cc-depth-input" type="number" min="0" max="50" @bind="ps.Max" style="width:50px" /></label>
                                                        <button class="cc-btn cc-btn-small" @onclick="() => ApplyScaleProviderAsync(lastProvider!)">Apply</button>
                                                    </span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                                <tr class="ww-row">
                                    <td class="ww-col-provider">@row.Provider</td>
                                    <td class="ww-col-name">@row.Name</td>
                                    <td class="ww-col-status"><span class="cc-pill">@row.Status</span></td>
                                    <td class="ww-col-min">@row.MinInstances</td>
                                    <td class="ww-col-max">@row.MaxInstances</td>
                                    <td class="ww-col-url">@if (!string.IsNullOrWhiteSpace(row.Url)) { <a href="@row.Url" target="_blank" rel="noopener noreferrer">@TruncateUrl(row.Url)</a> }</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        @* RabbitMQ status section *@
        <section class="cc-panel" style="margin-top:16px">
            <div class="cc-panel-header">
                <div>
                    <h2>RabbitMQ</h2>
                    <p class="cc-muted">Queue depths, consumers, and message rates.</p>
                </div>
                <div class="cc-toolbar">
                    <button class="cc-btn" @onclick="ReloadRabbitMqAsync" disabled="@_rmqLoading">Refresh</button>
                </div>
            </div>
            @if (_rmqError is not null)
            {
                <p class="cc-muted">@_rmqError</p>
            }
            else if (_rmqQueues.Count > 0)
            {
                <div class="rmq-summary">
                    <span class="rmq-stat"><strong>@_rmqQueues.Count</strong> queues</span>
                    <span class="rmq-stat"><strong>@_rmqConsumerGroups</strong> consumer groups</span>
                    <span class="rmq-stat"><strong>@_rmqTotalMessages</strong> total messages</span>
                    <span class="rmq-stat">v@_rmqVersion</span>
                </div>
                <div class="ww-grid-wrap" style="margin-top:8px">
                    <table class="ww-table">
                        <thead>
                            <tr>
                                <th>Queue</th>
                                <th style="text-align:center">Messages</th>
                                <th style="text-align:center">Ready</th>
                                <th style="text-align:center">Unacked</th>
                                <th style="text-align:center">Consumers</th>
                                <th>Consumer Tags</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var q in _rmqQueues)
                            {
                                <tr>
                                    <td>@q.Name</td>
                                    <td style="text-align:center">@q.Messages</td>
                                    <td style="text-align:center">@q.Ready</td>
                                    <td style="text-align:center">@q.Unacked</td>
                                    <td style="text-align:center">@q.Consumers</td>
                                    <td style="font-size:0.75rem;color:#94a3b8">
                                        @if (_rmqConsumerTags.TryGetValue(q.Name, out var tags))
                                        {
                                            @string.Join(", ", tags)
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

    @if (_activeTab == CommandTab.Logs)
    {
        <section class="cc-panel">
            <div class="cc-panel-header">
                <div>
                    <h2>Logs</h2>
                    <p class="cc-muted">Central log repository for infrastructure and application logs.</p>
                </div>
                <div class="cc-toolbar">
                    <button class="cc-btn" @onclick="ReloadLogsAsync" disabled="@_logsLoading">Reload</button>
                </div>
            </div>

            <div class="logs-sub-tabs">
                <button class="@(_logsSubTab == "app" ? "logs-sub-tab-active" : "")" @onclick="@(() => _logsSubTab = "app")">Application Logs</button>
                <button class="@(_logsSubTab == "worker" ? "logs-sub-tab-active" : "")" @onclick="@(() => _logsSubTab = "worker")">Worker Logs</button>
            </div>

            @if (_logsSubTab == "app")
            {
                <div class="logs-filters">
                    <select class="cc-input" @bind="_logLevelFilter">
                        <option value="">All levels</option>
                        @foreach (var lvl in _logLevels)
                        {
                            <option value="@lvl">@lvl</option>
                        }
                    </select>
                    <select class="cc-input" @bind="_logComponentFilter">
                        <option value="">All components</option>
                        @foreach (var comp in _logComponents)
                        {
                            <option value="@comp">@comp</option>
                        }
                    </select>
                    <input class="cc-input" type="text" placeholder="Search..." @bind="_logSearch" />
                </div>
                <ArgusDataGrid TGridItem="JsonElement"
                               Items="@LogRows.AsQueryable()"
                               SearchText="@_logSearch"
                               SearchTextChanged="@((string value) => _logSearch = value)"
                               SearchPlaceholder="Search logs..."
                               IsLoading="@_logsLoading"
                               EmptyText="No log entries found."
                               PersistKey="command-center-logs"
                               VirtualizedHeightPixels="500"
                               ItemKey="@((JsonElement e) => e.GetProperty("id").GetString() ?? "")">
                    <ChildContent>
                        <TemplateColumn Title="Time" Context="log" SortBy="@SortLogTime">
                            <span class="log-time">@FormatTime(Text(log, "timestamp", "Timestamp"))</span>
                        </TemplateColumn>
                        <TemplateColumn Title="Level" Context="log" SortBy="@SortLogLevel">
                            <span class="cc-pill log-level-@Text(log, "logLevel", "LogLevel").ToLower()">@Text(log, "logLevel", "LogLevel")</span>
                        </TemplateColumn>
                        <TemplateColumn Title="Component" Context="log" SortBy="@SortLogComponent">@Text(log, "component", "Component")</TemplateColumn>
                        <TemplateColumn Title="Message" Context="log" Class="wide-col">
                            <span class="argus-dg-clip" title="@Text(log, "message", "Message")">@Text(log, "message", "Message")</span>
                        </TemplateColumn>
                        <TemplateColumn Title="Exception" Context="log">
                            @if (!string.IsNullOrWhiteSpace(Text(log, "exception", "Exception")))
                            {
                                <span class="log-exception" title="@Text(log, "exception", "Exception")">@Truncate(Text(log, "exception", "Exception"), 100)</span>
                            }
                        </TemplateColumn>
                    </ChildContent>
                </ArgusDataGrid>
            }

            @if (_logsSubTab == "worker")
            {
                <div class="logs-filters">
                    <select class="cc-input" @bind="_workerLogLevelFilter">
                        <option value="">All levels</option>
                        @foreach (var lvl in _logLevels)
                        {
                            <option value="@lvl">@lvl</option>
                        }
                    </select>
                    <select class="cc-input" @bind="_workerLogWorkerFilter">
                        <option value="">All workers</option>
                        @foreach (var w in _workerComponents)
                        {
                            <option value="@w">@w</option>
                        }
                    </select>
                    <input class="cc-input" type="text" placeholder="Search..." @bind="_workerLogSearch" />
                </div>
                <ArgusDataGrid TGridItem="JsonElement"
                               Items="@WorkerLogRows.AsQueryable()"
                               SearchText="@_workerLogSearch"
                               SearchTextChanged="@((string value) => _workerLogSearch = value)"
                               SearchPlaceholder="Search worker logs..."
                               IsLoading="@_workerLogsLoading"
                               EmptyText="No worker log entries found."
                               PersistKey="command-center-worker-logs"
                               VirtualizedHeightPixels="500"
                               ItemKey="@((JsonElement e) => e.GetProperty("id").GetString() ?? "")">
                    <ChildContent>
                        <TemplateColumn Title="Time" Context="log" SortBy="@SortLogTime">
                            <span class="log-time">@FormatTime(Text(log, "timestamp", "Timestamp"))</span>
                        </TemplateColumn>
                        <TemplateColumn Title="Level" Context="log" SortBy="@SortLogLevel">
                            <span class="cc-pill log-level-@Text(log, "logLevel", "LogLevel").ToLower()">@Text(log, "logLevel", "LogLevel")</span>
                        </TemplateColumn>
                        <TemplateColumn Title="Worker" Context="log" SortBy="@SortLogComponent">@Text(log, "component", "Component")</TemplateColumn>
                        <TemplateColumn Title="Message" Context="log" Class="wide-col">
                            <span class="argus-dg-clip" title="@Text(log, "message", "Message")">@Text(log, "message", "Message")</span>
                        </TemplateColumn>
                        <TemplateColumn Title="Exception" Context="log">
                            @if (!string.IsNullOrWhiteSpace(Text(log, "exception", "Exception")))
                            {
                                <span class="log-exception" title="@Text(log, "exception", "Exception")">@Truncate(Text(log, "exception", "Exception"), 100)</span>
                            }
                        </TemplateColumn>
                    </ChildContent>
                </ArgusDataGrid>
            }
        </section>
    }
</div>

@code {
