    private int DesiredCloudMin(WorkerType worker) =>
        _cloudDesiredMin.TryGetValue(worker, out var value) ? value : DefaultCloudMin(worker);

    private int DesiredCloudMax(WorkerType worker)
    {
        var min = DesiredCloudMin(worker);
        return _cloudDesiredMax.TryGetValue(worker, out var value) ? NormalizeCloudMax(min, value) : NormalizeCloudMax(min, 10);
    }

    private void OnDesiredCloudMinChanged(WorkerType worker, ChangeEventArgs args)
    {
        if (!TryReadInt(args, out var value))
        {
            return;
        }

        _cloudDesiredMin[worker] = Math.Clamp(value, 0, 100);
        if (DesiredCloudMax(worker) < _cloudDesiredMin[worker])
        {
            _cloudDesiredMax[worker] = NormalizeCloudMax(_cloudDesiredMin[worker], _cloudDesiredMin[worker]);
        }
    }

    private void OnDesiredCloudMaxChanged(WorkerType worker, ChangeEventArgs args)
    {
        if (!TryReadInt(args, out var value))
        {
            return;
        }

        _cloudDesiredMax[worker] = NormalizeCloudMax(DesiredCloudMin(worker), value);
    }

    private async Task ApplyCloudScaleAsync(WorkerType worker)
    {
        if (!_cloudScaleBusy.Add(worker))
        {
            return;
        }

        try
        {
            var status = _cloudWorkers.FirstOrDefault(x => x.Worker == worker);
            if (status is { Status: CloudDeployStatus.NotDeployed })
            {
                _statusMessage = $"Cloud scale skipped for {CloudWorkerLabel(worker)} because the service is not deployed.";
                return;
            }

            var min = Math.Clamp(DesiredCloudMin(worker), 0, 100);
            var max = NormalizeCloudMax(min, DesiredCloudMax(worker));
            _cloudDesiredMin[worker] = min;
            _cloudDesiredMax[worker] = max;

            var result = await DeployService.ScaleWorkersAsync(min, max, [worker], _cts.Token).ConfigureAwait(false);
            var row = result.Results.FirstOrDefault(x => x.Worker == worker);
            if (row != default && !row.Result.Success)
            {
                _statusMessage = $"Cloud scale failed for {CloudWorkerLabel(worker)}: {row.Result.Message}";
            }
            else
            {
                _statusMessage = $"Cloud scale applied for {CloudWorkerLabel(worker)} (min={min}, max={max}).";
            }

            await ReloadCloudWorkersAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Cloud scale request failed for {CloudWorkerLabel(worker)}: {ex.Message}";
        }
        finally
        {
            _cloudScaleBusy.Remove(worker);
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

