        _statusMessage = "";
        try
        {
            using var response = await WorkerApi.Client.PostAsJsonAsync(
                "/api/ops/spider/restart",
                new RestartToolRequest(targetIds, AllTargets: false),
                _cts.Token).ConfigureAwait(false);
            response.EnsureSuccessStatusCode();

            using var doc = JsonDocument.Parse(await response.Content.ReadAsStringAsync(_cts.Token).ConfigureAwait(false));
            var targets = Long(doc.RootElement, "targets", "Targets");
            var requeued = Long(doc.RootElement, "requeuedExistingRequests", "RequeuedExistingRequests");
            var seeds = Long(doc.RootElement, "rootSeedsQueued", "RootSeedsQueued");
            var workerScale = Text(doc.RootElement, "workerScale", "WorkerScale");

            _statusMessage = $"{label} started for {targets} target(s). Requeued {requeued} existing requests, queued {seeds} root seeds. {workerScale}";
            await ReloadHttpQueueAsync().ConfigureAwait(false);
            await ReloadDockerWorkersAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Spider could not be started: {ex.Message}";
        }
        finally
        {
            _spiderLoading = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

