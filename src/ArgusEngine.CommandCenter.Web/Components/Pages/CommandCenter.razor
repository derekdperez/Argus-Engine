@page "/"
@page "/commandcenter"
@page "/ops"
@rendermode InteractiveServer

@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using ArgusEngine.CloudDeploy
@using ArgusEngine.CommandCenter.Contracts
@using ArgusEngine.CommandCenter.Models
@using ArgusEngine.CommandCenter.Realtime
@using ArgusEngine.CommandCenter.Web.Clients
@using Microsoft.AspNetCore.Components.Web.Virtualization
@implements IDisposable
@inject WorkerControlApiClient WorkerApi
@inject IGcpHybridDeployService DeployService
@inject DiscoveryRealtimeClient Realtime
@inject Microsoft.Extensions.Logging.ILogger<CommandCenter> Logger

<PageTitle>Argus Command Center - Argus Engine</PageTitle>

<div class="ops-page" @onclick="CloseContextMenu">
    <header class="ops-header">
        <div>
            <p class="eyebrow">Operations</p>
            <h1>Argus Command Center</h1>
            <p class="muted">Targets, assets, workers, HTTP queue, high value assets, and technology detection in one operations view.</p>
        </div>
        <button class="primary" type="button" @onclick="ReloadAllAsync">Refresh</button>
    </header>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="status">@_statusMessage</div>
    }

    <section class="summary-grid" aria-label="Operations summary">
        <article class="summary-card">
            <span>Targets</span>
            <strong>@FormatNumber(TotalTargets)</strong>
        </article>
        <article class="summary-card">
            <span>Assets</span>
            <strong>@FormatNumber(ConfirmedAssets)</strong>
        </article>
        <article class="summary-card">
            <span>Subdomains</span>
            <strong>@FormatNumber(ConfirmedSubdomains)</strong>
        </article>
        <article class="summary-card">
            <span>HTTP Queue</span>
            <strong>@FormatNumber(HttpQueueQueuedCount)</strong>
            <small>@FormatNumber(HttpRequestsSentPerMinute) sent/min</small>
        </article>
        <article class="summary-card summary-card-wide">
            <span>Asset Storage</span>
            <strong>@FormatStorageSize(TotalTrackedStorageBytes)</strong>
            <small>@StorageBreakdownLabel</small>
        </article>
    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Scope</p>
                <h2>Targets</h2>
            </div>
            <span class="muted">@FormatNumber(TargetRows.Length) visible</span>
        </div>

        <div class="toolbar">
            <input placeholder="Search targets" @bind="_targetSearch" @bind:event="oninput" />
            <input placeholder="New target root domain" @bind="_newTargetRootDomain" @bind:event="oninput" />
            <input class="depth-input" type="number" min="1" max="50" @bind="_newTargetDepth" />
            <button type="button" @onclick="CreateTargetAsync" disabled="@(!CanCreateTarget)">Add Target</button>
            <button type="button" @onclick="() => StartEnumerationAsync(selectedOnly: true)" disabled="@(_selectedTargetIds.Count == 0)">Enumerate selected (@_selectedTargetIds.Count)</button>
            <button type="button" @onclick="() => StartEnumerationAsync(selectedOnly: false)" disabled="@(TargetRows.Length == 0)">Enumerate all visible</button>
            <button type="button" @onclick="() => StartSpiderTargetsAsync(selectedOnly: true)" disabled="@(_selectedTargetIds.Count == 0)">Spider selected (@_selectedTargetIds.Count)</button>
            <button type="button" @onclick="() => StartSpiderTargetsAsync(selectedOnly: false)" disabled="@(TargetRows.Length == 0)">Spider all visible</button>
        </div>

        <div class="table-wrap grid-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th class="select-col">
                            <input type="checkbox" checked="@AllVisibleTargetsSelected" @onchange="ToggleAllVisibleTargets" />
                        </th>
                        <th><button type="button" class="sort" @onclick='() => SetTargetSort("name")'>Target @SortGlyph(_targetSort, "name", _targetSortDescending)</button></th>
                        <th><button type="button" class="sort" @onclick='() => SetTargetSort("depth")'>Depth @SortGlyph(_targetSort, "depth", _targetSortDescending)</button></th>
                        <th><button type="button" class="sort" @onclick='() => SetTargetSort("subdomains")'>Subs @SortGlyph(_targetSort, "subdomains", _targetSortDescending)</button></th>
                        <th><button type="button" class="sort" @onclick='() => SetTargetSort("assets")'>Assets @SortGlyph(_targetSort, "assets", _targetSortDescending)</button></th>
                        <th><button type="button" class="sort" @onclick='() => SetTargetSort("lastRun")'>Last run @SortGlyph(_targetSort, "lastRun", _targetSortDescending)</button></th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize TItem="JsonElement" Items="@TargetRows" Context="target" ItemSize="40" OverscanCount="20">
                    @{
                        var id = Text(target, "id", "Id");
                        <tr class="@RowClass(IsTargetSelected(id))"
                            @onclick="() => ToggleTargetSelection(id)"
                            @oncontextmenu="args => OpenTargetContextMenu(args, target)"
                            @oncontextmenu:preventDefault="true">
                            <td class="select-col">
                                <input type="checkbox" checked="@IsTargetSelected(id)" @onchange="args => SetTargetSelected(id, args)" @onclick:stopPropagation="true" />
                            </td>
                            <td><button type="button" class="link-button" @onclick="() => SelectActiveTarget(id)" @onclick:stopPropagation="true">@DisplayOrDash(Text(target, "rootDomain", "RootDomain"))</button></td>
                            <td>@DisplayOrDash(Text(target, "globalMaxDepth", "GlobalMaxDepth"))</td>
                            <td>@FormatNumber(Long(target, "subdomainCount", "SubdomainCount"))</td>
                            <td>@FormatNumber(Long(target, "confirmedAssetCount", "ConfirmedAssetCount"))</td>
                            <td>@FormatTime(Text(target, "lastRunAtUtc", "LastRunAtUtc"))</td>
                        </tr>
                    }
                    </Virtualize>
                </tbody>
            </table>
        </div>
    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Scope</p>
                <h2>Subdomains</h2>
            </div>
            <span class="muted">@ActiveTargetLabel · @FormatNumber(SubdomainRows.Length) visible</span>
        </div>

        <div class="toolbar">
            <input placeholder="Search subdomains" @bind="_subdomainSearch" @bind:event="oninput" />
            <button type="button" @onclick="() => StartSpiderSubdomainsAsync(selectedOnly: true)" disabled="@(_selectedSubdomainKeys.Count == 0)">Spider selected subdomains (@_selectedSubdomainKeys.Count)</button>
            <button type="button" @onclick="() => StartSpiderSubdomainsAsync(selectedOnly: false)" disabled="@(SubdomainRows.Length == 0)">Spider all visible subdomains</button>
            <button type="button" @onclick="SpiderActiveTargetAsync" disabled="@(string.IsNullOrWhiteSpace(_activeTargetId))">Spider active target</button>
        </div>

        <div class="table-wrap grid-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th class="select-col">
                            <input type="checkbox" checked="@AllVisibleSubdomainsSelected" @onchange="ToggleAllVisibleSubdomains" />
                        </th>
                        <th><button type="button" class="sort" @onclick='() => SetSubdomainSort("name")'>Subdomain @SortGlyph(_subdomainSort, "name", _subdomainSortDescending)</button></th>
                        <th><button type="button" class="sort" @onclick='() => SetSubdomainSort("discovered")'>Discovered @SortGlyph(_subdomainSort, "discovered", _subdomainSortDescending)</button></th>
                        <th>How found</th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize TItem="JsonElement" Items="@SubdomainRows" Context="row" ItemSize="40" OverscanCount="20">
                    @{
                        var key = SubdomainKey(row);
                        <tr class="@RowClass(IsSubdomainSelected(key))"
                            @onclick="() => ToggleSubdomainSelection(key)"
                            @oncontextmenu="args => OpenSubdomainContextMenu(args, row)"
                            @oncontextmenu:preventDefault="true">
                            <td class="select-col">
                                <input type="checkbox" checked="@IsSubdomainSelected(key)" @onchange="args => SetSubdomainSelected(key, args)" @onclick:stopPropagation="true" />
                            </td>
                            <td>@DisplayOrDash(SubdomainName(row))</td>
                            <td>@FormatTime(Text(row, "discoveredAtUtc", "DiscoveredAtUtc"))</td>
                            <td>@DisplayOrDash(Text(row, "discoveryContext", "DiscoveryContext"))</td>
                        </tr>
                    }
                    </Virtualize>
                </tbody>
            </table>
        </div>

    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Inventory</p>
                <h2>Assets</h2>
            </div>
            <span class="muted">@FormatNumber(AssetRows.Length) visible</span>
        </div>

        <div class="toolbar">
            <input placeholder="Search assets" @bind="_assetSearch" @bind:event="oninput" />
            <select @bind="_assetFilter">
                <option value="">All kinds</option>
                <option value="Domain">Domain</option>
                <option value="Subdomain">Subdomain</option>
                <option value="Url">URL</option>
                <option value="IpAddress">IP address</option>
                <option value="OpenPort">Open port</option>
            </select>
            <button type="button" @onclick="ReloadAssetsAsync">Reload assets</button>
        </div>

        <div class="table-wrap grid-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th class="select-col">
                            <input type="checkbox" checked="@AllVisibleAssetsSelected" @onchange="ToggleAllVisibleAssets" />
                        </th>
                        <th><button type="button" class="sort" @onclick='() => SetAssetSort("kind")'>Kind @SortGlyph(_assetSort, "kind", _assetSortDescending)</button></th>
                        <th>Value</th>
                        <th><button type="button" class="sort" @onclick='() => SetAssetSort("discovered")'>Discovered @SortGlyph(_assetSort, "discovered", _assetSortDescending)</button></th>
                        <th>Last seen</th>
                        <th>How found</th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize TItem="JsonElement" Items="@AssetRows" Context="asset" ItemSize="40" OverscanCount="20">
                    @{
                        var id = Text(asset, "id", "Id");
                        var finalUrl = Text(asset, "finalUrl", "FinalUrl");
                        var href = TryHttpHref(finalUrl);
                        <tr class="@RowClass(IsAssetSelected(id))" @onclick="() => ToggleAssetSelection(id)">
                            <td class="select-col">
                                <input type="checkbox" checked="@IsAssetSelected(id)" @onchange="args => SetAssetSelected(id, args)" @onclick:stopPropagation="true" />
                            </td>
                            <td>@DisplayOrDash(Text(asset, "kind", "Kind"))</td>
                            <td>
                                @if (href is null)
                                {
                                    @DisplayOrDash(AssetValue(asset))
                                }
                                else
                                {
                                    <a href="@href" target="_blank" rel="noopener noreferrer">@DisplayOrDash(finalUrl)</a>
                                }
                            </td>
                            <td>@FormatTime(Text(asset, "discoveredAtUtc", "DiscoveredAtUtc"))</td>
                            <td>@FormatTime(Text(asset, "lastSeenAtUtc", "LastSeenAtUtc"))</td>
                            <td>@DisplayOrDash(Text(asset, "discoveryContext", "DiscoveryContext"))</td>
                        </tr>
                    }
                    </Virtualize>
                </tbody>
            </table>
        </div>

    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Infrastructure</p>
                <h2>Workers</h2>
            </div>
            <span class="muted">@FormatNumber(WorkerRows.Count) services</span>
        </div>

        @if (!string.IsNullOrWhiteSpace(_dockerWorkersError))
        {
            <div class="warning">@_dockerWorkersError</div>
        }

        <div class="table-wrap grid-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th class="select-col">
                            <input type="checkbox" checked="@AllVisibleWorkersSelected" @onchange="ToggleAllVisibleWorkers" />
                        </th>
                        <th>Worker</th>
                        <th>State</th>
                        <th>Running</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize TItem="JsonElement" Items="@WorkerRows" Context="worker" ItemSize="40" OverscanCount="20">
                    @{
                        var service = Text(worker, "serviceName", "ServiceName");
                        <tr class="@RowClass(IsWorkerSelected(service))" @onclick="() => ToggleWorkerSelection(service)">
                            <td class="select-col">
                                <input type="checkbox" checked="@IsWorkerSelected(service)" @onchange="args => SetWorkerSelected(service, args)" @onclick:stopPropagation="true" />
                            </td>
                            <td><button type="button" class="link-button" @onclick="() => OpenWorkerDetailsAsync(service)" @onclick:stopPropagation="true">@DisplayOrDash(Text(worker, "displayName", "DisplayName", "serviceName", "ServiceName"))</button></td>
                            <td>@DisplayOrDash(Text(worker, "overallState", "OverallState"))</td>
                            <td>@FormatNumber(Long(worker, "runningCount", "RunningCount"))</td>
                            <td>@FormatNumber(Long(worker, "totalCount", "TotalCount"))</td>
                        </tr>
                    }
                    </Virtualize>
                </tbody>
            </table>
        </div>

        <h3>Google Cloud Run manual scale</h3>
        @if (!string.IsNullOrWhiteSpace(_cloudWorkersError))
        {
            <div class="warning">@_cloudWorkersError</div>
        }

        <div class="toolbar">
            <button type="button" @onclick="ReloadCloudWorkersAsync" disabled="@_cloudWorkersLoading">Refresh Cloud worker status</button>
            <span class="muted">@FormatNumber(CloudWorkerRows.Length) worker types</span>
        </div>

        <div class="table-wrap grid-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th>Worker Type</th>
                        <th>Status</th>
                        <th>Current</th>
                        <th>Live Min</th>
                        <th>Live Max</th>
                        <th>Manual Min</th>
                        <th>Manual Max</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize TItem="WorkerStatus" Items="@CloudWorkerRows" Context="cloudWorker" ItemSize="40" OverscanCount="20">
                    @{
                        var busy = _cloudScaleBusy.Contains(cloudWorker.Worker);
                        <tr>
                            <td>@CloudWorkerLabel(cloudWorker.Worker)</td>
                            <td>@cloudWorker.Status</td>
                            <td>@FormatNumber(cloudWorker.CurrentInstances)</td>
                            <td>@FormatNumber(cloudWorker.MinInstances)</td>
                            <td>@FormatNumber(cloudWorker.MaxInstances)</td>
                            <td>
                                <input type="number"
                                       min="0"
                                       max="100"
                                       value="@DesiredCloudMin(cloudWorker.Worker)"
                                       @onchange="args => OnDesiredCloudMinChanged(cloudWorker.Worker, args)"
                                       disabled="@busy" />
                            </td>
                            <td>
                                <input type="number"
                                       min="0"
                                       max="100"
                                       value="@DesiredCloudMax(cloudWorker.Worker)"
                                       @onchange="args => OnDesiredCloudMaxChanged(cloudWorker.Worker, args)"
                                       disabled="@busy" />
                            </td>
                            <td>
                                <button type="button"
                                        @onclick="() => ApplyCloudScaleAsync(cloudWorker.Worker)"
                                        disabled="@(busy || cloudWorker.Status == CloudDeployStatus.NotDeployed)">
                                    @(busy ? "Applying..." : "Apply")
                                </button>
                            </td>
                        </tr>
                    }
                    </Virtualize>
                </tbody>
            </table>
        </div>
    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">HTTP</p>
                <h2>HTTP Queue</h2>
            </div>
            <span class="muted">@FormatNumber(HttpRows.Length) requests</span>
        </div>

        <div class="toolbar">
            <input placeholder="Search HTTP queue" @bind="_httpSearch" @bind:event="oninput" />
            <select value="@_httpStateFilter" @onchange="OnHttpStateFilterChanged">
                <option value="">All states</option>
                <option value="Queued">Queued</option>
                <option value="InFlight">In flight</option>
                <option value="Retry">Retry</option>
                <option value="Succeeded">Completed</option>
                <option value="Failed">Failed</option>
            </select>
            <button type="button" @onclick="RetrySelectedHttpRowsAsync" disabled="@(_selectedHttpIds.Count == 0)">Retry selected</button>
            <button type="button" @onclick="ClearSelectedHttpRowsAsync" disabled="@(_selectedHttpIds.Count == 0)">Clear selected</button>
            <button type="button" @onclick="ClearCompletedHttpRowsAsync">Clear completed</button>
            <button type="button" @onclick="ClearFailedHttpRowsAsync">Clear failed</button>
        </div>

        <div class="table-wrap grid-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th class="select-col">
                            <input type="checkbox" checked="@AllVisibleHttpSelected" @onchange="ToggleAllVisibleHttp" />
                        </th>
                        <th><button type="button" class="sort" @onclick='() => SetHttpSort("created")'>Created @SortGlyph(_httpSort, "created", _httpSortDescending)</button></th>
                        <th>State</th>
                        <th>Method</th>
                        <th>URL</th>
                        <th>Domain</th>
                        <th>Status</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize TItem="JsonElement" Items="@HttpRows" Context="q" ItemSize="40" OverscanCount="24">
                    @{
                        var id = Text(q, "id", "Id");
                        <tr class="@RowClass(IsHttpSelected(id))" @onclick="() => ToggleHttpSelection(id)">
                            <td class="select-col">
                                <input type="checkbox" checked="@IsHttpSelected(id)" @onchange="args => SetHttpSelected(id, args)" @onclick:stopPropagation="true" />
                            </td>
                            <td>@FormatTime(Text(q, "createdAtUtc", "CreatedAtUtc"))</td>
                            <td>@DisplayOrDash(Text(q, "state", "State"))</td>
                            <td>@DisplayOrDash(Text(q, "method", "Method"))</td>
                            <td>@DisplayOrDash(Text(q, "requestUrl", "RequestUrl"))</td>
                            <td>@DisplayOrDash(Text(q, "domainKey", "DomainKey"))</td>
                            <td>@DisplayOrDash(Text(q, "lastHttpStatus", "LastHttpStatus"))</td>
                            <td>@DisplayOrDash(Text(q, "lastError", "LastError"))</td>
                        </tr>
                    }
                    </Virtualize>
                </tbody>
            </table>
        </div>
    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">High Value</p>
                <h2>High Value Assets</h2>
            </div>
            <span class="muted">@FormatNumber(HighValueRows.Count) rows</span>
        </div>

        <div class="toolbar">
            <input placeholder="Search high value assets" @bind="_highValueSearch" @bind:event="oninput" />
            <select @bind="_highValueStatusFilter">
                <option value="Active">Active</option>
                <option value="">All statuses</option>
                <option value="Pending">Pending</option>
                <option value="In Process">In Process</option>
                <option value="False Positive">False Positive</option>
                <option value="Valid Finding">Valid Finding</option>
            </select>
            <button type="button" @onclick="ReloadHighValueAssetsAsync">Refresh</button>
        </div>

        <div class="table-wrap grid-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th class="select-col">
                            <input type="checkbox" checked="@AllVisibleHighValueSelected" @onchange="ToggleAllVisibleHighValue" />
                        </th>
                        <th>Last seen</th>
                        <th>Status</th>
                        <th>Target</th>
                        <th>Kind</th>
                        <th>URL / Asset</th>
                        <th>Finding</th>
                        <th>Severity</th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize TItem="JsonElement" Items="@FilteredHighValueRows" Context="row" ItemSize="40" OverscanCount="24">
                    @{
                        var key = HighValueKey(row);
                        <tr class="@RowClass(IsHighValueSelected(key))" @onclick="() => ToggleHighValueSelection(key)">
                            <td class="select-col">
                                <input type="checkbox" checked="@IsHighValueSelected(key)" @onchange="args => SetHighValueSelected(key, args)" @onclick:stopPropagation="true" />
                            </td>
                            <td>@FormatTime(Text(row, "lastSeenAtUtc", "LastSeenAtUtc", "findingDiscoveredAtUtc", "FindingDiscoveredAtUtc"))</td>
                            <td>@DisplayOrDash(Text(row, "investigationStatus", "InvestigationStatus"))</td>
                            <td>@DisplayOrDash(Text(row, "targetRootDomain", "TargetRootDomain"))</td>
                            <td>@DisplayOrDash(Text(row, "kind", "Kind"))</td>
                            <td>@DisplayOrDash(BestAssetUrl(row))</td>
                            <td>@DisplayOrDash(Text(row, "findingType", "FindingType"))</td>
                            <td>@DisplayOrDash(Text(row, "severity", "Severity"))</td>
                        </tr>
                    }
                    </Virtualize>
                </tbody>
            </table>
        </div>
    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Technology ID</p>
                <h2>Top 10 Technologies</h2>
            </div>
            <span class="muted">Grouped by name regardless of version</span>
        </div>

        <ol class="top-tech-list">
            @foreach (var row in TopTechnologyRows.Take(10))
            {
                <li>
                    <button type="button" class="link-button" @onclick="() => OpenTechnologyModal(row.Name)">
                        @row.Name (@FormatNumber(row.TargetCount) targets, @FormatNumber(row.SubdomainCount) subdomains)
                    </button>
                </li>
            }
        </ol>

        <div class="toolbar">
            <input placeholder="Search technologies" @bind="_technologySearch" @bind:event="oninput" />
            <button type="button" @onclick="ReloadTechnologyDataAsync">Refresh</button>
        </div>

        <div class="table-wrap grid-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th class="select-col">
                            <input type="checkbox" checked="@AllVisibleTechnologySelected" @onchange="ToggleAllVisibleTechnologies" />
                        </th>
                        <th>Last seen</th>
                        <th>Target</th>
                        <th>Subdomain</th>
                        <th>Technology</th>
                        <th>Version</th>
                        <th>Source</th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize TItem="JsonElement" Items="@FilteredTechnologyRows" Context="row" ItemSize="40" OverscanCount="24">
                    @{
                        var key = TechnologyKey(row);
                        <tr class="@RowClass(IsTechnologySelected(key))" @onclick="() => ToggleTechnologySelection(key)">
                            <td class="select-col">
                                <input type="checkbox" checked="@IsTechnologySelected(key)" @onchange="args => SetTechnologySelected(key, args)" @onclick:stopPropagation="true" />
                            </td>
                            <td>@FormatTime(Text(row, "lastSeenUtc", "LastSeenUtc"))</td>
                            <td>@DisplayOrDash(Text(row, "targetRootDomain", "TargetRootDomain"))</td>
                            <td>@DisplayOrDash(Text(row, "subdomain", "Subdomain"))</td>
                            <td><button type="button" class="link-button" @onclick='() => OpenTechnologyModal(Text(row, "technologyName", "TechnologyName"))' @onclick:stopPropagation="true">@DisplayOrDash(Text(row, "technologyName", "TechnologyName"))</button></td>
                            <td>@DisplayOrDash(Text(row, "version", "Version"))</td>
                            <td>@DisplayOrDash(Text(row, "sourceType", "SourceType"))</td>
                        </tr>
                    }
                    </Virtualize>
                </tbody>
            </table>
        </div>
    </section>

</div>

@if (_contextMenuVisible)
{
    <div class="ops-context-menu"
         style="@($"left:{_contextMenuX}px;top:{_contextMenuY}px")"
         @onclick:stopPropagation="true">
        @foreach (var item in _contextMenuItems)
        {
            <button type="button" class="ops-context-menu-item" @onclick="() => OnContextMenuItemAsync(item)">@item.Label</button>
        }
    </div>
}

@if (_workerDetailLoading || _workerDetailModal is not null || !string.IsNullOrWhiteSpace(_workerDetailError))
{
    <div class="modal-backdrop" role="presentation">
        <div class="modal-card" role="dialog" aria-modal="true">
            <div class="modal-header">
                <h2>@(_workerDetailLoading ? "Loading worker..." : DisplayOrDash(Text(_workerDetailModal ?? default, "displayName", "DisplayName", "serviceName", "ServiceName")))</h2>
                <button type="button" @onclick="CloseWorkerDetails">Close</button>
            </div>

            @if (_workerDetailLoading)
            {
                <p class="muted">Fetching worker details.</p>
            }
            else if (!string.IsNullOrWhiteSpace(_workerDetailError))
            {
                <div class="warning">@_workerDetailError</div>
            }
            else if (_workerDetailModal is JsonElement details)
            {
                var heartbeats = ArrayProperty(details, "heartbeats", "Heartbeats");
                var activeWork = ArrayProperty(details, "activeHttpRequests", "ActiveHttpRequests");
                var recentEvents = ArrayProperty(details, "recentEvents", "RecentEvents");
                var recentHttp = ArrayProperty(details, "recentHttpWork", "RecentHttpWork");
                var summaries = ArrayProperty(details, "summaries", "Summaries");

                <dl class="detail-grid">
                    <div><dt>Service</dt><dd>@DisplayOrDash(Text(details, "serviceName", "ServiceName"))</dd></div>
                    <div><dt>State</dt><dd>@DisplayOrDash(Text(details, "overallState", "OverallState"))</dd></div>
                    <div><dt>Running</dt><dd>@FormatNumber(Long(details, "runningCount", "RunningCount"))</dd></div>
                    <div><dt>Observed</dt><dd>@FormatTime(Text(details, "generatedAtUtc", "GeneratedAtUtc"))</dd></div>
                </dl>

                @if (summaries.Count > 0)
                {
                    <h3>What it has done so far</h3>
                    <ul>
                        @foreach (var item in summaries)
                        {
                            <li>@DisplayOrDash(Text(item, "label", "Label")): @DisplayOrDash(Text(item, "value", "Value"))</li>
                        }
                    </ul>
                }

                <h3>Processes</h3>
                <div class="table-wrap compact">
                    <table class="ops-table">
                        <thead><tr><th>Worker key</th><th>Host</th><th>Process</th><th>Consumers</th><th>Health</th><th>Last heartbeat</th></tr></thead>
                        <tbody>
                            @foreach (var hb in heartbeats)
                            {
                                <tr>
                                    <td>@DisplayOrDash(Text(hb, "workerKey", "WorkerKey"))</td>
                                    <td>@DisplayOrDash(Text(hb, "hostName", "HostName"))</td>
                                    <td>@DisplayOrDash(Text(hb, "processId", "ProcessId"))</td>
                                    <td>@DisplayOrDash(Text(hb, "activeConsumerCount", "ActiveConsumerCount"))</td>
                                    <td>@DisplayOrDash(Text(hb, "health", "Health", "healthMessage", "HealthMessage"))</td>
                                    <td>@FormatTime(Text(hb, "lastHeartbeatUtc", "LastHeartbeatUtc"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <h3>Current target / active HTTP work</h3>
                <div class="table-wrap compact">
                    <table class="ops-table">
                        <thead><tr><th>Target</th><th>State</th><th>Method</th><th>URL</th><th>Locked by</th><th>Started</th><th>Error</th></tr></thead>
                        <tbody>
                            @foreach (var item in activeWork)
                            {
                                <tr>
                                    <td>@DisplayOrDash(Text(item, "targetRootDomain", "TargetRootDomain", "targetId", "TargetId"))</td>
                                    <td>@DisplayOrDash(Text(item, "state", "State"))</td>
                                    <td>@DisplayOrDash(Text(item, "method", "Method"))</td>
                                    <td>@DisplayOrDash(Text(item, "requestUrl", "RequestUrl"))</td>
                                    <td>@DisplayOrDash(Text(item, "lockedBy", "LockedBy"))</td>
                                    <td>@FormatTime(Text(item, "startedAtUtc", "StartedAtUtc"))</td>
                                    <td>@DisplayOrDash(Text(item, "lastError", "LastError"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <h3>Recent events</h3>
                <div class="table-wrap compact">
                    <table class="ops-table">
                        <thead><tr><th>Occurred</th><th>Direction</th><th>Message</th><th>Status</th><th>Error</th></tr></thead>
                        <tbody>
                            @foreach (var evt in recentEvents)
                            {
                                <tr>
                                    <td>@FormatTime(Text(evt, "occurredAtUtc", "OccurredAtUtc"))</td>
                                    <td>@DisplayOrDash(Text(evt, "direction", "Direction"))</td>
                                    <td>@DisplayOrDash(Text(evt, "messageType", "MessageType"))</td>
                                    <td>@DisplayOrDash(Text(evt, "status", "Status"))</td>
                                    <td>@DisplayOrDash(Text(evt, "error", "Error"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <h3>Recent HTTP work</h3>
                <div class="table-wrap compact">
                    <table class="ops-table">
                        <thead><tr><th>Updated</th><th>Target</th><th>State</th><th>URL</th><th>Status</th><th>Error</th></tr></thead>
                        <tbody>
                            @foreach (var row in recentHttp)
                            {
                                <tr>
                                    <td>@FormatTime(Text(row, "updatedAtUtc", "UpdatedAtUtc"))</td>
                                    <td>@DisplayOrDash(Text(row, "targetRootDomain", "TargetRootDomain", "targetId", "TargetId"))</td>
                                    <td>@DisplayOrDash(Text(row, "state", "State"))</td>
                                    <td>@DisplayOrDash(Text(row, "requestUrl", "RequestUrl"))</td>
                                    <td>@DisplayOrDash(Text(row, "lastHttpStatus", "LastHttpStatus"))</td>
                                    <td>@DisplayOrDash(Text(row, "lastError", "LastError"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@if (_selectedTechnologyName is not null)
{
    <div class="modal-backdrop" role="presentation">
        <div class="modal-card" role="dialog" aria-modal="true">
            <div class="modal-header">
                <h2>@_selectedTechnologyName version breakdown</h2>
                <button type="button" @onclick="CloseTechnologyModal">Close</button>
            </div>

            <div class="table-wrap compact">
                <table class="ops-table">
                    <thead><tr><th>Version</th><th>Targets</th><th>Subdomains</th></tr></thead>
                    <tbody>
                        @foreach (var row in SelectedTechnologyVersionRows)
                        {
                            <tr>
                                <td>@DisplayOrDash(row.Version)</td>
                                <td>@FormatNumber(row.TargetCount)</td>
                                <td>@FormatNumber(row.SubdomainCount)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private readonly CancellationTokenSource _cts = new();

    private JsonElement? _overview;
    private readonly List<JsonElement> _targets = [];
    private readonly List<JsonElement> _assets = [];
    private readonly List<JsonElement> _queue = [];
    private readonly List<JsonElement> _workers = [];
    private readonly List<JsonElement> _highValueRows = [];
    private readonly List<JsonElement> _technologyRows = [];
    private readonly List<JsonElement> _technologyUsage = [];
    private readonly List<WorkerStatus> _cloudWorkers = [];
    private readonly Dictionary<WorkerType, int> _cloudDesiredMin = [];
    private readonly Dictionary<WorkerType, int> _cloudDesiredMax = [];
    private readonly HashSet<WorkerType> _cloudScaleBusy = [];

    private JsonElement? _workerDetailModal;
    private bool _workerDetailLoading;
    private string _workerDetailError = "";

    private readonly HashSet<string> _selectedTargetIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedSubdomainKeys = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedAssetIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedWorkerServices = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedHttpIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedHighValueKeys = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedTechnologyKeys = new(StringComparer.OrdinalIgnoreCase);

    private string _statusMessage = "";
    private string _dockerWorkersError = "";
    private string _cloudWorkersError = "";
    private string _activeTargetId = "";
    private string _newTargetRootDomain = "";
    private int _newTargetDepth = 12;

    private string _targetSearch = "";
    private string _targetSort = "name";
    private bool _targetSortDescending;
    private string _subdomainSearch = "";
    private string _subdomainSort = "name";
    private bool _subdomainSortDescending;
    private string _assetSearch = "";
    private string _assetFilter = "";
    private string _assetSort = "discovered";
    private bool _assetSortDescending = true;
    private string _httpSearch = "";
    private string _httpStateFilter = "";
    private string _httpSort = "created";
    private bool _httpSortDescending = true;
    private string _highValueSearch = "";
    private string _highValueStatusFilter = "Active";
    private string _technologySearch = "";
    private string? _selectedTechnologyName;

    private bool _targetsLoading;
    private bool _assetsLoading;
    private bool _httpLoading;
    private bool _workersLoading;
    private bool _cloudWorkersLoading;
    private bool _highValueLoading;
    private bool _technologiesLoading;
    private bool _enumLoading;
    private bool _spiderLoading;
    private bool _loadingAny => _targetsLoading || _assetsLoading || _httpLoading || _workersLoading || _cloudWorkersLoading || _highValueLoading || _technologiesLoading || _enumLoading || _spiderLoading;
    private bool _contextMenuVisible;
    private double _contextMenuX;
    private double _contextMenuY;
    private IReadOnlyList<ContextMenuItem> _contextMenuItems = [];

    private long TotalTargets => Math.Max(OverviewLong("totalTargets", "TotalTargets"), _targets.Count);
    private long ConfirmedAssets => Math.Max(OverviewLong("totalAssetsConfirmed", "TotalAssetsConfirmed"), _targets.Sum(t => Long(t, "confirmedAssetCount", "ConfirmedAssetCount")));
    private long ConfirmedSubdomains => Math.Max(OverviewLong("subdomainsDiscovered", "SubdomainsDiscovered"), _targets.Sum(t => Long(t, "subdomainCount", "SubdomainCount")));
    private long TotalTrackedStorageBytes => OverviewLong("totalTrackedStorageBytes", "TotalTrackedStorageBytes");
    private long AssetMetadataStorageBytes => OverviewLong("assetMetadataStorageBytes", "AssetMetadataStorageBytes");
    private long HttpArtifactStorageBytes => OverviewLong("httpArtifactStorageBytes", "HttpArtifactStorageBytes");
    private long InlineHttpStorageBytes => OverviewLong("inlineHttpStorageBytes", "InlineHttpStorageBytes");
    private long EventJournalStorageBytes => OverviewLong("eventJournalStorageBytes", "EventJournalStorageBytes");
    private long HttpQueueQueuedCount => OverviewLong("httpQueueQueuedAssetCount", "HttpQueueQueuedAssetCount");
    private long HttpRequestsSentPerMinute => OverviewLong("httpRequestsSentLastMinuteCount", "HttpRequestsSentLastMinuteCount");
    private string StorageBreakdownLabel => $"Assets {FormatStorageSize(AssetMetadataStorageBytes)} / HTTP {FormatStorageSize(HttpArtifactStorageBytes + InlineHttpStorageBytes)} / Events {FormatStorageSize(EventJournalStorageBytes)}";
    private bool CanCreateTarget => !string.IsNullOrWhiteSpace(_newTargetRootDomain) && _newTargetDepth > 0;

    private JsonElement[] TargetRows => MaterializeSorted(_targets.Where(TargetMatchesFilter), TargetSortKey, _targetSortDescending);
    private JsonElement[] SubdomainRows => MaterializeSorted(
        _assets
            .Where(MatchesSelectedTargetsScope)
            .Where(a => Text(a, "kind", "Kind").Equals("Subdomain", StringComparison.OrdinalIgnoreCase))
            .Where(SubdomainMatchesFilter)
            .GroupBy(SubdomainKey, StringComparer.OrdinalIgnoreCase)
            .Select(g => g.OrderByDescending(a => Text(a, "discoveredAtUtc", "DiscoveredAtUtc"), StringComparer.Ordinal).First()),
        SubdomainSortKey,
        _subdomainSortDescending);
    private JsonElement[] AssetRows => MaterializeSorted(_assets.Where(MatchesSelectedSubdomainsScope).Where(AssetMatchesFilter), AssetSortKey, _assetSortDescending);
    private List<JsonElement> WorkerRows => _workers;
    private WorkerStatus[] CloudWorkerRows => _cloudWorkers
        .OrderBy(x => CloudWorkerLabel(x.Worker), StringComparer.OrdinalIgnoreCase)
        .ToArray();
    private JsonElement[] HttpRows => MaterializeSorted(_queue.Where(HttpMatchesFilter), HttpSortKey, _httpSortDescending);
    private IReadOnlyList<JsonElement> HighValueRows => _highValueRows;
    private JsonElement[] FilteredHighValueRows => _highValueRows.Where(HighValueMatchesFilter).ToArray();
    private JsonElement[] FilteredTechnologyRows => _technologyRows.Where(TechnologyMatchesFilter).ToArray();

    private IReadOnlyList<TopTechnologyRow> TopTechnologyRows => _technologyUsage
        .GroupBy(u => Text(u, "technologyName", "TechnologyName"), StringComparer.OrdinalIgnoreCase)
        .Where(g => !string.IsNullOrWhiteSpace(g.Key))
        .Select(g =>
        {
            var locations = g.SelectMany(u => ArrayProperty(u, "locations", "Locations")).ToArray();
            return new TopTechnologyRow(
                g.Key,
                locations.Select(l => Text(l, "targetId", "TargetId")).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount(),
                locations.Select(l => Text(l, "subdomain", "Subdomain")).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount());
        })
        .OrderByDescending(x => x.SubdomainCount)
        .ThenByDescending(x => x.TargetCount)
        .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private IReadOnlyList<TechnologyVersionRow> SelectedTechnologyVersionRows => _selectedTechnologyName is null
        ? []
        : _technologyUsage
            .Where(u => Text(u, "technologyName", "TechnologyName").Equals(_selectedTechnologyName, StringComparison.OrdinalIgnoreCase))
            .GroupBy(u => DisplayOrDash(Text(u, "version", "Version")), StringComparer.OrdinalIgnoreCase)
            .Select(g =>
            {
                var locations = g.SelectMany(u => ArrayProperty(u, "locations", "Locations")).ToArray();
                return new TechnologyVersionRow(
                    g.Key == "-" ? "Unknown / unversioned" : g.Key,
                    locations.Select(l => Text(l, "targetId", "TargetId")).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount(),
                    locations.Select(l => Text(l, "subdomain", "Subdomain")).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount());
            })
            .OrderByDescending(x => x.SubdomainCount)
            .ThenBy(x => x.Version, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private string ActiveTargetLabel
    {
        get
        {
            var target = _targets.FirstOrDefault(t => Text(t, "id", "Id").Equals(_activeTargetId, StringComparison.OrdinalIgnoreCase));
            var label = target.ValueKind == JsonValueKind.Object ? Text(target, "rootDomain", "RootDomain") : "";
            return string.IsNullOrWhiteSpace(label) ? "Select a target" : label;
        }
    }

    private bool AllVisibleTargetsSelected => TargetRows.Length > 0 && TargetRows.All(t => _selectedTargetIds.Contains(Text(t, "id", "Id")));
    private bool AllVisibleSubdomainsSelected => SubdomainRows.Length > 0 && SubdomainRows.All(s => _selectedSubdomainKeys.Contains(SubdomainKey(s)));
    private bool AllVisibleAssetsSelected => AssetRows.Length > 0 && AssetRows.All(a => _selectedAssetIds.Contains(Text(a, "id", "Id")));
    private bool AllVisibleWorkersSelected => WorkerRows.Count > 0 && WorkerRows.All(w => _selectedWorkerServices.Contains(Text(w, "serviceName", "ServiceName")));
    private bool AllVisibleHttpSelected => HttpRows.Length > 0 && HttpRows.All(q => _selectedHttpIds.Contains(Text(q, "id", "Id")));
    private bool AllVisibleHighValueSelected => FilteredHighValueRows.Length > 0 && FilteredHighValueRows.All(x => _selectedHighValueKeys.Contains(HighValueKey(x)));
    private bool AllVisibleTechnologySelected => FilteredTechnologyRows.Length > 0 && FilteredTechnologyRows.All(x => _selectedTechnologyKeys.Contains(TechnologyKey(x)));

    protected override async Task OnInitializedAsync()
    {
        Realtime.DomainEventReceived += OnRealtimeEvent;
        await ReloadAllAsync().ConfigureAwait(false);
        await StartRealtimeAsync().ConfigureAwait(false);
        _ = PollAsync();
    }

    private async Task PollAsync()
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(8));
            while (await timer.WaitForNextTickAsync(_cts.Token).ConfigureAwait(false))
            {
                if (!Realtime.IsConnected)
                {
                    await ReloadLiveAsync().ConfigureAwait(false);
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task StartRealtimeAsync()
    {
        try
        {
            await Realtime.EnsureStartedAsync(_cts.Token).ConfigureAwait(false);
        }
        catch (OperationCanceledException) when (_cts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "CommandCenter realtime connection failed; polling remains active.");
        }
    }

    private void OnRealtimeEvent(object? sender, LiveUiEventDto evt)
    {
        _ = InvokeAsync(async () =>
        {
            if (_cts.IsCancellationRequested)
            {
                return;
            }

            try
            {
                switch (evt.Scope)
                {
                    case "targets":
                        await Task.WhenAll(ReloadTargetsAsync(), ReloadAssetsAsync(), ReloadOverviewAsync()).ConfigureAwait(false);
                        break;
                    case "assets":
                    case "http":
                        await Task.WhenAll(ReloadAssetsAsync(), ReloadHttpQueueAsync(), ReloadOverviewAsync()).ConfigureAwait(false);
                        break;
                    case "workers":
                        await Task.WhenAll(ReloadDockerWorkersAsync(), ReloadCloudWorkersAsync(), ReloadOverviewAsync()).ConfigureAwait(false);
                        break;
                    default:
                        await ReloadLiveAsync().ConfigureAwait(false);
                        break;
                }

                StateHasChanged();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "CommandCenter realtime refresh failed.");
            }
        });
    }

    private async Task ReloadLiveAsync()
    {
        try
        {
            await Task.WhenAll(ReloadOverviewAsync(), ReloadHttpQueueAsync(), ReloadDockerWorkersAsync(), ReloadCloudWorkersAsync()).ConfigureAwait(false);
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
        catch
        {
        }
    }

    private async Task ReloadAllAsync()
    {
        _statusMessage = "";
        try
        {
            await Task.WhenAll(
                ReloadOverviewAsync(),
                ReloadTargetsAsync(),
                ReloadAssetsAsync(),
                ReloadHttpQueueAsync(),
                ReloadDockerWorkersAsync(),
                ReloadCloudWorkersAsync(),
                ReloadHighValueAssetsAsync(),
                ReloadTechnologyDataAsync()).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Operations refresh failed: {ex.Message}";
        }

        EnsureActiveTarget();
        await InvokeAsync(StateHasChanged).ConfigureAwait(false);
    }

    private async Task ReloadOverviewAsync()
    {
        _overview = await GetObjectAsync("/api/ops/overview").ConfigureAwait(false);
    }

    private async Task ReloadTargetsAsync()
    {
        _targetsLoading = true;
        try
        {
            Replace(_targets, await GetArrayAsync("/api/targets").ConfigureAwait(false));
            _selectedTargetIds.RemoveWhere(id => !_targets.Any(t => Text(t, "id", "Id").Equals(id, StringComparison.OrdinalIgnoreCase)));
            EnsureActiveTarget();
        }
        finally
        {
            _targetsLoading = false;
        }
    }

    private async Task ReloadAssetsAsync()
    {
        _assetsLoading = true;
        try
        {
            Replace(_assets, await GetArrayAsync("/api/assets").ConfigureAwait(false));
            _selectedAssetIds.RemoveWhere(id => !_assets.Any(a => Text(a, "id", "Id").Equals(id, StringComparison.OrdinalIgnoreCase)));
            _selectedSubdomainKeys.RemoveWhere(key => !_assets.Any(a => SubdomainKey(a).Equals(key, StringComparison.OrdinalIgnoreCase)));
        }
        finally
        {
            _assetsLoading = false;
        }
    }

    private async Task ReloadHttpQueueAsync()
    {
        _httpLoading = true;
        try
        {
            var uri = string.IsNullOrWhiteSpace(_httpStateFilter)
                ? "/api/http-request-queue"
                : $"/api/http-request-queue?state={Uri.EscapeDataString(_httpStateFilter)}";
            Replace(_queue, await GetArrayAsync(uri).ConfigureAwait(false));
            _selectedHttpIds.RemoveWhere(id => !_queue.Any(q => Text(q, "id", "Id").Equals(id, StringComparison.OrdinalIgnoreCase)));
        }
        finally
        {
            _httpLoading = false;
        }
    }

    private async Task OnHttpStateFilterChanged(ChangeEventArgs args)
    {
        _httpStateFilter = Convert.ToString(args.Value, CultureInfo.InvariantCulture) ?? "";
        await ReloadHttpQueueAsync().ConfigureAwait(false);
    }

    private async Task ReloadDockerWorkersAsync()
    {
        _workersLoading = true;
        try
        {
            var root = await GetObjectAsync("/api/workers/docker-status").ConfigureAwait(false);
            if (root is JsonElement obj)
            {
                _dockerWorkersError = obj.TryGetProperty("error", out var error) ? error.GetString() ?? "" : "";
                Replace(_workers, ArrayProperty(obj, "services", "Services"));
            }

            _selectedWorkerServices.RemoveWhere(id => !_workers.Any(w => Text(w, "serviceName", "ServiceName").Equals(id, StringComparison.OrdinalIgnoreCase)));
        }
        catch (Exception ex)
        {
            _dockerWorkersError = ex.Message;
        }
        finally
        {
            _workersLoading = false;
        }
    }

    private async Task ReloadCloudWorkersAsync()
    {
        _cloudWorkersLoading = true;
        try
        {
            var statuses = await DeployService.GetWorkerStatusesAsync(null, _cts.Token).ConfigureAwait(false);
            _cloudWorkersError = "";

            _cloudWorkers.Clear();
            _cloudWorkers.AddRange(statuses);

            foreach (var status in statuses)
            {
                var normalizedMin = Math.Clamp(status.MinInstances, 0, 100);
                var normalizedMax = NormalizeCloudMax(normalizedMin, status.MaxInstances);
                if (!_cloudScaleBusy.Contains(status.Worker))
                {
                    _cloudDesiredMin[status.Worker] = normalizedMin;
                    _cloudDesiredMax[status.Worker] = normalizedMax;
                    continue;
                }

                _cloudDesiredMin.TryAdd(status.Worker, normalizedMin);
                _cloudDesiredMax.TryAdd(status.Worker, normalizedMax);
            }
        }
        catch (Exception ex)
        {
            _cloudWorkersError = ex.Message;
        }
        finally
        {
            _cloudWorkersLoading = false;
        }
    }

    private async Task ReloadHighValueAssetsAsync()
    {
        _highValueLoading = true;
        try
        {
            Replace(_highValueRows, await GetArrayAsync("/api/high-value-assets?includeResolved=true").ConfigureAwait(false));
            _selectedHighValueKeys.RemoveWhere(key => !_highValueRows.Any(row => HighValueKey(row).Equals(key, StringComparison.OrdinalIgnoreCase)));
        }
        catch (Exception ex)
        {
            _statusMessage = $"High value assets could not be loaded: {ex.Message}";
        }
        finally
        {
            _highValueLoading = false;
        }
    }

    private async Task ReloadTechnologyDataAsync()
    {
        _technologiesLoading = true;
        try
        {
            var technologiesTask = GetArrayAsync("/api/technology-identification/technologies");
            var usageTask = GetArrayAsync("/api/technology-identification/usage");
            Replace(_technologyRows, await technologiesTask.ConfigureAwait(false));
            Replace(_technologyUsage, await usageTask.ConfigureAwait(false));
            _selectedTechnologyKeys.RemoveWhere(key => !_technologyRows.Any(row => TechnologyKey(row).Equals(key, StringComparison.OrdinalIgnoreCase)));
        }
        catch (Exception ex)
        {
            _statusMessage = $"Technology data could not be loaded: {ex.Message}";
        }
        finally
        {
            _technologiesLoading = false;
        }
    }

    private async Task CreateTargetAsync()
    {
        if (!CanCreateTarget)
        {
            return;
        }

        try
        {
            using var response = await WorkerApi.Client.PostAsJsonAsync(
                "/api/targets",
                new { rootDomain = _newTargetRootDomain.Trim(), globalMaxDepth = _newTargetDepth },
                _cts.Token).ConfigureAwait(false);
            response.EnsureSuccessStatusCode();
            _newTargetRootDomain = "";
            await ReloadTargetsAsync().ConfigureAwait(false);
            await ReloadOverviewAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Target could not be added: {ex.Message}";
        }
    }

    private async Task StartEnumerationAsync(bool selectedOnly)
    {
        _enumLoading = true;
        _statusMessage = "";
        try
        {
            var ids = selectedOnly
                ? _selectedTargetIds.ToArray()
                : TargetRows.Select(t => Text(t, "id", "Id")).Where(id => !string.IsNullOrWhiteSpace(id)).Distinct(StringComparer.OrdinalIgnoreCase).ToArray();

            if (selectedOnly && ids.Length == 0)
            {
                _statusMessage = "Select one or more target rows before starting subdomain enumeration.";
                return;
            }

            using var response = await WorkerApi.Client.PostAsJsonAsync(
                "/api/ops/subdomain-enum/restart",
                new RestartToolRequest(ids, AllTargets: false),
                _cts.Token).ConfigureAwait(false);
            response.EnsureSuccessStatusCode();

            using var doc = JsonDocument.Parse(await response.Content.ReadAsStringAsync(_cts.Token).ConfigureAwait(false));
            var targets = Long(doc.RootElement, "targets", "Targets");
            var jobs = Long(doc.RootElement, "jobsQueued", "JobsQueued");
            var workerScale = Text(doc.RootElement, "workerScale", "WorkerScale");

            _statusMessage = $"Subdomain enumeration started for {targets} target(s), {jobs} job(s) queued. {workerScale}";
            await ReloadLiveAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Enumeration could not be started: {ex.Message}";
        }
        finally
        {
            _enumLoading = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private async Task StartEnumerationForTargetAsync(string targetId)
    {
        if (string.IsNullOrWhiteSpace(targetId))
        {
            return;
        }

        _enumLoading = true;
        _statusMessage = "";
        try
        {
            using var response = await WorkerApi.Client.PostAsJsonAsync(
                "/api/ops/subdomain-enum/restart",
                new RestartToolRequest([targetId], AllTargets: false),
                _cts.Token).ConfigureAwait(false);
            response.EnsureSuccessStatusCode();

            using var doc = JsonDocument.Parse(await response.Content.ReadAsStringAsync(_cts.Token).ConfigureAwait(false));
            var targets = Long(doc.RootElement, "targets", "Targets");
            var jobs = Long(doc.RootElement, "jobsQueued", "JobsQueued");
