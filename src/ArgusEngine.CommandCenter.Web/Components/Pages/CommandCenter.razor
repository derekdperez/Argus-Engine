    private static int NormalizeCloudMax(int min, int max)
    {
        // Cloud Run requires max instances >= 1 even when min is 0.
        var minAllowed = Math.Max(min, 1);
        return Math.Clamp(Math.Max(max, minAllowed), 1, 100);
    }

