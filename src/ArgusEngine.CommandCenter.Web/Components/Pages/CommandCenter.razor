    private static readonly GridSort<JsonElement> SortTargetCreated = GridSort<JsonElement>.ByDescending(row => SortableTime(row, "createdAtUtc", "CreatedAtUtc", "createdAt", "CreatedAt"));
    private static readonly GridSort<JsonElement> SortTargetSubdomainCount = GridSort<JsonElement>.ByDescending(row => Long(row, "subdomainCount", "SubdomainCount"));
    private static readonly GridSort<JsonElement> SortTargetAssetCount = GridSort<JsonElement>.ByDescending(row => Long(row, "confirmedAssetCount", "ConfirmedAssetCount", "assetCount", "AssetCount"));
    private static readonly GridSort<JsonElement> SortSubdomainTarget = GridSort<JsonElement>.ByAscending(row => Text(row, "rootDomain", "RootDomain", "target", "Target"));
    private static readonly GridSort<JsonElement> SortSubdomainName = GridSort<JsonElement>.ByAscending(row => Text(row, "subdomain", "Subdomain", "canonicalKey", "CanonicalKey", "rawValue", "RawValue"));
    private static readonly GridSort<JsonElement> SortSubdomainTechnologyCount = GridSort<JsonElement>.ByAscending(row => Long(row, "technologyCount", "TechnologyCount"));
    private static readonly GridSort<JsonElement> SortSubdomainLastSeen = GridSort<JsonElement>.ByDescending(row => SortableTime(row, "lastSeenUtc", "LastSeenUtc", "lastSeenAtUtc", "LastSeenAtUtc"));
    private static readonly GridSort<JsonElement> SortAssetKind = GridSort<JsonElement>.ByAscending(row => Text(row, "kind", "Kind"));
    private static readonly GridSort<JsonElement> SortAssetText = GridSort<JsonElement>.ByAscending(row => Text(row, "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue", "finalUrl", "FinalUrl"));
    private static readonly GridSort<JsonElement> SortAssetCategory = GridSort<JsonElement>.ByAscending(row => Text(row, "category", "Category"));
    private static readonly GridSort<JsonElement> SortAssetSeen = GridSort<JsonElement>.ByDescending(row => SortableTime(row, "lastSeenAtUtc", "LastSeenAtUtc", "discoveredAtUtc", "DiscoveredAtUtc"));
    private static readonly GridSort<JsonElement> SortHighValueSeverity = GridSort<JsonElement>.ByAscending(row => Text(row, "severity", "Severity"));
    private static readonly GridSort<JsonElement> SortHighValueAsset = GridSort<JsonElement>.ByAscending(row => Text(row, "displayName", "DisplayName", "canonicalKey", "CanonicalKey", "rawValue", "RawValue"));
    private static readonly GridSort<JsonElement> SortHighValueFinding = GridSort<JsonElement>.ByAscending(row => Text(row, "findingType", "FindingType", "patternName", "PatternName"));
    private static readonly GridSort<JsonElement> SortHighValueScore = GridSort<JsonElement>.ByDescending(row => Long(row, "importanceScore", "ImportanceScore", "confidence", "Confidence"));
    private static readonly GridSort<JsonElement> SortHighValueSeen = GridSort<JsonElement>.ByDescending(row => SortableTime(row, "findingDiscoveredAtUtc", "FindingDiscoveredAtUtc", "discoveredAtUtc", "DiscoveredAtUtc"));
    private static readonly GridSort<JsonElement> SortTechnologyName = GridSort<JsonElement>.ByAscending(row => Text(row, "technologyName", "TechnologyName", "name", "Name", "technology", "Technology"));
    private static readonly GridSort<JsonElement> SortTechnologyVersion = GridSort<JsonElement>.ByAscending(row => Text(row, "version", "Version"));
    private static readonly GridSort<JsonElement> SortTechnologyEvidence = GridSort<JsonElement>.ByAscending(row => Text(row, "evidence", "Evidence", "source", "Source", "category", "Category"));
    private static readonly GridSort<JsonElement> SortTechnologySeen = GridSort<JsonElement>.ByDescending(row => SortableTime(row, "lastSeenUtc", "LastSeenUtc", "observedAtUtc", "ObservedAtUtc"));
    private static readonly GridSort<JsonElement> SortLogTime = GridSort<JsonElement>.ByDescending(row => SortableTime(row, "timestamp", "Timestamp"));
    private static readonly GridSort<JsonElement> SortLogLevel = GridSort<JsonElement>.ByAscending(row => Text(row, "logLevel", "LogLevel"));
    private static readonly GridSort<JsonElement> SortLogComponent = GridSort<JsonElement>.ByAscending(row => Text(row, "component", "Component"));

    private string[] AssetKinds => _assets
        .Select(row => Text(row, "kind", "Kind"))
        .Where(static value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(static value => value, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private long TotalTargets => OverviewLong("totalTargets", "TotalTargets", "targetCount", "TargetCount");
    private long ConfirmedAssets => OverviewLong("totalAssetsConfirmed", "TotalAssetsConfirmed", "confirmedAssets", "ConfirmedAssets", "assetCount", "AssetCount", "totalAssets", "TotalAssets");
    private long HttpQueueCount => OverviewLong("httpQueueQueuedAssetCount", "HttpQueueQueuedAssetCount", "httpQueueCount", "HttpQueueCount", "queuedHttpRequests", "QueuedHttpRequests");
    private long HighValueCount => OverviewLong("highValueAssetCount", "HighValueAssetCount", "highValueCount", "HighValueCount", "highValueFindings", "HighValueFindings");
    private long TechnologyCount => OverviewLong("uniqueTechnologyCount", "UniqueTechnologyCount", "technologyCount", "TechnologyCount", "technologies", "Technologies");
    private long WorkerCount => OverviewLong("workerCount", "WorkerCount", "activeWorkers", "ActiveWorkers");

    protected override async Task OnInitializedAsync()
    {
        await LoadInitialWorkspaceAsync().ConfigureAwait(false);

        _summaryTimer = new PeriodicTimer(TimeSpan.FromSeconds(15));
        _summaryPollingTask = PollSummaryAsync();
    }

    private async Task LoadInitialWorkspaceAsync()
    {
        _statusMessage = "Loading recent workspace data...";
        try
        {
            await Task.WhenAll(
                ReloadOverviewAsync(),
                ReloadTargetsAsync(),
                ReloadSubdomainsAsync(),
                ReloadAssetsAsync(),
                ReloadWorkersAsync()).ConfigureAwait(false);
        }
        finally
        {
            _statusMessage = null;
        }
    }

    private async Task PollSummaryAsync()
    {
        if (_summaryTimer is null)
        {
            return;
        }

        try
        {
            while (await _summaryTimer.WaitForNextTickAsync(_disposeCts.Token).ConfigureAwait(false))
            {
                await ReloadOverviewAsync(showLoading: false).ConfigureAwait(false);

                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
            // Expected during component disposal.
        }
    }

    private async Task SelectTabAsync(CommandTab tab)
    {
        _activeTab = tab;

        switch (tab)
        {
            case CommandTab.Targets when _targets.Count == 0:
                await ReloadTargetsAsync().ConfigureAwait(false);
                break;
            case CommandTab.Discovery when _highValue.Count == 0 || _technology.Count == 0:
                await ReloadHighValueAsync().ConfigureAwait(false);
                await ReloadTechnologyAsync().ConfigureAwait(false);
                break;
            case CommandTab.Workers when _allWorkerRows.Count == 0:
                await ReloadWorkersAsync().ConfigureAwait(false);
                break;
            case CommandTab.Logs when _logs.Count == 0:
                await ReloadLogsAsync().ConfigureAwait(false);
                await ReloadWorkerLogsAsync().ConfigureAwait(false);
                break;
        }
    }

    private async Task RefreshActiveAsync()
    {
        switch (_activeTab)
        {
            case CommandTab.Targets:
                await Task.WhenAll(ReloadTargetsAsync(), ReloadSubdomainsAsync(), ReloadAssetsAsync()).ConfigureAwait(false);
                break;
            case CommandTab.Discovery:
                await Task.WhenAll(ReloadHighValueAsync(), ReloadTechnologyAsync()).ConfigureAwait(false);
                break;
            case CommandTab.Workers:
                await ReloadWorkersAsync().ConfigureAwait(false);
                break;
            case CommandTab.Logs:
                await ReloadLogsAsync().ConfigureAwait(false);
                await ReloadWorkerLogsAsync().ConfigureAwait(false);
                break;
        }

        await Task.WhenAll(
            ReloadOverviewAsync(showLoading: false),
            LoadSystemEventsAsync()).ConfigureAwait(false);
    }

    private async Task RefreshEverythingAsync()
    {
        await Task.WhenAll(
            ReloadOverviewAsync(),
            ReloadTargetsAsync(),
            ReloadSubdomainsAsync(),
            ReloadAssetsAsync(),
            ReloadWorkersAsync(),
            LoadSystemEventsAsync()).ConfigureAwait(false);
    }

    private async Task ReloadOverviewAsync(bool showLoading = true)
    {
        if (showLoading)
        {
            _overviewLoading = true;
        }

        try
        {
            _overview = await GetObjectAsync("/api/ops/overview").ConfigureAwait(false);
            if (_overview.HasValue)
            {
                _httpQueueCount = Long(_overview.Value, "httpQueueQueuedAssetCount", "httpQueueCount");
                _publishedEvents = Long(_overview.Value, "publishedEventCount", "PublishedEventCount");
                _appVersion = Text(_overview.Value, "componentVersion", "ComponentVersion") ?? "?";
                _buildTime = Text(_overview.Value, "buildTime", "BuildTime") ?? "?";
                if (_buildTime.Length > 19) _buildTime = _buildTime[..19].Replace("T", " ");
            }
        }
        finally
        {
            if (showLoading)
            {
                _overviewLoading = false;
            }
        }
    }

    private async Task ReloadTargetsAsync()
    {
        _targetsLoading = true;
        try
        {
            var raw = await GetArrayAsync("/api/targets").ConfigureAwait(false);
            var deduped = raw
                .GroupBy(t => RowKey(t), StringComparer.OrdinalIgnoreCase)
                .Select(g => g.First())
                .ToList();
            Replace(_targets, deduped);
            _targetsRefreshedUtc = DateTimeOffset.UtcNow;
            PruneSelection(_selectedTargetIds, _targets);
            await LoadTargetEnrichmentAsync();
        }
        finally
        {
            _targetsLoading = false;
        }
    }

    private async Task LoadTargetEnrichmentAsync()
    {
        try
        {
            var enrichment = await Http.GetFromJsonAsync<List<JsonElement>>("/api/ops/target-enrichment");
            if (enrichment is null) return;
            _targetEnrichment = enrichment
                .Select(e =>
                {
                    var id = Text(e, "targetId", "TargetId") ?? "";
                    var status = Text(e, "orchestratorStatus", "OrchestratorStatus") ?? "none";
                    var enumerated = Text(e, "hasSubdomainsEnumerated", "HasSubdomainsEnumerated") == "True";
                    var spidered = Text(e, "hasBeenSpidered", "HasBeenSpidered") == "True";
                    return new { id, status, enumerated, spidered };
                })
                .Where(x => !string.IsNullOrWhiteSpace(x.id))
                .ToDictionary(x => x.id, x => new TargetEnrichment(x.status, x.enumerated, x.spidered));
        }
        catch
        {
            _targetEnrichment = new();
        }
    }

    private async Task EnumerateTargetAsync(string targetId)
    {
        if (string.IsNullOrWhiteSpace(targetId)) return;
        try
        {
            await Http.PostAsJsonAsync("/api/ops/subdomain-enum/restart",
                new { targetIds = new[] { targetId }, allTargets = false });
        }
        catch { }
    }

    private async Task SpiderTargetAsync(string targetId)
    {
        if (string.IsNullOrWhiteSpace(targetId)) return;
        try
        {
            await Http.PostAsJsonAsync("/api/ops/spider/restart",
                new { targetIds = new[] { targetId }, allTargets = false });
        }
        catch { }
    }

    private async Task ReloadSubdomainsAsync()
    {
        _subdomainsLoading = true;
        try
        {
            Replace(_subdomains, await GetArrayAsync("/api/technology-identification/subdomains").ConfigureAwait(false));
            if (_subdomains.Count > 1)
            {
                var deduped = _subdomains.GroupBy(s => RowKey(s), StringComparer.OrdinalIgnoreCase).Select(g => g.First()).ToList();
                Replace(_subdomains, deduped);
            }
            _subdomainsRefreshedUtc = DateTimeOffset.UtcNow;
        }
        finally
        {
            _subdomainsLoading = false;
        }
    }

    private async Task ReloadAssetsAsync()
    {
        _assetsLoading = true;
        try
        {
            Replace(_assets, await GetArrayAsync($"/api/assets?take={AssetTake}").ConfigureAwait(false));
            if (_assets.Count > 1)
            {
                var deduped = _assets.GroupBy(a => RowKey(a), StringComparer.OrdinalIgnoreCase).Select(g => g.First()).ToList();
                Replace(_assets, deduped);
            }
            _assetsRefreshedUtc = DateTimeOffset.UtcNow;
        }
        finally
        {
            _assetsLoading = false;
        }
    }

    private async Task ReloadHttpQueueAsync(bool showLoading = true)
    {
        if (showLoading)
        {
            _httpLoading = true;
        }

        try
        {
            var stateQuery = string.IsNullOrWhiteSpace(_httpStateFilter)
                ? ""
                : $"&state={WebUtility.UrlEncode(_httpStateFilter)}";

            Replace(_httpQueue, await GetArrayAsync($"/api/http-request-queue?take={HttpQueueTake}{stateQuery}").ConfigureAwait(false));
            PruneSelection(_selectedHttpIds, _httpQueue);
        }
        finally
        {
            if (showLoading)
            {
                _httpLoading = false;
            }
        }
    }

    private async Task ReloadHighValueAsync()
    {
        _highValueLoading = true;
        try
        {
            Replace(_highValue, await GetArrayAsync($"/api/high-value-assets?includeResolved=false&take={HighValueTake}").ConfigureAwait(false));
            _highValueRefreshedUtc = DateTimeOffset.UtcNow;
        }
        finally
        {
            _highValueLoading = false;
        }
    }

    private async Task ReloadTechnologyAsync()
    {
        _technologyLoading = true;
        try
        {
            Replace(_technology, await GetArrayAsync($"/api/technology-identification/technologies?take={TechnologyTake}").ConfigureAwait(false));
            _technologyRefreshedUtc = DateTimeOffset.UtcNow;
        }
        finally
        {
            _technologyLoading = false;
        }
    }

    private async Task ReloadWorkersAsync()
    {
        _workersLoading = true;
        try
        {
            var rows = new List<WorkerRow>();

            // Local workers
            try
            {
                var local = await Http.GetFromJsonAsync<List<JsonElement>>("/api/workers");
                if (local is not null)
                {
                    foreach (var w in local)
                    {
                        var name = Text(w, "name", "Name", "displayName", "DisplayName", "id", "Id") ?? "unknown";
                        var status = Text(w, "overallState", "OverallState", "status", "Status", "state", "State") ?? "unknown";
                        rows.Add(new WorkerRow("Local", name, status, 0, 0, null));
                    }
                }
            }
            catch { }

            // Google Cloud workers
            try
            {
                var gcpJson = await Http.GetFromJsonAsync<JsonElement>("/api/gcp-workers/status");
                _gcpConfigured = gcpJson.TryGetProperty("configured", out var cfg) && cfg.GetBoolean();
                if (_gcpConfigured && gcpJson.TryGetProperty("workers", out var w))
                {
                    foreach (var gw in w.EnumerateArray())
                    {
                        var name = Text(gw, "name", "Name") ?? "unknown";
                        var status = Text(gw, "status", "Status") ?? "inactive";
                        var min = Int(gw, "minInstances", "MinInstances");
                        var max = Int(gw, "maxInstances", "MaxInstances");
