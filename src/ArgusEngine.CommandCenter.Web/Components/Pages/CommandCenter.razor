    private bool StatusMatchesHighValue(JsonElement row)
    {
        var status = Text(row, "investigationStatus", "InvestigationStatus");
        var isHighValue = Bool(row, "isHighValue", "IsHighValue");

        if (_highValueStatusFilter == "Active" && (!isHighValue || status is "False Positive" or "Valid Finding"))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(_highValueStatusFilter) &&
            _highValueStatusFilter != "Active" &&
            !status.Equals(_highValueStatusFilter, StringComparison.OrdinalIgnoreCase))
