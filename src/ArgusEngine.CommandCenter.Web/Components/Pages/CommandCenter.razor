            using var response = await Http.PostAsJsonAsync("/api/http-request-queue/retry", new { ids }, _disposeCts.Token).ConfigureAwait(false);
            await EnsureSuccessAsync(response, "retry HTTP queue rows").ConfigureAwait(false);
            _selectedHttpIds.Clear();
            _statusMessage = $"Retry queued for {ids.Length:N0} request(s).";
