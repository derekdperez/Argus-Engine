    private static bool HasStackTrace(SystemError e) =>
        !string.IsNullOrWhiteSpace(e.Exception);

    private static string BuildErrorSummary(SystemError e)
    {
        var message = Fallback(e.Message, "Error log entry did not include a message.");
        var exceptionHeadline = GetExceptionHeadline(e.Exception);

        if (!string.IsNullOrWhiteSpace(exceptionHeadline))
        {
            if (IsGenericErrorMessage(message))
            {
                return exceptionHeadline;
            }

            var exceptionDetail = exceptionHeadline.Split(':', 2)[^1].Trim();

            if (!message.Contains(exceptionHeadline, StringComparison.OrdinalIgnoreCase) &&
                !message.Contains(exceptionDetail, StringComparison.OrdinalIgnoreCase))
            {
                return $"{message} — {exceptionHeadline}";
            }
        }

        return message;
    }

    private static string BuildContextLine(SystemError e)
    {
        var context = new List<string>
        {
            $"Logger: {Fallback(e.LoggerName, "unknown")}"
        };

        if (!string.IsNullOrWhiteSpace(e.MachineName))
        {
            context.Add($"Machine: {e.MachineName}");
        }

        var metadata = ParseMetadata(e.MetadataJson);

        if (metadata.TryGetValue("source", out var source) && !string.IsNullOrWhiteSpace(source))
        {
            context.Add($"Source: {source}");
        }

        if (metadata.TryGetValue("event_id", out var eventId) && !string.IsNullOrWhiteSpace(eventId))
        {
            context.Add($"EventId: {eventId}");
        }

        if (metadata.TryGetValue("event_name", out var eventName) && !string.IsNullOrWhiteSpace(eventName))
        {
            context.Add($"Event: {eventName}");
        }

        if (metadata.TryGetValue("trace_id", out var traceId) && !string.IsNullOrWhiteSpace(traceId))
        {
            context.Add($"Trace: {traceId}");
        }

        if (metadata.TryGetValue("containerId", out var containerId) && !string.IsNullOrWhiteSpace(containerId))
        {
            context.Add($"Container: {containerId}");
        }

        return string.Join(" • ", context);
    }

    private static string BuildFullErrorDetail(SystemError e)
    {
        var sb = new StringBuilder();
        sb.AppendLine($"Time EST: {AppTimeFormat.Format(e.Timestamp)}");
        sb.AppendLine($"Component: {Fallback(e.Component, "unknown")}");
        sb.AppendLine($"Level: {Fallback(e.LogLevel, "Error")}");
        sb.AppendLine($"Logger: {Fallback(e.LoggerName, "unknown")}");
        sb.AppendLine($"Machine: {Fallback(e.MachineName, "unknown")}");
        sb.AppendLine();
        sb.AppendLine("Message:");
        sb.AppendLine(Fallback(e.Message, "Error log entry did not include a message."));

        if (!string.IsNullOrWhiteSpace(e.Exception))
        {
            sb.AppendLine();
            sb.AppendLine("Exception / Docker log context:");
            sb.AppendLine(e.Exception.Trim());
        }

        if (!string.IsNullOrWhiteSpace(e.MetadataJson))
        {
            sb.AppendLine();
            sb.AppendLine("Metadata:");
            sb.AppendLine(FormatMetadata(e.MetadataJson));
        }

        return sb.ToString();
    }

    private static string? GetExceptionHeadline(string? exception)
    {
        if (string.IsNullOrWhiteSpace(exception))
        {
            return null;
        }

        var firstLine = exception
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .FirstOrDefault();

        return string.IsNullOrWhiteSpace(firstLine) ? null : firstLine;
    }

    private static bool IsGenericErrorMessage(string message)
    {
        var normalized = message.Trim().TrimEnd('.');

        return normalized.Equals("An error has occurred", StringComparison.OrdinalIgnoreCase) ||
               normalized.Equals("An error has occured", StringComparison.OrdinalIgnoreCase) ||
               normalized.Equals("An unhandled exception has occurred while executing the request", StringComparison.OrdinalIgnoreCase) ||
               normalized.Equals("Unhandled exception rendering component", StringComparison.OrdinalIgnoreCase) ||
               normalized.Equals("Circuit host terminated unexpectedly", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatMetadata(string metadataJson)
    {
        try
        {
            using var document = JsonDocument.Parse(metadataJson);

            return JsonSerializer.Serialize(
                document.RootElement,
                new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return metadataJson;
        }
    }

    private static IReadOnlyDictionary<string, string?> ParseMetadata(string? metadataJson)
    {
        if (string.IsNullOrWhiteSpace(metadataJson))
        {
            return new Dictionary<string, string?>();
        }

        try
        {
            using var document = JsonDocument.Parse(metadataJson);

            if (document.RootElement.ValueKind != JsonValueKind.Object)
            {
                return new Dictionary<string, string?>();
            }

            return document.RootElement
                .EnumerateObject()
                .ToDictionary(
                    property => property.Name,
                    property => property.Value.ValueKind == JsonValueKind.String
                        ? property.Value.GetString()
                        : property.Value.ToString(),
                    StringComparer.OrdinalIgnoreCase);
        }
        catch
        {
            return new Dictionary<string, string?>();
        }
    }

    private static string Fallback(string? value, string fallback) =>
        string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();

    // ── AI Bug Fix ────────────────────────────────────────────────────────────

    private AiBugFixRunDto? _latestAiBugFixRun;
    private bool _aiBugFixStarting;
    private bool _aiBugFixActionBusy;
    private string? _aiBugFixError;
    private CancellationTokenSource? _aiBugFixPollCts;

    private async Task StartAiBugFixAsync()
    {
        _aiBugFixError = null;
        _aiBugFixStarting = true;
        _aiBugFixActionBusy = true;
        StateHasChanged();

        try
        {
            await RefreshErrorsAsync().ConfigureAwait(false);

            var request = new CreateAiBugFixRunRequest(
                Scope: "all",
                Components: null,
                ErrorIds: null,
                IncludeDockerLogs: true,
                IncludeStructuredErrors: true);

            var response = await MaintenanceApi.Client
                .PostAsJsonAsync("/api/diagnostics/ai-bug-fixes", request, _devPollCts.Token)
                .ConfigureAwait(false);

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync(_devPollCts.Token).ConfigureAwait(false);
                _aiBugFixError = $"Failed to start run ({(int)response.StatusCode}): {body}";
                return;
            }

            var result = await response.Content
                .ReadFromJsonAsync<AiBugFixRunDto>(cancellationToken: _devPollCts.Token)
                .ConfigureAwait(false);

            await RefreshAiBugFixRunAsync().ConfigureAwait(false);

            if (result is not null && AiBugFixRunStatus.IsActive(result.Status))
            {
                StartAiBugFixPoll();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to start AI bug-fix run.");
            _aiBugFixError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _aiBugFixStarting = false;
            _aiBugFixActionBusy = false;
        }
    }

    private async Task RefreshAiBugFixRunAsync()
    {
        try
        {
            var runs = await MaintenanceApi.Client
                .GetFromJsonAsync<List<AiBugFixRunDto>>("/api/diagnostics/ai-bug-fixes", _devPollCts.Token)
                .ConfigureAwait(false);

            _latestAiBugFixRun = runs?.FirstOrDefault();

            if (_latestAiBugFixRun is not null && AiBugFixRunStatus.IsActive(_latestAiBugFixRun.Status))
            {
                StartAiBugFixPoll();
            }
            else
            {
                StopAiBugFixPoll();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to refresh AI bug-fix run status.");
        }
        finally
        {
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private void StartAiBugFixPoll()
    {
        if (_aiBugFixPollCts is not null)
        {
            return;
        }

        _aiBugFixPollCts = CancellationTokenSource.CreateLinkedTokenSource(_devPollCts.Token);
        var pollToken = _aiBugFixPollCts.Token;

        _ = Task.Run(async () =>
        {
            while (!pollToken.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(5_000, pollToken).ConfigureAwait(false);
                }
                catch (OperationCanceledException)
                {
                    break;
                }

                await RefreshAiBugFixRunAsync().ConfigureAwait(false);

                if (_latestAiBugFixRun is null || AiBugFixRunStatus.IsTerminal(_latestAiBugFixRun.Status))
                {
                    break;
                }
            }

            StopAiBugFixPoll();
        }, pollToken);
    }

    private void StopAiBugFixPoll()
    {
        _aiBugFixPollCts?.Cancel();
        _aiBugFixPollCts?.Dispose();
        _aiBugFixPollCts = null;
    }

    private async Task CancelAiBugFixRunAsync()
    {
        if (_latestAiBugFixRun is null)
        {
            return;
        }

        _aiBugFixActionBusy = true;
        StateHasChanged();

        try
        {
            await MaintenanceApi.Client
                .PostAsync($"/api/diagnostics/ai-bug-fixes/{_latestAiBugFixRun.Id}/cancel", null, _devPollCts.Token)
                .ConfigureAwait(false);

            await RefreshAiBugFixRunAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _aiBugFixError = $"Cancel failed: {ex.Message}";
        }
        finally
        {
            _aiBugFixActionBusy = false;
        }
    }

    private async Task RetryAiBugFixRunAsync()
    {
        if (_latestAiBugFixRun is null)
        {
            return;
        }

        _aiBugFixActionBusy = true;
        StateHasChanged();

        try
        {
            var response = await MaintenanceApi.Client
                .PostAsync($"/api/diagnostics/ai-bug-fixes/{_latestAiBugFixRun.Id}/retry", null, _devPollCts.Token)
                .ConfigureAwait(false);

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync(_devPollCts.Token).ConfigureAwait(false);
                _aiBugFixError = $"Retry failed ({(int)response.StatusCode}): {body}";
                return;
            }

            await RefreshAiBugFixRunAsync().ConfigureAwait(false);
            StartAiBugFixPoll();
        }
        catch (Exception ex)
        {
            _aiBugFixError = $"Retry failed: {ex.Message}";
        }
        finally
        {
            _aiBugFixActionBusy = false;
        }
    }

    private static string StatusBadgeClass(string status) =>
        status switch
        {
            AiBugFixRunStatus.Deployed => "ok",
            AiBugFixRunStatus.MergeReady or AiBugFixRunStatus.WaitingForApproval or AiBugFixRunStatus.PullRequestOpen => "info",
            AiBugFixRunStatus.Failed or AiBugFixRunStatus.Canceled => "fail",
            _ => "loading",
        };

    public void Dispose()
    {
        Realtime.DomainEventReceived -= OnRealtimeEvent;
        StopAiBugFixPoll();
        _devPollCts.Cancel();
        _devPollCts.Dispose();
    }
