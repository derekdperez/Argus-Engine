@page "/development"
@using System.Globalization
@using System.Net
@using System.Net.Http.Json
@using System.Net.Sockets
@using System.Text
@using System.Text.Json
@using ArgusEngine.CommandCenter.Contracts
@using ArgusEngine.CommandCenter.Models
@using ArgusEngine.CommandCenter.Realtime
@using ArgusEngine.CommandCenter.Web.Clients
@using ArgusEngine.Domain.Entities
@using ArgusEngine.Harness.Core
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Hosting
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@inject MaintenanceApiClient MaintenanceApi
@inject WorkerControlApiClient WorkerControl
@inject LocalDockerClient DockerClient
@inject IJSRuntime Js
@inject ILogger<Development> Logger
@inject IConfiguration Configuration
@inject IHostEnvironment HostEnvironment
@inject DiscoveryRealtimeClient Realtime
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Development - Argus Engine</PageTitle>

<div class="dev-page">
    <header class="page-header">
        <div class="eyebrow">Diagnostic Suite</div>
        <div class="header-content">
            <h1>Development &amp; Diagnostics</h1>
            <p class="description">
                Execute internal test harnesses, manage local workers, watch real-time system events,
                and collect deployment-wide error context.
            </p>
        </div>
    </header>

    @if (_initError is not null)
    {
        <div class="error-detail-card">
            <strong>Initialization Error:</strong> @_initError
        </div>
    }

    <section>
        <div class="section-heading">
            <div class="title-group">
                <h2>Worker Test Harness</h2>
                <p>Executes health-check logic within each worker project to exercise core functionality.</p>
            </div>
            <button class="btn primary glow" @onclick="RunHarnessAsync" disabled="@_busy">
                @if (_busy)
                {
                    <span><span class="spinner"></span>Running Diagnostics...</span>
                }
                else
                {
                    <span>Run Test Harness</span>
                }
            </button>
        </div>

        @if (_result != null)
        {
            <div class="harness-summary-card">
                <div class="summary-stat">
                    <span class="label">Executed At</span>
                    <span class="value">@AppTimeFormat.Format(_result.ExecutedAtUtc)</span>
                </div>
                <div class="summary-stat">
                    <span class="label">Overall Status</span>
                    <span class="value @(_result.WorkerResults.All(r => r.Success) ? "success" : "danger")">
                        @(_result.WorkerResults.All(r => r.Success) ? "HEALTHY" : "DEGRADED")
                    </span>
                </div>
                <div class="summary-stat">
                    <span class="label">Success Rate</span>
                    <span class="value">@_result.WorkerResults.Count(r => r.Success) / @_result.WorkerResults.Count</span>
                </div>
            </div>

            <table class="dev-grid">
                <thead>
                    <tr>
                        <th>Worker</th>
                        <th>Status</th>
                        <th>Output</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _result.WorkerResults)
                    {
                        <tr>
                            <td>
                                <span class="worker-name-cell">
                                    <span class="kind-indicator"></span>
                                    @r.WorkerName
                                </span>
                            </td>
                            <td>@(r.Success ? "PASSED" : "FAILED")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(r.Output))
                                {
                                    <button class="btn secondary" @onclick="() => ShowOutputAsync(r)">View Output</button>
                                }
                                else
                                {
                                    <span>No log available</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (!_busy)
        {
            <div class="harness-empty">
                <div class="empty-icon">🧪</div>
                <h3>Ready to test</h3>
                <p>Click the button above to begin the automated worker health check suite.</p>
            </div>
        }
    </section>

    <section>
        <div class="section-heading">
            <div class="title-group">
                <h2>Local Worker Scaling</h2>
                <p>
                    Manage Docker Compose worker services through the Worker Control API.
                    Scale down uses Compose desired-count changes instead of killing containers directly.
                </p>
            </div>
            <button class="btn secondary" @onclick="LoadDockerWorkersAsync" disabled="@_loadingDockerWorkers">
                @if (_loadingDockerWorkers)
                {
                    <span><span class="spinner"></span>Refreshing...</span>
                }
                else
                {
                    <span>Refresh</span>
                }
            </button>
        </div>

        @if (_dockerWorkerSnapshot is not null && !_dockerWorkerSnapshot.DockerAvailable)
        {
            <div class="error-detail-card">
                Docker worker status unavailable: @_dockerWorkerSnapshot.Error
            </div>
        }

        <table class="dev-grid">
            <thead>
                <tr>
                    <th>Worker Service</th>
                    <th>Running</th>
                    <th>Total Containers</th>
                    <th>State</th>
                    <th>Last Action</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var service in WorkerRows)
                {
                    <tr>
                        <td>
                            <strong>@service.ServiceName</strong>
                            <div>@service.DisplayName</div>
                        </td>
                        <td>@service.RunningCount</td>
                        <td>@service.TotalCount</td>
                        <td>
                            <span class="badge-component">@service.OverallState</span>
                        </td>
                        <td>@(_workerScaleStatus.TryGetValue(service.ServiceName, out var status) ? status : "—")</td>
                        <td>
                            <button class="btn primary"
                                    @onclick="() => ScaleUpWorkerAsync(service.ServiceName)"
                                    disabled="@IsWorkerScaleBusy(service.ServiceName)">
                                Scale Up
                            </button>
                            <button class="btn secondary"
                                    @onclick="() => ScaleDownWorkerAsync(service.ServiceName)"
                                    disabled="@(IsWorkerScaleBusy(service.ServiceName) || service.RunningCount <= 0)">
                                Scale Down
                            </button>
                        </td>
                    </tr>

                    @if (service.Containers.Count > 0)
                    {
                        <tr>
                            <td colspan="6">
                                <small>
                                    @string.Join(", ", service.Containers.Select(c => $"{c.Name} [{c.State}]"))
                                </small>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </section>

    <section>
        <div class="section-heading">
            <div class="title-group">
                <h2>Real-Time System Events</h2>
                <p>Live chronological feed of domain events as they occur across the engine.</p>
            </div>
            <div class="actions">
                <span>@(Realtime.IsConnected ? "Live" : "Connecting...")</span>
                <button class="btn secondary" @onclick="() => _liveEvents.Clear()">Clear Feed</button>
            </div>
        </div>

        @if (_liveEvents.Count == 0)
        {
            <p>Waiting for system events...</p>
        }
        else
        {
            <table class="dev-grid">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Scope</th>
                        <th>Kind</th>
                        <th>Summary</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in _liveEvents.OrderByDescending(e => e.OccurredAtUtc))
                    {
                        <tr>
                            <td>@AppTimeFormat.Format(evt.OccurredAtUtc)</td>
                            <td>@evt.Scope</td>
                            <td>@evt.Kind</td>
                            <td>@evt.Summary</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="error-log-panel">
        <div class="section-heading">
            <div class="title-group">
                <h2>System-Wide Error Log</h2>
                <p>
                    Collects structured diagnostics plus Docker log errors from every Argus Compose container.
                    Each Docker log match includes at least @DockerErrorContextLines lines of surrounding context.
                </p>
                @if (!string.IsNullOrWhiteSpace(_errorCollectionStatus))
                {
                    <p>@_errorCollectionStatus</p>
                }
            </div>
            <div class="actions">
                <button class="btn secondary" @onclick="RefreshErrorsAsync" disabled="@_errorsLoading">
                    @if (_errorsLoading)
                    {
                        <span><span class="spinner"></span>Loading...</span>
                    }
                    else
                    {
                        <span>Refresh</span>
                    }
                </button>
                <button class="btn secondary" @onclick="DownloadConcatenatedErrorsAsync">Concatenate All Errors</button>
                <button class="btn secondary" @onclick="GenerateBugFixPromptAsync" disabled="@_generatingBugFixPrompt">
                    @if (_generatingBugFixPrompt)
                    {
                        <span>Generating...</span>
                    }
                    else
                    {
                        <span>Generate Bug Fix Prompt</span>
                    }
                </button>
                <button class="btn danger" @onclick="ClearErrorsAsync">Clear Structured Errors</button>
            </div>
        </div>

        <div class="harness-summary-card">
            <div class="summary-stat">
                <span class="label">Total Errors</span>
                <span class="value">@(_errorsLoading ? "Loading..." : _errors.Count.ToString(CultureInfo.InvariantCulture))</span>
            </div>
            <div class="summary-stat">
                <span class="label">Components Covered</span>
                <span class="value">
                    @(_errorsLoading
                        ? "Loading..."
                        : _errors.Select(e => e.Component).Where(c => !string.IsNullOrWhiteSpace(c)).Distinct(StringComparer.OrdinalIgnoreCase).Count().ToString(CultureInfo.InvariantCulture))
                </span>
            </div>
            <div class="summary-stat">
                <span class="label">Docker Log Context</span>
                <span class="value">±@DockerErrorContextLines lines</span>
            </div>
        </div>

        @if (_selectedError != null)
        {
            <div class="error-detail-card">
                <div class="error-detail-header">
                    <div>
                        <div class="eyebrow">Selected Error</div>
                        <h3>@BuildErrorSummary(_selectedError)</h3>
                        <p>@BuildContextLine(_selectedError)</p>
                    </div>
                    <button class="btn secondary" @onclick="CloseErrorDetail">Close</button>
                </div>
                <div class="error-detail-meta">
                    <div><span class="label">Time</span><strong>@AppTimeFormat.Format(_selectedError.Timestamp)</strong></div>
                    <div><span class="label">Component</span><strong>@Fallback(_selectedError.Component, "unknown")</strong></div>
                    <div><span class="label">Logger</span><strong>@Fallback(_selectedError.LoggerName, "unknown")</strong></div>
                    <div><span class="label">Machine</span><strong>@Fallback(_selectedError.MachineName, "unknown")</strong></div>
                </div>
                <pre class="stack-trace">@BuildFullErrorDetail(_selectedError)</pre>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_bugFixPrompt))
        {
            <div class="bug-fix-prompt-card">
                <div class="bug-fix-prompt-header">
                    <div>
                        <div class="eyebrow">Generated AI Agent Prompt</div>
                        <h3>Investigate System-Wide Errors and Create a PR</h3>
                        <p>
                            Generated @(_bugFixPromptGeneratedAtUtc is null ? "unknown" : $"{AppTimeFormat.Format(_bugFixPromptGeneratedAtUtc.Value)} EST").
                            Credential values are intentionally redacted; the agent must obtain them through approved secure channels.
                        </p>
                    </div>
                    <div class="actions">
                        <button class="btn secondary" @onclick="CopyBugFixPromptAsync">Copy Prompt</button>
                        <button class="btn secondary" @onclick="CloseBugFixPrompt">Close</button>
                    </div>
                </div>
                <textarea class="bug-fix-prompt-textarea" readonly>@_bugFixPrompt</textarea>
            </div>
        }

        @if (_errorsLoading)
        {
            <p>Loading structured errors and Docker logs from every deployment component...</p>
        }
        else if (_errors.Count == 0)
        {
            <p>No errors found in structured diagnostics or recent Docker logs.</p>
        }
        else
        {
            <table class="dev-grid error-grid">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Component</th>
                        <th>Level</th>
                        <th>Summary</th>
                        <th>Context</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in _errors.OrderByDescending(e => e.Timestamp))
                    {
                        <tr @onclick="() => ToggleErrorDetail(e)">
                            <td>@AppTimeFormat.Format(e.Timestamp)</td>
                            <td><span class="badge-component">@Fallback(e.Component, "unknown")</span></td>
                            <td>@Fallback(e.LogLevel, "Error")</td>
                            <td class="error-message-cell">
                                <strong>@BuildErrorSummary(e)</strong>
                                <span>@(HasStackTrace(e) ? "Context captured" : "Details")</span>
                            </td>
                            <td>@BuildContextLine(e)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="error-log-panel">
        <div class="section-heading">
            <div class="title-group">
                <h2>AI Bug Fix Automation</h2>
                <p>
                    Gather all current errors, dispatch an AI coding workflow to generate fixes,
                    open a PR, wait for human approval, merge, and deploy — all from here.
                </p>
                @if (!string.IsNullOrWhiteSpace(_aiBugFixError))
                {
                    <p>@_aiBugFixError</p>
                }
            </div>
            <div class="actions">
                @if (_latestAiBugFixRun is not null && _latestAiBugFixRun.Status == AiBugFixRunStatus.Failed)
                {
                    <button class="btn secondary" @onclick="RetryAiBugFixRunAsync" disabled="@_aiBugFixActionBusy">Retry Failed Run</button>
                }
                @if (_latestAiBugFixRun is not null && AiBugFixRunStatus.IsActive(_latestAiBugFixRun.Status))
                {
                    <button class="btn danger" @onclick="CancelAiBugFixRunAsync" disabled="@_aiBugFixActionBusy">Cancel Run</button>
                }
                <button class="btn secondary" @onclick="RefreshAiBugFixRunAsync" disabled="@_aiBugFixActionBusy">Refresh Status</button>
                <button class="btn primary glow" @onclick="StartAiBugFixAsync" disabled="@(_aiBugFixStarting || _aiBugFixActionBusy)">
                    @if (_aiBugFixStarting)
                    {
                        <span><span class="spinner"></span>Starting...</span>
                    }
                    else
                    {
                        <span>Fix Bugs with AI</span>
                    }
                </button>
            </div>
        </div>

        @if (_latestAiBugFixRun is not null)
        {
            <div class="harness-summary-card">
                <div class="summary-stat">
                    <span class="label">Status</span>
                    <span class="value @StatusBadgeClass(_latestAiBugFixRun.Status)">@_latestAiBugFixRun.Status</span>
                </div>
                <div class="summary-stat">
                    <span class="label">Errors captured</span>
                    <span class="value">@_latestAiBugFixRun.ErrorCount</span>
                </div>
                <div class="summary-stat">
                    <span class="label">Branch</span>
                    <span class="value">@Fallback(_latestAiBugFixRun.GitHubBranch, "—")</span>
                </div>
            </div>

            <div class="error-detail-card">
                <p>
                    <strong>Pull Request:</strong>
                    @if (_latestAiBugFixRun.GitHubPrUrl is not null)
                    {
                        <a href="@_latestAiBugFixRun.GitHubPrUrl" target="_blank">#@_latestAiBugFixRun.GitHubPrNumber — View PR</a>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </p>
                <p>
                    <strong>Workflow:</strong>
                    @if (_latestAiBugFixRun.GitHubWorkflowUrl is not null)
                    {
                        <a href="@_latestAiBugFixRun.GitHubWorkflowUrl" target="_blank">View Actions run</a>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </p>
                <p>
                    <strong>Deployment:</strong>
                    @if (_latestAiBugFixRun.DeploymentUrl is not null)
                    {
                        <a href="@_latestAiBugFixRun.DeploymentUrl" target="_blank">View deployment</a>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </p>
                <p><strong>Last message:</strong> @Fallback(_latestAiBugFixRun.StatusMessage, "—")</p>
                @if (!string.IsNullOrWhiteSpace(_latestAiBugFixRun.FailureDetail))
                {
                    <pre class="stack-trace">@_latestAiBugFixRun.FailureDetail</pre>
                }
                <p>
                    Run started @AppTimeFormat.Format(_latestAiBugFixRun.CreatedAtUtc)
                    • Last updated @AppTimeFormat.Format(_latestAiBugFixRun.UpdatedAtUtc)
                </p>
            </div>
        }
        else
        {
            <p>No AI bug-fix runs yet. Click Fix Bugs with AI to start the first run.</p>
        }
    </section>
</div>

@code {
    private const int DockerErrorContextLines = 15;

    private bool _busy;
    private bool _generatingBugFixPrompt;
    private bool _errorsLoading = true;
    private bool _errorsReloadRunning;
    private HarnessResultDto? _result;
    private List<SystemError> _errors = new();
    private readonly List<LiveUiEventDto> _liveEvents = new();
    private SystemError? _selectedError;
    private string? _bugFixPrompt;
    private DateTimeOffset? _bugFixPromptGeneratedAtUtc;
    private string? _errorCollectionStatus;
    private string? _initError;

    private DockerWorkerStatusSnapshotDto? _dockerWorkerSnapshot;
    private bool _loadingDockerWorkers;
    private readonly Dictionary<string, string> _workerScaleStatus = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _workerScaleBusy = new(StringComparer.OrdinalIgnoreCase);
    private readonly CancellationTokenSource _devPollCts = new();

    private readonly string[] _workerServices =
    [
        "worker-spider",
        "worker-enum",
        "worker-portscan",
        "worker-highvalue",
        "worker-techid",
        "worker-http-requester"
    ];

    private IReadOnlyList<DockerWorkerServiceDto> WorkerRows =>
        _dockerWorkerSnapshot?.Services.Count > 0
            ? _dockerWorkerSnapshot.Services
            : _workerServices
                .Select(serviceName => new DockerWorkerServiceDto(
                    serviceName,
                    serviceName,
                    0,
                    0,
                    "unknown",
                    "gray",
                    Array.Empty<DockerWorkerContainerDto>()))
                .ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Realtime.DomainEventReceived += OnRealtimeEvent;
            await Realtime.EnsureStartedAsync(_devPollCts.Token);
            await RefreshErrorsAsync();
            await LoadDockerWorkersAsync();
            await RefreshAiBugFixRunAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize Development page.");
            _initError = $"Initialization failed: {ex.Message}";
        }
    }

    private void OnRealtimeEvent(object? sender, LiveUiEventDto evt)
    {
        _ = InvokeAsync(() =>
        {
            _liveEvents.Insert(0, evt);

            if (_liveEvents.Count > 100)
            {
                _liveEvents.RemoveAt(_liveEvents.Count - 1);
            }

            StateHasChanged();
        });
    }

    private async Task LoadDockerWorkersAsync()
    {
        if (_loadingDockerWorkers)
        {
            return;
        }

        _loadingDockerWorkers = true;
        StateHasChanged();

        try
        {
            _dockerWorkerSnapshot = await WorkerControl
                .GetDockerWorkerStatusAsync(_devPollCts.Token)
                .ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not load Docker worker status from Worker Control API.");
            _dockerWorkerSnapshot = new DockerWorkerStatusSnapshotDto(
                DateTimeOffset.UtcNow,
                DockerAvailable: false,
                Error: ex.Message,
                Services: Array.Empty<DockerWorkerServiceDto>());
        }
        finally
        {
            _loadingDockerWorkers = false;
        }
    }

    private async Task ScaleUpWorkerAsync(string serviceName)
    {
        var current = GetRunningWorkerCount(serviceName);
        await ScaleWorkerAsync(serviceName, current + 1).ConfigureAwait(false);
    }

    private async Task ScaleDownWorkerAsync(string serviceName)
    {
        var current = GetRunningWorkerCount(serviceName);
        await ScaleWorkerAsync(serviceName, Math.Max(0, current - 1)).ConfigureAwait(false);
    }

    private async Task ScaleWorkerAsync(string serviceName, int desiredCount)
    {
        if (!_workerScaleBusy.Add(serviceName))
        {
            return;
        }

        StateHasChanged();

        try
        {
            var result = await WorkerControl
                .ScaleDockerWorkerAsync(serviceName, Math.Clamp(desiredCount, 0, 50), _devPollCts.Token)
                .ConfigureAwait(false);

            _workerScaleStatus[serviceName] = result.Message;
            await LoadDockerWorkersAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to scale Docker worker service {ServiceName}.", serviceName);
            _workerScaleStatus[serviceName] = $"Failed: {ex.Message}";
            await Js.InvokeVoidAsync("alert", $"Failed to scale {serviceName}: {ex.Message}").ConfigureAwait(false);
        }
        finally
        {
            _workerScaleBusy.Remove(serviceName);
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private int GetRunningWorkerCount(string serviceName) =>
        _dockerWorkerSnapshot?.Services.FirstOrDefault(service =>
            string.Equals(service.ServiceName, serviceName, StringComparison.OrdinalIgnoreCase))?.RunningCount ?? 0;

    private bool IsWorkerScaleBusy(string serviceName) =>
        _loadingDockerWorkers || _workerScaleBusy.Contains(serviceName);

    private async Task RefreshErrorsAsync()
    {
        if (_errorsReloadRunning)
        {
            return;
        }

        _errorsReloadRunning = true;
        _errorsLoading = true;
        _errorCollectionStatus = "Loading structured diagnostics and Docker logs from every Compose container...";

        try
        {
            var structuredErrors = await MaintenanceApi.Client
                .GetFromJsonAsync<List<SystemError>>("/api/diagnostics/system-errors", _devPollCts.Token)
                .ConfigureAwait(false) ?? new List<SystemError>();

            var dockerErrors = await DockerClient
                .GetDeploymentSystemErrorsAsync(tailLines: 2500, contextLines: DockerErrorContextLines, ct: _devPollCts.Token)
                .ConfigureAwait(false);

            _errors = MergeErrors(structuredErrors, dockerErrors);

            if (_selectedError is not null)
            {
                _selectedError = _errors.FirstOrDefault(error => error.Id == _selectedError.Id);
            }

            _errorCollectionStatus = $"Loaded {structuredErrors.Count.ToString(CultureInfo.InvariantCulture)} structured error(s) and " +
                                     $"{dockerErrors.Count.ToString(CultureInfo.InvariantCulture)} Docker log error block(s) across " +
                                     $"{_errors.Select(e => e.Component).Where(c => !string.IsNullOrWhiteSpace(c)).Distinct(StringComparer.OrdinalIgnoreCase).Count().ToString(CultureInfo.InvariantCulture)} component(s).";
        }
        catch (OperationCanceledException)
        {
            _errorCollectionStatus = "Error collection was canceled.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load system-wide errors for the development diagnostics page.");
            _errorCollectionStatus = $"Failed to collect all deployment errors: {ex.Message}";
        }
        finally
        {
            _errorsLoading = false;
            _errorsReloadRunning = false;
        }
    }

    private static List<SystemError> MergeErrors(IEnumerable<SystemError> structuredErrors, IEnumerable<SystemError> dockerErrors) =>
        structuredErrors
            .Concat(dockerErrors)
            .GroupBy(error => error.Id)
            .Select(group => group.First())
            .OrderByDescending(error => error.Timestamp)
            .Take(1000)
            .ToList();

    private async Task ClearErrorsAsync()
    {
        if (!await Js.InvokeAsync<bool>(
                "confirm",
                "Are you sure you want to clear structured system errors? Docker log errors will remain until the container logs rotate or the services are recreated.")
            .ConfigureAwait(false))
        {
            return;
        }

        try
        {
            await MaintenanceApi.Client.DeleteAsync("/api/diagnostics/system-errors", _devPollCts.Token).ConfigureAwait(false);
            _selectedError = null;
            await RefreshErrorsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to clear system-wide errors from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Failed to clear structured errors: {ex.Message}").ConfigureAwait(false);
        }
    }

    private async Task RunHarnessAsync()
    {
        _busy = true;
        _result = null;
        StateHasChanged();

        try
        {
            await Task.Delay(500, _devPollCts.Token).ConfigureAwait(false);

            _result = await MaintenanceApi.Client
                .GetFromJsonAsync<HarnessResultDto>("/api/diagnostics/harness", _devPollCts.Token)
                .ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Harness execution failed from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Harness Execution Error: {ex.Message}").ConfigureAwait(false);
        }
        finally
        {
            _busy = false;
            await RefreshErrorsAsync().ConfigureAwait(false);
        }
    }

    private async Task DownloadConcatenatedErrorsAsync()
    {
        try
        {
            await RefreshErrorsAsync().ConfigureAwait(false);

            var generatedAtUtc = DateTimeOffset.UtcNow;
            var contents = BuildConcatenatedErrorFile(_errors, generatedAtUtc);
            var fileName = $"argus-errors-{generatedAtUtc:yyyyMMdd-HHmmss}.txt";

            await Js.InvokeVoidAsync(
                    "argusUi.downloadTextFile",
                    fileName,
                    contents,
                    "text/plain;charset=utf-8")
                .ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to download concatenated system errors from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Failed to concatenate errors: {ex.Message}").ConfigureAwait(false);
        }
    }

