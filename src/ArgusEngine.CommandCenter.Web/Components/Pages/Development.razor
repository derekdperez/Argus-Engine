@page "/development"
@using System.Globalization
@using System.Net
@using System.Net.Http.Json
@using System.Net.Sockets
@using System.Text
@using System.Text.Json
@using ArgusEngine.CommandCenter.Models
@using ArgusEngine.CommandCenter.Realtime
@using ArgusEngine.CommandCenter.Web.Clients
@using ArgusEngine.Domain.Entities
@using ArgusEngine.Harness.Core
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Hosting
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@inject MaintenanceApiClient MaintenanceApi
@inject LocalDockerClient DockerClient
@inject IJSRuntime Js
@inject ILogger<Development> Logger
@inject IConfiguration Configuration
@inject IHostEnvironment HostEnvironment
@inject DiscoveryRealtimeClient Realtime
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Development - Argus Engine</PageTitle>

<div class="page-shell development-page">
    <section class="hero-card">
        <p class="eyebrow">Diagnostic Suite</p>
        <h1>Development &amp; Diagnostics</h1>
        <p>Execute internal test harnesses, manage local workers, watch real-time system events, and collect deployment-wide error context.</p>
    </section>

    <section class="surface-card">
        <div class="section-heading">
            <div>
                <h2>Worker Test Harness</h2>
                <p>Executes health-check logic within each worker project to exercise core functionality.</p>
            </div>
            <button class="btn btn-primary" disabled="@_busy" @onclick="RunHarnessAsync">
                @if (_busy)
                {
                    <span>Running Diagnostics...</span>
                }
                else
                {
                    <span>Run Test Harness</span>
                }
            </button>
        </div>

        @if (_result != null)
        {
            <div class="stat-grid">
                <article class="stat-card">
                    <span>Executed At</span>
                    <strong>@_result.ExecutedAtUtc.ToLocalTime().ToString("HH:mm:ss", CultureInfo.InvariantCulture)</strong>
                </article>
                <article class="stat-card">
                    <span>Overall Status</span>
                    <strong>@(_result.WorkerResults.All(r => r.Success) ? "HEALTHY" : "DEGRADED")</strong>
                </article>
                <article class="stat-card">
                    <span>Success Rate</span>
                    <strong>@_result.WorkerResults.Count(r => r.Success) / @_result.WorkerResults.Count</strong>
                </article>
            </div>

            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Worker</th>
                            <th>Status</th>
                            <th>Output</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _result.WorkerResults)
                        {
                            <tr>
                                <td>@r.WorkerName</td>
                                <td>@(r.Success ? "PASSED" : "FAILED")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(r.Output))
                                    {
                                        <button class="btn btn-secondary" @onclick="() => ShowOutputAsync(r)">View Output</button>
                                    }
                                    else
                                    {
                                        <span>No log available</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (!_busy)
        {
            <div class="empty-state">
                <h3>Ready to test</h3>
                <p>Click the button above to begin the automated worker health check suite.</p>
            </div>
        }
    </section>

    <section class="surface-card">
        <div class="section-heading">
            <div>
                <h2>Local Worker Scaling</h2>
                <p>Manage local Docker Compose workers. Scaling down destroys containers immediately for failure testing.</p>
            </div>
            <button class="btn btn-secondary" disabled="@_loadingDockerWorkers" @onclick="LoadDockerWorkersAsync">
                @if (_loadingDockerWorkers)
                {
                    <span>Refreshing...</span>
                }
                else
                {
                    <span>Refresh</span>
                }
            </button>
        </div>

        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Worker Service</th>
                        <th>Containers Running</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var svc in _workerServices)
                    {
                        var count = _dockerWorkers.TryGetValue(svc, out var list) ? list.Count : 0;
                        <tr>
                            <td>@svc</td>
                            <td>@count</td>
                            <td class="button-row">
                                <button class="btn btn-secondary" @onclick="() => ScaleUpWorkerAsync(svc)">Scale Up</button>
                                <button class="btn btn-danger" disabled="@(count == 0)" @onclick="() => ScaleDownWorkerAsync(svc)">Scale Down (Kill)</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="surface-card">
        <div class="section-heading">
            <div>
                <h2>Real-Time System Events</h2>
                <p>Live chronological feed of domain events as they occur across the engine.</p>
            </div>
            <div class="button-row">
                <span class="status-pill @(Realtime.IsConnected ? "ok" : "loading")">@(Realtime.IsConnected ? "Live" : "Connecting...")</span>
                <button class="btn btn-secondary" @onclick="() => _liveEvents.Clear()">Clear Feed</button>
            </div>
        </div>

        @if (_liveEvents.Count == 0)
        {
            <div class="empty-state">Waiting for system events...</div>
        }
        else
        {
            <div class="event-list">
                @foreach (var evt in _liveEvents.OrderByDescending(e => e.OccurredAtUtc))
                {
                    <article class="event-row">
                        <time>@evt.OccurredAtUtc.ToLocalTime().ToString("HH:mm:ss", CultureInfo.InvariantCulture)</time>
                        <strong>@evt.Scope</strong>
                        <span>@evt.Kind</span>
                        <p>@evt.Summary</p>
                    </article>
                }
            </div>
        }
    </section>

    <section class="surface-card">
        <div class="section-heading">
            <div>
                <h2>System-Wide Error Log</h2>
                <p>
                    Collects structured diagnostics plus Docker log errors from every Argus Compose container.
                    Each Docker log match includes at least 15 lines of surrounding context.
                </p>
                @if (!string.IsNullOrWhiteSpace(_errorCollectionStatus))
                {
                    <p class="muted">@_errorCollectionStatus</p>
                }
            </div>
            <div class="button-row">
                <button class="btn btn-secondary" disabled="@_errorsLoading" @onclick="RefreshErrorsAsync">
                    @if (_errorsLoading)
                    {
                        <span>Loading...</span>
                    }
                    else
                    {
                        <span>Refresh</span>
                    }
                </button>
                <button class="btn btn-secondary" disabled="@(_errorsLoading || _errors.Count == 0)" @onclick="DownloadConcatenatedErrorsAsync">Concatenate All Errors</button>
                <button class="btn btn-secondary" disabled="@(_errorsLoading || _errors.Count == 0 || _generatingBugFixPrompt)" @onclick="GenerateBugFixPromptAsync">
                    @if (_generatingBugFixPrompt)
                    {
                        <span>Generating...</span>
                    }
                    else
                    {
                        <span>Generate Bug Fix Prompt</span>
                    }
                </button>
                <button class="btn btn-danger" disabled="@_errorsLoading" @onclick="ClearErrorsAsync">Clear Structured Errors</button>
            </div>
        </div>

        <div class="stat-grid">
            <article class="stat-card">
                <span>Total Errors</span>
                @if (_errorsLoading)
                {
                    <strong>Loading...</strong>
                }
                else
                {
                    <strong>@_errors.Count</strong>
                }
            </article>
            <article class="stat-card">
                <span>Components Covered</span>
                @if (_errorsLoading)
                {
                    <strong>Loading...</strong>
                }
                else
                {
                    <strong>@_errors.Select(e => e.Component).Where(c => !string.IsNullOrWhiteSpace(c)).Distinct(StringComparer.OrdinalIgnoreCase).Count()</strong>
                }
            </article>
            <article class="stat-card">
                <span>Docker Log Context</span>
                <strong>±15 lines</strong>
            </article>
        </div>

        @if (_selectedError != null)
        {
            <aside class="detail-panel">
                <div class="section-heading">
                    <div>
                        <p class="eyebrow">Selected Error</p>
                        <h3>@BuildErrorSummary(_selectedError)</h3>
                        <p>@BuildContextLine(_selectedError)</p>
                    </div>
                    <button class="btn btn-secondary" @onclick="CloseErrorDetail">Close</button>
                </div>

                <dl class="detail-grid">
                    <dt>Time</dt>
                    <dd>@_selectedError.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz", CultureInfo.InvariantCulture)</dd>
                    <dt>Component</dt>
                    <dd>@Fallback(_selectedError.Component, "unknown")</dd>
                    <dt>Logger</dt>
                    <dd>@Fallback(_selectedError.LoggerName, "unknown")</dd>
                    <dt>Machine</dt>
                    <dd>@Fallback(_selectedError.MachineName, "unknown")</dd>
                </dl>

                <pre class="log-block">@BuildFullErrorDetail(_selectedError)</pre>
            </aside>
        }

        @if (!string.IsNullOrWhiteSpace(_bugFixPrompt))
        {
            <aside class="detail-panel">
                <div class="section-heading">
                    <div>
                        <p class="eyebrow">Generated AI Agent Prompt</p>
                        <h3>Investigate System-Wide Errors and Create a PR</h3>
                        <p>
                            Generated @(_bugFixPromptGeneratedAtUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz", CultureInfo.InvariantCulture) ?? "unknown").
                            Credential values are intentionally redacted; the agent must obtain them through approved secure channels.
                        </p>
                    </div>
                    <div class="button-row">
                        <button class="btn btn-secondary" @onclick="CopyBugFixPromptAsync">Copy Prompt</button>
                        <button class="btn btn-secondary" @onclick="CloseBugFixPrompt">Close</button>
                    </div>
                </div>
                <pre class="log-block">@_bugFixPrompt</pre>
            </aside>
        }

        @if (_errorsLoading)
        {
            <div class="empty-state">Loading structured errors and Docker logs from every deployment component...</div>
        }
        else if (_errors.Count == 0)
        {
            <div class="empty-state">No errors found in structured diagnostics or recent Docker logs.</div>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Component</th>
                            <th>Level</th>
                            <th>Summary</th>
                            <th>Context</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in _errors.OrderByDescending(e => e.Timestamp))
                        {
                            <tr class="clickable-row" @onclick="() => ToggleErrorDetail(e)">
                                <td>@e.Timestamp.ToLocalTime().ToString("MM/dd HH:mm:ss", CultureInfo.InvariantCulture)</td>
                                <td>@Fallback(e.Component, "unknown")</td>
                                <td>@Fallback(e.LogLevel, "Error")</td>
                                <td>@BuildErrorSummary(e)</td>
                                <td>@BuildContextLine(e) @(HasStackTrace(e) ? " • Context captured" : "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@code {
    private const int DockerErrorContextLines = 15;
    private bool _busy;
    private bool _generatingBugFixPrompt;
    private bool _errorsLoading = true;
    private bool _errorsReloadRunning;
    private HarnessResultDto? _result;
    private List<SystemError> _errors = new();
    private readonly List<LiveUiEventDto> _liveEvents = new();
    private SystemError? _selectedError;
    private string? _bugFixPrompt;
    private DateTimeOffset? _bugFixPromptGeneratedAtUtc;
    private string? _errorCollectionStatus;
    private readonly CancellationTokenSource _devPollCts = new();

    protected override async Task OnInitializedAsync()
    {
        Realtime.DomainEventReceived += OnRealtimeEvent;
        await Realtime.EnsureStartedAsync(_devPollCts.Token).ConfigureAwait(false);
        await RefreshErrorsAsync().ConfigureAwait(false);
        await LoadDockerWorkersAsync().ConfigureAwait(false);
    }

    private void OnRealtimeEvent(object? sender, LiveUiEventDto evt)
    {
        _ = InvokeAsync(() =>
        {
            _liveEvents.Insert(0, evt);

            if (_liveEvents.Count > 100)
            {
                _liveEvents.RemoveAt(_liveEvents.Count - 1);
            }

            StateHasChanged();
        });
    }

    private async Task RefreshErrorsAsync()
    {
        if (_errorsReloadRunning)
        {
            return;
        }

        _errorsReloadRunning = true;
        _errorsLoading = true;
        _errorCollectionStatus = "Loading structured diagnostics and Docker logs from every Compose container...";

        try
        {
            var structuredErrors = await MaintenanceApi.Client
                .GetFromJsonAsync<List<SystemError>>("/api/diagnostics/system-errors", _devPollCts.Token)
                .ConfigureAwait(false) ?? new List<SystemError>();

            var dockerErrors = await DockerClient
                .GetDeploymentSystemErrorsAsync(tailLines: 2500, contextLines: DockerErrorContextLines, ct: _devPollCts.Token)
                .ConfigureAwait(false);

            _errors = MergeErrors(structuredErrors, dockerErrors);

            if (_selectedError is not null)
            {
                _selectedError = _errors.FirstOrDefault(error => error.Id == _selectedError.Id);
            }

            _errorCollectionStatus =
                $"Loaded {structuredErrors.Count.ToString(CultureInfo.InvariantCulture)} structured error(s) and " +
                $"{dockerErrors.Count.ToString(CultureInfo.InvariantCulture)} Docker log error block(s) across " +
                $"{_errors.Select(e => e.Component).Where(c => !string.IsNullOrWhiteSpace(c)).Distinct(StringComparer.OrdinalIgnoreCase).Count().ToString(CultureInfo.InvariantCulture)} component(s).";
        }
        catch (OperationCanceledException)
        {
            _errorCollectionStatus = "Error collection was canceled.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load system-wide errors for the development diagnostics page.");
            _errorCollectionStatus = $"Failed to collect all deployment errors: {ex.Message}";
        }
        finally
        {
            _errorsLoading = false;
            _errorsReloadRunning = false;
        }
    }

    private static List<SystemError> MergeErrors(IEnumerable<SystemError> structuredErrors, IEnumerable<SystemError> dockerErrors)
    {
        return structuredErrors
            .Concat(dockerErrors)
            .GroupBy(error => error.Id)
            .Select(group => group.First())
            .OrderByDescending(error => error.Timestamp)
            .Take(1000)
            .ToList();
    }

    private async Task ClearErrorsAsync()
    {
        if (!await Js.InvokeAsync<bool>("confirm", "Are you sure you want to clear structured system errors? Docker log errors will remain until the container logs rotate or the services are recreated.").ConfigureAwait(false))
        {
            return;
        }

        try
        {
            await MaintenanceApi.Client.DeleteAsync("/api/diagnostics/system-errors", _devPollCts.Token).ConfigureAwait(false);
            _selectedError = null;
            await RefreshErrorsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to clear system-wide errors from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Failed to clear structured errors: {ex.Message}").ConfigureAwait(false);
        }
    }

    private async Task RunHarnessAsync()
    {
        _busy = true;
        _result = null;
        StateHasChanged();

        try
        {
            await Task.Delay(500, _devPollCts.Token).ConfigureAwait(false);
            _result = await MaintenanceApi.Client
                .GetFromJsonAsync<HarnessResultDto>("/api/diagnostics/harness", _devPollCts.Token)
                .ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Harness execution failed from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Harness Execution Error: {ex.Message}").ConfigureAwait(false);
        }
        finally
        {
            _busy = false;
            await RefreshErrorsAsync().ConfigureAwait(false);
        }
    }

    private async Task DownloadConcatenatedErrorsAsync()
    {
        try
        {
            await RefreshErrorsAsync().ConfigureAwait(false);
            var generatedAtUtc = DateTimeOffset.UtcNow;
            var contents = BuildConcatenatedErrorFile(_errors, generatedAtUtc);
            var fileName = $"argus-errors-{generatedAtUtc:yyyyMMdd-HHmmss}.txt";

            await Js.InvokeVoidAsync(
                    "argusUi.downloadTextFile",
                    fileName,
                    contents,
                    "text/plain;charset=utf-8")
                .ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to download concatenated system errors from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Failed to concatenate errors: {ex.Message}").ConfigureAwait(false);
        }
    }

    private async Task GenerateBugFixPromptAsync()
    {
        _generatingBugFixPrompt = true;
        StateHasChanged();

        try
        {
            await RefreshErrorsAsync().ConfigureAwait(false);
            _bugFixPromptGeneratedAtUtc = DateTimeOffset.UtcNow;
            _bugFixPrompt = BuildBugFixPrompt(_errors, _bugFixPromptGeneratedAtUtc.Value);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to generate the bug-fix prompt from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Failed to generate bug fix prompt: {ex.Message}").ConfigureAwait(false);
        }
        finally
        {
            _generatingBugFixPrompt = false;
        }
    }

    private async Task CopyBugFixPromptAsync()
    {
        if (string.IsNullOrWhiteSpace(_bugFixPrompt))
        {
            return;
        }

        try
        {
            await Js.InvokeVoidAsync("navigator.clipboard.writeText", _bugFixPrompt).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Clipboard copy failed for the generated bug-fix prompt.");
            await Js.InvokeVoidAsync("alert", "The browser blocked clipboard access. Select the prompt text and copy it manually.").ConfigureAwait(false);
        }
    }

    private void CloseBugFixPrompt()
    {
        _bugFixPrompt = null;
        _bugFixPromptGeneratedAtUtc = null;
    }

    private string BuildConcatenatedErrorFile(IReadOnlyCollection<SystemError> errors, DateTimeOffset generatedAtUtc)
    {
        var orderedErrors = errors
            .OrderByDescending(error => error.Timestamp)
            .ToList();

        var sb = new StringBuilder();

        sb.AppendLine("Argus Engine Concatenated Error Export");
        sb.AppendLine("=====================================");
        sb.AppendLine();
        sb.AppendLine("This file contains every structured diagnostic error and Docker-log error block currently loaded on the Development page.");
        sb.AppendLine("It is intended to be attached to an AI agent task or debugging ticket.");
        sb.AppendLine();
        sb.AppendLine($"Generated UTC: {generatedAtUtc:yyyy-MM-dd HH:mm:ss zzz}");
        sb.AppendLine($"Generated local server time: {generatedAtUtc.ToLocalTime():yyyy-MM-dd HH:mm:ss zzz}");
        sb.AppendLine($"ASP.NET Core environment: {Fallback(HostEnvironment.EnvironmentName, "unknown")}");
        sb.AppendLine($"Application: {Fallback(HostEnvironment.ApplicationName, "unknown")}");
        sb.AppendLine($"Server machine: {Environment.MachineName}");
        sb.AppendLine($"Command Center URL visible to this browser: {Fallback(Navigation.Uri, "unknown")}");
        sb.AppendLine($"Error count: {orderedErrors.Count.ToString(CultureInfo.InvariantCulture)}");
        sb.AppendLine();

        if (orderedErrors.Count == 0)
        {
            sb.AppendLine("No errors were loaded when this export was generated.");
            return sb.ToString();
        }

        var index = 1;

        foreach (var error in orderedErrors)
        {
            sb.AppendLine($"--- Error {index.ToString(CultureInfo.InvariantCulture)} of {orderedErrors.Count.ToString(CultureInfo.InvariantCulture)} ---");
            sb.AppendLine(BuildFullErrorDetail(error));
            sb.AppendLine();
            index++;
        }

        return sb.ToString();
    }

    private string BuildBugFixPrompt(IReadOnlyCollection<SystemError> errors, DateTimeOffset generatedAtUtc)
    {
        var orderedErrors = errors
            .OrderByDescending(error => error.Timestamp)
            .ToList();

        var sb = new StringBuilder();

        sb.AppendLine("# Argus Engine System-Wide Error Bug Fix Task");
        sb.AppendLine();
        sb.AppendLine("You are an AI software engineering agent working on the Argus Engine repository.");
        sb.AppendLine("Investigate every error listed below, identify shared root causes, implement fixes, add or update regression coverage, run validation commands, and create a pull request.");
        sb.AppendLine();
        sb.AppendLine("## Repository and PR instructions");
        sb.AppendLine("- Repository: https://github.com/derekdperez/Argus-Engine");
        sb.AppendLine("- Create a new branch with a descriptive name.");
        sb.AppendLine("- Do not clear or mutate production diagnostics data as part of the fix.");
        sb.AppendLine("- Preserve existing behavior unless it is clearly broken by one of the logged failures.");
        sb.AppendLine("- Add targeted tests for each root cause whenever practical.");
        sb.AppendLine("- Run `dotnet build ArgusEngine.slnx` and relevant `dotnet test` commands before opening the PR.");
        sb.AppendLine();
        sb.AppendLine("## Runtime context captured from the Development page");
        sb.AppendLine($"- Generated at UTC: {generatedAtUtc:yyyy-MM-dd HH:mm:ss zzz}");
        sb.AppendLine($"- Generated at local server time: {generatedAtUtc.ToLocalTime():yyyy-MM-dd HH:mm:ss zzz}");
        sb.AppendLine($"- ASP.NET Core environment: {Fallback(HostEnvironment.EnvironmentName, "unknown")}");
        sb.AppendLine($"- Application name: {Fallback(HostEnvironment.ApplicationName, "unknown")}");
        sb.AppendLine($"- Content root: {Fallback(HostEnvironment.ContentRootPath, "unknown")}");
        sb.AppendLine($"- Server machine name: {Environment.MachineName}");
        sb.AppendLine($"- Server process id: {Environment.ProcessId.ToString(CultureInfo.InvariantCulture)}");
        sb.AppendLine($"- Server OS: {Environment.OSVersion}");
        sb.AppendLine($"- Server IP address(es): {BuildServerIpAddressList()}");
        sb.AppendLine($"- Command Center URL visible to this browser: {Fallback(Navigation.Uri, "unknown")}");
        sb.AppendLine($"- Docker log context: at least {DockerErrorContextLines.ToString(CultureInfo.InvariantCulture)} lines before and after each detected error line.");
        sb.AppendLine();
        sb.AppendLine("## Credentials, secrets, and service access likely required");
        sb.AppendLine("The following entries identify required or relevant credentials/configuration without exposing their values:");
        sb.AppendLine();

        var credentialReferences = BuildCredentialReferenceLines();

        if (credentialReferences.Count == 0)
        {
            sb.AppendLine("- No credential-like configuration keys were visible to the Development page configuration provider.");
            sb.AppendLine("- The agent will still likely need GitHub write access, deployment log access, database diagnostics, message broker diagnostics, and service secrets through approved channels.");
        }
        else
        {
            foreach (var reference in credentialReferences)
            {
                sb.AppendLine($"- {reference}");
            }
        }

        sb.AppendLine();
        sb.AppendLine("## Error inventory");
        sb.AppendLine($"Total errors currently loaded on the Development page: {orderedErrors.Count.ToString(CultureInfo.InvariantCulture)}");
        sb.AppendLine();

        if (orderedErrors.Count == 0)
        {
            sb.AppendLine("No errors were present when this prompt was generated. Confirm whether the diagnostics page is loading the system-wide error log correctly before making code changes.");
        }

        var index = 1;

        foreach (var error in orderedErrors)
        {
            sb.AppendLine($"### Error {index.ToString(CultureInfo.InvariantCulture)}");
            sb.AppendLine($"- Id: {error.Id}");
            sb.AppendLine($"- Timestamp UTC: {error.Timestamp.UtcDateTime:yyyy-MM-dd HH:mm:ss}Z");
            sb.AppendLine($"- Timestamp local: {error.Timestamp.ToLocalTime():yyyy-MM-dd HH:mm:ss zzz}");
            sb.AppendLine($"- Component: {Fallback(error.Component, "unknown")}");
            sb.AppendLine($"- Level: {Fallback(error.LogLevel, "Error")}");
            sb.AppendLine($"- Logger: {Fallback(error.LoggerName, "unknown")}");
            sb.AppendLine($"- Machine: {Fallback(error.MachineName, "unknown")}");
            sb.AppendLine($"- Summary: {BuildErrorSummary(error)}");
            sb.AppendLine($"- Context: {BuildContextLine(error)}");
            sb.AppendLine();
            sb.AppendLine("Message:");
            sb.AppendLine("```text");
            sb.AppendLine(Fallback(error.Message, "Error log entry did not include a message."));
            sb.AppendLine("```");

            if (!string.IsNullOrWhiteSpace(error.Exception))
            {
                sb.AppendLine();
                sb.AppendLine("Exception / Docker log context:");
                sb.AppendLine("```text");
                sb.AppendLine(error.Exception.Trim());
                sb.AppendLine("```");
            }

            if (!string.IsNullOrWhiteSpace(error.MetadataJson))
            {
                sb.AppendLine();
                sb.AppendLine("Metadata:");
                sb.AppendLine("```json");
                sb.AppendLine(FormatMetadata(error.MetadataJson));
                sb.AppendLine("```");
            }

            sb.AppendLine();
            index++;
        }

        sb.AppendLine("## Expected investigation workflow");
        sb.AppendLine("1. Group errors by component, logger, exception type, trace ID, and likely root cause.");
        sb.AppendLine("2. Reproduce failures locally or in a safe staging environment.");
        sb.AppendLine("3. Fix root causes, not just symptoms. Prefer small, reviewable commits.");
        sb.AppendLine("4. Add regression coverage for affected service/component boundaries.");
        sb.AppendLine("5. Validate the Development page still shows contextual error messages and working stack-trace/details behavior.");
        sb.AppendLine("6. Create the PR and include exact build/test commands run, remaining risks, and deployment notes.");

        return sb.ToString();
    }

    private List<string> BuildCredentialReferenceLines()
    {
        var references = Configuration
            .AsEnumerable()
            .Where(entry => IsCredentialOrServiceAccessKey(entry.Key))
            .Select(entry =>
            {
                var status = string.IsNullOrWhiteSpace(entry.Value) ? "not configured or empty" : "configured; value redacted";
                return $"{NormalizeConfigurationKey(entry.Key)}: [{status}]";
            })
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(line => line, StringComparer.OrdinalIgnoreCase)
            .Take(75)
            .ToList();

        references.Add("GitHub repository write access or an approved automation token: [required for branch and PR creation; value not available to the application]");
        references.Add("Deployment/runtime log access: [required for correlation with the system-wide error log; obtain through approved operations tooling]");

        return references
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static bool IsCredentialOrServiceAccessKey(string? key)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return false;
        }

        var normalized = NormalizeConfigurationKey(key);

        return normalized.StartsWith("ConnectionStrings:", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":ConnectionString", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":Password", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":Pwd", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":Secret", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":Token", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":ApiKey", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":ClientSecret", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":AccessKey", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":PrivateKey", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":Credential", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("AWS:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("RabbitMQ:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("RabbitMq:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("Postgres:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("Npgsql:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("Database:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("OpenTelemetry:", StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizeConfigurationKey(string key)
    {
        return key.Replace("__", ":", StringComparison.Ordinal);
    }

    private static string BuildServerIpAddressList()
    {
        try
        {
            var hostName = Dns.GetHostName();
            var addresses = Dns.GetHostAddresses(hostName)
                .Where(address => address.AddressFamily is AddressFamily.InterNetwork or AddressFamily.InterNetworkV6 && !IPAddress.IsLoopback(address))
                .Select(address => address.ToString())
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(address => address, StringComparer.OrdinalIgnoreCase)
                .ToList();

            return addresses.Count == 0 ? "none detected" : string.Join(", ", addresses);
        }
        catch (Exception ex)
        {
            return $"unavailable ({ex.GetType().Name}: {ex.Message})";
        }
    }

    private async Task ShowOutputAsync(WorkerHealthCheckResultDto r)
    {
        await Js.InvokeVoidAsync("alert", $"{r.WorkerName} Health Check Output:\n\n{r.Output}").ConfigureAwait(false);
    }

    private void ToggleErrorDetail(SystemError e)
    {
        if (_selectedError?.Id == e.Id)
        {
            _selectedError = null;
            return;
        }

        _selectedError = e;
    }

    private void CloseErrorDetail()
    {
        _selectedError = null;
    }

    private Dictionary<string, List<DockerContainerDto>> _dockerWorkers = new();
    private bool _loadingDockerWorkers;

    private readonly string[] _workerServices =
    [
        "worker-spider",
        "worker-enum",
        "worker-portscan",
        "worker-highvalue",
        "worker-techid",
        "worker-http-requester"
    ];

    private async Task LoadDockerWorkersAsync()
    {
        _loadingDockerWorkers = true;
        StateHasChanged();

        try
        {
            _dockerWorkers.Clear();

            foreach (var svc in _workerServices)
            {
                var containers = await DockerClient.GetContainersAsync(svc, _devPollCts.Token).ConfigureAwait(false);
                _dockerWorkers[svc] = containers;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not load docker workers. Ensure docker socket is mounted.");
        }
        finally
        {
            _loadingDockerWorkers = false;
        }
    }

    private async Task ScaleDownWorkerAsync(string serviceName)
    {
        if (!_dockerWorkers.TryGetValue(serviceName, out var list) || list.Count == 0)
        {
            return;
        }

        var container = list.Last();

        try
        {
            await DockerClient.KillContainerAsync(container.Id, _devPollCts.Token).ConfigureAwait(false);
            await LoadDockerWorkersAsync().ConfigureAwait(false);
            await RefreshErrorsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            await Js.InvokeVoidAsync("alert", $"Failed to kill container: {ex.Message}").ConfigureAwait(false);
        }
    }

    private async Task ScaleUpWorkerAsync(string serviceName)
    {
        try
        {
            await DockerClient.ScaleUpAsync(serviceName, _devPollCts.Token).ConfigureAwait(false);
            await LoadDockerWorkersAsync().ConfigureAwait(false);
            await RefreshErrorsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            await Js.InvokeVoidAsync("alert", $"Failed to scale up container: {ex.Message}").ConfigureAwait(false);
        }
    }

    private static bool HasStackTrace(SystemError e)
    {
        return !string.IsNullOrWhiteSpace(e.Exception);
    }

    private static string BuildErrorSummary(SystemError e)
    {
        var message = Fallback(e.Message, "Error log entry did not include a message.");
        var exceptionHeadline = GetExceptionHeadline(e.Exception);

        if (!string.IsNullOrWhiteSpace(exceptionHeadline))
        {
            if (IsGenericErrorMessage(message))
            {
                return exceptionHeadline;
            }

            var exceptionDetail = exceptionHeadline.Split(':', 2)[^1].Trim();

            if (!message.Contains(exceptionHeadline, StringComparison.OrdinalIgnoreCase) &&
                !message.Contains(exceptionDetail, StringComparison.OrdinalIgnoreCase))
            {
                return $"{message} — {exceptionHeadline}";
            }
        }

        return message;
    }

    private static string BuildContextLine(SystemError e)
    {
        var context = new List<string>
        {
            $"Logger: {Fallback(e.LoggerName, "unknown")}"
        };

        if (!string.IsNullOrWhiteSpace(e.MachineName))
        {
            context.Add($"Machine: {e.MachineName}");
        }

        var metadata = ParseMetadata(e.MetadataJson);

        if (metadata.TryGetValue("source", out var source) && !string.IsNullOrWhiteSpace(source))
        {
            context.Add($"Source: {source}");
        }

        if (metadata.TryGetValue("event_id", out var eventId) && !string.IsNullOrWhiteSpace(eventId))
        {
            context.Add($"EventId: {eventId}");
        }

        if (metadata.TryGetValue("event_name", out var eventName) && !string.IsNullOrWhiteSpace(eventName))
        {
            context.Add($"Event: {eventName}");
        }

        if (metadata.TryGetValue("trace_id", out var traceId) && !string.IsNullOrWhiteSpace(traceId))
        {
            context.Add($"Trace: {traceId}");
        }

        if (metadata.TryGetValue("containerId", out var containerId) && !string.IsNullOrWhiteSpace(containerId))
        {
            context.Add($"Container: {containerId}");
        }

        return string.Join(" • ", context);
    }

    private static string BuildFullErrorDetail(SystemError e)
    {
        var sb = new StringBuilder();

        sb.AppendLine($"Time: {e.Timestamp.ToLocalTime():yyyy-MM-dd HH:mm:ss zzz}");
        sb.AppendLine($"Component: {Fallback(e.Component, "unknown")}");
        sb.AppendLine($"Level: {Fallback(e.LogLevel, "Error")}");
        sb.AppendLine($"Logger: {Fallback(e.LoggerName, "unknown")}");
        sb.AppendLine($"Machine: {Fallback(e.MachineName, "unknown")}");
        sb.AppendLine();
        sb.AppendLine("Message:");
        sb.AppendLine(Fallback(e.Message, "Error log entry did not include a message."));

        if (!string.IsNullOrWhiteSpace(e.Exception))
        {
            sb.AppendLine();
            sb.AppendLine("Exception / Docker log context:");
            sb.AppendLine(e.Exception.Trim());
        }

        if (!string.IsNullOrWhiteSpace(e.MetadataJson))
        {
            sb.AppendLine();
            sb.AppendLine("Metadata:");
            sb.AppendLine(FormatMetadata(e.MetadataJson));
        }

        return sb.ToString();
    }

    private static string? GetExceptionHeadline(string? exception)
    {
        if (string.IsNullOrWhiteSpace(exception))
        {
            return null;
        }

        var firstLine = exception
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .FirstOrDefault();

        return string.IsNullOrWhiteSpace(firstLine) ? null : firstLine;
    }

    private static bool IsGenericErrorMessage(string message)
    {
        var normalized = message.Trim().TrimEnd('.');

        return normalized.Equals("An error has occurred", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("An error has occured", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("An unhandled exception has occurred while executing the request", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("Unhandled exception rendering component", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("Circuit host terminated unexpectedly", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatMetadata(string metadataJson)
    {
        try
        {
            using var document = JsonDocument.Parse(metadataJson);

            return JsonSerializer.Serialize(
                document.RootElement,
                new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return metadataJson;
        }
    }

    private static IReadOnlyDictionary<string, string?> ParseMetadata(string? metadataJson)
    {
        if (string.IsNullOrWhiteSpace(metadataJson))
        {
            return new Dictionary<string, string?>();
        }

        try
        {
            using var document = JsonDocument.Parse(metadataJson);

            if (document.RootElement.ValueKind != JsonValueKind.Object)
            {
                return new Dictionary<string, string?>();
            }

            return document.RootElement
                .EnumerateObject()
                .ToDictionary(
                    property => property.Name,
                    property => property.Value.ValueKind == JsonValueKind.String ? property.Value.GetString() : property.Value.ToString(),
                    StringComparer.OrdinalIgnoreCase);
        }
        catch
        {
            return new Dictionary<string, string?>();
        }
    }

    private static string Fallback(string? value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();
    }

    public void Dispose()
    {
        Realtime.DomainEventReceived -= OnRealtimeEvent;
        _devPollCts.Cancel();
        _devPollCts.Dispose();
    }
