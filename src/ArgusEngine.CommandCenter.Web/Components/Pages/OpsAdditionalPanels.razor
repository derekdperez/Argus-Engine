@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using ArgusEngine.CommandCenter.Web.Clients
@using Radzen
@using Radzen.Blazor
@inject WorkerControlApiClient WorkerApi

<section class="ops-extra-panels">
    <div class="ops-extra-grid">
        <RadzenCard class="ops-extra-card">
            <div class="ops-extra-header">
                <div>
                    <p class="eyebrow">High Value</p>
                    <h2>High Value Assets</h2>
                    <p class="muted">Moved from the standalone High Value page. Standard grid filtering, sorting, and paging are enabled.</p>
                </div>
                <RadzenButton ButtonStyle="ButtonStyle.Secondary"
                              Size="ButtonSize.Small"
                              Click="@ReloadHighValueAsync"
                              Disabled="@_highValueLoading"
                              Text="@(_highValueLoading ? "Refreshing..." : "Refresh")" />
            </div>

            <div class="ops-extra-toolbar">
                <RadzenTextBox @bind-Value="_highValueSearch"
                               Placeholder="Search high value assets..."
                               Change="@(_ => StateHasChanged())"
                               Style="min-width: 18rem;" />
                <RadzenDropDown TValue="string"
                                Data="@HighValueStatusOptions"
                                @bind-Value="_highValueStatusFilter"
                                Change="@(_ => StateHasChanged())"
                                Style="min-width: 12rem;" />
            </div>

            <RadzenDataGrid TItem="HighValueGridRow"
                            Data="@FilteredHighValueRows"
                            AllowFiltering="true"
                            FilterMode="FilterMode.Simple"
                            AllowSorting="true"
                            AllowPaging="true"
                            PageSize="250"
                            PageSizeOptions="@GridPageSizeOptions"
                            AllowVirtualization="true"
                            Style="height: 560px"
                            Density="Density.Compact"
                            IsLoading="@_highValueLoading"
                            EmptyText="No high value assets found.">
                <Columns>
                    <RadzenDataGridColumn TItem="HighValueGridRow" Property="LastSeenAtUtc" Title="Last seen" Width="190px">
                        <Template Context="row">@AppTimeFormat.Format(row.LastSeenAtUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HighValueGridRow" Property="InvestigationStatus" Title="Status" Width="140px" />
                    <RadzenDataGridColumn TItem="HighValueGridRow" Property="TargetRootDomain" Title="Target" Width="180px" />
                    <RadzenDataGridColumn TItem="HighValueGridRow" Property="Kind" Title="Kind" Width="110px" />
                    <RadzenDataGridColumn TItem="HighValueGridRow" Property="Category" Title="Category" Width="130px" />
                    <RadzenDataGridColumn TItem="HighValueGridRow" Property="FinalUrl" Title="URL / Asset" Width="280px">
                        <Template Context="row">
                            @if (IsHttpUrl(row.FinalUrl))
                            {
                                <a href="@row.FinalUrl" target="_blank" rel="noopener noreferrer">@row.FinalUrl</a>
                            }
                            else
                            {
                                @DisplayOrDash(row.FinalUrl)
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HighValueGridRow" Property="FindingType" Title="Finding" Width="160px" />
                    <RadzenDataGridColumn TItem="HighValueGridRow" Property="Severity" Title="Severity" Width="110px" />
                    <RadzenDataGridColumn TItem="HighValueGridRow" Property="PatternName" Title="Pattern" Width="170px" />
                    <RadzenDataGridColumn TItem="HighValueGridRow" Property="MatchedText" Title="Matched text" />
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>

        <RadzenCard class="ops-extra-card">
            <div class="ops-extra-header">
                <div>
                    <p class="eyebrow">Technology ID</p>
                    <h2>Top 10 Technologies</h2>
                    <p class="muted">Grouped by technology name regardless of version. Select a name to inspect version usage.</p>
                </div>
                <RadzenButton ButtonStyle="ButtonStyle.Secondary"
                              Size="ButtonSize.Small"
                              Click="@ReloadTechnologiesAsync"
                              Disabled="@_technologyLoading"
                              Text="@(_technologyLoading ? "Refreshing..." : "Refresh")" />
            </div>

            @if (_technologyLoading && TopTechnologyRows.Count == 0)
            {
                <p class="muted">Loading technology usage…</p>
            }
            else if (TopTechnologyRows.Count == 0)
            {
                <p class="muted">No technology usage has been recorded yet.</p>
            }
            else
            {
                <ol class="top-tech-list">
                    @foreach (var row in TopTechnologyRows.Take(10))
                    {
                        <li>
                            <button type="button" class="link-button" @onclick="@(() => SelectTechnology(row.Name))">
                                @row.Name
                            </button>
                            <span>(@FormatNumber(row.TargetCount) targets, @FormatNumber(row.SubdomainCount) subdomains)</span>
                        </li>
                    }
                </ol>
            }

            <div class="ops-extra-toolbar">
                <RadzenTextBox @bind-Value="_technologySearch"
                               Placeholder="Search technology detections..."
                               Change="@(_ => StateHasChanged())"
                               Style="min-width: 18rem;" />
            </div>

            <RadzenDataGrid TItem="TechnologyGridRow"
                            Data="@FilteredTechnologyRows"
                            AllowFiltering="true"
                            FilterMode="FilterMode.Simple"
                            AllowSorting="true"
                            AllowPaging="true"
                            PageSize="250"
                            PageSizeOptions="@GridPageSizeOptions"
                            AllowVirtualization="true"
                            Style="height: 560px"
                            Density="Density.Compact"
                            IsLoading="@_technologyLoading"
                            EmptyText="No technology detections found.">
                <Columns>
                    <RadzenDataGridColumn TItem="TechnologyGridRow" Property="LastSeenUtc" Title="Last seen" Width="190px">
                        <Template Context="row">@AppTimeFormat.Format(row.LastSeenUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TechnologyGridRow" Property="TargetRootDomain" Title="Target" Width="180px" />
                    <RadzenDataGridColumn TItem="TechnologyGridRow" Property="Subdomain" Title="Subdomain" Width="220px" />
                    <RadzenDataGridColumn TItem="TechnologyGridRow" Property="TechnologyName" Title="Technology" Width="180px" />
                    <RadzenDataGridColumn TItem="TechnologyGridRow" Property="Version" Title="Version" Width="120px" />
                    <RadzenDataGridColumn TItem="TechnologyGridRow" Property="SourceType" Title="Source" Width="120px" />
                    <RadzenDataGridColumn TItem="TechnologyGridRow" Property="DetectionMode" Title="Mode" Width="140px" />
                    <RadzenDataGridColumn TItem="TechnologyGridRow" Property="EvidenceSummary" Title="Evidence" />
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </div>
</section>

@if (_selectedTechnologyName is not null)
{
    <div class="ops-modal-backdrop" role="presentation" @onclick="CloseTechnologyBreakdown">
        <div class="ops-modal" role="dialog" aria-modal="true" aria-labelledby="technology-breakdown-title" @onclick:stopPropagation="true">
            <div class="ops-extra-header">
                <div>
                    <p class="eyebrow">Version breakdown</p>
                    <h2 id="technology-breakdown-title">@_selectedTechnologyName</h2>
                </div>
                <RadzenButton ButtonStyle="ButtonStyle.Secondary"
                              Size="ButtonSize.Small"
                              Click="@CloseTechnologyBreakdown"
                              Text="Close" />
            </div>

            <RadzenDataGrid TItem="TechnologyVersionGridRow"
                            Data="@SelectedTechnologyVersionRows"
                            AllowFiltering="true"
                            FilterMode="FilterMode.Simple"
                            AllowSorting="true"
                            AllowPaging="true"
                            PageSize="250"
                            PageSizeOptions="@GridPageSizeOptions"
                            AllowVirtualization="true"
                            Style="height: 420px"
                            Density="Density.Compact"
                            EmptyText="No version usage found.">
                <Columns>
                    <RadzenDataGridColumn TItem="TechnologyVersionGridRow" Property="Version" Title="Version" />
                    <RadzenDataGridColumn TItem="TechnologyVersionGridRow" Property="TargetCount" Title="Targets" />
                    <RadzenDataGridColumn TItem="TechnologyVersionGridRow" Property="SubdomainCount" Title="Subdomains" />
                </Columns>
            </RadzenDataGrid>
        </div>
    </div>
}

@code {
    private readonly CancellationTokenSource _cts = new();
    private readonly List<HighValueGridRow> _highValueRows = [];
    private readonly List<TechnologyGridRow> _technologyRows = [];
    private readonly List<TechnologyUsageRow> _technologyUsageRows = [];
    private bool _highValueLoading = true;
    private bool _technologyLoading = true;
    private string _highValueSearch = "";
    private string _highValueStatusFilter = "Active";
    private string _technologySearch = "";
    private string? _selectedTechnologyName;
    private static readonly int[] GridPageSizeOptions = [250, 1000, 10000];

    private static readonly string[] HighValueStatusOptions = ["Active", "All", "Pending", "In Process", "False Positive", "Valid Finding"];

    private IReadOnlyList<HighValueGridRow> FilteredHighValueRows => _highValueRows
        .Where(row => _highValueStatusFilter switch
        {
            "Active" => row.IsHighValue && !string.Equals(row.InvestigationStatus, "False Positive", StringComparison.OrdinalIgnoreCase),
            "All" => true,
            _ => string.Equals(row.InvestigationStatus, _highValueStatusFilter, StringComparison.OrdinalIgnoreCase)
        })
        .Where(row => string.IsNullOrWhiteSpace(_highValueSearch) || row.SearchText.Contains(_highValueSearch, StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(row => row.LastSeenAtUtc ?? row.FindingDiscoveredAtUtc)
        .ToArray();

    private IReadOnlyList<TechnologyGridRow> FilteredTechnologyRows => _technologyRows
        .Where(row => string.IsNullOrWhiteSpace(_technologySearch) || row.SearchText.Contains(_technologySearch, StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(row => row.LastSeenUtc)
        .ToArray();

    private IReadOnlyList<TopTechnologyGridRow> TopTechnologyRows
    {
        get
        {
            var usageRows = BuildTopTechnologyRowsFromUsage();
            if (usageRows.Count > 0)
            {
                return usageRows;
            }

            return _technologyRows
                .Where(row => !string.IsNullOrWhiteSpace(row.TechnologyName))
                .GroupBy(row => row.TechnologyName, StringComparer.OrdinalIgnoreCase)
                .Select(group => new TopTechnologyGridRow(
                    group.Key,
                    group.Select(row => row.TargetRootDomain).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount(),
                    group.Select(row => row.Subdomain).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount()))
                .OrderByDescending(row => row.SubdomainCount)
                .ThenByDescending(row => row.TargetCount)
                .ThenBy(row => row.Name, StringComparer.OrdinalIgnoreCase)
                .ToArray();
        }
    }

    private IReadOnlyList<TechnologyVersionGridRow> SelectedTechnologyVersionRows
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_selectedTechnologyName))
            {
                return [];
            }

            var usageRows = _technologyUsageRows
                .Where(row => string.Equals(row.TechnologyName, _selectedTechnologyName, StringComparison.OrdinalIgnoreCase))
                .GroupBy(row => string.IsNullOrWhiteSpace(row.Version) ? "Unknown / unversioned" : row.Version, StringComparer.OrdinalIgnoreCase)
                .Select(group => new TechnologyVersionGridRow(
                    group.Key,
                    group.SelectMany(row => row.Locations).Select(location => location.TargetId).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount(),
                    group.SelectMany(row => row.Locations).Select(location => location.Subdomain).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount()))
                .ToArray();

            if (usageRows.Length > 0)
            {
                return usageRows
                    .OrderByDescending(row => row.SubdomainCount)
                    .ThenByDescending(row => row.TargetCount)
                    .ThenBy(row => row.Version, StringComparer.OrdinalIgnoreCase)
                    .ToArray();
            }

            return _technologyRows
                .Where(row => string.Equals(row.TechnologyName, _selectedTechnologyName, StringComparison.OrdinalIgnoreCase))
                .GroupBy(row => string.IsNullOrWhiteSpace(row.Version) ? "Unknown / unversioned" : row.Version, StringComparer.OrdinalIgnoreCase)
                .Select(group => new TechnologyVersionGridRow(
                    group.Key,
                    group.Select(row => row.TargetRootDomain).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount(),
                    group.Select(row => row.Subdomain).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount()))
                .OrderByDescending(row => row.SubdomainCount)
                .ThenByDescending(row => row.TargetCount)
                .ThenBy(row => row.Version, StringComparer.OrdinalIgnoreCase)
                .ToArray();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(ReloadHighValueAsync(), ReloadTechnologiesAsync()).ConfigureAwait(false);
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private async Task ReloadHighValueAsync()
    {
        _highValueLoading = true;
        try
        {
            var elements = await GetJsonArrayAsync("/api/high-value-assets?limit=500", "items", "rows", "findings", "assets").ConfigureAwait(false);
            _highValueRows.Clear();
            _highValueRows.AddRange(elements.Select(HighValueGridRow.FromJson));
        }
        catch
        {
            _highValueRows.Clear();
        }
        finally
        {
            _highValueLoading = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private async Task ReloadTechnologiesAsync()
    {
        _technologyLoading = true;
        try
        {
            var usageTask = GetJsonArrayAsync("/api/technology-identification/usage", "items", "rows", "usage");
            var techTask = GetJsonArrayAsync("/api/technology-identification/technologies", "items", "rows", "technologies", "detections");

            await Task.WhenAll(usageTask, techTask).ConfigureAwait(false);

            _technologyUsageRows.Clear();
            _technologyUsageRows.AddRange(usageTask.Result.Select(TechnologyUsageRow.FromJson));

            _technologyRows.Clear();
            _technologyRows.AddRange(techTask.Result.Select(TechnologyGridRow.FromJson));
        }
        catch
        {
            _technologyUsageRows.Clear();
            _technologyRows.Clear();
        }
        finally
        {
            _technologyLoading = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private void SelectTechnology(string name)
    {
        _selectedTechnologyName = name;
    }

    private void CloseTechnologyBreakdown()
    {
        _selectedTechnologyName = null;
    }

    private IReadOnlyList<TopTechnologyGridRow> BuildTopTechnologyRowsFromUsage() => _technologyUsageRows
        .Where(row => !string.IsNullOrWhiteSpace(row.TechnologyName))
        .GroupBy(row => row.TechnologyName, StringComparer.OrdinalIgnoreCase)
        .Select(group =>
        {
            var locations = group.SelectMany(row => row.Locations).ToArray();
            return new TopTechnologyGridRow(
                group.Key,
                locations.Select(location => location.TargetId).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount(),
                locations.Select(location => location.Subdomain).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount());
        })
        .OrderByDescending(row => row.SubdomainCount)
        .ThenByDescending(row => row.TargetCount)
        .ThenBy(row => row.Name, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private async Task<IReadOnlyList<JsonElement>> GetJsonArrayAsync(string url, params string[] envelopePropertyNames)
    {
        using var response = await WorkerApi.Client.GetAsync(url, _cts.Token).ConfigureAwait(false);
        response.EnsureSuccessStatusCode();

        await using var stream = await response.Content.ReadAsStreamAsync(_cts.Token).ConfigureAwait(false);
        using var doc = await JsonDocument.ParseAsync(stream, cancellationToken: _cts.Token).ConfigureAwait(false);
        var root = doc.RootElement;

        if (root.ValueKind == JsonValueKind.Array)
        {
            return root.EnumerateArray().Select(element => element.Clone()).ToArray();
        }

        foreach (var name in envelopePropertyNames)
        {
            if (TryGetProperty(root, name, out var property) && property.ValueKind == JsonValueKind.Array)
            {
                return property.EnumerateArray().Select(element => element.Clone()).ToArray();
            }
        }

        return [];
    }

    private static bool TryGetProperty(JsonElement element, string name, out JsonElement value)
    {
        if (element.ValueKind == JsonValueKind.Object)
        {
            foreach (var property in element.EnumerateObject())
            {
                if (string.Equals(property.Name, name, StringComparison.OrdinalIgnoreCase))
                {
                    value = property.Value;
                    return true;
                }
            }
        }

        value = default;
        return false;
    }

    private static string Text(JsonElement element, params string[] names)
    {
        foreach (var name in names)
        {
            if (TryGetProperty(element, name, out var value))
            {
                return value.ValueKind switch
                {
                    JsonValueKind.String => value.GetString() ?? "",
                    JsonValueKind.Number => value.ToString(),
                    JsonValueKind.True => "true",
                    JsonValueKind.False => "false",
                    _ => value.ToString()
                };
            }
        }

        return "";
    }

    private static bool Bool(JsonElement element, bool defaultValue, params string[] names)
    {
        foreach (var name in names)
        {
            if (TryGetProperty(element, name, out var value))
            {
                if (value.ValueKind is JsonValueKind.True or JsonValueKind.False)
                {
                    return value.GetBoolean();
                }

                if (bool.TryParse(value.ToString(), out var parsed))
                {
                    return parsed;
                }
            }
        }

        return defaultValue;
    }

    private static DateTimeOffset? Date(JsonElement element, params string[] names)
    {
        var text = Text(element, names);
        return DateTimeOffset.TryParse(text, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var parsed)
            ? parsed
            : null;
    }

    private static string DisplayOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static bool IsHttpUrl(string? value) => Uri.TryCreate(value, UriKind.Absolute, out var uri)
        && (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);

    private static string FormatNumber(long value) => value.ToString("N0", CultureInfo.InvariantCulture);

    private sealed record HighValueGridRow(
        DateTimeOffset? LastSeenAtUtc,
        DateTimeOffset? FindingDiscoveredAtUtc,
        string InvestigationStatus,
        string TargetRootDomain,
        string Kind,
        string Category,
        string FinalUrl,
        string FindingType,
        string Severity,
        string PatternName,
        string MatchedText,
        bool IsHighValue)
    {
        public string SearchText => string.Join(" ", InvestigationStatus, TargetRootDomain, Kind, Category, FinalUrl, FindingType, Severity, PatternName, MatchedText);

        public static HighValueGridRow FromJson(JsonElement element) => new(
            Date(element, "lastSeenAtUtc", "LastSeenAtUtc", "lastSeenUtc", "LastSeenUtc"),
            Date(element, "findingDiscoveredAtUtc", "FindingDiscoveredAtUtc", "discoveredAtUtc", "DiscoveredAtUtc"),
            DisplayOrDash(Text(element, "investigationStatus", "InvestigationStatus", "status", "Status")),
            Text(element, "targetRootDomain", "TargetRootDomain", "rootDomain", "RootDomain"),
            Text(element, "kind", "Kind", "assetKind", "AssetKind"),
            Text(element, "category", "Category", "assetCategory", "AssetCategory"),
            Text(element, "finalUrl", "FinalUrl", "url", "Url", "assetUrl", "AssetUrl", "rawValue", "RawValue"),
            Text(element, "findingType", "FindingType", "type", "Type"),
            Text(element, "severity", "Severity"),
            Text(element, "patternName", "PatternName", "pattern", "Pattern"),
            Text(element, "matchedText", "MatchedText", "evidence", "Evidence"),
            Bool(element, true, "isHighValue", "IsHighValue"));
    }

    private sealed record TechnologyGridRow(
        DateTimeOffset? LastSeenUtc,
        string TargetRootDomain,
        string Subdomain,
        string TechnologyName,
        string Version,
        string SourceType,
        string DetectionMode,
        string EvidenceSummary)
    {
        public string SearchText => string.Join(" ", TargetRootDomain, Subdomain, TechnologyName, Version, SourceType, DetectionMode, EvidenceSummary);

        public static TechnologyGridRow FromJson(JsonElement element) => new(
            Date(element, "lastSeenUtc", "LastSeenUtc", "lastSeenAtUtc", "LastSeenAtUtc"),
            Text(element, "targetRootDomain", "TargetRootDomain", "rootDomain", "RootDomain"),
            Text(element, "subdomain", "Subdomain", "host", "Host"),
            Text(element, "technologyName", "TechnologyName", "name", "Name"),
            Text(element, "version", "Version"),
            Text(element, "sourceType", "SourceType", "source", "Source"),
            Text(element, "detectionMode", "DetectionMode", "mode", "Mode"),
            Text(element, "evidenceSummary", "EvidenceSummary", "evidence", "Evidence"));
    }

    private sealed record TechnologyUsageRow(string TechnologyName, string Version, IReadOnlyList<TechnologyUsageLocation> Locations)
    {
        public static TechnologyUsageRow FromJson(JsonElement element)
        {
            var locations = new List<TechnologyUsageLocation>();
            if (TryGetProperty(element, "locations", out var array) || TryGetProperty(element, "Locations", out array))
            {
                if (array.ValueKind == JsonValueKind.Array)
                {
                    locations.AddRange(array.EnumerateArray().Select(TechnologyUsageLocation.FromJson));
                }
            }

            if (locations.Count == 0)
            {
                locations.Add(new TechnologyUsageLocation(
                    Text(element, "targetId", "TargetId", "targetRootDomain", "TargetRootDomain"),
                    Text(element, "subdomain", "Subdomain", "host", "Host")));
            }

            return new TechnologyUsageRow(
                Text(element, "technologyName", "TechnologyName", "name", "Name"),
                Text(element, "version", "Version"),
                locations);
        }
    }

    private sealed record TechnologyUsageLocation(string TargetId, string Subdomain)
    {
        public static TechnologyUsageLocation FromJson(JsonElement element) => new(
            Text(element, "targetId", "TargetId", "targetRootDomain", "TargetRootDomain"),
            Text(element, "subdomain", "Subdomain", "host", "Host"));
    }

    private sealed record TopTechnologyGridRow(string Name, long TargetCount, long SubdomainCount);

    private sealed record TechnologyVersionGridRow(string Version, long TargetCount, long SubdomainCount);
}
