    protected override Task OnInitializedAsync()
    {
        Realtime.DomainEventReceived += OnRealtimeEvent;
        Realtime.ConnectionStateChanged += OnRealtimeConnectionChanged;
        return Task.CompletedTask;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialLoadStarted)
        {
            _initialLoadStarted = true;
            _ = InvokeAsync(InitializeAfterFirstRenderAsync);
        }

        return Task.CompletedTask;
    }

    private async Task InitializeAfterFirstRenderAsync()
    {
        await ReloadAllAsync().ConfigureAwait(false);
        await StartRealtimeAsync().ConfigureAwait(false);
        _ = PollLiveAsync();
        await InvokeAsync(StateHasChanged).ConfigureAwait(false);
    }

    private async Task StartRealtimeAsync()
    {
        try
        {
            await Realtime.EnsureStartedAsync(_realtimeCts.Token).ConfigureAwait(false);
        }
        catch
        {
            // One-second live polling remains active if the hub cannot connect.
        }
    }

    private void OnRealtimeEvent(object? sender, LiveUiEventDto evt)
    {
        _ = evt;
        _ = InvokeAsync(ReloadLiveAsync);
    }

    private void OnRealtimeConnectionChanged(object? sender, EventArgs args)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task PollLiveAsync()
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            while (await timer.WaitForNextTickAsync(_realtimeCts.Token).ConfigureAwait(false))
            {
                await ReloadLiveAsync().ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ReloadLiveAsync()
    {
        var now = DateTimeOffset.UtcNow;
        if (_liveRefreshRunning || now - _lastLiveRefreshUtc < TimeSpan.FromSeconds(1))
        {
            return;
        }

        _liveRefreshRunning = true;
        _lastLiveRefreshUtc = now;
        try
        {
            await Task.WhenAll(
                    ReloadOverviewAsync(),
                    ReloadHttpQueueAsync())
                .ConfigureAwait(false);
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
        catch
        {
            // Keep the current snapshot visible; the next tick/event will retry.
        }
        finally
        {
            _liveRefreshRunning = false;
        }
    }

    private async Task ReloadAllAsync()
    {
        _statusMessage = "";

        try
        {
            await Task.WhenAll(
                ReloadOverviewAsync(),
                ReloadTargetsAsync(),
                ReloadAssetsAsync(),
                ReloadHttpQueueAsync());
        }
        catch (Exception ex)
        {
            _statusMessage = $"Operations refresh failed: {ex.Message}";
        }
        finally
        {
            EnsureSelection();
        }
    }

    private async Task CreateTargetAsync()
    {
        if (!CanCreateTarget)
