    private bool StatusMatches(HighValueAssetRowDto row) => _highValueStatusFilter switch
    {
        "Active" => row.IsHighValue && row.InvestigationStatus is not ("False Positive" or "Valid Finding"),
        "" => true,
        _ => string.Equals(row.InvestigationStatus, _highValueStatusFilter, StringComparison.OrdinalIgnoreCase),
    };

    private static bool HighValueAssetMatches(HighValueAssetRowDto row, string search)
    {
        if (string.IsNullOrWhiteSpace(search))
        {
            return true;
        }

        return Matches(row.TargetRootDomain, search)
            || Matches(row.Kind, search)
            || Matches(row.Category, search)
            || Matches(row.FinalUrl, search)
            || Matches(row.RawValue, search)
            || Matches(row.DisplayName, search)
            || Matches(row.DiscoveredBy, search)
            || Matches(row.DiscoveryContext, search)
            || Matches(row.WorkerName, search)
            || Matches(row.FindingType, search)
            || Matches(row.Severity, search)
            || Matches(row.PatternName, search)
            || Matches(row.MatchedText, search)
            || Matches(row.InvestigationStatus, search);
    }

    private static bool TechnologyMatches(TechnologyIdentificationRowDto row, string search)
    {
        return string.IsNullOrWhiteSpace(search)
            || Matches(row.TargetRootDomain, search)
            || Matches(row.Subdomain, search)
            || Matches(row.AssetCanonicalKey, search)
            || Matches(row.TechnologyName, search)
            || Matches(row.Vendor, search)
            || Matches(row.Product, search)
            || Matches(row.Version, search)
            || Matches(row.SourceType, search)
            || Matches(row.DetectionMode, search)
            || Matches(row.FingerprintId, search)
            || Matches(row.EvidenceSummary, search);
    }

