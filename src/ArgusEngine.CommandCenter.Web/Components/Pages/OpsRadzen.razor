@page "/"
@page "/ops"
@rendermode InteractiveServer
@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using ArgusEngine.CommandCenter.Contracts
@using ArgusEngine.CommandCenter.Web.Clients
@implements IDisposable
@inject WorkerControlApiClient WorkerApi

<PageTitle>Operations - Argus Engine</PageTitle>

<section class="ops-shell">
    <header class="ops-header">
        <div>
            <p class="eyebrow">Operations</p>
            <h1>Argus Engine Command Center</h1>
            <p class="muted">Targets, assets, workers, and HTTP request flow.</p>
        </div>
        <button class="btn primary" type="button" @onclick="ReloadAllAsync" disabled="@_loadingAny">
            @(_loadingAny ? "Refreshing..." : "Refresh")
        </button>
    </header>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="status-banner">@_statusMessage</div>
    }

    <section class="summary-grid">
        <article class="summary-card">
            <span>Targets</span>
            <strong>@(_targetsLoading && TotalTargets == 0 ? "—" : FormatNumber(TotalTargets))</strong>
        </article>
        <article class="summary-card">
            <span>Assets</span>
            <strong>@(_assetsLoading && ConfirmedAssets == 0 ? "—" : FormatNumber(ConfirmedAssets))</strong>
        </article>
        <article class="summary-card">
            <span>Subdomains</span>
            <strong>@(_assetsLoading && ConfirmedSubdomains == 0 ? "—" : FormatNumber(ConfirmedSubdomains))</strong>
        </article>
        <article class="summary-card">
            <span>HTTP Queue</span>
            <strong>@(_httpLoading && HttpQueueQueuedCount == 0 ? "—" : $"{FormatNumber(HttpQueueQueuedCount)} queued")</strong>
            <small>@FormatNumber(HttpRequestsSentPerMinute) sent/min</small>
        </article>
        <article class="summary-card wide">
            <span>Asset Storage</span>
            <strong>@FormatStorageSize(TotalTrackedStorageBytes)</strong>
            <small>@StorageBreakdownLabel</small>
        </article>
    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Scope</p>
                <h2>Targets</h2>
            </div>
            <span class="badge">@FormatNumber(TargetRows.Count) visible</span>
        </div>

        <div class="toolbar">
            <input placeholder="New target" @bind="_newTargetRootDomain" />
            <input type="number" min="1" max="50" @bind="_newTargetDepth" />
            <button class="btn" type="button" @onclick="CreateTargetAsync" disabled="@(!CanCreateTarget)">Add Target</button>
            <input placeholder="Search targets" @bind="_targetSearch" @bind:event="oninput" />
            <select @bind="_targetFilter">
                <option value="">All</option>
                <option value="with-assets">With assets</option>
                <option value="with-subdomains">With subdomains</option>
            </select>
        </div>

        <div class="toolbar">
            <button class="btn primary" type="button" @onclick="() => StartEnumerationAsync(selectedOnly: true)" disabled="@(_enumLoading || _selectedTargetIds.Count == 0)">
                @(_enumLoading ? "Starting..." : $"Enumerate selected ({_selectedTargetIds.Count})")
            </button>
            <button class="btn" type="button" @onclick="() => StartEnumerationAsync(selectedOnly: false)" disabled="@_enumLoading">
                Enumerate all visible
            </button>
            <button class="btn primary" type="button" @onclick="() => StartSpiderAsync(selectedOnly: true)" disabled="@(_spiderLoading || _selectedTargetIds.Count == 0)">
                @(_spiderLoading ? "Starting..." : $"Spider selected ({_selectedTargetIds.Count})")
            </button>
            <button class="btn" type="button" @onclick="() => StartSpiderAsync(selectedOnly: false)" disabled="@_spiderLoading">
                Spider all visible
            </button>
        </div>

        <div class="table-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th><input type="checkbox" checked="@AllVisibleTargetsSelected" @onchange="ToggleAllVisibleTargets" /></th>
                        <th><button class="link-btn" @onclick='() => SortTargets("name")'>Target</button></th>
                        <th><button class="link-btn" @onclick='() => SortTargets("depth")'>Depth</button></th>
                        <th><button class="link-btn" @onclick='() => SortTargets("subdomains")'>Subs</button></th>
                        <th><button class="link-btn" @onclick='() => SortTargets("assets")'>Assets</button></th>
                        <th><button class="link-btn" @onclick='() => SortTargets("lastRun")'>Last run</button></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var target in TargetRows)
                    {
                        var id = Text(target, "id", "Id");
                        <tr class="@RowClass(id == _activeTargetId)" @onclick="() => ActivateTarget(id)">
                            <td @onclick:stopPropagation="true"><input type="checkbox" checked="@_selectedTargetIds.Contains(id)" @onchange="args => ToggleTarget(id, args)" /></td>
                            <td>@DisplayOrDash(Text(target, "rootDomain", "RootDomain"))</td>
                            <td>@DisplayOrDash(Text(target, "globalMaxDepth", "GlobalMaxDepth"))</td>
                            <td>@FormatNumber(Long(target, "subdomainCount", "SubdomainCount"))</td>
                            <td>@FormatNumber(Long(target, "confirmedAssetCount", "ConfirmedAssetCount"))</td>
                            <td>@FormatTime(Text(target, "lastRunAtUtc", "LastRunAtUtc"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Scope</p>
                <h2>Subdomains</h2>
                <p class="muted">@ActiveTargetLabel</p>
            </div>
            <span class="badge">@FormatNumber(SubdomainRows.Count) visible</span>
        </div>

        <div class="toolbar">
            <input placeholder="Search subdomains" @bind="_subdomainSearch" @bind:event="oninput" />
            <button class="btn primary" type="button" @onclick="StartSpiderForSelectedSubdomainsAsync" disabled="@(_spiderLoading || _selectedSubdomainKeys.Count == 0)">
                Spider selected subdomains (@_selectedSubdomainKeys.Count)
            </button>
            <button class="btn" type="button" @onclick="() => StartSpiderAsync(selectedOnly: true)" disabled="@(_spiderLoading || string.IsNullOrWhiteSpace(_activeTargetId))">
                Spider active target
            </button>
        </div>

        <div class="table-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th><input type="checkbox" checked="@AllVisibleSubdomainsSelected" @onchange="ToggleAllVisibleSubdomains" /></th>
                        <th><button class="link-btn" @onclick='() => SortSubdomains("name")'>Subdomain</button></th>
                        <th><button class="link-btn" @onclick='() => SortSubdomains("discovered")'>Discovered</button></th>
                        <th>How found</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in SubdomainRows)
                    {
                        var key = SubdomainKey(row);
                        <tr class="@RowClass(_selectedSubdomainKeys.Contains(key))">
                            <td><input type="checkbox" checked="@_selectedSubdomainKeys.Contains(key)" @onchange="args => ToggleSubdomain(key, args)" /></td>
                            <td>@DisplayOrDash(SubdomainName(row))</td>
                            <td>@FormatTime(Text(row, "discoveredAtUtc", "DiscoveredAtUtc"))</td>
                            <td>@DisplayOrDash(Text(row, "discoveryContext", "DiscoveryContext"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Inventory</p>
                <h2>Assets</h2>
            </div>
            <span class="badge">@FormatNumber(AssetRows.Count) visible</span>
        </div>

        <div class="toolbar">
            <input placeholder="Search assets" @bind="_assetSearch" @bind:event="oninput" />
            <select @bind="_assetFilter">
                <option value="">All kinds</option>
                <option value="Domain">Domain</option>
                <option value="Subdomain">Subdomain</option>
                <option value="Url">URL</option>
                <option value="IpAddress">IP address</option>
                <option value="OpenPort">Open port</option>
            </select>
            <button class="btn" type="button" @onclick="ReloadAssetsAsync" disabled="@_assetsLoading">Reload assets</button>
        </div>

        <div class="table-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th><input type="checkbox" checked="@AllVisibleAssetsSelected" @onchange="ToggleAllVisibleAssets" /></th>
                        <th><button class="link-btn" @onclick='() => SortAssets("kind")'>Kind</button></th>
                        <th><button class="link-btn" @onclick='() => SortAssets("value")'>Value</button></th>
                        <th><button class="link-btn" @onclick='() => SortAssets("discovered")'>Discovered</button></th>
                        <th><button class="link-btn" @onclick='() => SortAssets("lastSeen")'>Last seen</button></th>
                        <th>How found</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var asset in AssetRows)
                    {
                        var id = Text(asset, "id", "Id");
                        <tr>
                            <td><input type="checkbox" checked="@_selectedAssetIds.Contains(id)" @onchange="args => ToggleAsset(id, args)" /></td>
                            <td>@DisplayOrDash(Text(asset, "kind", "Kind"))</td>
                            <td>@DisplayOrDash(AssetValue(asset))</td>
                            <td>@FormatTime(Text(asset, "discoveredAtUtc", "DiscoveredAtUtc"))</td>
                            <td>@FormatTime(Text(asset, "lastSeenAtUtc", "LastSeenAtUtc"))</td>
                            <td>@DisplayOrDash(Text(asset, "discoveryContext", "DiscoveryContext"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Infrastructure</p>
                <h2>Workers</h2>
            </div>
            <span class="badge">@FormatNumber(WorkerRows.Count) services</span>
        </div>

        @if (!string.IsNullOrWhiteSpace(_dockerWorkersError))
        {
            <div class="status-banner warning">@_dockerWorkersError</div>
        }

        <div class="table-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th><input type="checkbox" checked="@AllVisibleWorkersSelected" @onchange="ToggleAllVisibleWorkers" /></th>
                        <th>Worker</th>
                        <th>State</th>
                        <th>Running</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var worker in WorkerRows)
                    {
                        var service = Text(worker, "serviceName", "ServiceName");
                        <tr>
                            <td><input type="checkbox" checked="@_selectedWorkerServices.Contains(service)" @onchange="args => ToggleWorker(service, args)" /></td>
                            <td>
                                <button class="link-btn detail-link" type="button" @onclick="() => OpenWorkerDetailsAsync(service)">
                                    @DisplayOrDash(Text(worker, "displayName", "DisplayName", "serviceName", "ServiceName"))
                                </button>
                            </td>
                            <td>@DisplayOrDash(Text(worker, "overallState", "OverallState"))</td>
                            <td>@FormatNumber(Long(worker, "runningCount", "RunningCount"))</td>
                            <td>@FormatNumber(Long(worker, "totalCount", "TotalCount"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">HTTP</p>
                <h2>HTTP Requests</h2>
            </div>
            <span class="badge">@FormatNumber(HttpRows.Count) requests</span>
        </div>

        <div class="toolbar">
            <input placeholder="Search HTTP queue" @bind="_httpSearch" @bind:event="oninput" />
            <select @bind="_httpStateFilter" @onchange="ReloadHttpQueueAsync">
                <option value="">All states</option>
                <option value="Queued">Queued</option>
                <option value="InFlight">In flight</option>
                <option value="Retry">Retry</option>
                <option value="Succeeded">Completed</option>
                <option value="Failed">Failed</option>
            </select>
        </div>

        <div class="table-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th><input type="checkbox" checked="@AllVisibleHttpSelected" @onchange="ToggleAllVisibleHttp" /></th>
                        <th><button class="link-btn" @onclick='() => SortHttp("created")'>Created</button></th>
                        <th><button class="link-btn" @onclick='() => SortHttp("state")'>State</button></th>
                        <th>Method</th>
                        <th><button class="link-btn" @onclick='() => SortHttp("url")'>URL</button></th>
                        <th>Domain</th>
                        <th>Status</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var q in HttpRows)
                    {
                        var id = Text(q, "id", "Id");
                        <tr>
                            <td><input type="checkbox" checked="@_selectedHttpIds.Contains(id)" @onchange="args => ToggleHttp(id, args)" /></td>
                            <td>@FormatTime(Text(q, "createdAtUtc", "CreatedAtUtc"))</td>
                            <td>@DisplayOrDash(Text(q, "state", "State"))</td>
                            <td>@DisplayOrDash(Text(q, "method", "Method"))</td>
                            <td>@DisplayOrDash(Text(q, "requestUrl", "RequestUrl"))</td>
                            <td>@DisplayOrDash(Text(q, "domainKey", "DomainKey"))</td>
                            <td>@DisplayOrDash(Text(q, "lastHttpStatus", "LastHttpStatus"))</td>
                            <td>@DisplayOrDash(Text(q, "lastError", "LastError"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    @if (_workerDetailLoading || _workerDetailModal is not null || !string.IsNullOrWhiteSpace(_workerDetailError))
    {
        <div class="modal-backdrop" @onclick="CloseWorkerDetails">
            <section class="modal-card worker-detail-modal" @onclick:stopPropagation="true">
                <header class="modal-header">
                    <div>
                        <p class="eyebrow">Worker details</p>
                        <h2>@(_workerDetailLoading ? "Loading worker..." : DisplayOrDash(Text(_workerDetailModal ?? default, "displayName", "DisplayName", "serviceName", "ServiceName")))</h2>
                    </div>
                    <button class="btn" type="button" @onclick="CloseWorkerDetails">Close</button>
                </header>

                @if (_workerDetailLoading)
                {
                    <div class="status-banner">Loading worker activity…</div>
                }
                else if (!string.IsNullOrWhiteSpace(_workerDetailError))
                {
                    <div class="status-banner warning">@_workerDetailError</div>
                }
                else if (_workerDetailModal is JsonElement details)
                {
                    var containers = ArrayProperty(details, "containers", "Containers");
                    var heartbeats = ArrayProperty(details, "heartbeats", "Heartbeats");
                    var activeWork = ArrayProperty(details, "activeHttpRequests", "ActiveHttpRequests");
                    var recentHttp = ArrayProperty(details, "recentHttpWork", "RecentHttpWork");
                    var recentEvents = ArrayProperty(details, "recentEvents", "RecentEvents");
                    var recentOutbox = ArrayProperty(details, "recentOutbox", "RecentOutbox");
                    var summaries = ArrayProperty(details, "summaries", "Summaries");

                    <div class="detail-grid">
                        <article>
                            <span>Service</span>
                            <strong>@DisplayOrDash(Text(details, "serviceName", "ServiceName"))</strong>
                        </article>
                        <article>
                            <span>State</span>
                            <strong>@DisplayOrDash(Text(details, "overallState", "OverallState"))</strong>
                        </article>
                        <article>
                            <span>Running</span>
                            <strong>@FormatNumber(Long(details, "runningCount", "RunningCount"))</strong>
                        </article>
                        <article>
                            <span>Observed</span>
                            <strong>@FormatTime(Text(details, "generatedAtUtc", "GeneratedAtUtc"))</strong>
                        </article>
                    </div>

                    @if (summaries.Count > 0)
                    {
                        <div class="detail-section">
                            <h3>What it has done so far</h3>
                            <ul class="detail-list">
                                @foreach (var item in summaries)
                                {
                                    <li>@DisplayOrDash(Text(item, "label", "Label")): <strong>@DisplayOrDash(Text(item, "value", "Value"))</strong></li>
                                }
                            </ul>
                        </div>
                    }

                    <div class="detail-section">
                        <h3>Processes and containers</h3>
                        <div class="table-wrap compact">
                            <table class="ops-table">
                                <thead>
                                    <tr>
                                        <th>Worker key</th>
                                        <th>Host / container</th>
                                        <th>Process</th>
                                        <th>Active consumers</th>
                                        <th>Health</th>
                                        <th>Last heartbeat</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var hb in heartbeats)
                                    {
                                        <tr>
                                            <td>@DisplayOrDash(Text(hb, "workerKey", "WorkerKey"))</td>
                                            <td>@DisplayOrDash(Text(hb, "hostName", "HostName"))</td>
                                            <td>@DisplayOrDash(Text(hb, "processId", "ProcessId"))</td>
                                            <td>@DisplayOrDash(Text(hb, "activeConsumerCount", "ActiveConsumerCount"))</td>
                                            <td>@DisplayOrDash(Text(hb, "health", "Health"))</td>
                                            <td>@FormatTime(Text(hb, "lastHeartbeatUtc", "LastHeartbeatUtc"))</td>
                                        </tr>
                                    }
                                    @foreach (var c in containers)
                                    {
                                        <tr>
                                            <td>Docker</td>
                                            <td>@DisplayOrDash(Text(c, "name", "Name"))</td>
                                            <td>@DisplayOrDash(Text(c, "id", "Id"))</td>
                                            <td>—</td>
                                            <td>@DisplayOrDash(Text(c, "state", "State"))</td>
                                            <td>@DisplayOrDash(Text(c, "status", "Status"))</td>
                                        </tr>
                                    }
                                    @if (heartbeats.Count == 0 && containers.Count == 0)
                                    {
                                        <tr><td colspan="6">No active process or container data is currently available.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="detail-section">
                        <h3>Current target / active HTTP work</h3>
                        <div class="table-wrap compact">
                            <table class="ops-table">
                                <thead>
                                    <tr>
                                        <th>Target</th>
                                        <th>State</th>
                                        <th>Method</th>
                                        <th>URL</th>
                                        <th>Locked by</th>
                                        <th>Started</th>
                                        <th>Error</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in activeWork)
                                    {
                                        <tr>
                                            <td>@DisplayOrDash(Text(item, "targetRootDomain", "TargetRootDomain", "targetId", "TargetId"))</td>
                                            <td>@DisplayOrDash(Text(item, "state", "State"))</td>
                                            <td>@DisplayOrDash(Text(item, "method", "Method"))</td>
                                            <td>@DisplayOrDash(Text(item, "requestUrl", "RequestUrl"))</td>
                                            <td>@DisplayOrDash(Text(item, "lockedBy", "LockedBy"))</td>
                                            <td>@FormatTime(Text(item, "startedAtUtc", "StartedAtUtc"))</td>
                                            <td>@DisplayOrDash(Text(item, "lastError", "LastError"))</td>
                                        </tr>
                                    }
                                    @if (activeWork.Count == 0)
                                    {
                                        <tr><td colspan="7">No currently locked HTTP request rows were found for this worker.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="detail-section">
                        <h3>Recent events it reacted to</h3>
                        <div class="table-wrap compact">
                            <table class="ops-table">
                                <thead>
                                    <tr>
                                        <th>Occurred</th>
                                        <th>Direction</th>
                                        <th>Message</th>
                                        <th>Consumer / host</th>
                                        <th>Target</th>
                                        <th>Status</th>
                                        <th>Error</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var evt in recentEvents)
                                    {
                                        <tr>
                                            <td>@FormatTime(Text(evt, "occurredAtUtc", "OccurredAtUtc"))</td>
                                            <td>@DisplayOrDash(Text(evt, "direction", "Direction"))</td>
                                            <td>@DisplayOrDash(Text(evt, "messageType", "MessageType"))</td>
                                            <td>@DisplayOrDash(Text(evt, "consumerType", "ConsumerType", "hostName", "HostName"))</td>
                                            <td>@DisplayOrDash(Text(evt, "targetRootDomain", "TargetRootDomain", "targetId", "TargetId"))</td>
                                            <td>@DisplayOrDash(Text(evt, "status", "Status"))</td>
                                            <td>@DisplayOrDash(Text(evt, "error", "Error"))</td>
                                        </tr>
                                    }
                                    @if (recentEvents.Count == 0)
                                    {
                                        <tr><td colspan="7">No recent matching bus events were found for this worker.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="detail-section">
                        <h3>Recent HTTP work</h3>
                        <div class="table-wrap compact">
                            <table class="ops-table">
                                <thead>
                                    <tr>
                                        <th>Updated</th>
                                        <th>Target</th>
                                        <th>State</th>
                                        <th>URL</th>
                                        <th>Status</th>
                                        <th>Attempts</th>
                                        <th>Error</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in recentHttp)
                                    {
                                        <tr>
                                            <td>@FormatTime(Text(row, "updatedAtUtc", "UpdatedAtUtc"))</td>
                                            <td>@DisplayOrDash(Text(row, "targetRootDomain", "TargetRootDomain", "targetId", "TargetId"))</td>
                                            <td>@DisplayOrDash(Text(row, "state", "State"))</td>
                                            <td>@DisplayOrDash(Text(row, "requestUrl", "RequestUrl"))</td>
                                            <td>@DisplayOrDash(Text(row, "lastHttpStatus", "LastHttpStatus"))</td>
                                            <td>@DisplayOrDash(Text(row, "attemptCount", "AttemptCount")) / @DisplayOrDash(Text(row, "maxAttempts", "MaxAttempts"))</td>
                                            <td>@DisplayOrDash(Text(row, "lastError", "LastError"))</td>
                                        </tr>
                                    }
                                    @if (recentHttp.Count == 0)
                                    {
                                        <tr><td colspan="7">No recent HTTP queue rows matched this worker.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @if (recentOutbox.Count > 0)
                    {
                        <div class="detail-section">
                            <h3>Recent queued or dispatched events</h3>
                            <div class="table-wrap compact">
                                <table class="ops-table">
                                    <thead>
                                        <tr>
                                            <th>Updated</th>
                                            <th>Message</th>
                                            <th>State</th>
                                            <th>Producer</th>
                                            <th>Attempts</th>
                                            <th>Error</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var evt in recentOutbox)
                                        {
                                            <tr>
                                                <td>@FormatTime(Text(evt, "updatedAtUtc", "UpdatedAtUtc"))</td>
                                                <td>@DisplayOrDash(Text(evt, "messageType", "MessageType"))</td>
                                                <td>@DisplayOrDash(Text(evt, "state", "State"))</td>
                                                <td>@DisplayOrDash(Text(evt, "producer", "Producer"))</td>
                                                <td>@DisplayOrDash(Text(evt, "attemptCount", "AttemptCount"))</td>
                                                <td>@DisplayOrDash(Text(evt, "lastError", "LastError"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                }
            </section>
        </div>
    }
</section>

@code {
    private readonly CancellationTokenSource _cts = new();

    private JsonElement? _overview;
    private readonly List<JsonElement> _targets = [];
    private readonly List<JsonElement> _assets = [];
    private readonly List<JsonElement> _queue = [];
    private readonly List<JsonElement> _dockerWorkerServices = [];

    private JsonElement? _workerDetailModal;
    private bool _workerDetailLoading;
    private string _workerDetailError = "";

    private readonly HashSet<string> _selectedTargetIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedSubdomainKeys = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedAssetIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedWorkerServices = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedHttpIds = new(StringComparer.OrdinalIgnoreCase);

    private string _statusMessage = "";
    private string _dockerWorkersError = "";
    private string _activeTargetId = "";

    private string _newTargetRootDomain = "";
    private int _newTargetDepth = 12;

    private string _targetSearch = "";
    private string _targetFilter = "";
    private string _targetSort = "name";
    private bool _targetSortDescending;

    private string _subdomainSearch = "";
    private string _subdomainSort = "name";
    private bool _subdomainSortDescending;

    private string _assetSearch = "";
    private string _assetFilter = "";
    private string _assetSort = "discovered";
    private bool _assetSortDescending = true;

    private string _httpSearch = "";
    private string _httpStateFilter = "";
    private string _httpSort = "created";
    private bool _httpSortDescending = true;

    private bool _targetsLoading;
    private bool _assetsLoading;
    private bool _httpLoading;
    private bool _workersLoading;
    private bool _enumLoading;
    private bool _spiderLoading;
    private bool _loadingAny => _targetsLoading || _assetsLoading || _httpLoading || _workersLoading || _enumLoading || _spiderLoading;

    private long TotalTargets => Math.Max(OverviewLong("totalTargets", "TotalTargets"), _targets.Count);
    private long ConfirmedAssets => Math.Max(OverviewLong("totalAssetsConfirmed", "TotalAssetsConfirmed"), _targets.Sum(t => Long(t, "confirmedAssetCount", "ConfirmedAssetCount")));
    private long ConfirmedSubdomains => Math.Max(OverviewLong("subdomainsDiscovered", "SubdomainsDiscovered"), _targets.Sum(t => Long(t, "subdomainCount", "SubdomainCount")));
    private long TotalTrackedStorageBytes => OverviewLong("totalTrackedStorageBytes", "TotalTrackedStorageBytes");
    private long AssetMetadataStorageBytes => OverviewLong("assetMetadataStorageBytes", "AssetMetadataStorageBytes");
    private long HttpArtifactStorageBytes => OverviewLong("httpArtifactStorageBytes", "HttpArtifactStorageBytes");
    private long InlineHttpStorageBytes => OverviewLong("inlineHttpStorageBytes", "InlineHttpStorageBytes");
    private long EventJournalStorageBytes => OverviewLong("eventJournalStorageBytes", "EventJournalStorageBytes");
    private long HttpQueueQueuedCount => OverviewLong("httpQueueQueuedAssetCount", "HttpQueueQueuedAssetCount");
    private long HttpRequestsSentPerMinute => OverviewLong("httpRequestsSentLastMinuteCount", "HttpRequestsSentLastMinuteCount");
    private string StorageBreakdownLabel => $"Assets {FormatStorageSize(AssetMetadataStorageBytes)} / HTTP {FormatStorageSize(HttpArtifactStorageBytes + InlineHttpStorageBytes)} / Events {FormatStorageSize(EventJournalStorageBytes)}";
    private bool CanCreateTarget => !string.IsNullOrWhiteSpace(_newTargetRootDomain) && _newTargetDepth > 0;

    private IReadOnlyList<JsonElement> TargetRows => MaterializeSorted(
        _targets.Where(TargetMatchesFilter),
        TargetSortKey,
        _targetSortDescending);

    private IReadOnlyList<JsonElement> SubdomainRows => MaterializeSorted(
        _assets
            .Where(MatchesActiveTarget)
            .Where(a => Text(a, "kind", "Kind").Equals("Subdomain", StringComparison.OrdinalIgnoreCase))
            .Where(SubdomainMatchesFilter),
        SubdomainSortKey,
        _subdomainSortDescending);

    private IReadOnlyList<JsonElement> AssetRows => MaterializeSorted(
        _assets
            .Where(MatchesActiveTarget)
            .Where(AssetMatchesFilter),
        AssetSortKey,
        _assetSortDescending);

    private IReadOnlyList<JsonElement> WorkerRows => _dockerWorkerServices;

    private IReadOnlyList<JsonElement> HttpRows => MaterializeSorted(
        _queue.Where(HttpMatchesFilter),
        HttpSortKey,
        _httpSortDescending);

    private string ActiveTargetLabel
    {
        get
        {
            var target = _targets.FirstOrDefault(t => Text(t, "id", "Id").Equals(_activeTargetId, StringComparison.OrdinalIgnoreCase));
            var label = target.ValueKind == JsonValueKind.Object ? Text(target, "rootDomain", "RootDomain") : "";
            return string.IsNullOrWhiteSpace(label) ? "Select a target" : label;
        }
    }

    private bool AllVisibleTargetsSelected => TargetRows.Count > 0 && TargetRows.All(t => _selectedTargetIds.Contains(Text(t, "id", "Id")));
    private bool AllVisibleSubdomainsSelected => SubdomainRows.Count > 0 && SubdomainRows.All(s => _selectedSubdomainKeys.Contains(SubdomainKey(s)));
    private bool AllVisibleAssetsSelected => AssetRows.Count > 0 && AssetRows.All(a => _selectedAssetIds.Contains(Text(a, "id", "Id")));
    private bool AllVisibleWorkersSelected => WorkerRows.Count > 0 && WorkerRows.All(w => _selectedWorkerServices.Contains(Text(w, "serviceName", "ServiceName")));
    private bool AllVisibleHttpSelected => HttpRows.Count > 0 && HttpRows.All(q => _selectedHttpIds.Contains(Text(q, "id", "Id")));

    protected override async Task OnInitializedAsync()
    {
        await ReloadAllAsync().ConfigureAwait(false);
        _ = PollAsync();
    }

    private async Task PollAsync()
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));

            while (await timer.WaitForNextTickAsync(_cts.Token).ConfigureAwait(false))
            {
                await ReloadLiveAsync().ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ReloadLiveAsync()
    {
        try
        {
            await Task.WhenAll(ReloadOverviewAsync(), ReloadHttpQueueAsync(), ReloadDockerWorkersAsync()).ConfigureAwait(false);
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
        catch
        {
        }
    }

    private async Task ReloadAllAsync()
    {
        _statusMessage = "";

        try
        {
            await Task.WhenAll(
                    ReloadOverviewAsync(),
                    ReloadTargetsAsync(),
                    ReloadAssetsAsync(),
                    ReloadHttpQueueAsync(),
                    ReloadDockerWorkersAsync())
                .ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Operations refresh failed: {ex.Message}";
        }

        EnsureActiveTarget();
        await InvokeAsync(StateHasChanged).ConfigureAwait(false);
    }

    private async Task ReloadOverviewAsync()
    {
        _overview = await GetObjectAsync("/api/ops/overview").ConfigureAwait(false);
    }

    private async Task ReloadTargetsAsync()
    {
        _targetsLoading = true;

        try
        {
            Replace(_targets, await GetArrayAsync("/api/targets").ConfigureAwait(false));
            _selectedTargetIds.RemoveWhere(id => !_targets.Any(t => Text(t, "id", "Id").Equals(id, StringComparison.OrdinalIgnoreCase)));
            EnsureActiveTarget();
        }
        finally
        {
            _targetsLoading = false;
        }
    }

    private async Task ReloadAssetsAsync()
    {
        _assetsLoading = true;

        try
        {
            Replace(_assets, await GetArrayAsync("/api/assets").ConfigureAwait(false));
            _selectedAssetIds.RemoveWhere(id => !_assets.Any(a => Text(a, "id", "Id").Equals(id, StringComparison.OrdinalIgnoreCase)));
            _selectedSubdomainKeys.RemoveWhere(key => !_assets.Any(a => SubdomainKey(a).Equals(key, StringComparison.OrdinalIgnoreCase)));
        }
        finally
        {
            _assetsLoading = false;
        }
    }

    private async Task ReloadHttpQueueAsync()
    {
        _httpLoading = true;

        try
        {
            var uri = string.IsNullOrWhiteSpace(_httpStateFilter)
                ? "/api/http-request-queue"
                : $"/api/http-request-queue?state={Uri.EscapeDataString(_httpStateFilter)}";

            Replace(_queue, await GetArrayAsync(uri).ConfigureAwait(false));
            _selectedHttpIds.RemoveWhere(id => !_queue.Any(q => Text(q, "id", "Id").Equals(id, StringComparison.OrdinalIgnoreCase)));
        }
        finally
        {
            _httpLoading = false;
        }
    }

    private async Task ReloadDockerWorkersAsync()
    {
        _workersLoading = true;

        try
        {
            var root = await GetObjectAsync("/api/workers/docker-status").ConfigureAwait(false);

            if (root is JsonElement obj)
            {
                _dockerWorkersError = obj.TryGetProperty("error", out var error) ? error.GetString() ?? "" : "";
                Replace(_dockerWorkerServices, ArrayProperty(obj, "services", "Services"));
            }

            _selectedWorkerServices.RemoveWhere(id => !_dockerWorkerServices.Any(w => Text(w, "serviceName", "ServiceName").Equals(id, StringComparison.OrdinalIgnoreCase)));
        }
        catch (Exception ex)
        {
            _dockerWorkersError = ex.Message;
        }
        finally
        {
            _workersLoading = false;
        }
    }

    private async Task OpenWorkerDetailsAsync(string serviceName)
    {
        if (string.IsNullOrWhiteSpace(serviceName))
        {
            return;
        }

        _workerDetailModal = null;
        _workerDetailError = "";
        _workerDetailLoading = true;
        await InvokeAsync(StateHasChanged).ConfigureAwait(false);

        try
        {
            _workerDetailModal = await GetObjectAsync($"/api/workers/{Uri.EscapeDataString(serviceName)}/details").ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _workerDetailError = $"Worker details could not be loaded: {ex.Message}";
        }
        finally
        {
            _workerDetailLoading = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private void CloseWorkerDetails()
    {
        _workerDetailModal = null;
        _workerDetailError = "";
        _workerDetailLoading = false;
    }

    private async Task CreateTargetAsync()
    {
        if (!CanCreateTarget)
        {
            return;
        }

        try
        {
            using var response = await WorkerApi.Client.PostAsJsonAsync(
                    "/api/targets",
                    new { rootDomain = _newTargetRootDomain.Trim(), globalMaxDepth = _newTargetDepth },
                    _cts.Token)
                .ConfigureAwait(false);

            response.EnsureSuccessStatusCode();
            _newTargetRootDomain = "";
            await ReloadTargetsAsync().ConfigureAwait(false);
            await ReloadOverviewAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Target could not be added: {ex.Message}";
        }
    }

    private async Task StartEnumerationAsync(bool selectedOnly)
    {
        _enumLoading = true;
        _statusMessage = "";

        try
        {
            var ids = selectedOnly
                ? _selectedTargetIds.ToArray()
                : TargetRows.Select(t => Text(t, "id", "Id")).Where(id => !string.IsNullOrWhiteSpace(id)).Distinct(StringComparer.OrdinalIgnoreCase).ToArray();

            if (selectedOnly && ids.Length == 0)
            {
                _statusMessage = "Select one or more target rows before starting subdomain enumeration.";
                return;
            }

            var allTargets = !selectedOnly && ids.Length == 0;

            using var response = await WorkerApi.Client.PostAsJsonAsync(
                    "/api/ops/subdomain-enum/restart",
                    new RestartToolRequest(allTargets ? [] : ids, allTargets),
                    _cts.Token)
                .ConfigureAwait(false);

            response.EnsureSuccessStatusCode();

            using var doc = JsonDocument.Parse(await response.Content.ReadAsStringAsync(_cts.Token).ConfigureAwait(false));
            var targets = Long(doc.RootElement, "targets", "Targets");
            var jobs = Long(doc.RootElement, "jobsQueued", "JobsQueued");
            var workerScale = Text(doc.RootElement, "workerScale", "WorkerScale");

            _statusMessage = $"Subdomain enumeration started for {targets} target(s), {jobs} job(s) queued. {workerScale}";
            await ReloadLiveAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Enumeration could not be started: {ex.Message}";
        }
        finally
        {
            _enumLoading = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private async Task StartSpiderAsync(bool selectedOnly)
    {
        _spiderLoading = true;
        _statusMessage = "";

        try
        {
            var ids = selectedOnly
                ? SelectedTargetIdsForSpider()
                : TargetRows.Select(t => Text(t, "id", "Id")).Where(id => !string.IsNullOrWhiteSpace(id)).Distinct(StringComparer.OrdinalIgnoreCase).ToArray();

            if (selectedOnly && ids.Length == 0)
            {
                _statusMessage = "Select one or more target rows before starting spidering.";
                return;
            }

            var allTargets = !selectedOnly && ids.Length == 0;

            using var response = await WorkerApi.Client.PostAsJsonAsync(
                    "/api/ops/spider/restart",
                    new RestartToolRequest(allTargets ? [] : ids, allTargets),
                    _cts.Token)
                .ConfigureAwait(false);

            response.EnsureSuccessStatusCode();

            using var doc = JsonDocument.Parse(await response.Content.ReadAsStringAsync(_cts.Token).ConfigureAwait(false));
            var targets = Long(doc.RootElement, "targets", "Targets");
            var requeued = Long(doc.RootElement, "requeuedExistingRequests", "RequeuedExistingRequests");
            var seeds = Long(doc.RootElement, "rootSeedsQueued", "RootSeedsQueued");
            var workerScale = Text(doc.RootElement, "workerScale", "WorkerScale");

            _statusMessage = $"Spider started for {targets} target(s). Requeued {requeued} existing requests, queued {seeds} root seeds. {workerScale}";
            await ReloadHttpQueueAsync().ConfigureAwait(false);
            await ReloadDockerWorkersAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Spider could not be started: {ex.Message}";
        }
        finally
        {
            _spiderLoading = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private Task StartSpiderForSelectedSubdomainsAsync()
    {
        return StartSpiderAsync(selectedOnly: true);
    }

    private string[] SelectedTargetIdsForSpider()
    {
        var ids = new HashSet<string>(_selectedTargetIds, StringComparer.OrdinalIgnoreCase);

        foreach (var key in _selectedSubdomainKeys)
        {
            var pipe = key.IndexOf('|', StringComparison.Ordinal);
            if (pipe > 0)
            {
                ids.Add(key[..pipe]);
            }
        }

        return ids.Where(id => !string.IsNullOrWhiteSpace(id)).ToArray();
    }

    private bool TargetMatchesFilter(JsonElement target)
    {
        if (!string.IsNullOrWhiteSpace(_targetSearch) &&
            !MatchesAny(target, _targetSearch, "rootDomain", "RootDomain"))
        {
            return false;
        }

        return _targetFilter switch
        {
            "with-assets" => Long(target, "confirmedAssetCount", "ConfirmedAssetCount") > 0,
            "with-subdomains" => Long(target, "subdomainCount", "SubdomainCount") > 0,
            _ => true
        };
    }

    private bool SubdomainMatchesFilter(JsonElement asset)
    {
        return string.IsNullOrWhiteSpace(_subdomainSearch) ||
               SubdomainName(asset).Contains(_subdomainSearch, StringComparison.OrdinalIgnoreCase) ||
               MatchesAny(asset, _subdomainSearch, "discoveryContext", "DiscoveryContext");
    }

    private bool AssetMatchesFilter(JsonElement asset)
    {
        if (!string.IsNullOrWhiteSpace(_assetSearch) && !MatchesAny(asset, _assetSearch, "kind", "Kind", "rawValue", "RawValue", "canonicalKey", "CanonicalKey", "finalUrl", "FinalUrl", "displayName", "DisplayName", "discoveryContext", "DiscoveryContext"))
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(_assetFilter) ||
               Text(asset, "kind", "Kind").Equals(_assetFilter, StringComparison.OrdinalIgnoreCase);
    }

    private bool HttpMatchesFilter(JsonElement request)
    {
        return string.IsNullOrWhiteSpace(_httpSearch) ||
               MatchesAny(request, _httpSearch, "createdAtUtc", "CreatedAtUtc", "state", "State", "method", "Method", "requestUrl", "RequestUrl", "domainKey", "DomainKey", "lastHttpStatus", "LastHttpStatus", "lastError", "LastError");
    }

    private bool MatchesActiveTarget(JsonElement asset)
    {
        return string.IsNullOrWhiteSpace(_activeTargetId) ||
               Text(asset, "targetId", "TargetId").Equals(_activeTargetId, StringComparison.OrdinalIgnoreCase);
    }

    private string TargetSortKey(JsonElement target) => _targetSort switch
    {
        "depth" => NumberSortKey(Long(target, "globalMaxDepth", "GlobalMaxDepth")),
        "subdomains" => NumberSortKey(Long(target, "subdomainCount", "SubdomainCount")),
        "assets" => NumberSortKey(Long(target, "confirmedAssetCount", "ConfirmedAssetCount")),
        "lastRun" => Text(target, "lastRunAtUtc", "LastRunAtUtc"),
        _ => Text(target, "rootDomain", "RootDomain")
    };

    private string SubdomainSortKey(JsonElement asset) => _subdomainSort switch
    {
        "discovered" => Text(asset, "discoveredAtUtc", "DiscoveredAtUtc"),
        _ => SubdomainName(asset)
    };

    private string AssetSortKey(JsonElement asset) => _assetSort switch
    {
        "kind" => Text(asset, "kind", "Kind"),
        "value" => AssetValue(asset),
        "lastSeen" => Text(asset, "lastSeenAtUtc", "LastSeenAtUtc"),
        _ => Text(asset, "discoveredAtUtc", "DiscoveredAtUtc")
    };

    private string HttpSortKey(JsonElement request) => _httpSort switch
    {
        "state" => Text(request, "state", "State"),
        "url" => Text(request, "requestUrl", "RequestUrl"),
        _ => Text(request, "createdAtUtc", "CreatedAtUtc")
    };

    private void SortTargets(string key) => ToggleSort(ref _targetSort, ref _targetSortDescending, key);
    private void SortSubdomains(string key) => ToggleSort(ref _subdomainSort, ref _subdomainSortDescending, key);
    private void SortAssets(string key) => ToggleSort(ref _assetSort, ref _assetSortDescending, key);
    private void SortHttp(string key) => ToggleSort(ref _httpSort, ref _httpSortDescending, key);

    private static void ToggleSort(ref string sort, ref bool descending, string key)
    {
        if (sort.Equals(key, StringComparison.OrdinalIgnoreCase))
        {
            descending = !descending;
        }
        else
        {
            sort = key;
            descending = false;
        }
    }

    private void ToggleAllVisibleTargets(ChangeEventArgs args) => ToggleMany(_selectedTargetIds, TargetRows.Select(t => Text(t, "id", "Id")), IsChecked(args));
    private void ToggleAllVisibleSubdomains(ChangeEventArgs args) => ToggleMany(_selectedSubdomainKeys, SubdomainRows.Select(SubdomainKey), IsChecked(args));
    private void ToggleAllVisibleAssets(ChangeEventArgs args) => ToggleMany(_selectedAssetIds, AssetRows.Select(a => Text(a, "id", "Id")), IsChecked(args));
    private void ToggleAllVisibleWorkers(ChangeEventArgs args) => ToggleMany(_selectedWorkerServices, WorkerRows.Select(w => Text(w, "serviceName", "ServiceName")), IsChecked(args));
    private void ToggleAllVisibleHttp(ChangeEventArgs args) => ToggleMany(_selectedHttpIds, HttpRows.Select(q => Text(q, "id", "Id")), IsChecked(args));

    private void ToggleTarget(string id, ChangeEventArgs args)
    {
        ToggleOne(_selectedTargetIds, id, IsChecked(args));

        if (IsChecked(args))
        {
            ActivateTarget(id);
        }
    }

    private void ToggleSubdomain(string key, ChangeEventArgs args) => ToggleOne(_selectedSubdomainKeys, key, IsChecked(args));
    private void ToggleAsset(string id, ChangeEventArgs args) => ToggleOne(_selectedAssetIds, id, IsChecked(args));
    private void ToggleWorker(string service, ChangeEventArgs args) => ToggleOne(_selectedWorkerServices, service, IsChecked(args));
    private void ToggleHttp(string id, ChangeEventArgs args) => ToggleOne(_selectedHttpIds, id, IsChecked(args));

    private void ActivateTarget(string id)
    {
        if (!string.IsNullOrWhiteSpace(id))
        {
            _activeTargetId = id;
        }
    }

    private void EnsureActiveTarget()
    {
        if (_targets.Count == 0)
        {
            _activeTargetId = "";
            return;
        }

        if (string.IsNullOrWhiteSpace(_activeTargetId) ||
            !_targets.Any(t => Text(t, "id", "Id").Equals(_activeTargetId, StringComparison.OrdinalIgnoreCase)))
        {
            _activeTargetId = Text(_targets[0], "id", "Id");
        }
    }

    private static void ToggleOne(HashSet<string> set, string id, bool selected)
    {
        if (string.IsNullOrWhiteSpace(id))
        {
            return;
        }

        if (selected)
        {
            set.Add(id);
        }
        else
        {
            set.Remove(id);
        }
    }

    private static void ToggleMany(HashSet<string> set, IEnumerable<string> ids, bool selected)
    {
        foreach (var id in ids.Where(id => !string.IsNullOrWhiteSpace(id)))
        {
            if (selected)
            {
                set.Add(id);
            }
            else
            {
                set.Remove(id);
            }
        }
    }

    private static bool IsChecked(ChangeEventArgs args) => args.Value is bool value && value;

    private static IReadOnlyList<JsonElement> MaterializeSorted(
        IEnumerable<JsonElement> rows,
        Func<JsonElement, string> sortKey,
        bool descending)
    {
        return (descending
                ? rows.OrderByDescending(sortKey, StringComparer.OrdinalIgnoreCase)
                : rows.OrderBy(sortKey, StringComparer.OrdinalIgnoreCase))
            .ToList();
    }

    private static string NumberSortKey(long value) => value.ToString("D20", CultureInfo.InvariantCulture);

    private static bool MatchesAny(JsonElement element, string search, params string[] propertyNames)
    {
        return propertyNames.Any(name => Text(element, name).Contains(search, StringComparison.OrdinalIgnoreCase));
    }

    private long OverviewLong(params string[] propertyNames)
    {
        return _overview is JsonElement overview ? Long(overview, propertyNames) : 0;
    }

    private static long Long(JsonElement element, params string[] propertyNames)
    {
        foreach (var propertyName in propertyNames)
        {
            if (!TryGetProperty(element, propertyName, out var property))
            {
                continue;
            }

            if (property.ValueKind == JsonValueKind.Number && property.TryGetInt64(out var number))
            {
                return number;
            }

            if (property.ValueKind == JsonValueKind.String &&
                long.TryParse(property.GetString(), NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed))
            {
                return parsed;
            }
        }

        return 0;
    }

    private static string Text(JsonElement element, params string[] propertyNames)
    {
        foreach (var propertyName in propertyNames)
        {
            if (!TryGetProperty(element, propertyName, out var property))
            {
                continue;
            }

            return property.ValueKind switch
            {
                JsonValueKind.String => property.GetString() ?? "",
                JsonValueKind.Number => property.ToString(),
                JsonValueKind.True => "true",
                JsonValueKind.False => "false",
                _ => property.ToString()
            };
        }

        return "";
    }

    private static bool TryGetProperty(JsonElement element, string propertyName, out JsonElement property)
    {
        if (element.ValueKind == JsonValueKind.Object && element.TryGetProperty(propertyName, out property))
        {
            return true;
        }

        property = default;
        return false;
    }

    private static string DisplayOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;
    private static string FormatNumber(long value) => value.ToString("N0", CultureInfo.InvariantCulture);

    private static string FormatTime(string value)
    {
        return DateTimeOffset.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var parsed)
            ? parsed.ToLocalTime().ToString("g", CultureInfo.CurrentCulture)
            : "—";
    }

    private static string FormatStorageSize(long bytes)
    {
        if (bytes <= 0)
        {
            return "0 B";
        }

        string[] units = ["B", "KB", "MB", "GB", "TB"];
        var value = (double)bytes;
        var index = 0;

        while (value >= 1024 && index < units.Length - 1)
        {
            value /= 1024;
            index++;
        }

        return $"{value:0.##} {units[index]}";
    }

    private static string SubdomainName(JsonElement asset)
    {
        foreach (var value in new[]
                 {
                     Text(asset, "displayName", "DisplayName"),
                     Text(asset, "rawValue", "RawValue"),
                     Text(asset, "canonicalKey", "CanonicalKey"),
                     Text(asset, "finalUrl", "FinalUrl")
                 })
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                continue;
            }

            if (Uri.TryCreate(value, UriKind.Absolute, out var uri) && !string.IsNullOrWhiteSpace(uri.Host))
            {
                return uri.Host;
            }

            return value.Trim();
        }

        return "";
    }

    private static string SubdomainKey(JsonElement asset) => $"{Text(asset, "targetId", "TargetId")}|{SubdomainName(asset)}";
    private static string AssetValue(JsonElement asset) => DisplayOrDash(Text(asset, "finalUrl", "FinalUrl", "displayName", "DisplayName", "rawValue", "RawValue", "canonicalKey", "CanonicalKey"));
    private static string RowClass(bool selected) => selected ? "selected" : "";

    private async Task<JsonElement?> GetObjectAsync(string uri)
    {
        using var response = await WorkerApi.Client.GetAsync(uri, _cts.Token).ConfigureAwait(false);
        response.EnsureSuccessStatusCode();

        await using var stream = await response.Content.ReadAsStreamAsync(_cts.Token).ConfigureAwait(false);
        using var doc = await JsonDocument.ParseAsync(stream, cancellationToken: _cts.Token).ConfigureAwait(false);

        return doc.RootElement.Clone();
    }

    private async Task<List<JsonElement>> GetArrayAsync(string uri)
    {
        using var response = await WorkerApi.Client.GetAsync(uri, _cts.Token).ConfigureAwait(false);
        response.EnsureSuccessStatusCode();

        await using var stream = await response.Content.ReadAsStreamAsync(_cts.Token).ConfigureAwait(false);
        using var doc = await JsonDocument.ParseAsync(stream, cancellationToken: _cts.Token).ConfigureAwait(false);

        if (doc.RootElement.ValueKind == JsonValueKind.Array)
        {
            return doc.RootElement.EnumerateArray().Select(e => e.Clone()).ToList();
        }

        return [];
    }

    private static IReadOnlyList<JsonElement> ArrayProperty(JsonElement element, params string[] propertyNames)
    {
        foreach (var propertyName in propertyNames)
        {
            if (TryGetProperty(element, propertyName, out var property) && property.ValueKind == JsonValueKind.Array)
            {
                return property.EnumerateArray().Select(e => e.Clone()).ToList();
            }
        }

        return [];
    }

    private static void Replace(List<JsonElement> target, IEnumerable<JsonElement> values)
    {
        target.Clear();
        target.AddRange(values);
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
