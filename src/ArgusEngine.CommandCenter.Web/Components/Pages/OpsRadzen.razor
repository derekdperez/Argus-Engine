    private async Task OpenAssetDecisionAsync(JsonElement asset)
    {
        try
        {
            var targetId = Text(asset, "targetId", "TargetId");
            var canonicalKey = Text(asset, "canonicalKey", "CanonicalKey");
            var rawValue = Text(asset, "rawValue", "RawValue");
            var query = new List<string> { "take=1" };
            if (!string.IsNullOrWhiteSpace(targetId))
                query.Add($"targetId={Uri.EscapeDataString(targetId)}");
            if (!string.IsNullOrWhiteSpace(canonicalKey))
                query.Add($"canonicalKey={Uri.EscapeDataString(canonicalKey)}");
            else if (!string.IsNullOrWhiteSpace(rawValue))
                query.Add($"rawContains={Uri.EscapeDataString(rawValue)}");

            var rows = await GetArrayAsync($"/api/asset-admission-decisions?{string.Join("&", query)}")
                .ConfigureAwait(false);
            _assetDecisionModal = rows.FirstOrDefault();

            if (_assetDecisionModal.Value.ValueKind != JsonValueKind.Object)
            {
                _assetDecisionModal = JsonSerializer.SerializeToElement(new
                {
                    decision = DisplayOrDash(Text(asset, "lifecycleStatus", "LifecycleStatus")),
                    reasonCode = "No admission decision row found",
                    reasonDetail = "The asset row has discovery details, but no persisted admission decision matched it.",
                    discoveredBy = Text(asset, "discoveredBy", "DiscoveredBy"),
                    discoveryContext = Text(asset, "discoveryContext", "DiscoveryContext")
                });
            }

            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Asset decision could not be loaded: {ex.Message}";
        }
    }

