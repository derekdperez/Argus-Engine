@page "/"
@page "/ops"
@rendermode InteractiveServer

@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using ArgusEngine.CommandCenter.Models
@using ArgusEngine.CommandCenter.Realtime
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web.Virtualization
@implements IDisposable
@using ArgusEngine.CommandCenter.Web.Clients
@inject WorkerControlApiClient WorkerApi
@inject DiscoveryRealtimeClient Realtime

<PageTitle>Operations - Argus Engine</PageTitle>

<div class="page-shell ops-page ops-page-lite">
    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="ops-alert">@_statusMessage</div>
    }

    <section class="metrics-grid ops-summary-grid">
        <article class="metric-card">
            <span>Targets</span>
            <strong>@(_targetsLoading ? "—" : FormatNumber(TotalTargets))</strong>
        </article>
        <article class="metric-card">
            <span>Assets</span>
            <strong>@(_targetsLoading ? "—" : FormatNumber(ConfirmedAssets))</strong>
        </article>
        <article class="metric-card">
            <span>Subdomains</span>
            <strong>@(_targetsLoading ? "—" : FormatNumber(ConfirmedSubdomains))</strong>
        </article>
        <article class="metric-card">
            <span>Unique Technologies</span>
            <strong>@(_targetsLoading ? "—" : FormatNumber(UniqueTechnologies))</strong>
        </article>
        <article class="metric-card">
            <span>HTTP Queue</span>
            <strong>@(_httpLoading ? "—" : $"{FormatNumber(HttpQueueQueuedCount)} queued / {FormatNumber(HttpRequestsSentPerMinute)} sent/min")</strong>
        </article>
        <article class="metric-card">
            <span>Asset Storage</span>
            <strong>@(_targetsLoading ? "—" : FormatStorageSize(TotalTrackedStorageBytes))</strong>
            @if (!_targetsLoading) { <small>@StorageBreakdownLabel</small> }
        </article>
    </section>

    <section class="ops-scope-grid">
        <section class="panel scope-panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Scope</p>
                    <h2>Targets</h2>
                    @if (_targetsLoading)
                    {
                        <span class="loading-inline"><span class="spinner"></span> Loading...</span>
                    }
                </div>
                <span class="muted">@FormatNumber(TargetRows.Count)</span>
            </div>

            <div class="ops-rz-toolbar simple dense-toolbar">
                <label class="target-create">
                    <span>New target</span>
                    <input type="text" class="ops-filter" @bind="_newTargetRootDomain" @bind:event="oninput" placeholder="example.com" />
                </label>
                <label class="target-depth">
                    <span>Depth</span>
                    <input type="number" min="1" max="64" class="ops-filter compact-filter" @bind="_newTargetDepth" />
                </label>
                <button type="button" class="btn" @onclick="CreateTargetAsync" disabled="@(!CanCreateTarget)">Add Target</button>
                <label class="file-import-button">
                    <span>Import</span>
                    <InputFile OnChange="ImportTargetsAsync" disabled="@_importingTargets" />
                </label>
                <label class="wide-search">
                    <span>Search</span>
                    <input type="search" class="ops-filter" @bind="_targetSearch" @bind:event="oninput" placeholder="Search targets..." />
                </label>
                <label>
                    <span>Filter</span>
                    <select class="ops-filter compact-filter" @bind="_targetFilter">
                        <option value="">All</option>
                        <option value="with-assets">With assets</option>
                        <option value="with-subdomains">With subdomains</option>
                    </select>
                </label>
            </div>

            <div class="ops-table-wrap scope-table-wrap">
                <table class="ops-table targets-table">
                    <thead>
                        <tr>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetTargetSort("name"))">Target</button></th>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetTargetSort("depth"))">Depth</button></th>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetTargetSort("subdomains"))">Subs</button></th>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetTargetSort("assets"))">Assets</button></th>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetTargetSort("lastRun"))">Last run</button></th>
                        </tr>
                    </thead>
                    <tbody>
                        <Virtualize TItem="JsonElement" Items="TargetRows" Context="t" ItemSize="30" OverscanCount="16" SpacerElement="tr">
                            <tr class="selectable-row @(IsSelectedTarget(t) ? "selected" : "")" @onclick="@(() => SelectTarget(t))">
                                <td class="clip" title="@Text(t, "rootDomain", "RootDomain")">@Text(t, "rootDomain", "RootDomain")</td>
                                <td>@DisplayOrDash(Text(t, "globalMaxDepth", "GlobalMaxDepth"))</td>
                                <td>@FormatNumber(Long(t, "subdomainCount", "SubdomainCount"))</td>
                                <td>@FormatNumber(Long(t, "confirmedAssetCount", "ConfirmedAssetCount"))</td>
                                <td>@FormatTime(Text(t, "lastRunAtUtc", "LastRunAtUtc"))</td>
                            </tr>
                        </Virtualize>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="panel scope-panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Scope</p>
                    <h2>Subdomains</h2>
                </div>
                <span class="muted">@SelectedTargetLabel - @FormatNumber(SubdomainRows.Count)</span>
            </div>

            <div class="ops-rz-toolbar simple dense-toolbar">
                <label class="wide-search">
                    <span>Search</span>
                    <input type="search" class="ops-filter" @bind="_subdomainSearch" @bind:event="oninput" placeholder="Search subdomains..." />
                </label>
                <label>
                    <span>Filter</span>
                    <select class="ops-filter compact-filter" @bind="_subdomainFilter">
                        <option value="">All</option>
                        <option value="selected">Selected</option>
                    </select>
                </label>
                <button type="button" class="btn" @onclick="SpiderSelectedDomainsAsync" disabled="@(!CanSpiderSelectedDomains)">
                    Spider
                </button>
            </div>

            <div class="ops-table-wrap scope-table-wrap">
                <table class="ops-table subdomains-table">
                    <thead>
                        <tr>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetSubdomainSort("name"))">Subdomain</button></th>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetSubdomainSort("discovered"))">Discovered</button></th>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetSubdomainSort("context"))">How found</button></th>
                        </tr>
                    </thead>
                    <tbody>
                        <Virtualize TItem="JsonElement" Items="SubdomainRows" Context="subdomain" ItemSize="30" OverscanCount="16" SpacerElement="tr">
                            @{
                                var name = SubdomainName(subdomain);
                            }
                            <tr class="selectable-row @(IsSelectedSubdomain(name) ? "selected" : "")" @onclick="@(() => SelectSubdomain(name))">
                                <td class="clip" title="@name">@DisplayOrDash(name)</td>
                                <td>@FormatTime(Text(subdomain, "discoveredAtUtc", "DiscoveredAtUtc"))</td>
                                <td class="clip" title="@Text(subdomain, "discoveryContext", "DiscoveryContext")">@DisplayOrDash(Text(subdomain, "discoveryContext", "DiscoveryContext"))</td>
                            </tr>
                        </Virtualize>
                    </tbody>
                </table>
            </div>
        </section>
    </section>

    <section class="panel">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Inventory</p>
                <h2>Assets</h2>
                @if (_assetsLoading)
                {
                    <span class="loading-inline"><span class="spinner"></span> Loading...</span>
                }
            </div>
            <span class="muted">@FormatNumber(FilteredAssetRows.Count) visible assets</span>
        </div>

        <div class="ops-rz-toolbar simple">
            <label class="wide-search">
                <span>Search</span>
                <input type="search" class="ops-filter" @bind="_assetSearch" @bind:event="oninput" placeholder="Search assets..." />
            </label>
            <label>
                <span>Filter</span>
                <select class="ops-filter compact-filter" @bind="_assetFilter">
                    <option value="">All kinds</option>
                    <option value="Domain">Domain</option>
                    <option value="Subdomain">Subdomain</option>
                    <option value="Url">URL</option>
                    <option value="IpAddress">IP address</option>
                    <option value="OpenPort">Open port</option>
                </select>
            </label>
            <button type="button" class="btn" @onclick="ReloadAssetsAsync" disabled="@_assetsLoading">
                @(_assetsLoading ? "Loading..." : "Reload assets")
            </button>
        </div>

        <div class="ops-table-wrap asset-table-wrap">
            <table class="ops-table asset-table">
                <thead>
                    <tr>
                        <th>Info</th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetAssetSort("discovered"))">Discovered</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetAssetSort("lastSeen"))">Last seen</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetAssetSort("kind"))">Kind</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetAssetSort("category"))">Category</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetAssetSort("url"))">Final URL</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetAssetSort("context"))">How found</button></th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize TItem="JsonElement" Items="FilteredAssetRows" Context="a" ItemSize="30" OverscanCount="16" SpacerElement="tr">
                        <tr @key="AssetKey(a)">
                            @{
                                var finalUrl = Text(a, "finalUrl", "FinalUrl");
                                var href = TryHttpHref(finalUrl);
                            }
                            <td>
                                <button type="button" class="btn ghost small" title="Show admission decision" @onclick="() => OpenAssetDecisionAsync(a)">?</button>
                            </td>
                            <td>@FormatTime(Text(a, "discoveredAtUtc", "DiscoveredAtUtc"))</td>
                            <td>@FormatTime(Text(a, "lastSeenAtUtc", "LastSeenAtUtc"))</td>
                            <td>@Text(a, "kind", "Kind")</td>
                            <td>@Text(a, "category", "Category")</td>
                            <td class="clip" title="@finalUrl">
                                @if (href is null)
                                {
                                    <span>@DisplayOrDash(finalUrl)</span>
                                }
                                else
                                {
                                    <a href="@href" target="_blank" rel="noopener noreferrer">@finalUrl</a>
                                }
                            </td>
                            <td class="clip" title="@Text(a, "discoveryContext", "DiscoveryContext")">@Text(a, "discoveryContext", "DiscoveryContext")</td>
                        </tr>
                    </Virtualize>
                </tbody>
            </table>
        </div>
    </section>

    <section class="panel">
        <div class="section-heading">
            <div>
                <p class="eyebrow">HTTP</p>
                <h2>HTTP Requests</h2>
                @if (_httpLoading)
                {
                    <span class="loading-inline"><span class="spinner"></span> Loading...</span>
                }
            </div>
            <span class="muted">@FormatNumber(HttpRows.Count) requests</span>
        </div>

        <div class="ops-rz-toolbar simple">
            <label class="wide-search">
                <span>Search</span>
                <input type="search" class="ops-filter" @bind="_httpSearch" @bind:event="oninput" placeholder="Search HTTP requests..." />
            </label>
            <label>
                <span>Filter</span>
                <select class="ops-filter compact-filter" @bind="_httpStateFilter" @bind:after="ReloadHttpQueueAsync">
                    <option value="">All states</option>
                    <option value="Queued">Queued</option>
                    <option value="InFlight">In flight</option>
                    <option value="Retry">Retry</option>
                    <option value="Succeeded">Completed</option>
                    <option value="Failed">Failed</option>
                </select>
            </label>
            <button type="button" class="btn" @onclick="RetrySelectedHttpRowsAsync" disabled="@(!_selectedHttpIds.Any())">Retry Selected</button>
            <button type="button" class="btn danger" @onclick="ClearSelectedHttpRowsAsync" disabled="@(!_selectedHttpIds.Any())">Clear Selected</button>
            <button type="button" class="btn" @onclick="ClearCompletedHttpRowsAsync">Clear Completed</button>
            <button type="button" class="btn" @onclick="ClearFailedHttpRowsAsync">Clear Failed</button>
            <button type="button" class="btn danger" @onclick="ClearOlderThanSelectedHttpRowAsync" disabled="@(SelectedHttpCutoffUtc is null)">Clear Older Than Selected</button>
        </div>

        <div class="ops-table-wrap compact">
            <table class="ops-table http-table">
                <thead>
                    <tr>
                        <th>Select</th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetHttpSort("created"))">Created</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetHttpSort("state"))">State</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetHttpSort("method"))">Method</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetHttpSort("url"))">URL</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetHttpSort("domain"))">Domain</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetHttpSort("attempts"))">Attempts</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetHttpSort("status"))">Status</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetHttpSort("duration"))">Duration</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetHttpSort("error"))">Error</button></th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize TItem="JsonElement" Items="HttpRows" Context="q" ItemSize="30" OverscanCount="16" SpacerElement="tr">
                        @{
                            var requestUrl = Text(q, "requestUrl", "RequestUrl");
                            var id = Text(q, "id", "Id");
                        }
                        <tr>
                            <td>
                                <input type="checkbox" checked="@IsHttpRowSelected(id)" @onchange="args => ToggleHttpRow(id, args)" />
                            </td>
                            <td>@FormatTime(Text(q, "createdAtUtc", "CreatedAtUtc"))</td>
                            <td><span class="queue-state @CssToken(Text(q, "state", "State"))">@DisplayOrDash(Text(q, "state", "State"))</span></td>
                            <td>@DisplayOrDash(Text(q, "method", "Method"))</td>
                            <td class="clip" title="@requestUrl">@DisplayOrDash(requestUrl)</td>
                            <td class="clip" title="@Text(q, "domainKey", "DomainKey")">@DisplayOrDash(Text(q, "domainKey", "DomainKey"))</td>
                            <td>@DisplayOrDash(Text(q, "attemptCount", "AttemptCount")) / @DisplayOrDash(Text(q, "maxAttempts", "MaxAttempts"))</td>
                            <td>@DisplayOrDash(Text(q, "lastHttpStatus", "LastHttpStatus"))</td>
                            <td>@DurationLabel(q)</td>
                            <td class="clip" title="@Text(q, "lastError", "LastError")">@DisplayOrDash(Text(q, "lastError", "LastError"))</td>
                        </tr>
                    </Virtualize>
                </tbody>
            </table>
        </div>
    </section>

</div>

@if (_assetDecisionModal is not null)
{
    <div class="modal-backdrop" @onclick="CloseAssetDecisionModal">
        <section class="modal-card decision-modal" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-label="Asset admission decision">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Asset Admission</p>
                    <h2>Decision reason</h2>
                </div>
                <button type="button" class="btn ghost small" @onclick="CloseAssetDecisionModal">Close</button>
            </div>
            <dl class="decision-details">
                <dt>Decision</dt>
                <dd>@DisplayOrDash(Text(_assetDecisionModal.Value, "decision", "Decision"))</dd>
                <dt>Reason</dt>
                <dd>@DisplayOrDash(Text(_assetDecisionModal.Value, "reasonCode", "ReasonCode"))</dd>
                <dt>Detail</dt>
                <dd>@DisplayOrDash(Text(_assetDecisionModal.Value, "reasonDetail", "ReasonDetail"))</dd>
                <dt>Discovered by</dt>
                <dd>@DisplayOrDash(Text(_assetDecisionModal.Value, "discoveredBy", "DiscoveredBy"))</dd>
                <dt>Discovery context</dt>
                <dd>@DisplayOrDash(Text(_assetDecisionModal.Value, "discoveryContext", "DiscoveryContext"))</dd>
            </dl>
        </section>
    </div>
}

@code {
    private JsonElement? _overview;
    private readonly List<JsonElement> _targets = [];
    private readonly List<JsonElement> _assets = [];
    private readonly List<JsonElement> _queue = [];
    private readonly List<JsonElement> _workerSummaries = [];
    private readonly List<JsonElement> _workerInstances = [];
    private readonly List<JsonElement> _workerScaleTargets = [];
    private readonly List<JsonElement> _rabbitQueues = [];
    private readonly List<JsonElement> _events = [];

    private bool _assetsLoading = true;
    private bool _targetsLoading = true;
    private bool _httpLoading = true;
    private bool _busLoading;
    private bool _eventsLoading;
    private bool _workersLoading;
    private bool _scaleLoading;
    private string _targetSearch = "";
    private string _targetFilter = "";
    private string _targetSort = "name";
    private bool _targetSortDescending;
    private string _subdomainSearch = "";
    private string _subdomainFilter = "";
    private string _subdomainSort = "name";
    private bool _subdomainSortDescending;
    private string _assetSearch = "";
    private string _assetFilter = "";
    private string _assetSort = "discovered";
    private bool _assetSortDescending = true;
    private string _httpSearch = "";
    private string _httpSort = "created";
    private bool _httpSortDescending = true;
    private string _httpStateFilter = "";
    private string _rabbitSearch = "";
    private string _rabbitFilter = "";
    private string _rabbitSort = "queue";
    private bool _rabbitSortDescending;
    private string _eventSearch = "";
    private string _eventFilter = "";
    private string _eventSort = "published";
    private bool _eventSortDescending = true;
    private string _workerSearch = "";
    private string _workerFilter = "";
    private string _workerSort = "worker";
    private bool _workerSortDescending;
    private string _statusMessage = "";
    private string? _selectedTargetId;
    private string? _selectedSubdomain;
    private string _newTargetRootDomain = "";
    private int _newTargetDepth = 12;
    private bool _importingTargets;
    private bool _initialLoadStarted;
    private bool _liveRefreshRunning;
    private DateTimeOffset _lastLiveRefreshUtc = DateTimeOffset.MinValue;
    private readonly CancellationTokenSource _realtimeCts = new();
    private readonly HashSet<string> _selectedHttpIds = new(StringComparer.OrdinalIgnoreCase);
    private JsonElement? _assetDecisionModal;

    private bool UsingEcsWorkers => _workerScaleTargets.Count > 0;
    private long TotalTargets => _targets.Count;
    private long ConfirmedAssets => _targets.Sum(t => Long(t, "confirmedAssetCount", "ConfirmedAssetCount"));
    private long ConfirmedSubdomains => _targets.Sum(t => Long(t, "subdomainCount", "SubdomainCount"));
    private long UniqueTechnologies => OverviewLong("uniqueTechnologyCount", "UniqueTechnologyCount");
    private long TotalTrackedStorageBytes => OverviewLong("totalTrackedStorageBytes", "TotalTrackedStorageBytes");
    private long AssetMetadataStorageBytes => OverviewLong("assetMetadataStorageBytes", "AssetMetadataStorageBytes");
    private long HttpArtifactStorageBytes => OverviewLong("httpArtifactStorageBytes", "HttpArtifactStorageBytes");
    private long InlineHttpStorageBytes => OverviewLong("inlineHttpStorageBytes", "InlineHttpStorageBytes");
    private long EventJournalStorageBytes => OverviewLong("eventJournalStorageBytes", "EventJournalStorageBytes");
    private long HttpRequestsSentPerMinute => OverviewLong("httpRequestsSentLastMinuteCount", "HttpRequestsSentLastMinuteCount");
    private long HttpQueueQueuedCount => OverviewLong("httpQueueQueuedAssetCount", "HttpQueueQueuedAssetCount");
    private long RunningWorkerCount => UsingEcsWorkers
        ? _workerScaleTargets.Sum(w => Long(w, "runningCount", "RunningCount"))
        : _workerInstances.Count;
    private long FailedWorkerCount => _workerInstances.LongCount(IsFailedWorker);
    private long HttpQueueCount => _queue.Count;
    private bool CanSpiderSelectedDomains => !string.IsNullOrWhiteSpace(_selectedTargetId);

    private string WorkerHealthTitle => UsingEcsWorkers ? "ECS worker health" : "Local / EC2 worker health";
    private string WorkerHealthSubtitle => UsingEcsWorkers
        ? "ECS service scale targets and live worker activity"
        : "Workers running with the local or EC2 deployment";

    private bool CanCreateTarget =>
        !string.IsNullOrWhiteSpace(_newTargetRootDomain) && _newTargetDepth > 0;

    private string StorageBreakdownLabel =>
        $"Assets {FormatStorageSize(AssetMetadataStorageBytes)} / HTTP {FormatStorageSize(HttpArtifactStorageBytes + InlineHttpStorageBytes)} / Events {FormatStorageSize(EventJournalStorageBytes)}";

    private string TopDomainLabel
    {
        get
        {
            var top = _targets
                .Select(t => new
                {
                    RootDomain = Text(t, "rootDomain", "RootDomain"),
                    Count = Long(t, "confirmedAssetCount", "ConfirmedAssetCount")
                })
                .Where(t => !string.IsNullOrWhiteSpace(t.RootDomain))
                .OrderByDescending(t => t.Count)
                .ThenBy(t => t.RootDomain, StringComparer.OrdinalIgnoreCase)
                .FirstOrDefault();

            return top is null ? "-" : $"{top.RootDomain} ({FormatNumber(top.Count)} confirmed assets)";
        }
    }

    private ICollection<JsonElement> TargetRows => MaterializeSorted(
        _targets.Where(TargetMatchesFilter),
        TargetSortKey,
        _targetSortDescending);

    private ICollection<JsonElement> FilteredAssetRows => MaterializeSorted(
        _assets
            .Where(MatchesSelectedTarget)
            .Where(MatchesSelectedSubdomain)
            .Where(AssetMatchesFilter),
        AssetSortKey,
        _assetSortDescending);

    private ICollection<JsonElement> SubdomainRows => MaterializeSorted(
        _assets
            .Where(MatchesSelectedTarget)
            .Where(a => Text(a, "kind", "Kind").Equals("Subdomain", StringComparison.OrdinalIgnoreCase))
            .GroupBy(SubdomainName, StringComparer.OrdinalIgnoreCase)
            .Where(g => !string.IsNullOrWhiteSpace(g.Key))
            .Select(g => g.OrderByDescending(a => Text(a, "discoveredAtUtc", "DiscoveredAtUtc"), StringComparer.Ordinal).First())
            .Where(SubdomainMatchesFilter),
        SubdomainSortKey,
        _subdomainSortDescending);

    private ICollection<JsonElement> HttpRows => MaterializeSorted(
        _queue.Where(HttpMatchesFilter),
        HttpSortKey,
        _httpSortDescending);

    private ICollection<JsonElement> RabbitQueueRows => MaterializeSorted(
        _rabbitQueues.Where(RabbitMatchesFilter),
        RabbitSortKey,
        _rabbitSortDescending);

    private ICollection<JsonElement> EventRows => MaterializeSorted(
        _events.Where(EventMatchesFilter),
        EventSortKey,
        _eventSortDescending);

    private ICollection<JsonElement> WorkerInstanceRows => MaterializeSorted(
        _workerInstances.Where(WorkerMatchesFilter),
        WorkerSortKey,
        _workerSortDescending);

    private string SelectedTargetLabel
    {
        get
        {
            var target = _targets.FirstOrDefault(t => IsSelectedTarget(t));
            var label = target.ValueKind == JsonValueKind.Object
                ? Text(target, "rootDomain", "RootDomain")
                : "";

            return string.IsNullOrWhiteSpace(label) ? "Select a target" : label;
        }
    }

    private DateTimeOffset? SelectedHttpCutoffUtc => _queue
        .Where(q => _selectedHttpIds.Contains(Text(q, "id", "Id")))
        .Select(q => DateTimeOffset.TryParse(
            Text(q, "createdAtUtc", "CreatedAtUtc"),
            CultureInfo.InvariantCulture,
            DateTimeStyles.AssumeUniversal,
            out var parsed)
                ? parsed
                : (DateTimeOffset?)null)
        .Where(d => d is not null)
        .Min();

    private bool TargetMatchesFilter(JsonElement target)
    {
        if (!string.IsNullOrWhiteSpace(_targetSearch) && !MatchesAny(target, _targetSearch, "rootDomain", "RootDomain"))
        {
            return false;
        }

        return _targetFilter switch
        {
            "with-assets" => Long(target, "confirmedAssetCount", "ConfirmedAssetCount") > 0,
            "with-subdomains" => Long(target, "subdomainCount", "SubdomainCount") > 0,
            _ => true,
        };
    }

    private bool SubdomainMatchesFilter(JsonElement subdomain)
    {
        var name = SubdomainName(subdomain);
        if (!string.IsNullOrWhiteSpace(_subdomainSearch) && !MatchesAny(subdomain, _subdomainSearch, "discoveryContext", "DiscoveryContext") && !name.Contains(_subdomainSearch, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        return _subdomainFilter != "selected" || IsSelectedSubdomain(name);
    }

    private bool AssetMatchesFilter(JsonElement asset)
    {
        if (!string.IsNullOrWhiteSpace(_assetSearch) && !MatchesAsset(asset, _assetSearch))
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(_assetFilter)
            || Text(asset, "kind", "Kind").Equals(_assetFilter, StringComparison.OrdinalIgnoreCase);
    }

    private bool HttpMatchesFilter(JsonElement request) =>
        string.IsNullOrWhiteSpace(_httpSearch)
        || MatchesAny(request, _httpSearch, "createdAtUtc", "CreatedAtUtc", "state", "State", "method", "Method", "requestUrl", "RequestUrl", "domainKey", "DomainKey", "lastHttpStatus", "LastHttpStatus", "lastError", "LastError");

    private bool RabbitMatchesFilter(JsonElement queue)
    {
        if (!string.IsNullOrWhiteSpace(_rabbitSearch) && !MatchesAny(queue, _rabbitSearch, "name", "Name", "likelyWorkerKey", "LikelyWorkerKey"))
        {
            return false;
        }

        var ready = Long(queue, "messagesReady", "MessagesReady");
        var unacked = Long(queue, "messagesUnacknowledged", "MessagesUnacknowledged");
        var consumers = Long(queue, "consumers", "Consumers");
        return _rabbitFilter switch
        {
            "with-messages" => ready + unacked > 0,
            "with-consumers" => consumers > 0,
            "no-consumers" => consumers == 0,
            _ => true,
        };
    }

    private bool EventMatchesFilter(JsonElement evt)
    {
        if (!string.IsNullOrWhiteSpace(_eventSearch) && !MatchesAny(evt, _eventSearch, "publishedAtUtc", "PublishedAtUtc", "eventName", "EventName", "producer", "Producer", "hostName", "HostName", "payloadPreview", "PayloadPreview"))
        {
            return false;
        }

        var consumers = Long(evt, "consumerCount", "ConsumerCount");
        return _eventFilter switch
        {
            "consumed" => consumers > 0,
            "unconsumed" => consumers == 0,
            _ => true,
        };
    }

    private bool WorkerMatchesFilter(JsonElement worker)
    {
        if (!string.IsNullOrWhiteSpace(_workerSearch) && !MatchesAny(worker, _workerSearch, "hostName", "HostName", "workerKind", "WorkerKind", "consumerShortName", "ConsumerShortName", "status", "Status", "activityLabel", "ActivityLabel", "messageType", "MessageType"))
        {
            return false;
        }

        var status = Text(worker, "status", "Status", "activityLabel", "ActivityLabel");
        return _workerFilter switch
        {
            "healthy" => status.Contains("healthy", StringComparison.OrdinalIgnoreCase),
            "unhealthy" => status.Contains("unhealthy", StringComparison.OrdinalIgnoreCase),
            "idle" => status.Contains("idle", StringComparison.OrdinalIgnoreCase),
            _ => true,
        };
    }

    private static bool IsFailedWorker(JsonElement worker)
    {
        var status = Text(worker, "status", "Status", "activityLabel", "ActivityLabel");
        var error = Text(worker, "error", "Error");
        return !string.IsNullOrWhiteSpace(error)
            || status.Contains("error", StringComparison.OrdinalIgnoreCase)
            || status.Contains("failed", StringComparison.OrdinalIgnoreCase)
            || status.Contains("unhealthy", StringComparison.OrdinalIgnoreCase);
    }

