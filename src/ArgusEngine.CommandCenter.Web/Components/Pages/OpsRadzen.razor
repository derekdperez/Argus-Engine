            using var response = await WorkerApi.Client.PostAsJsonAsync(
                    "/api/targets",
                    new { rootDomain = _newTargetRootDomain.Trim(), globalMaxDepth = _newTargetDepth },
                    _realtimeCts.Token)
                .ConfigureAwait(false);
            response.EnsureSuccessStatusCode();
            _newTargetRootDomain = "";
            await ReloadTargetsAsync().ConfigureAwait(false);
            await ReloadOverviewAsync().ConfigureAwait(false);
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Target could not be added: {ex.Message}";
        }
    }

    private async Task ImportTargetsAsync(InputFileChangeEventArgs args)
    {
        if (args.FileCount == 0)
        {
            return;
        }

        _importingTargets = true;
        try
        {
            await using var stream = args.File.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024, _realtimeCts.Token);
            using var reader = new StreamReader(stream);
            var text = await reader.ReadToEndAsync(_realtimeCts.Token).ConfigureAwait(false);
            var domains = text.Split(['\r', '\n', ',', ';', '\t'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            using var response = await WorkerApi.Client.PostAsJsonAsync(
                    "/api/targets/bulk",
                    new { domains, globalMaxDepth = _newTargetDepth },
                    _realtimeCts.Token)
                .ConfigureAwait(false);
            response.EnsureSuccessStatusCode();
            await ReloadTargetsAsync().ConfigureAwait(false);
            await ReloadOverviewAsync().ConfigureAwait(false);
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Targets could not be imported: {ex.Message}";
        }
        finally
        {
            _importingTargets = false;
        }
    }

