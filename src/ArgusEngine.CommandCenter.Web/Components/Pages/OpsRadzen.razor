@page "/"
@page "/ops"
@rendermode InteractiveServer
@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using ArgusEngine.CommandCenter.Contracts
@using ArgusEngine.CommandCenter.Realtime
@using ArgusEngine.CommandCenter.Web.Clients
@implements IDisposable
@inject WorkerControlApiClient WorkerApi
@inject DiscoveryRealtimeClient Realtime

<PageTitle>Operations - Argus Engine</PageTitle>

<section class="ops-shell">
    <header class="ops-header">
        <div>
            <p class="eyebrow">Operations</p>
            <h1>Argus Engine Command Center</h1>
            <p class="muted">Targets, assets, HTTP queue, high value assets, and technology detection in one operations view.</p>
        </div>
        <button type="button" class="btn primary" disabled="@_loadingAny" @onclick="ReloadAllAsync">
            @(_loadingAny ? "Refreshing..." : "Refresh")
        </button>
    </header>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="alert">@_statusMessage</div>
    }

    <section class="metric-grid">
        <article class="metric-card">
            <span>Targets</span>
            <strong>@FormatNumber(TotalTargets)</strong>
        </article>
        <article class="metric-card">
            <span>Assets</span>
            <strong>@FormatNumber(ConfirmedAssets)</strong>
        </article>
        <article class="metric-card">
            <span>Subdomains</span>
            <strong>@FormatNumber(ConfirmedSubdomains)</strong>
        </article>
        <article class="metric-card">
            <span>Unique Technologies</span>
            <strong>@FormatNumber(TopTechnologyRows.Count)</strong>
        </article>
        <article class="metric-card">
            <span>HTTP Queue</span>
            <strong>@FormatNumber(HttpRows.Count)</strong>
            <small>@FormatNumber(HttpRequestsSentPerMinute) sent/min</small>
        </article>
        <article class="metric-card">
            <span>High Value Assets</span>
            <strong>@FormatNumber(HighValueRows.Count(r => r.IsHighValue))</strong>
        </article>
    </section>

    <section class="panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Scope</p>
                <h2>Targets</h2>
            </div>
            <div class="toolbar">
                <input placeholder="Search targets" @bind="_targetSearch" @bind:event="oninput" />
                <input placeholder="New target" @bind="_newTargetRootDomain" @bind:event="oninput" />
                <input type="number" min="1" max="50" @bind="_newTargetDepth" />
                <button type="button" class="btn" disabled="@(!CanCreateTarget)" @onclick="CreateTargetAsync">Add Target</button>
                <button type="button" class="btn" disabled="@(_enumLoading || TargetRows.Count == 0)" @onclick="EnumerateAllTargetsAsync">
                    @(_enumLoading ? "Enqueuing..." : "Enumerate")
                </button>
                <button type="button" class="btn" disabled="@(_spiderAllLoading || TargetRows.Count == 0)" @onclick="SpiderAllTargetsAsync">
                    @(_spiderAllLoading ? "Enqueuing..." : "Spider All")
                </button>
            </div>
        </div>

        @if (_targetsLoading)
        {
            <p class="muted">Loading targets…</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Target</th>
                            <th>Depth</th>
                            <th>Subdomains</th>
                            <th>Assets</th>
                            <th>Last run</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var target in TargetRows)
                        {
                            var id = Text(target, "id", "Id");
                            <tr class="@(IsSelectedTarget(target) ? "selected" : null)" @onclick="() => SelectTarget(target)">
                                <td>@DisplayOrDash(Text(target, "rootDomain", "RootDomain"))</td>
                                <td>@DisplayOrDash(Text(target, "globalMaxDepth", "GlobalMaxDepth"))</td>
                                <td>@FormatNumber(Long(target, "subdomainCount", "SubdomainCount"))</td>
                                <td>@FormatNumber(Long(target, "confirmedAssetCount", "ConfirmedAssetCount"))</td>
                                <td>@FormatTime(Text(target, "lastRunAtUtc", "LastRunAtUtc"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Scope</p>
                <h2>Subdomains</h2>
                <p class="muted">@SelectedTargetLabel · @FormatNumber(SubdomainRows.Count) rows</p>
            </div>
            <div class="toolbar">
                <input placeholder="Search subdomains" @bind="_subdomainSearch" @bind:event="oninput" />
                <button type="button" class="btn" disabled="@(!CanSpiderSelectedDomains || _spiderSubdomainLoading)" @onclick="() => SpiderSubdomainAsync(null)">
                    @(_spiderSubdomainLoading ? "Starting..." : "Spider Selected Target")
                </button>
            </div>
        </div>

        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Subdomain</th>
                        <th>Discovered</th>
                        <th>How found</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var subdomain in SubdomainRows)
                    {
                        var name = SubdomainName(subdomain);
                        <tr class="@(IsSelectedSubdomain(name) ? "selected" : null)" @onclick="() => SelectSubdomain(name)">
                            <td>@DisplayOrDash(name)</td>
                            <td>@FormatTime(Text(subdomain, "discoveredAtUtc", "DiscoveredAtUtc"))</td>
                            <td>@DisplayOrDash(Text(subdomain, "discoveryContext", "DiscoveryContext"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Inventory</p>
                <h2>Assets</h2>
                <p class="muted">@FormatNumber(FilteredAssetRows.Count) visible assets</p>
            </div>
            <div class="toolbar">
                <input placeholder="Search assets" @bind="_assetSearch" @bind:event="oninput" />
                <select @bind="_assetFilter">
                    <option value="">All kinds</option>
                    <option value="Domain">Domain</option>
                    <option value="Subdomain">Subdomain</option>
                    <option value="Url">URL</option>
                    <option value="IpAddress">IP address</option>
                    <option value="OpenPort">Open port</option>
                </select>
            </div>
        </div>

        @if (_assetsLoading)
        {
            <p class="muted">Loading assets…</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Discovered</th>
                            <th>Last seen</th>
                            <th>Kind</th>
                            <th>Category</th>
                            <th>Final URL</th>
                            <th>How found</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var asset in FilteredAssetRows)
                        {
                            var finalUrl = Text(asset, "finalUrl", "FinalUrl");
                            var href = TryHttpHref(finalUrl);
                            <tr>
                                <td>@FormatTime(Text(asset, "discoveredAtUtc", "DiscoveredAtUtc"))</td>
                                <td>@FormatTime(Text(asset, "lastSeenAtUtc", "LastSeenAtUtc"))</td>
                                <td>@DisplayOrDash(Text(asset, "kind", "Kind"))</td>
                                <td>@DisplayOrDash(Text(asset, "category", "Category"))</td>
                                <td>
                                    @if (href is null)
                                    {
                                        @DisplayOrDash(finalUrl)
                                    }
                                    else
                                    {
                                        <a href="@href" target="_blank" rel="noopener noreferrer">@finalUrl</a>
                                    }
                                </td>
                                <td>@DisplayOrDash(Text(asset, "discoveryContext", "DiscoveryContext"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">HTTP</p>
                <h2>HTTP Queue</h2>
                <p class="muted">@FormatNumber(HttpRows.Count) requests</p>
            </div>
            <div class="toolbar">
                <input placeholder="Search HTTP queue" @bind="_httpSearch" @bind:event="oninput" />
                <select @bind="_httpStateFilter" @bind:after="ReloadHttpQueueAsync">
                    <option value="">All states</option>
                    <option value="Queued">Queued</option>
                    <option value="InFlight">In flight</option>
                    <option value="Retry">Retry</option>
                    <option value="Succeeded">Completed</option>
                    <option value="Failed">Failed</option>
                </select>
                <button type="button" class="btn" @onclick="RetrySelectedHttpRowsAsync">Retry Selected</button>
                <button type="button" class="btn" @onclick="ClearSelectedHttpRowsAsync">Clear Selected</button>
                <button type="button" class="btn" @onclick="ClearCompletedHttpRowsAsync">Clear Completed</button>
                <button type="button" class="btn" @onclick="ClearFailedHttpRowsAsync">Clear Failed</button>
            </div>
        </div>

        @if (_httpLoading)
        {
            <p class="muted">Loading HTTP queue…</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Select</th>
                            <th>Created</th>
                            <th>State</th>
                            <th>Method</th>
                            <th>URL</th>
                            <th>Domain</th>
                            <th>Attempts</th>
                            <th>Status</th>
                            <th>Duration</th>
                            <th>Error</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var q in HttpRows)
                        {
                            var id = Text(q, "id", "Id");
                            <tr>
                                <td><input type="checkbox" checked="@IsHttpRowSelected(id)" @onchange="args => ToggleHttpRow(id, args)" /></td>
                                <td>@FormatTime(Text(q, "createdAtUtc", "CreatedAtUtc"))</td>
                                <td>@DisplayOrDash(Text(q, "state", "State"))</td>
                                <td>@DisplayOrDash(Text(q, "method", "Method"))</td>
                                <td class="wrap">@DisplayOrDash(Text(q, "requestUrl", "RequestUrl"))</td>
                                <td>@DisplayOrDash(Text(q, "domainKey", "DomainKey"))</td>
                                <td>@DisplayOrDash(Text(q, "attemptCount", "AttemptCount")) / @DisplayOrDash(Text(q, "maxAttempts", "MaxAttempts"))</td>
                                <td>@DisplayOrDash(Text(q, "lastHttpStatus", "LastHttpStatus"))</td>
                                <td>@DurationLabel(q)</td>
                                <td class="wrap">@DisplayOrDash(Text(q, "lastError", "LastError"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">High Value</p>
                <h2>High Value Assets</h2>
                <p class="muted">Moved from the removed High Value page.</p>
            </div>
            <div class="toolbar">
                <input placeholder="Search high value assets" @bind="_highValueSearch" @bind:event="oninput" />
                <select @bind="_highValueStatusFilter">
                    <option value="Active">Active</option>
                    <option value="">All statuses</option>
                    <option value="Pending">Pending</option>
                    <option value="In Process">In Process</option>
                    <option value="False Positive">False Positive</option>
                    <option value="Valid Finding">Valid Finding</option>
                </select>
                <button type="button" class="btn" disabled="@_highValueLoading" @onclick="ReloadHighValueAssetsAsync">
                    @(_highValueLoading ? "Refreshing..." : "Refresh")
                </button>
            </div>
        </div>

        <div class="mini-metrics">
            <span>@FormatNumber(HighValueRows.Count(r => r.IsHighValue)) high value</span>
            <span>@FormatNumber(ValidFindingCount) valid findings</span>
            <span>@FormatNumber(FalsePositiveCount) false positives</span>
            <span>@ActualFindingRate actual finding rate</span>
        </div>

        @if (_highValueLoading)
        {
            <p class="muted">Loading high value assets…</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Last seen</th>
                            <th>Status</th>
                            <th>Target</th>
                            <th>Kind</th>
                            <th>Category</th>
                            <th>URL / Asset</th>
                            <th>Finding</th>
                            <th>Severity</th>
                            <th>Pattern</th>
                            <th>Matched text</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in FilteredHighValueRows)
                        {
                            <tr>
                                <td>@FormatTime(row.LastSeenAtUtc)</td>
                                <td>
                                    <select value="@row.InvestigationStatus" @onchange="args => UpdateInvestigationStatusAsync(row, args.Value?.ToString())">
                                        @foreach (var status in InvestigationStatuses)
                                        {
                                            <option value="@status">@status</option>
                                        }
                                    </select>
                                </td>
                                <td>@DisplayOrDash(row.TargetRootDomain)</td>
                                <td>@DisplayOrDash(row.Kind)</td>
                                <td>@DisplayOrDash(row.Category)</td>
                                <td class="wrap">
                                    @{
                                        var finalUrl = BestAssetUrl(row);
                                        var href = TryHttpHref(finalUrl);
                                    }
                                    @if (href is null)
                                    {
                                        @DisplayOrDash(finalUrl)
                                    }
                                    else
                                    {
                                        <a href="@href" target="_blank" rel="noopener noreferrer">@finalUrl</a>
                                    }
                                </td>
                                <td>@DisplayOrDash(row.FindingType)</td>
                                <td>@DisplayOrDash(row.Severity)</td>
                                <td><code>@DisplayOrDash(row.PatternName)</code></td>
                                <td class="wrap">@DisplayOrDash(row.MatchedText)</td>
                                <td><button type="button" class="btn small" @onclick="() => MarkFalsePositiveAsync(row)">False Positive</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Technology ID</p>
                <h2>Top 10 Technologies</h2>
                <p class="muted">Grouped by technology name regardless of version. Click a name for version usage.</p>
            </div>
            <div class="toolbar">
                <input placeholder="Search technologies" @bind="_technologySearch" @bind:event="oninput" />
                <button type="button" class="btn" disabled="@_technologiesLoading" @onclick="ReloadTechnologyDataAsync">
                    @(_technologiesLoading ? "Refreshing..." : "Refresh")
                </button>
            </div>
        </div>

        @if (_usageLoading)
        {
            <p class="muted">Loading technology usage…</p>
        }
        else
        {
            <ol class="top-tech-list">
                @foreach (var row in TopTechnologyRows.Take(10))
                {
                    <li>
                        <button type="button" class="link-button" @onclick="() => OpenTechnologyModal(row.Name)">
                            @row.Name
                        </button>
                        <span>(@FormatNumber(row.TargetCount) targets, @FormatNumber(row.SubdomainCount) subdomains)</span>
                    </li>
                }
            </ol>
        }

        <h3>Technologies</h3>
        @if (_technologiesLoading)
        {
            <p class="muted">Loading technologies…</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Last seen</th>
                            <th>Target</th>
                            <th>Subdomain</th>
                            <th>Technology</th>
                            <th>Version</th>
                            <th>Source</th>
                            <th>Mode</th>
                            <th>Evidence</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in FilteredTechnologyRows)
                        {
                            <tr>
                                <td>@FormatTime(row.LastSeenUtc)</td>
                                <td>@DisplayOrDash(row.TargetRootDomain)</td>
                                <td>@DisplayOrDash(row.Subdomain)</td>
                                <td>@DisplayOrDash(row.TechnologyName)</td>
                                <td>@DisplayOrDash(row.Version)</td>
                                <td>@DisplayOrDash(row.SourceType)</td>
                                <td>@DisplayOrDash(row.DetectionMode)</td>
                                <td class="wrap">@DisplayOrDash(row.EvidenceSummary)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</section>

@if (_selectedTechnologyName is not null)
{
    <div class="modal-backdrop" @onclick="CloseTechnologyModal">
        <section class="modal" @onclick:stopPropagation="true">
            <header class="modal-header">
                <div>
                    <p class="eyebrow">Version breakdown</p>
                    <h2>@_selectedTechnologyName</h2>
                </div>
                <button type="button" class="btn" @onclick="CloseTechnologyModal">Close</button>
            </header>

            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Version</th>
                            <th>Targets</th>
                            <th>Subdomains</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in SelectedTechnologyVersionRows)
                        {
                            <tr>
                                <td>@DisplayOrDash(row.Version)</td>
                                <td>@FormatNumber(row.TargetCount)</td>
                                <td>@FormatNumber(row.SubdomainCount)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
}

@code {
    private JsonElement? _overview;
    private readonly List<JsonElement> _targets = [];
    private readonly List<JsonElement> _assets = [];
    private readonly List<JsonElement> _queue = [];
    private readonly List<HighValueAssetRowDto> _highValueRows = [];
    private readonly List<TechnologyIdentificationRowDto> _technologyRows = [];
    private readonly List<TechnologyUsageDto> _technologyUsage = [];
    private readonly CancellationTokenSource _cts = new();

    private bool _initialLoadStarted;
    private bool _overviewLoading = true;
    private bool _targetsLoading = true;
    private bool _assetsLoading = true;
    private bool _httpLoading = true;
    private bool _highValueLoading = true;
    private bool _technologiesLoading = true;
    private bool _usageLoading = true;
    private bool _enumLoading;
    private bool _spiderAllLoading;
    private bool _spiderSubdomainLoading;
    private string? _statusMessage;

    private string _targetSearch = "";
    private string _subdomainSearch = "";
    private string _assetSearch = "";
    private string _assetFilter = "";
    private string _httpSearch = "";
    private string _httpStateFilter = "";
    private string _highValueSearch = "";
    private string _highValueStatusFilter = "Active";
    private string _technologySearch = "";
    private string _newTargetRootDomain = "";
    private int _newTargetDepth = 12;
    private string? _selectedTargetId;
    private string? _selectedSubdomain;
    private string? _selectedTechnologyName;
    private readonly HashSet<string> _selectedHttpIds = new(StringComparer.OrdinalIgnoreCase);

    private static readonly IReadOnlyList<string> InvestigationStatuses = ["Pending", "In Process", "False Positive", "Valid Finding"];

    private bool _loadingAny => _overviewLoading || _targetsLoading || _assetsLoading || _httpLoading || _highValueLoading || _technologiesLoading || _usageLoading;
    private long TotalTargets => _targets.Count;
    private long ConfirmedAssets => _targets.Sum(t => Long(t, "confirmedAssetCount", "ConfirmedAssetCount"));
    private long ConfirmedSubdomains => _targets.Sum(t => Long(t, "subdomainCount", "SubdomainCount"));
    private long HttpRequestsSentPerMinute => OverviewLong("httpRequestsSentLastMinuteCount", "HttpRequestsSentLastMinuteCount");
    private IReadOnlyList<HighValueAssetRowDto> HighValueRows => _highValueRows;
    private long ValidFindingCount => _highValueRows.LongCount(r => r.InvestigationStatus == "Valid Finding");
    private long FalsePositiveCount => _highValueRows.LongCount(r => r.InvestigationStatus == "False Positive" || !r.IsHighValue);
    private string ActualFindingRate
    {
        get
        {
            var totalClassified = ValidFindingCount + FalsePositiveCount;
            return totalClassified == 0 ? "-" : (ValidFindingCount / (decimal)totalClassified).ToString("P0", CultureInfo.InvariantCulture);
        }
    }

    private bool CanCreateTarget => !string.IsNullOrWhiteSpace(_newTargetRootDomain) && _newTargetDepth > 0;
    private bool CanSpiderSelectedDomains => !string.IsNullOrWhiteSpace(_selectedTargetId);

    private IReadOnlyList<JsonElement> TargetRows => _targets
        .Where(t => string.IsNullOrWhiteSpace(_targetSearch) || Text(t, "rootDomain", "RootDomain").Contains(_targetSearch, StringComparison.OrdinalIgnoreCase))
        .OrderBy(t => Text(t, "rootDomain", "RootDomain"), StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private IReadOnlyList<JsonElement> SubdomainRows => _assets
        .Where(MatchesSelectedTarget)
        .Where(a => Text(a, "kind", "Kind").Equals("Subdomain", StringComparison.OrdinalIgnoreCase))
        .GroupBy(SubdomainName, StringComparer.OrdinalIgnoreCase)
        .Where(g => !string.IsNullOrWhiteSpace(g.Key))
        .Select(g => g.OrderByDescending(a => Text(a, "discoveredAtUtc", "DiscoveredAtUtc"), StringComparer.Ordinal).First())
        .Where(s => string.IsNullOrWhiteSpace(_subdomainSearch) || SubdomainName(s).Contains(_subdomainSearch, StringComparison.OrdinalIgnoreCase))
        .OrderBy(SubdomainName, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private IReadOnlyList<JsonElement> FilteredAssetRows => _assets
        .Where(MatchesSelectedTarget)
        .Where(MatchesSelectedSubdomain)
        .Where(AssetMatchesFilter)
        .OrderByDescending(a => Text(a, "discoveredAtUtc", "DiscoveredAtUtc"), StringComparer.Ordinal)
        .Take(500)
        .ToArray();

    private IReadOnlyList<JsonElement> HttpRows => _queue
        .Where(q => string.IsNullOrWhiteSpace(_httpSearch) || MatchesAny(q, _httpSearch, "createdAtUtc", "CreatedAtUtc", "state", "State", "method", "Method", "requestUrl", "RequestUrl", "domainKey", "DomainKey", "lastHttpStatus", "LastHttpStatus", "lastError", "LastError"))
        .OrderByDescending(q => Text(q, "createdAtUtc", "CreatedAtUtc"), StringComparer.Ordinal)
        .Take(500)
        .ToArray();

    private IReadOnlyList<HighValueAssetRowDto> FilteredHighValueRows => _highValueRows
        .Where(StatusMatches)
        .Where(row => HighValueAssetMatches(row, _highValueSearch))
        .OrderByDescending(row => row.LastSeenAtUtc ?? row.FindingDiscoveredAtUtc)
        .Take(500)
        .ToArray();

    private IReadOnlyList<TechnologyIdentificationRowDto> FilteredTechnologyRows => _technologyRows
        .Where(row => TechnologyMatches(row, _technologySearch))
        .OrderByDescending(row => row.LastSeenUtc)
        .Take(500)
        .ToArray();

    private IReadOnlyList<TopTechnologyRow> TopTechnologyRows => _technologyUsage
        .GroupBy(u => u.TechnologyName, StringComparer.OrdinalIgnoreCase)
        .Select(g =>
        {
            var locations = g.SelectMany(x => x.Locations).ToArray();
            return new TopTechnologyRow(
                g.Key,
                locations.Select(l => l.TargetId).Distinct().LongCount(),
                locations.Select(l => l.Subdomain).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount());
        })
        .OrderByDescending(x => x.SubdomainCount)
        .ThenByDescending(x => x.TargetCount)
        .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private IReadOnlyList<TechnologyVersionRow> SelectedTechnologyVersionRows => _selectedTechnologyName is null
        ? []
        : _technologyUsage
            .Where(u => string.Equals(u.TechnologyName, _selectedTechnologyName, StringComparison.OrdinalIgnoreCase))
            .GroupBy(u => string.IsNullOrWhiteSpace(u.Version) ? "" : u.Version, StringComparer.OrdinalIgnoreCase)
            .Select(g =>
            {
                var locations = g.SelectMany(x => x.Locations).ToArray();
                return new TechnologyVersionRow(
                    string.IsNullOrWhiteSpace(g.Key) ? "Unknown / unversioned" : g.Key,
                    locations.Select(l => l.TargetId).Distinct().LongCount(),
                    locations.Select(l => l.Subdomain).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).LongCount());
            })
            .OrderByDescending(x => x.SubdomainCount)
            .ThenBy(x => x.Version, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private string SelectedTargetLabel
    {
        get
        {
            var target = _targets.FirstOrDefault(IsSelectedTarget);
            var label = target.ValueKind == JsonValueKind.Object ? Text(target, "rootDomain", "RootDomain") : "";
            return string.IsNullOrWhiteSpace(label) ? "Select a target" : label;
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialLoadStarted)
        {
            _initialLoadStarted = true;
            _ = InvokeAsync(InitializeAsync);
        }

        return Task.CompletedTask;
    }

    private async Task InitializeAsync()
    {
        await ReloadAllAsync().ConfigureAwait(false);

        try
        {
            await Realtime.EnsureStartedAsync(_cts.Token).ConfigureAwait(false);
            Realtime.DomainEventReceived += OnRealtimeEvent;
        }
        catch
        {
            // Manual refresh remains available if realtime is unavailable.
        }

        await InvokeAsync(StateHasChanged).ConfigureAwait(false);
    }

    private void OnRealtimeEvent(object? sender, LiveUiEventDto evt)
    {
        if (evt.Scope is "targets" or "assets" or "http" or "findings" or "technology" or "ops")
        {
            _ = InvokeAsync(async () =>
            {
                await ReloadAllAsync().ConfigureAwait(false);
                StateHasChanged();
            });
        }
    }

    private async Task ReloadAllAsync()
    {
        _statusMessage = null;
        await Task.WhenAll(
            ReloadOverviewAsync(),
            ReloadTargetsAsync(),
            ReloadAssetsAsync(),
            ReloadHttpQueueAsync(),
            ReloadHighValueAssetsAsync(),
            ReloadTechnologyDataAsync()).ConfigureAwait(false);

        EnsureSelection();
    }

