    private bool IsSelectedTarget(JsonElement target) =>
        !string.IsNullOrWhiteSpace(_selectedTargetId)
        && Text(target, "id", "Id").Equals(_selectedTargetId, StringComparison.OrdinalIgnoreCase);

    private void SelectTarget(JsonElement target)
    {
        var targetId = Text(target, "id", "Id");
        if (string.IsNullOrWhiteSpace(targetId))
        {
            return;
        }

        if (!string.Equals(_selectedTargetId, targetId, StringComparison.OrdinalIgnoreCase))
        {
            _selectedSubdomain = null;
        }

        _selectedTargetId = targetId;
    }

    private bool IsSelectedSubdomain(string subdomain) =>
        !string.IsNullOrWhiteSpace(_selectedSubdomain)
        && subdomain.Equals(_selectedSubdomain, StringComparison.OrdinalIgnoreCase);

    private void SelectSubdomain(string subdomain)
