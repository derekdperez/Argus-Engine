@page "/status"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using ArgusEngine.CommandCenter.Models
@using ArgusEngine.CommandCenter.Realtime

@using ArgusEngine.CommandCenter.Web.Clients
@inject OperationsApiClient OperationsApi
@inject DiscoveryRealtimeClient Realtime
@inject IJSRuntime Js

@implements IDisposable

<PageTitle>System Status</PageTitle>

<section class="status-page">
    <div class="status-hero">
        <div>
            <p class="eyebrow">Live operations</p>
            <h1>System Status</h1>
            <p class="muted">
                Snapshot-driven Command Center health with realtime queue, worker, dependency, SLO, and alert signals.
            </p>
        </div>

        <div class="hero-actions">
            <span class="hero-badge @ToBadgeClass(_snapshot?.Color)">
                @(_snapshot?.Status ?? "Loading")
            </span>
            <span class="connection-state">Realtime: @Realtime.State</span>
            <button class="refresh-button" @onclick="ReloadAsync" disabled="@_loading">
                @(_loading ? "Refreshing..." : "Refresh now")
            </button>
            <button class="refresh-button download-button"
                    @onclick="CreateLogBundleAsync"
                    disabled="@(!CanCreateLogBundle)"
                    title="@LogBundleButtonTitle">
                Create Log Bundle
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-red">
            @_error
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_logBundleMessage))
    {
        <div class="alert alert-blue">
            @_logBundleMessage
        </div>
    }

    @if (_snapshot is null)
    {
        <div class="empty-card">
            Loading system status…
        </div>
    }
    else
    {
        <div class="status-grid">
            <article class="status-card">
                <span class="label">Overall</span>
                <strong>@_snapshot.Status</strong>
                <span class="badge @ToBadgeClass(_snapshot.Color)">@_snapshot.Color</span>
            </article>

            <article class="status-card">
                <span class="label">Version</span>
                <strong>@_snapshot.Version</strong>
                <span class="muted">Build @_snapshot.BuildStamp</span>
            </article>

            <article class="status-card">
                <span class="label">Snapshot</span>
                <strong>@AppTimeFormat.FormatCompact(_snapshot.AtUtc)</strong>
                <span class="muted">Eastern Time</span>
            </article>

            <article class="status-card">
                <span class="label">Alerts</span>
                <strong>@_snapshot.Alerts.Count</strong>
                <span class="muted">active operational alerts</span>
            </article>
        </div>

        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">SLOs</p>
                    <h2>Service-level indicators</h2>
                </div>
            </div>

            <div class="responsive-table">
                <table>
                    <thead>
                    <tr>
                        <th>Name</th>
                        <th>Current</th>
                        <th>Target</th>
                        <th>Status</th>
                        <th>Reason</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var indicator in _snapshot.Indicators)
                    {
                        <tr>
                            <td>@indicator.Name</td>
                            <td>@indicator.CurrentValue</td>
                            <td>@indicator.Target</td>
                            <td><span class="badge @ToBadgeClass(indicator.Color)">@indicator.Status</span></td>
                            <td>@indicator.Reason</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Workers</p>
                    <h2>Worker readiness</h2>
                </div>
            </div>

            <div class="responsive-table">
                <table>
                    <thead>
                    <tr>
                        <th>Worker</th>
                        <th>Desired</th>
                        <th>Running</th>
                        <th>Pending</th>
                        <th>Status</th>
                        <th>Reason</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var worker in _snapshot.Workers)
                    {
                        <tr>
                            <td>
                                <strong>@worker.DisplayName</strong>
                                <div class="muted">@worker.Key</div>
                            </td>
                            <td>@worker.DesiredCount</td>
                            <td>@worker.RunningCount</td>
                            <td>@worker.PendingCount</td>
                            <td><span class="badge @ToBadgeClass(worker.Color)">@worker.Status</span></td>
                            <td>@worker.Reason</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Queues</p>
                    <h2>Backlog and age</h2>
                </div>
            </div>

            <div class="responsive-table">
                <table>
                    <thead>
                    <tr>
                        <th>Queue</th>
                        <th>Depth</th>
                        <th>Oldest age</th>
                        <th>Status</th>
                        <th>Reason</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var queue in _snapshot.Queues)
                    {
                        <tr>
                            <td>
                                <strong>@queue.DisplayName</strong>
                                <div class="muted">@queue.Key</div>
                            </td>
                            <td>@FormatDepth(queue.Depth)</td>
                            <td>@FormatAge(queue.OldestAgeSeconds)</td>
                            <td><span class="badge @ToBadgeClass(queue.Color)">@queue.Status</span></td>
                            <td>@queue.Reason</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Dependencies</p>
                    <h2>Runtime dependencies</h2>
                </div>
            </div>

            <div class="responsive-table">
                <table>
                    <thead>
                    <tr>
                        <th>Dependency</th>
                        <th>Status</th>
                        <th>Reason</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var dependency in _snapshot.Dependencies)
                    {
                        <tr>
                            <td>
                                <strong>@dependency.DisplayName</strong>
                                <div class="muted">@dependency.Key</div>
                            </td>
                            <td><span class="badge @ToBadgeClass(dependency.Color)">@dependency.Status</span></td>
                            <td>@dependency.Reason</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Components</p>
                    <h2>Component versions</h2>
                </div>
            </div>

            <div class="responsive-table">
                <table>
                    <thead>
                    <tr>
                        <th>Component</th>
                        <th>Version</th>
                        <th>Status</th>
                        <th>Reason</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var component in _snapshot.Components)
                    {
                        <tr>
                            <td>
                                <strong>@component.DisplayName</strong>
                                <div class="muted">@component.Key</div>
                            </td>
                            <td>@component.Version</td>
                            <td><span class="badge @ToBadgeClass(component.Color)">@component.Status</span></td>
                            <td>@component.Reason</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        @if (_dockerSnapshot is not null)
        {
            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Docker runtime</p>
                        <h2>Container components</h2>
                    </div>
                    <span class="badge @ToBadgeClass(_dockerSnapshot.Color)">@_dockerSnapshot.Status</span>
                </div>

                @if (!_dockerSnapshot.DockerAvailable)
                {
                    <div class="empty-card">@(_dockerSnapshot.Error ?? "Docker runtime is unavailable.")</div>
                }
                else
                {
                    <div class="responsive-table">
                        <table>
                            <thead>
                            <tr>
                                <th>Component</th>
                                <th>Version</th>
                                <th>First released</th>
                                <th>Status</th>
                                <th>Reason</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var component in _dockerSnapshot.Components)
                            {
                                <tr>
                                    <td>
                                        <strong>@component.DisplayName</strong>
                                        <div class="muted">@component.Key</div>
                                    </td>
                                    <td>@component.Version</td>
                                    <td>@AppTimeFormat.FormatCompact(component.FirstReleasedAtUtc)</td>
                                    <td><span class="badge @ToBadgeClass(component.Color)">@component.Status</span></td>
                                    <td>@component.Reason</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            @if (_dockerSnapshot.Containers.Count > 0)
            {
                <section class="panel">
                    <div class="panel-heading">
                        <div>
                            <p class="eyebrow">Containers</p>
                            <h2>Container health and recent logs</h2>
                        </div>
                        <button class="refresh-button download-button"
                                @onclick="CreateLogBundleAsync"
                                disabled="@(!CanCreateLogBundle)"
                                title="@LogBundleButtonTitle">
                            Create Log Bundle
                        </button>
                    </div>

                    <div class="runtime-grid">
                        @foreach (var container in _dockerSnapshot.Containers)
                        {
                            var visibleLogLines = GetVisibleLogLines(container);

                            <article class="runtime-card">
                                <div class="runtime-card-header">
                                    <div>
                                        <strong>@container.Name</strong>
                                        <div class="muted">@container.Image</div>
                                        <div class="worker-label">@ResolveWorkerName(container)</div>
                                    </div>
                                    <span class="badge @ToBadgeClass(container.Color)">@container.Status</span>
                                </div>

                                <div class="muted">
                                    Version @container.Version · Docker @container.DockerStatusText · Health @container.HealthCheckStatus
                                </div>

                                @if (visibleLogLines.Count > 0)
                                {
                                    <pre class="log-tail">@string.Join(Environment.NewLine, visibleLogLines)</pre>
                                }
                            </article>
                        }
                    </div>
                </section>
            }
        }

        @if (_ecsSnapshot is not null)
        {
            <section class="panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">ECS</p>
                        <h2>Worker service deployment state</h2>
                    </div>
                    <span class="badge @ToBadgeClass(_ecsSnapshot.Color)">@_ecsSnapshot.Status</span>
                </div>

                @if (!_ecsSnapshot.EcsAvailable)
                {
                    <div class="empty-card">@(_ecsSnapshot.Error ?? "ECS is not configured or unavailable.")</div>
                }
                else
                {
                    <div class="responsive-table">
                        <table>
                            <thead>
                            <tr>
                                <th>Worker</th>
                                <th>Service</th>
                                <th>Version</th>
                                <th>Desired</th>
                                <th>Running</th>
                                <th>Pending</th>
                                <th>Status</th>
                                <th>Deployment</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var service in _ecsSnapshot.Services)
                            {
                                <tr>
                                    <td>
                                        <strong>@service.WorkerKey</strong>
                                        <div class="muted">@AppTimeFormat.FormatCompact(service.FirstReleasedAtUtc)</div>
                                    </td>
                                    <td>@service.ServiceName</td>
                                    <td>@service.Version</td>
                                    <td>@service.DesiredCount</td>
                                    <td>@service.RunningCount</td>
                                    <td>@service.PendingCount</td>
                                    <td><span class="badge @ToBadgeClass(service.Color)">@service.ServiceStatus</span></td>
                                    <td>@service.DeploymentStatus</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        }

        <section class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Alerts</p>
                    <h2>Active operational alerts</h2>
                </div>
            </div>

            @if (_snapshot.Alerts.Count == 0)
            {
                <div class="empty-card">No active operational alerts.</div>
            }
            else
            {
                <div class="alert-list">
                    @foreach (var alert in _snapshot.Alerts)
                    {
                        <div class="alert-row">
                            <span class="badge @ToBadgeClass(alert.Color)">@alert.Severity</span>
                            <div>
                                <strong>@alert.Scope</strong>
                                <p>@alert.Message</p>
                                <span class="muted">@AppTimeFormat.FormatCompact(alert.AtUtc)</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    }
</section>

