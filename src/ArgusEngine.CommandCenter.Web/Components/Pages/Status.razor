</style>

@code {
    private readonly CancellationTokenSource _pollCts = new();

    private CommandCenterStatusSnapshot? _snapshot;
    private DockerRuntimeStatusDto? _dockerSnapshot;
    private EcsRuntimeStatusDto? _ecsSnapshot;
    private bool _loading = true;
    private bool _initialLoadStarted;
    private string? _error;
    private string? _logBundleMessage;

    private bool CanCreateLogBundle =>
        _dockerSnapshot?.Containers.Any(container => GetVisibleLogLines(container).Count > 0) == true;

    private string LogBundleButtonTitle =>
        CanCreateLogBundle
            ? "Download the log lines currently visible on this screen, grouped by worker/container."
            : "No visible container log lines are currently loaded.";

    protected override Task OnInitializedAsync()
    {
        Realtime.DomainEventReceived += OnDomainEventReceived;
        Realtime.StatusChangedReceived += OnStatusChangedReceived;
        Realtime.ConnectionStateChanged += OnConnectionStateChanged;
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialLoadStarted)
        {
            return;
        }

        _initialLoadStarted = true;
        await LoadInitialAsync();
    }

    private async Task LoadInitialAsync()
    {
        await ReloadAsync();

        try
        {
            await Realtime.EnsureStartedAsync(_pollCts.Token);
        }
        catch (Exception ex)
        {
            _error = $"Realtime connection unavailable. Falling back to periodic refresh. {ex.Message}";
        }

        _ = PollWhenDisconnectedAsync(_pollCts.Token);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;
        _logBundleMessage = null;

        try
        {
            _snapshot = await OperationsApi.Client.GetFromJsonAsync<CommandCenterStatusSnapshot>("/api/status/summary", _pollCts.Token);

            try
            {
                _dockerSnapshot = await OperationsApi.Client.GetFromJsonAsync<DockerRuntimeStatusDto>("/api/ops/docker-status", _pollCts.Token);
            }
            catch
            {
                _dockerSnapshot = null;
            }

            try
            {
                _ecsSnapshot = await OperationsApi.Client.GetFromJsonAsync<EcsRuntimeStatusDto>("/api/ops/ecs-status", _pollCts.Token);
            }
            catch
            {
                _ecsSnapshot = null;
            }
        }
        catch (Exception ex)
        {
            _error = $"Unable to load system status. {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CreateLogBundleAsync()
    {
        _error = null;
        _logBundleMessage = null;

        try
        {
            var bundleText = BuildLogBundle();

            if (string.IsNullOrWhiteSpace(bundleText))
            {
                _logBundleMessage = "No visible container log lines are currently loaded on the System Status screen.";
                return;
            }

            var fileName = $"argus-system-status-log-bundle-{DateTimeOffset.UtcNow:yyyyMMdd-HHmmss}.txt";

            await Js.InvokeVoidAsync(
                "argusUi.downloadTextFile",
                fileName,
                bundleText,
                "text/plain;charset=utf-8");

            _logBundleMessage = $"Created log bundle {fileName}.";
        }
        catch (Exception ex)
        {
            _error = $"Unable to create log bundle. {ex.Message}";
        }
    }

    private string BuildLogBundle()
    {
        if (_dockerSnapshot is null || _dockerSnapshot.Containers.Count == 0)
        {
            return string.Empty;
        }

        var entries = _dockerSnapshot.Containers
            .Select(container => new
            {
                Container = container,
                WorkerName = ResolveWorkerName(container),
                Lines = GetVisibleLogLines(container)
            })
            .Where(entry => entry.Lines.Count > 0)
            .OrderBy(entry => entry.WorkerName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(entry => entry.Container.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (entries.Count == 0)
        {
            return string.Empty;
        }

        var sb = new System.Text.StringBuilder();
        var generatedUtc = DateTimeOffset.UtcNow;

        sb.AppendLine("Argus Engine System Status Log Bundle");
        sb.AppendLine("====================================");
        sb.AppendLine($"GeneratedUtc: {generatedUtc:O}");
        sb.AppendLine($"SystemStatusSnapshotUtc: {_snapshot?.AtUtc.ToString("O") ?? "unavailable"}");
        sb.AppendLine($"DockerSnapshotUtc: {_dockerSnapshot.AtUtc:O}");
        sb.AppendLine($"DockerStatus: {_dockerSnapshot.Status}");
        sb.AppendLine($"ContainersWithVisibleLogs: {entries.Count:N0}");
        sb.AppendLine($"VisibleLogLinesPerContainer: 25");
        sb.AppendLine($"TotalVisibleLogLines: {entries.Sum(entry => entry.Lines.Count):N0}");
        sb.AppendLine();

        foreach (var entry in entries)
        {
            var container = entry.Container;

            sb.AppendLine("--------------------------------------------------------------------------------");
            sb.AppendLine($"Worker: {entry.WorkerName}");
            sb.AppendLine($"Container: {container.Name}");
            sb.AppendLine($"ContainerId: {container.Id}");
            sb.AppendLine($"Image: {container.Image}");
            sb.AppendLine($"Version: {container.Version}");
            sb.AppendLine($"ContainerStatus: {container.Status}");
            sb.AppendLine($"DockerStatus: {container.DockerStatusText}");
            sb.AppendLine($"HealthCheckStatus: {container.HealthCheckStatus}");
            sb.AppendLine($"VisibleLogLineCount: {entry.Lines.Count:N0}");
            sb.AppendLine("--------------------------------------------------------------------------------");

            foreach (var line in entry.Lines)
            {
                sb.AppendLine(line);
            }

            sb.AppendLine();
        }

        return sb.ToString();
    }

    private string ResolveWorkerName(DockerContainerStatusDto container)
    {
        if (_snapshot is not null)
        {
            foreach (var worker in _snapshot.Workers)
            {
                if (ContainsOrdinal(container.Name, worker.Key)
                    || ContainsOrdinal(container.Name, worker.DisplayName)
                    || ContainsOrdinal(container.Image, worker.Key)
                    || ContainsOrdinal(container.Image, worker.DisplayName))
                {
                    return $"{worker.DisplayName} ({worker.Key})";
                }
            }
        }

        if (!string.IsNullOrWhiteSpace(container.Name))
        {
            return container.Name;
        }

        return !string.IsNullOrWhiteSpace(container.Id)
            ? container.Id
            : "Unknown worker";
    }

    private static IReadOnlyList<string> GetVisibleLogLines(DockerContainerStatusDto container)
    {
        return container.LogTail.Count <= 25
            ? container.LogTail
            : container.LogTail.TakeLast(25).ToArray();
    }

    private static bool ContainsOrdinal(string? value, string? match)
    {
        return !string.IsNullOrWhiteSpace(value)
            && !string.IsNullOrWhiteSpace(match)
            && value.Contains(match, StringComparison.OrdinalIgnoreCase);
    }

    private async Task PollWhenDisconnectedAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(30), cancellationToken);

                if (!Realtime.IsConnected)
                {
                    await ReloadAsync();
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException)
            {
                return;
            }
        }
    }

    private void OnDomainEventReceived(object? sender, LiveUiEventDto evt)
    {
        if (evt.Scope is "workers" or "http" or "assets" or "targets" or "status" or "ops")
        {
            _ = InvokeAsync(async () =>
            {
                await ReloadAsync();
                StateHasChanged();
            });
        }
    }

    private void OnStatusChangedReceived(object? sender, CommandCenterStatusSnapshot snapshot)
    {
        _snapshot = snapshot;
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnConnectionStateChanged(object? sender, EventArgs args)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private static string FormatAge(double? seconds)
    {
        return seconds is null ? "—" : AppTimeFormat.FormatDuration(TimeSpan.FromSeconds(Math.Max(0, seconds.Value)));
    }

    private static string FormatDepth(long? depth)
    {
        return depth?.ToString("N0") ?? "—";
    }

    private static string ToBadgeClass(string? color)
    {
        return color?.ToLowerInvariant() switch
        {
            "green" => "badge-green",
            "yellow" => "badge-yellow",
            "red" => "badge-red",
            _ => "badge-gray"
        };
    }

    public void Dispose()
    {
        Realtime.DomainEventReceived -= OnDomainEventReceived;
        Realtime.StatusChangedReceived -= OnStatusChangedReceived;
        Realtime.ConnectionStateChanged -= OnConnectionStateChanged;
        _pollCts.Cancel();
        _pollCts.Dispose();
    }
}


