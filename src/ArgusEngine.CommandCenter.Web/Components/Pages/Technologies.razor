@using System.Net.Http.Json
@using ArgusEngine.CommandCenter.Models
@using ArgusEngine.CommandCenter.Realtime
@implements IDisposable
@using ArgusEngine.CommandCenter.Web.Clients
@inject DiscoveryApiClient DiscoveryApi
@inject DiscoveryRealtimeClient Realtime
@inject Microsoft.Extensions.Logging.ILogger<Technologies> Logger
@rendermode InteractiveServer

<PageTitle>Technologies and Tags · Argus Engine</PageTitle>

<div class="page-shell ops-page">
    <section class="page-hero ops-hero">
        <div>
            <p class="eyebrow">Detection</p>
            <h1>Technologies and Tags</h1>
            <p class="hero-copy">Technologies identified across assets through headers, HTML content, cookies, and other fingerprints.</p>

            <div class="hero-meta">
                <span class="live-pill @LiveStateCss">@Realtime.State</span>
                <span>@(_lastLoadedAtUtc is null ? "Not loaded" : $"Last refresh {AppTimeFormat.Format(_lastLoadedAtUtc)} EST")</span>
                <span>@FilteredRows.Count.ToString("N0") rows</span>
            </div>
        </div>

        <div class="hero-actions">
            <button type="button" class="btn" @onclick="ReloadAsync" disabled="@_loading">@(_loading ? "Refreshing..." : "Refresh")</button>
        </div>
    </section>

    <section class="panel ops-rz-panel">
        <div class="ops-grid-toolbar">
            <input type="text" class="ops-filter wide" placeholder="Search target, subdomain, technology, version, evidence..." @bind="_search" @bind:event="oninput" />
            <input type="text" class="ops-filter" placeholder="Target" @bind="_targetFilter" @bind:event="oninput" />
            <input type="text" class="ops-filter" placeholder="Subdomain" @bind="_subdomainFilter" @bind:event="oninput" />
            <input type="text" class="ops-filter" placeholder="Technology" @bind="_technologyFilter" @bind:event="oninput" />
            <button type="button" class="btn ghost" @onclick="ClearFilters">Clear filters</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <section class="panel">
                <p class="muted">@_errorMessage</p>
            </section>
        }

        @if (_lastLoadedAtUtc is null)
        {
            <section class="panel">
                <p class="muted">Loading technology detections...</p>
            </section>
        }
        else
        {
            var rows = FilteredRows;

            <RadzenDataGrid TItem="TechnologyDetectionRowDto"
                            Data="@rows"
                            Count="@rows.Count"
                            AllowSorting="true"
                            AllowFiltering="false"
                            AllowPaging="true"
                            PageSize="250"
                            PageSizeOptions="@GridPageSizeOptions"
                            AllowGrouping="true"
                            AllowVirtualization="true"
                            Style="height: 860px"
                            Density="Density.Compact"
                            GridLines="DataGridGridLines.Both"
                            IsLoading="@_loading"
                            ColumnWidth="180px">
                <Columns>
                    <RadzenDataGridColumn TItem="TechnologyDetectionRowDto" Property="DetectedAtUtc" Title="Detected" Width="180px" SortOrder="SortOrder.Descending">
                        <Template Context="r">@AppTimeFormat.Format(r.DetectedAtUtc)</Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="TechnologyDetectionRowDto" Property="TargetRootDomain" Title="Target" Width="200px" />

                    <RadzenDataGridColumn TItem="TechnologyDetectionRowDto" Property="AssetCanonicalKey" Title="Subdomain" Width="240px">
                        <Template Context="r">
                            <span class="ops-rz-clip" title="@r.AssetCanonicalKey">@r.AssetCanonicalKey</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="TechnologyDetectionRowDto" Property="TechnologyName" Title="Technology" Width="200px">
                        <Template Context="r"><strong>@r.TechnologyName</strong></Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="TechnologyDetectionRowDto" Property="Version" Title="Version" Width="120px" />
                    <RadzenDataGridColumn TItem="TechnologyDetectionRowDto" Property="CategoryName" Title="Category" Width="180px" />
                    <RadzenDataGridColumn TItem="TechnologyDetectionRowDto" Property="EvidenceSource" Title="Source" Width="120px" />

                    <RadzenDataGridColumn TItem="TechnologyDetectionRowDto" Property="MatchedText" Title="Evidence" Width="400px">
                        <Template Context="r">
                            @if (!string.IsNullOrEmpty(r.EvidenceKey))
                            {
                                <span class="muted">[@r.EvidenceKey]</span><br />
                            }

                            <span class="ops-rz-clip" title="@r.MatchedText">@r.MatchedText</span>

                            @if (!string.IsNullOrEmpty(r.Pattern))
                            {
                                <br /><code title="@r.Pattern">@r.Pattern</code>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
    </section>
</div>

@code {
    private readonly CancellationTokenSource _pollCts = new();
    private readonly SemaphoreSlim _reloadLock = new(1, 1);
    private IReadOnlyList<TechnologyDetectionRowDto> _rows = Array.Empty<TechnologyDetectionRowDto>();

    private bool _initialLoadStarted;
    private bool _loading = true;
    private bool _disposed;
    private DateTimeOffset? _lastLoadedAtUtc;
    private string? _errorMessage;

    private string _search = "";
    private string _targetFilter = "";
    private string _subdomainFilter = "";
    private string _technologyFilter = "";
    private static readonly int[] GridPageSizeOptions = [250, 1000, 10000];

    private string LiveStateCss => Realtime.IsConnected ? "ok" : "warn";

    private IReadOnlyList<TechnologyDetectionRowDto> FilteredRows => _rows
        .Where(r =>
            Matches(r.TargetRootDomain, _targetFilter)
            && Matches(r.AssetCanonicalKey, _subdomainFilter)
            && Matches(r.TechnologyName, _technologyFilter)
            && (
                Matches(r.TargetRootDomain, _search)
                || Matches(r.AssetCanonicalKey, _search)
                || Matches(r.TechnologyName, _search)
                || Matches(r.CategoryName, _search)
                || Matches(r.Version, _search)
                || Matches(r.EvidenceSource, _search)
                || Matches(r.EvidenceKey, _search)
                || Matches(r.Pattern, _search)
                || Matches(r.MatchedText, _search)))
        .ToArray();

    protected override Task OnInitializedAsync()
    {
        Realtime.DomainEventReceived += OnRealtimeEvent;
        return Task.CompletedTask;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialLoadStarted)
        {
            _initialLoadStarted = true;
            _ = InvokeAsync(LoadInitialAsync);
        }

        return Task.CompletedTask;
    }

    private async Task LoadInitialAsync()
    {
        try
        {
            await ReloadAsync();
            await StartRealtimeAsync();
            _ = PollAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Technology page failed during initial load.");
            _errorMessage = "The technologies page failed to initialize. Check command-center-web logs for details.";
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task StartRealtimeAsync()
    {
        try
        {
            await Realtime.EnsureStartedAsync(_pollCts.Token);
        }
        catch (OperationCanceledException) when (_pollCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Technology page realtime connection failed; polling remains active.");
        }
    }

    private void OnRealtimeEvent(object? sender, LiveUiEventDto evt)
    {
        // Technology detections are published as "assets" domain events.
        if (evt.Scope is not ("findings" or "assets" or "http"))
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            if (_disposed)
            {
                return;
            }

            try
            {
                await ReloadAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Technology page realtime refresh failed.");
                _errorMessage = "Realtime refresh failed. Manual refresh and polling remain available.";
                StateHasChanged();
            }
        });
    }

    private async Task PollAsync()
    {
        try
        {
            while (!_pollCts.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(30), _pollCts.Token);

                if (_disposed || Realtime.IsConnected)
                {
                    continue;
                }

                await InvokeAsync(async () =>
                {
                    if (!_disposed)
                    {
                        await ReloadAsync();
                    }
                });
            }
        }
        catch (OperationCanceledException) when (_pollCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Technology page polling loop failed.");
        }
    }

    private async Task ReloadAsync()
    {
        if (_disposed)
        {
            return;
        }

        if (!await _reloadLock.WaitAsync(0))
        {
            return;
        }

        try
        {
            _loading = true;
            _errorMessage = null;
            await InvokeAsync(StateHasChanged);

            var list = await DiscoveryApi.Client.GetFromJsonAsync<List<TechnologyDetectionRowDto>>(
                "/api/technologies?take=10000",
                _pollCts.Token);

            _rows = list?.ToArray() ?? Array.Empty<TechnologyDetectionRowDto>();
            _lastLoadedAtUtc = DateTimeOffset.UtcNow;
        }
        catch (OperationCanceledException) when (_pollCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load technology detections.");
            _rows = Array.Empty<TechnologyDetectionRowDto>();
            _errorMessage = "Unable to load technology detections. Check command-center-web logs for details.";
        }
        finally
        {
            _loading = false;
            _reloadLock.Release();

            if (!_disposed)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void ClearFilters()
    {
        _search = "";
        _targetFilter = "";
        _subdomainFilter = "";
        _technologyFilter = "";
    }

    private static bool Matches(string? value, string? filter) =>
        string.IsNullOrWhiteSpace(filter)
        || (!string.IsNullOrWhiteSpace(value) && value.Contains(filter.Trim(), StringComparison.OrdinalIgnoreCase));

    public void Dispose()
    {
        _disposed = true;
        Realtime.DomainEventReceived -= OnRealtimeEvent;
        _pollCts.Cancel();
        _pollCts.Dispose();
        _reloadLock.Dispose();
    }
}
