@page "/technology-identification"
@rendermode InteractiveServer

@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using ArgusEngine.CommandCenter.Models
@using ArgusEngine.CommandCenter.Web.Clients
@inject DiscoveryApiClient DiscoveryApi

<PageTitle>Technology Identification - Argus Engine</PageTitle>

<div class="page-shell ops-page ops-page-lite tech-id-page">
    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="ops-alert">@_statusMessage</div>
    }

    <section class="metrics-grid tech-id-summary">
        <article class="metric-card">
            <span>Targets</span>
            <strong>@_targets.Count.ToString("N0", CultureInfo.InvariantCulture)</strong>
        </article>
        <article class="metric-card">
            <span>Subdomains</span>
            <strong>@_subdomains.Count.ToString("N0", CultureInfo.InvariantCulture)</strong>
        </article>
        <article class="metric-card">
            <span>Technologies</span>
            <strong>@TechnologyCount.ToString("N0", CultureInfo.InvariantCulture)</strong>
        </article>
        <article class="metric-card">
            <span>Observations</span>
            <strong>@_technologies.Count.ToString("N0", CultureInfo.InvariantCulture)</strong>
        </article>
    </section>

    <section class="tech-usage-strip">
        <article class="panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Usage</p>
                    <h2>Top app/version combinations</h2>
                </div>
            </div>
            <ol class="usage-list">
                @foreach (var row in UsageRows.Take(10))
                {
                    <li><span>@TechnologyLabel(row)</span><strong>@row.SubdomainCount.ToString("N0", CultureInfo.InvariantCulture)</strong></li>
                }
            </ol>
        </article>
        <article class="panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Usage</p>
                    <h2>Top technologies</h2>
                </div>
            </div>
            <ol class="usage-list">
                @foreach (var row in TopTechnologiesWithoutVersions)
                {
                    <li><span>@row.Name</span><strong>@row.Count.ToString("N0", CultureInfo.InvariantCulture)</strong></li>
                }
            </ol>
        </article>
    </section>

    <section class="ops-scope-grid tech-id-scope">
        <section class="panel tech-id-panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Inventory</p>
                    <h2>Targets</h2>
                </div>
                <button type="button" class="btn" @onclick="ReloadAsync" disabled="@_anyLoading">@(_anyLoading ? "Loading..." : "Reload")</button>
            </div>

            <ArgusDataGrid TGridItem="TechnologyIdentificationTargetDto"
                           Items="@FilteredTargets.AsQueryable()"
                           RowMatches="TargetMatches"
                           SearchText="@_targetSearch"
                           SearchTextChanged="@((string value) => _targetSearch = value)"
                           SearchPlaceholder="Search targets..."
                           IsLoading="@_targetsLoading"
                           EmptyText="No targets found."
                           PersistKey="technology-id-targets"
                           ClearFiltersRequested="ClearTargetFilters"
                           ActiveFilterCount="@TargetActiveFilterCount"
                           VirtualizedHeightPixels="360"
                           StickyFirstColumn="true">
                <ToolbarTemplate>
                    <label class="argus-dg-page-size">
                        <span>Filter</span>
                        <select value="@_targetFilter" @onchange="args => _targetFilter = args.Value?.ToString() ?? string.Empty">
                            <option value="">All</option>
                            <option value="with-tech">With technologies</option>
                            <option value="without-tech">Without technologies</option>
                        </select>
                    </label>
                    @if (_selectedTargetId is not null)
                    {
                        <button type="button" class="btn ghost small" @onclick="ClearTargetAsync">All targets</button>
                    }
                </ToolbarTemplate>
                <ChildContent>
                    <TemplateColumn Title="Selected" Context="row">
                        <input type="checkbox" checked="@IsSelectedTarget(row.TargetId)" @onchange="args => SelectTargetAsync(row.TargetId)" />
                    </TemplateColumn>
                    <PropertyColumn Title="Target" Property="@(row => row.TargetRootDomain)" Sortable="true" />
                    <PropertyColumn Title="Subs" Property="@(row => row.SubdomainCount)" Sortable="true" />
                    <PropertyColumn Title="Tech" Property="@(row => row.TechnologyCount)" Sortable="true" />
                    <TemplateColumn Title="Last Seen" Context="row" SortBy="@SortTargetLastSeen">@FormatTime(row.LastObservedAtUtc)</TemplateColumn>
                </ChildContent>
            </ArgusDataGrid>
        </section>

        <section class="panel tech-id-panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Inventory</p>
                    <h2>Subdomains</h2>
                </div>
                @if (_selectedSubdomain is not null)
                {
                    <button type="button" class="btn ghost small" @onclick="ClearSubdomainAsync">All subdomains</button>
                }
            </div>

            <ArgusDataGrid TGridItem="TechnologyIdentificationSubdomainDto"
                           Items="@FilteredSubdomains.AsQueryable()"
                           RowMatches="SubdomainMatches"
                           SearchText="@_subdomainSearch"
                           SearchTextChanged="@((string value) => _subdomainSearch = value)"
                           SearchPlaceholder="Search subdomains..."
                           IsLoading="@_subdomainsLoading"
                           EmptyText="No subdomains found."
                           PersistKey="technology-id-subdomains"
                           ClearFiltersRequested="ClearSubdomainFilters"
                           ActiveFilterCount="@SubdomainActiveFilterCount"
                           VirtualizedHeightPixels="360"
                           StickyFirstColumn="true">
                <ToolbarTemplate>
                    <label class="argus-dg-page-size">
                        <span>Filter</span>
                        <select value="@_subdomainFilter" @onchange="args => _subdomainFilter = args.Value?.ToString() ?? string.Empty">
                            <option value="">All</option>
                            <option value="with-tech">With technologies</option>
                            <option value="without-tech">Without technologies</option>
                        </select>
                    </label>
                </ToolbarTemplate>
                <ChildContent>
                    <TemplateColumn Title="Selected" Context="row">
                        <input type="checkbox" checked="@IsSelectedSubdomain(row.Subdomain)" @onchange="args => SelectSubdomainAsync(row.Subdomain)" />
                    </TemplateColumn>
                    <PropertyColumn Title="Subdomain" Property="@(row => row.Subdomain)" Sortable="true" />
                    <PropertyColumn Title="Tech" Property="@(row => row.TechnologyCount)" Sortable="true" />
                    <PropertyColumn Title="Observations" Property="@(row => row.ObservationCount)" Sortable="true" />
                    <TemplateColumn Title="Last Seen" Context="row" SortBy="@SortSubdomainLastSeen">@FormatTime(row.LastObservedAtUtc)</TemplateColumn>
                </ChildContent>
            </ArgusDataGrid>
        </section>
    </section>

    <section class="panel">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Detection</p>
                <h2>Technologies</h2>
            </div>
            <span class="muted">@ScopeLabel</span>
        </div>

        <ArgusDataGrid TGridItem="TechnologyIdentificationRowDto"
                       Items="@FilteredTechnologies.AsQueryable()"
                       RowMatches="TechnologyMatches"
                       SearchText="@_technologySearch"
                       SearchTextChanged="@((string value) => _technologySearch = value)"
                       SearchPlaceholder="Search technologies, evidence, source..."
                       IsLoading="@_technologiesLoading"
                       EmptyText="No technology detections match this scope."
                       PersistKey="technology-id-technologies"
                       ClearFiltersRequested="ClearTechnologyFilters"
                       ActiveFilterCount="@TechnologyActiveFilterCount"
                       VirtualizedHeightPixels="560"
                       EnableCsvExport="true"
                       ExportFileName="technology-detections.csv">
            <ToolbarTemplate>
                <label class="argus-dg-page-size">
                    <span>Source</span>
                    <select value="@_technologySourceFilter" @onchange="args => _technologySourceFilter = args.Value?.ToString() ?? string.Empty">
                        <option value="">All</option>
                        <option value="observation">Observations</option>
                        <option value="legacy-detection">Legacy detections</option>
                    </select>
                </label>
            </ToolbarTemplate>
            <ChildContent>
                <TemplateColumn Title="Selected" Context="row">
                    <input type="checkbox" checked="@_selectedObservationIds.Contains(row.Id)" @onchange="args => ToggleObservation(row.Id, args)" />
                </TemplateColumn>
                <TemplateColumn Title="Last Seen" Context="row" SortBy="@SortTechnologyLastSeen">@FormatTime(row.LastSeenUtc)</TemplateColumn>
                <PropertyColumn Title="Target" Property="@(row => row.TargetRootDomain)" Sortable="true" />
                <PropertyColumn Title="Subdomain" Property="@(row => row.Subdomain)" Sortable="true" />
                <PropertyColumn Title="Technology" Property="@(row => row.TechnologyName)" Sortable="true" />
                <TemplateColumn Title="Version" Context="row" SortBy="@SortTechnologyVersion">@DisplayOrDash(row.Version)</TemplateColumn>
                <PropertyColumn Title="Confidence" Property="@(row => row.Confidence)" Format="P0" Sortable="true" />
                <PropertyColumn Title="Mode" Property="@(row => row.DetectionMode)" Sortable="true" />
                <TemplateColumn Title="Evidence" Context="row" SortBy="@SortTechnologyEvidence">
                    <span class="argus-dg-clip" title="@row.EvidenceSummary">@DisplayOrDash(row.EvidenceSummary)</span>
                </TemplateColumn>
            </ChildContent>
        </ArgusDataGrid>
    </section>

    <section class="panel">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Usage</p>
                <h2>Technology Usage</h2>
            </div>
            <span class="muted">Unique app/version combinations</span>
        </div>

        <ArgusDataGrid TGridItem="TechnologyUsageDto"
                       Items="@UsageRows.AsQueryable()"
                       RowMatches="UsageMatches"
                       SearchText="@_usageSearch"
                       SearchTextChanged="@((string value) => _usageSearch = value)"
                       SearchPlaceholder="Search usage by technology or version..."
                       IsLoading="@_usageLoading"
                       EmptyText="No technology usage found."
                       PersistKey="technology-id-usage"
                       VirtualizedHeightPixels="520"
                       EnableCsvExport="true"
                       ExportFileName="technology-usage.csv">
            <ChildContent>
                <TemplateColumn Title="Selected" Context="row">
                    <input type="checkbox" checked="@_selectedUsageKeys.Contains(UsageKey(row))" @onchange="args => ToggleUsage(row, args)" />
                </TemplateColumn>
                <PropertyColumn Title="Technology" Property="@(row => row.TechnologyName)" Sortable="true" />
                <TemplateColumn Title="Version" Context="row" SortBy="@SortUsageVersion">@DisplayOrDash(row.Version)</TemplateColumn>
                <PropertyColumn Title="Targets" Property="@(row => row.TargetCount)" Sortable="true" />
                <PropertyColumn Title="Subdomains" Property="@(row => row.SubdomainCount)" Sortable="true" />
                <TemplateColumn Title="Locations" Context="row">
                    <button type="button" class="btn ghost small" @onclick="() => OpenUsageModal(row)">View JSON</button>
                </TemplateColumn>
            </ChildContent>
        </ArgusDataGrid>
    </section>
</div>

@if (_usageModal is not null)
{
    <div class="modal-backdrop" @onclick="CloseUsageModal">
        <section class="modal-card usage-modal" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-label="Technology usage locations">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Usage</p>
                    <h2>@TechnologyLabel(_usageModal)</h2>
                </div>
                <button type="button" class="btn ghost small" @onclick="CloseUsageModal">Close</button>
            </div>
            <pre class="json-modal">@UsageModalJson</pre>
        </section>
    </div>
}

@code {
    private readonly List<TechnologyIdentificationTargetDto> _targets = [];
    private readonly List<TechnologyIdentificationSubdomainDto> _subdomains = [];
    private readonly List<TechnologyIdentificationRowDto> _technologies = [];
    private readonly List<TechnologyUsageDto> _usage = [];
    private readonly HashSet<Guid> _selectedObservationIds = [];
    private readonly HashSet<string> _selectedUsageKeys = new(StringComparer.OrdinalIgnoreCase);

    private bool _targetsLoading = true;
    private bool _subdomainsLoading = true;
    private bool _technologiesLoading = true;
    private bool _usageLoading = true;
    private bool _anyLoading => _targetsLoading || _subdomainsLoading || _technologiesLoading || _usageLoading;
    private bool _initialLoadStarted;
    private string? _statusMessage;
    private readonly List<string> _loadErrors = [];
    private Guid? _selectedTargetId;
    private string? _selectedSubdomain;
    private TechnologyUsageDto? _usageModal;

    private string _targetSearch = "";
    private string _targetFilter = "";
    private string _subdomainSearch = "";
    private string _subdomainFilter = "";
    private string _technologySearch = "";
    private string _technologySourceFilter = "";
    private string _usageSearch = "";

    private List<TechnologyIdentificationTargetDto> FilteredTargets => _targets
        .Where(t => _targetFilter switch
        {
            "with-tech" => t.TechnologyCount > 0,
            "without-tech" => t.TechnologyCount == 0,
            _ => true,
        })
        .ToList();

    private List<TechnologyIdentificationSubdomainDto> FilteredSubdomains => _subdomains
        .Where(s => _subdomainFilter switch
        {
            "with-tech" => s.TechnologyCount > 0,
            "without-tech" => s.TechnologyCount == 0,
            _ => true,
        })
        .ToList();

    private List<TechnologyIdentificationRowDto> FilteredTechnologies => _technologies
        .Where(t => string.IsNullOrWhiteSpace(_technologySourceFilter)
            || string.Equals(t.DataSource, _technologySourceFilter, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private List<TechnologyUsageDto> UsageRows => _usage
        .Where(u => string.IsNullOrWhiteSpace(_selectedSubdomain)
            || u.Locations.Any(l => string.Equals(l.Subdomain, _selectedSubdomain, StringComparison.OrdinalIgnoreCase)))
        .OrderByDescending(u => u.SubdomainCount)
        .ThenBy(u => u.TechnologyName, StringComparer.OrdinalIgnoreCase)
        .ThenBy(u => u.Version, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private IEnumerable<(string Name, long Count)> TopTechnologiesWithoutVersions => UsageRows
        .GroupBy(u => u.TechnologyName, StringComparer.OrdinalIgnoreCase)
        .Select(g => (Name: g.Key, Count: g.Sum(x => x.SubdomainCount)))
        .OrderByDescending(x => x.Count)
        .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
        .Take(10);

    private long TechnologyCount => UsageRows.LongCount();

    private int TargetActiveFilterCount => string.IsNullOrWhiteSpace(_targetFilter) ? 0 : 1;
    private int SubdomainActiveFilterCount => string.IsNullOrWhiteSpace(_subdomainFilter) ? 0 : 1;
    private int TechnologyActiveFilterCount => string.IsNullOrWhiteSpace(_technologySourceFilter) ? 0 : 1;

    private string ScopeLabel =>
        !string.IsNullOrWhiteSpace(_selectedSubdomain)
            ? _selectedSubdomain
            : _selectedTargetId is { } targetId
                ? _targets.FirstOrDefault(t => t.TargetId == targetId)?.TargetRootDomain ?? "Selected target"
                : "All targets";

    private string UsageModalJson => _usageModal is null
        ? ""
        : JsonSerializer.Serialize(_usageModal.Locations, new JsonSerializerOptions { WriteIndented = true });

    private static readonly GridSort<TechnologyIdentificationTargetDto> SortTargetLastSeen =
        GridSort<TechnologyIdentificationTargetDto>.ByDescending(static row => row.LastObservedAtUtc);

    private static readonly GridSort<TechnologyIdentificationSubdomainDto> SortSubdomainLastSeen =
        GridSort<TechnologyIdentificationSubdomainDto>.ByDescending(static row => row.LastObservedAtUtc);

    private static readonly GridSort<TechnologyIdentificationRowDto> SortTechnologyLastSeen =
        GridSort<TechnologyIdentificationRowDto>.ByDescending(static row => row.LastSeenUtc);

    private static readonly GridSort<TechnologyIdentificationRowDto> SortTechnologyVersion =
        GridSort<TechnologyIdentificationRowDto>.ByAscending(static row => row.Version);

    private static readonly GridSort<TechnologyIdentificationRowDto> SortTechnologyEvidence =
        GridSort<TechnologyIdentificationRowDto>.ByAscending(static row => row.EvidenceSummary);

    private static readonly GridSort<TechnologyUsageDto> SortUsageVersion =
        GridSort<TechnologyUsageDto>.ByAscending(static row => row.Version);

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialLoadStarted)
        {
            _initialLoadStarted = true;
            return InvokeAsync(async () =>
            {
                await ReloadAsync();
                StateHasChanged();
            });
        }

        return Task.CompletedTask;
    }

    private async Task ReloadAsync()
    {
        _loadErrors.Clear();
        _statusMessage = null;
        await Task.WhenAll(ReloadTargetsAsync(), ReloadSubdomainsAsync(), ReloadTechnologiesAsync(), ReloadUsageAsync());
        ApplyLoadErrors();
    }

    private async Task SelectTargetAsync(Guid targetId)
    {
        _selectedTargetId = targetId;
        _selectedSubdomain = null;
        _subdomainSearch = "";
        _loadErrors.Clear();
        _statusMessage = null;
        await Task.WhenAll(ReloadSubdomainsAsync(), ReloadTechnologiesAsync(), ReloadUsageAsync());
        ApplyLoadErrors();
    }

    private async Task ClearTargetAsync()
    {
        _selectedTargetId = null;
        _selectedSubdomain = null;
        _loadErrors.Clear();
        _statusMessage = null;
        await Task.WhenAll(ReloadSubdomainsAsync(), ReloadTechnologiesAsync(), ReloadUsageAsync());
        ApplyLoadErrors();
    }

    private async Task SelectSubdomainAsync(string subdomain)
    {
        _selectedSubdomain = subdomain;
        _loadErrors.Clear();
        _statusMessage = null;
        await ReloadTechnologiesAsync();
        ApplyLoadErrors();
    }

    private async Task ClearSubdomainAsync()
    {
        _selectedSubdomain = null;
        _loadErrors.Clear();
        _statusMessage = null;
        await ReloadTechnologiesAsync();
        ApplyLoadErrors();
    }

    private async Task ReloadTargetsAsync()
    {
        _targetsLoading = true;
        try
        {
            var targets = await DiscoveryApi.Client.GetFromJsonAsync<List<TechnologyIdentificationTargetDto>>("/api/technology-identification/targets");
            _targets.Clear();
            if (targets is not null)
                _targets.AddRange(targets);
        }
        catch (Exception ex)
        {
            AddLoadError($"targets: {ex.Message}");
        }
        finally
        {
            _targetsLoading = false;
        }
    }

    private async Task ReloadSubdomainsAsync()
    {
        _subdomainsLoading = true;
        try
        {
            var url = _selectedTargetId is { } targetId
                ? $"/api/technology-identification/subdomains?targetId={targetId}"
                : "/api/technology-identification/subdomains";

            var rows = await DiscoveryApi.Client.GetFromJsonAsync<List<TechnologyIdentificationSubdomainDto>>(url);
            _subdomains.Clear();
            if (rows is not null)
                _subdomains.AddRange(rows);
        }
        catch (Exception ex)
        {
            AddLoadError($"subdomains: {ex.Message}");
        }
        finally
        {
            _subdomainsLoading = false;
        }
    }

    private async Task ReloadTechnologiesAsync()
    {
        _technologiesLoading = true;
        try
        {
            var techs = await DiscoveryApi.Client.GetFromJsonAsync<List<TechnologyIdentificationRowDto>>($"/api/technology-identification/technologies{BuildTechnologyQuery()}");
            _technologies.Clear();
            if (techs is not null)
                _technologies.AddRange(techs);
        }
        catch (Exception ex)
        {
            AddLoadError($"technologies: {ex.Message}");
        }
        finally
        {
            _technologiesLoading = false;
        }
    }

    private async Task ReloadUsageAsync()
    {
        _usageLoading = true;
        try
        {
            var url = _selectedTargetId is { } targetId
                ? $"/api/technology-identification/usage?targetId={targetId}"
                : "/api/technology-identification/usage";
            var usage = await DiscoveryApi.Client.GetFromJsonAsync<List<TechnologyUsageDto>>(url);
            _usage.Clear();
            if (usage is not null)
                _usage.AddRange(usage);
        }
        catch (Exception ex)
        {
            AddLoadError($"technology usage: {ex.Message}");
        }
        finally
        {
            _usageLoading = false;
        }
    }

    private string BuildTechnologyQuery()
    {
        var query = new List<string>();
        if (_selectedTargetId is { } targetId)
            query.Add($"targetId={targetId}");
        if (!string.IsNullOrWhiteSpace(_selectedSubdomain))
            query.Add($"subdomain={Uri.EscapeDataString(_selectedSubdomain)}");

        return query.Count > 0 ? "?" + string.Join("&", query) : "";
    }

    private Task ClearTargetFilters()
    {
        _targetSearch = "";
        _targetFilter = "";
        return Task.CompletedTask;
    }

    private Task ClearSubdomainFilters()
    {
        _subdomainSearch = "";
        _subdomainFilter = "";
        return Task.CompletedTask;
    }

    private Task ClearTechnologyFilters()
    {
        _technologySearch = "";
        _technologySourceFilter = "";
        return Task.CompletedTask;
    }

    private void AddLoadError(string message)
    {
        lock (_loadErrors)
        {
            _loadErrors.Add(message);
        }
    }

    private void ApplyLoadErrors()
    {
        lock (_loadErrors)
        {
            _statusMessage = _loadErrors.Count == 0
                ? null
                : "Failed to load " + string.Join("; ", _loadErrors);
        }
    }

    private bool IsSelectedTarget(Guid targetId) => _selectedTargetId == targetId;

    private bool IsSelectedSubdomain(string subdomain) =>
        string.Equals(_selectedSubdomain, subdomain, StringComparison.OrdinalIgnoreCase);

    private void ToggleObservation(Guid id, ChangeEventArgs args)
    {
        if (args.Value is bool selected && selected)
            _selectedObservationIds.Add(id);
        else
            _selectedObservationIds.Remove(id);
    }

    private void ToggleUsage(TechnologyUsageDto row, ChangeEventArgs args)
    {
        var key = UsageKey(row);
        if (args.Value is bool selected && selected)
            _selectedUsageKeys.Add(key);
        else
            _selectedUsageKeys.Remove(key);
    }

    private void OpenUsageModal(TechnologyUsageDto row) => _usageModal = row;

    private void CloseUsageModal() => _usageModal = null;

    private static bool TargetMatches(TechnologyIdentificationTargetDto row, string search) =>
        Matches(row.TargetRootDomain, search);

    private static bool SubdomainMatches(TechnologyIdentificationSubdomainDto row, string search) =>
        Matches(row.Subdomain, search);

    private static bool TechnologyMatches(TechnologyIdentificationRowDto row, string search) =>
        Matches(row.TargetRootDomain, search)
        || Matches(row.Subdomain, search)
        || Matches(row.AssetCanonicalKey, search)
        || Matches(row.TechnologyName, search)
        || Matches(row.Vendor, search)
        || Matches(row.Product, search)
        || Matches(row.Version, search)
        || Matches(row.SourceType, search)
        || Matches(row.DetectionMode, search)
        || Matches(row.FingerprintId, search)
        || Matches(row.EvidenceSummary, search);

    private static bool UsageMatches(TechnologyUsageDto row, string search) =>
        Matches(row.TechnologyName, search)
        || Matches(row.Version, search);

    private static bool Matches(string? value, string? search) =>
        string.IsNullOrWhiteSpace(search)
        || (!string.IsNullOrWhiteSpace(value) && value.Contains(search.Trim(), StringComparison.OrdinalIgnoreCase));

    private static string TechnologyLabel(TechnologyUsageDto row) =>
        string.IsNullOrWhiteSpace(row.Version) ? row.TechnologyName : $"{row.TechnologyName} {row.Version}";

    private static string UsageKey(TechnologyUsageDto row) => $"{row.TechnologyName}|{row.Version}";

    private static string FormatTime(DateTimeOffset? value) =>
        value is null ? "-" : value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture);

    private static string DisplayOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
}


