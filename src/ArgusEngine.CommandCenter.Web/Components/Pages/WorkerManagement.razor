@page "/worker-management"
@using System.Globalization
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Logging

@inject ILogger<WorkerManagement> Logger

<PageTitle>Worker Management - Argus Engine</PageTitle>

<div class="page-shell worker-management-page">
    <section class="hero-card">
        <p class="eyebrow">Cloud Deployment</p>
        <h1>Worker Management</h1>
        <p>Deploy and scale Argus background workers across AWS, Azure, and Google Cloud with full control over the instances.</p>
    </section>

    <div class="tabs-container" style="margin-bottom: 20px;">
        <div class="tabs-header" style="display: flex; gap: 10px; border-bottom: 1px solid #e5e7eb; padding-bottom: 10px;">
            <button class="btn @(ActiveTab == "aws" ? "btn-primary" : "btn-secondary")" @onclick="@(() => ActiveTab = "aws")">AWS (ECS)</button>
            <button class="btn @(ActiveTab == "azure" ? "btn-primary" : "btn-secondary")" @onclick="@(() => ActiveTab = "azure")">Azure (Container Apps)</button>
            <button class="btn @(ActiveTab == "gcp" ? "btn-primary" : "btn-secondary")" @onclick="@(() => ActiveTab = "gcp")">GCP (Cloud Run)</button>
        </div>
    </div>

    @if (ActiveTab == "aws")
    {
        <section class="surface-card">
            <div class="section-heading">
                <div>
                    <h2>AWS Configuration</h2>
                    <p>Configure AWS ECS deployment parameters.</p>
                </div>
            </div>
            <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="form-group">
                    <label>AWS Access Key ID</label>
                    <input type="text" class="form-control" @bind="AwsConfig.AccessKeyId" placeholder="AKIA..." />
                </div>
                <div class="form-group">
                    <label>AWS Secret Access Key</label>
                    <input type="password" class="form-control" @bind="AwsConfig.SecretAccessKey" placeholder="Secret..." />
                </div>
                <div class="form-group">
                    <label>Region</label>
                    <input type="text" class="form-control" @bind="AwsConfig.Region" placeholder="us-east-1" />
                </div>
                <div class="form-group">
                    <label>ECS Cluster Name</label>
                    <input type="text" class="form-control" @bind="AwsConfig.ClusterName" placeholder="argus-workers" />
                </div>
            </div>
        </section>
    }
    else if (ActiveTab == "azure")
    {
        <section class="surface-card">
            <div class="section-heading">
                <div>
                    <h2>Azure Configuration</h2>
                    <p>Configure Azure Container Apps deployment parameters.</p>
                </div>
            </div>
            <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="form-group">
                    <label>Subscription ID</label>
                    <input type="text" class="form-control" @bind="AzureConfig.SubscriptionId" />
                </div>
                <div class="form-group">
                    <label>Resource Group</label>
                    <input type="text" class="form-control" @bind="AzureConfig.ResourceGroup" placeholder="argus-rg" />
                </div>
                <div class="form-group">
                    <label>Location</label>
                    <input type="text" class="form-control" @bind="AzureConfig.Location" placeholder="eastus" />
                </div>
                <div class="form-group">
                    <label>Container Apps Environment</label>
                    <input type="text" class="form-control" @bind="AzureConfig.EnvName" placeholder="argus-env" />
                </div>
            </div>
        </section>
    }
    else if (ActiveTab == "gcp")
    {
        <section class="surface-card">
            <div class="section-heading">
                <div>
                    <h2>GCP Configuration</h2>
                    <p>Configure Google Cloud Run deployment parameters.</p>
                </div>
            </div>
            <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="form-group">
                    <label>Project ID</label>
                    <input type="text" class="form-control" @bind="GcpConfig.ProjectId" />
                </div>
                <div class="form-group">
                    <label>Region</label>
                    <input type="text" class="form-control" @bind="GcpConfig.Region" placeholder="us-central1" />
                </div>
                <div class="form-group" style="grid-column: span 2;">
                    <label>Service Account JSON Key</label>
                    <textarea class="form-control" @bind="GcpConfig.ServiceAccountJson" rows="4" placeholder="{ ... }"></textarea>
                </div>
            </div>
        </section>
    }

    <section class="surface-card" style="margin-top: 20px;">
        <div class="section-heading">
            <div>
                <h2>Worker Scaling &amp; Credentials</h2>
                <p>Configure the desired number of instances and machine control for each worker type.</p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 2px solid #e5e7eb; text-align: left;">
                        <th style="padding: 10px;">Worker Service</th>
                        <th style="padding: 10px;">Desired Count</th>
                        <th style="padding: 10px;">CPU</th>
                        <th style="padding: 10px;">Memory</th>
                        <th style="padding: 10px;">Machine Control</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var worker in Workers)
                    {
                        <tr style="border-bottom: 1px solid #e5e7eb;">
                            <td style="padding: 10px;"><strong>@worker.Name</strong></td>
                            <td style="padding: 10px;">
                                <input type="number" class="form-control" @bind="worker.DesiredCount" style="width: 80px;" min="0" />
                            </td>
                            <td style="padding: 10px;">
                                <select class="form-control" @bind="worker.Cpu">
                                    <option value="0.5">0.5 vCPU</option>
                                    <option value="1.0">1.0 vCPU</option>
                                    <option value="2.0">2.0 vCPU</option>
                                    <option value="4.0">4.0 vCPU</option>
                                </select>
                            </td>
                            <td style="padding: 10px;">
                                <select class="form-control" @bind="worker.Memory">
                                    <option value="1Gi">1 GiB</option>
                                    <option value="2Gi">2 GiB</option>
                                    <option value="4Gi">4 GiB</option>
                                    <option value="8Gi">8 GiB</option>
                                </select>
                            </td>
                            <td style="padding: 10px;">
                                <button class="btn btn-secondary btn-sm">Shell Access</button>
                                <button class="btn btn-secondary btn-sm">View Logs</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="surface-card" style="margin-top: 20px;">
        <div class="section-heading">
            <div>
                <h2>Actions</h2>
                <p>Trigger deployment operations for the selected cloud provider.</p>
            </div>
        </div>
        <div class="actions-area" style="display: flex; gap: 10px;">
            <button class="btn btn-primary" @onclick="DeployWorkersAsync">Deploy Workers</button>
            <button class="btn btn-secondary" @onclick="SaveConfiguration">Save Configuration</button>
            <button class="btn btn-danger" @onclick="DestroyWorkersAsync">Destroy Workers</button>
        </div>
        
        @if (!string.IsNullOrEmpty(LogOutput))
        {
            <div class="log-output" style="margin-top: 20px; background: #1e1e1e; color: #d4d4d4; padding: 15px; border-radius: 8px; font-family: monospace; max-height: 300px; overflow-y: auto;">
                <pre>@LogOutput</pre>
            </div>
        }
    </section>
</div>

@code {
    private string ActiveTab = "azure";
    private string LogOutput = "";

    private AwsModel AwsConfig = new();
    private AzureModel AzureConfig = new();
    private GcpModel GcpConfig = new();

    private List<WorkerScaleModel> Workers = new()
    {
        new() { Name = "gatekeeper", DesiredCount = 1, Cpu = "0.5", Memory = "1Gi" },
        new() { Name = "command-center-spider-dispatcher", DesiredCount = 1, Cpu = "0.5", Memory = "1Gi" },
        new() { Name = "worker-spider", DesiredCount = 2, Cpu = "1.0", Memory = "2Gi" },
        new() { Name = "worker-http-requester", DesiredCount = 2, Cpu = "1.0", Memory = "2Gi" },
        new() { Name = "worker-enum", DesiredCount = 1, Cpu = "1.0", Memory = "2Gi" },
        new() { Name = "worker-portscan", DesiredCount = 1, Cpu = "1.0", Memory = "2Gi" },
        new() { Name = "worker-highvalue", DesiredCount = 1, Cpu = "2.0", Memory = "4Gi" },
        new() { Name = "worker-techid", DesiredCount = 1, Cpu = "1.0", Memory = "2Gi" }
    };

    private async Task DeployWorkersAsync()
    {
        LogOutput = $"[INFO] Starting deployment to {ActiveTab.ToUpper()}...\n";
        LogOutput += "[INFO] Reading configuration and environment variables...\n";
        
        // Mock execution for now
        await Task.Delay(1000);
        LogOutput += "[INFO] Invoking deployment scripts...\n";
        LogOutput += "[WARN] This is a UI mockup. Backend integration pending choice of Option A or B.\n";
        
        Logger.LogInformation("Deploy triggered for {Cloud}", ActiveTab);
    }

    private async Task DestroyWorkersAsync()
    {
        LogOutput = $"[WARN] Triggering destruction of workers on {ActiveTab.ToUpper()}...\n";
        await Task.Delay(1000);
        LogOutput += "[WARN] Backend integration pending.\n";
    }

    private void SaveConfiguration()
    {
        LogOutput = "[INFO] Configuration saved locally in browser state (Mock).\n";
    }

    public class AwsModel
    {
        public string AccessKeyId { get; set; } = "";
        public string SecretAccessKey { get; set; } = "";
        public string Region { get; set; } = "us-east-1";
        public string ClusterName { get; set; } = "argus-workers";
    }

    public class AzureModel
    {
        public string SubscriptionId { get; set; } = "";
        public string ResourceGroup { get; set; } = "argus-rg";
        public string Location { get; set; } = "eastus";
        public string EnvName { get; set; } = "argus-env";
    }

    public class GcpModel
    {
        public string ProjectId { get; set; } = "";
        public string Region { get; set; } = "us-central1";
        public string ServiceAccountJson { get; set; } = "";
    }

    public class WorkerScaleModel
    {
        public string Name { get; set; } = "";
        public int DesiredCount { get; set; }
        public string Cpu { get; set; } = "1.0";
        public string Memory { get; set; } = "2Gi";
    }
}
