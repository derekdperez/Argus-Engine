@page "/asset-graph"
@rendermode InteractiveServer
@using ArgusEngine.Application.Assets
@using ArgusEngine.Application.TechnologyIdentification
@using ArgusEngine.CommandCenter.Models
@inject HttpClient Http

<PageTitle>Asset graph</PageTitle>

<section class="page-stack">
    <header class="page-header">
        <div>
            <h1>Asset graph</h1>
            <p>Explore the target-rooted parent/child asset hierarchy and relationship metrics.</p>
        </div>
        <button class="btn btn-primary" @onclick="LoadAsync" disabled="@_loading">@(_loading ? "Loading…" : "Refresh")</button>
    </header>

    <div class="card">
        <label for="target">Target</label>
        <select id="target" @bind="_selectedTargetIdText" @bind:after="LoadSelectedTargetAsync">
            <option value="">Select a target…</option>
            @foreach (var target in _targets)
            {
                <option value="@target.Id">@target.RootDomain</option>
            }
        </select>

        <label for="technology-filter">Technology filter</label>
        <select id="technology-filter" @bind="_selectedTechnologyTagSlug" @bind:after="ApplyTechnologyFilterAsync">
            <option value="">All technologies</option>
            @foreach (var tag in _technologyTags)
            {
                <option value="@tag.Slug">@tag.Name</option>
            }
        </select>
    </div>

    @if (_metrics is not null)
    {
        <div class="metric-grid">
            <div class="metric-card">
                <strong>@_metrics.AssetsWithoutParents</strong>
                <span>assets without parents</span>
            </div>
            <div class="metric-card">
                <strong>@_metrics.RelationshipsByType.Sum(x => x.Count)</strong>
                <span>relationships</span>
            </div>
            <div class="metric-card">
                <strong>@_metrics.AssetsByKind.Sum(x => x.Count)</strong>
                <span>assets</span>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert">@_error</div>
    }

    @if (_loading && !_initialLoadCompleted)
    {
        <div class="card">
            <p class="muted">Loading asset graph...</p>
        </div>
    }
    else if (_visibleTree.Count > 0)
    {
        <div class="card graph-card">
            <h2>Target tree</h2>
            @if (!string.IsNullOrWhiteSpace(_selectedTechnologyTagSlug))
            {
                <p class="muted">Filtered to assets tagged with @_selectedTechnologyTagSlug. Ancestors are retained for context.</p>
            }
            @foreach (var node in _visibleTree)
            {
                <AssetTreeView Node="node" AssetTags="_assetTags" />
            }
        </div>
    }
    else if (!_loading && _tree.Count > 0 && !string.IsNullOrWhiteSpace(_selectedTechnologyTagSlug))
    {
        <div class="card">
            <p>No assets in this tree currently match the selected technology tag.</p>
        </div>
    }
</section>

@code {
    private bool _initialLoadStarted;
    private bool _initialLoadCompleted;
    private bool _loading = true;
    private string? _error;
    private string _selectedTargetIdText = "";
    private string _selectedTechnologyTagSlug = "";
    private List<TargetSummary> _targets = [];
    private List<TechnologyTagOption> _technologyTags = [];
    private List<AssetTreeNodeDto> _tree = [];
    private List<AssetTreeNodeDto> _visibleTree = [];
    private Dictionary<Guid, IReadOnlyList<AssetTagDto>> _assetTags = [];
    private AssetGraphMetrics? _metrics;

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialLoadStarted)
        {
            _initialLoadStarted = true;
            _ = InvokeAsync(LoadAndRefreshAsync);
        }

        return Task.CompletedTask;
    }

    private async Task LoadAndRefreshAsync()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _targets = await Http.GetFromJsonAsync<List<TargetSummary>>("/api/targets") ?? [];
            _technologyTags = await Http.GetFromJsonAsync<List<TechnologyTagOption>>("/api/tags?type=Technology") ?? [];
            if (string.IsNullOrWhiteSpace(_selectedTargetIdText) && _targets.Count > 0)
                _selectedTargetIdText = _targets[0].Id.ToString();

            await LoadSelectedTargetAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            _initialLoadCompleted = true;
        }
    }

    private async Task LoadSelectedTargetAsync()
    {
        _tree = [];
        _visibleTree = [];
        _assetTags = [];
        _metrics = null;
        if (!Guid.TryParse(_selectedTargetIdText, out var targetId))
            return;

        _tree = await Http.GetFromJsonAsync<List<AssetTreeNodeDto>>($"/api/targets/{targetId}/asset-tree?maxDepth=5") ?? [];
        _metrics = await Http.GetFromJsonAsync<AssetGraphMetrics>($"/api/targets/{targetId}/asset-graph/metrics");
        await LoadAssetTagsForTreeAsync(_tree);
        await ApplyTechnologyFilterAsync();
    }

    private async Task ApplyTechnologyFilterAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedTechnologyTagSlug))
        {
            _visibleTree = _tree;
            return;
        }

        if (!Guid.TryParse(_selectedTargetIdText, out var targetId))
        {
            _visibleTree = [];
            return;
        }

        var tag = Uri.EscapeDataString(_selectedTechnologyTagSlug);
        var matches = await Http.GetFromJsonAsync<List<AssetMatch>>($"/api/assets?targetId={targetId}&tag={tag}&take=5000") ?? [];
        var matchedIds = matches.Select(x => x.Id).ToHashSet();
        _visibleTree = FilterTree(_tree, matchedIds);
    }

    private async Task LoadAssetTagsForTreeAsync(IReadOnlyList<AssetTreeNodeDto> nodes)
    {
        foreach (var assetId in Flatten(nodes).Select(n => n.Asset.Id).Distinct())
        {
            var tags = await Http.GetFromJsonAsync<List<AssetTagDto>>($"/api/assets/{assetId}/tags") ?? [];
            if (tags.Count > 0)
                _assetTags[assetId] = tags;
        }
    }

    private static List<AssetTreeNodeDto> FilterTree(IReadOnlyList<AssetTreeNodeDto> nodes, HashSet<Guid> matchedIds)
    {
        var output = new List<AssetTreeNodeDto>();
        foreach (var node in nodes)
        {
            var children = FilterTree(node.Children, matchedIds);
            if (matchedIds.Contains(node.Asset.Id) || children.Count > 0)
                output.Add(new AssetTreeNodeDto(node.Asset, node.IncomingRelationship, node.GraphDepth, children));
        }

        return output;
    }

    private static IEnumerable<AssetTreeNodeDto> Flatten(IEnumerable<AssetTreeNodeDto> nodes)
    {
        foreach (var node in nodes)
        {
            yield return node;
            foreach (var child in Flatten(node.Children))
                yield return child;
        }
    }

    private sealed record TechnologyTagOption(
        Guid Id,
        string Slug,
        string Name,
        string TagType,
        string Source,
        string? Description,
        string? Website);

    private sealed record AssetMatch(Guid Id);

    private sealed record CountByName(string Name, long Count);

    private sealed record AssetGraphMetrics(
        IReadOnlyList<CountByName> AssetsByKind,
        IReadOnlyList<CountByName> AssetsByCategory,
        IReadOnlyList<CountByName> RelationshipsByType,
        long AssetsWithoutParents,
        long DuplicateRelationshipRows);
}
