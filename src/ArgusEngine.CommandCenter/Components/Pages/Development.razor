@page "/development"

@using System.Text
@using System.Text.Json
@using ArgusEngine.Harness.Core
@using ArgusEngine.Domain.Entities
@using ArgusEngine.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@inject IDbContextFactory<ArgusDbContext> DbFactory
@inject HarnessRunner Harness
@inject IJSRuntime Js
@inject ILogger<Development> Logger

<PageTitle>Development - Argus Engine</PageTitle>

<div class="dev-page">
    <div class="page-header">
        <div class="header-content">
            <p class="eyebrow">Diagnostic Suite</p>
            <h1>Development & Diagnostics</h1>
            <p class="description">Execute internal test harness to verify worker integrity and cross-component connectivity.</p>
        </div>
    </div>

    <section class="panel">
        <div class="section-heading">
            <div class="title-group">
                <h2>Worker Test Harness</h2>
                <p class="muted">Executes "Health Check" logic within each worker project to exercise core functionality.</p>
            </div>

            <button type="button" class="btn primary glow" disabled="@_busy" @onclick="RunHarnessAsync">
                @if (_busy)
                {
                    <span class="spinner"></span>
                    <span>Running Diagnostics...</span>
                }
                else
                {
                    <i class="ms-Icon ms-Icon--TestBeaker"></i>
                    <span>Run Test Harness</span>
                }
            </button>
        </div>

        @if (_result != null)
        {
            <div class="harness-summary-card">
                <div class="summary-stat">
                    <span class="label">Executed At</span>
                    <span class="value">@_result.ExecutedAtUtc.ToLocalTime().ToString("HH:mm:ss")</span>
                </div>

                <div class="summary-stat">
                    <span class="label">Overall Status</span>
                    @if (_result.WorkerResults.All(r => r.Success))
                    {
                        <span class="value success">HEALTHY</span>
                    }
                    else
                    {
                        <span class="value danger">DEGRADED</span>
                    }
                </div>

                <div class="summary-stat">
                    <span class="label">Success Rate</span>
                    <span class="value">@(_result.WorkerResults.Count(r => r.Success)) / @(_result.WorkerResults.Count)</span>
                </div>
            </div>

            <div class="grid-container">
                <RadzenDataGrid TItem="WorkerHealthCheckResultDto"
                                Data="@_result.WorkerResults"
                                AllowSorting="true"
                                class="dev-grid">
                    <Columns>
                        <RadzenDataGridColumn TItem="WorkerHealthCheckResultDto" Property="WorkerName" Title="Worker Component" Width="220px">
                            <Template Context="r">
                                <div class="worker-name-cell">
                                    <span class="kind-indicator"></span>
                                    <strong>@r.WorkerName</strong>
                                </div>
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="WorkerHealthCheckResultDto" Property="Success" Title="Result" Width="120px">
                            <Template Context="r">
                                <span class="badge @(r.Success ? "badge-green" : "badge-red")">
                                    @(r.Success ? "PASSED" : "FAILED")
                                </span>
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="WorkerHealthCheckResultDto" Property="Message" Title="Diagnostic Message" />

                        <RadzenDataGridColumn TItem="WorkerHealthCheckResultDto" Title="Detailed Log" Width="140px" TextAlign="TextAlign.Center">
                            <Template Context="r">
                                @if (!string.IsNullOrEmpty(r.Output))
                                {
                                    <button type="button" class="btn small outline" @onclick="@(() => ShowOutputAsync(r))">View Output</button>
                                }
                                else
                                {
                                    <span class="muted small">No log available</span>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
        else if (!_busy)
        {
            <div class="harness-empty">
                <div class="empty-icon"></div>
                <h3>Ready to test</h3>
                <p>Click the button above to begin the automated worker health check suite.</p>
            </div>
        }
    </section>

    <section class="panel error-log-panel">
        <div class="section-heading">
            <div class="title-group">
                <h2>System-Wide Error Log</h2>
                <p class="muted">Centralized collection of all Critical and Error level logs from all system components.</p>
            </div>

            <div class="actions">
                <button type="button" class="btn small outline" @onclick="RefreshErrorsAsync">
                    <i class="ms-Icon ms-Icon--Refresh"></i>
                    <span>Refresh</span>
                </button>

                <button type="button" class="btn small danger-outline" @onclick="ClearErrorsAsync">
                    <i class="ms-Icon ms-Icon--Delete"></i>
                    <span>Clear All</span>
                </button>
            </div>
        </div>

        @if (_selectedError != null)
        {
            <div class="error-detail-card">
                <div class="error-detail-header">
                    <div>
                        <p class="eyebrow">Selected Error</p>
                        <h3>@BuildErrorSummary(_selectedError)</h3>
                        <p class="muted">@BuildContextLine(_selectedError)</p>
                    </div>

                    <button type="button" class="btn small outline" @onclick="CloseErrorDetail">Close</button>
                </div>

                <div class="error-detail-meta">
                    <div>
                        <span class="label">Time</span>
                        <strong>@_selectedError.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz")</strong>
                    </div>
                    <div>
                        <span class="label">Component</span>
                        <strong>@Fallback(_selectedError.Component, "unknown")</strong>
                    </div>
                    <div>
                        <span class="label">Logger</span>
                        <strong>@Fallback(_selectedError.LoggerName, "unknown")</strong>
                    </div>
                    <div>
                        <span class="label">Machine</span>
                        <strong>@Fallback(_selectedError.MachineName, "unknown")</strong>
                    </div>
                </div>

                <pre class="stack-trace">@BuildFullErrorDetail(_selectedError)</pre>
            </div>
        }

        <div class="grid-container">
            <RadzenDataGrid TItem="SystemError"
                            Data="@_errors"
                            AllowPaging="true"
                            PageSize="10"
                            AllowSorting="true"
                            class="dev-grid error-grid">
                <Columns>
                    <RadzenDataGridColumn TItem="SystemError" Property="Timestamp" Title="Time" Width="160px">
                        <Template Context="e">
                            @e.Timestamp.ToLocalTime().ToString("MM/dd HH:mm:ss")
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="SystemError" Property="Component" Title="Component" Width="140px">
                        <Template Context="e">
                            <span class="badge badge-component">@Fallback(e.Component, "unknown")</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="SystemError" Property="LogLevel" Title="Level" Width="100px">
                        <Template Context="e">
                            <span class="badge @(e.LogLevel == "Critical" ? "badge-critical" : "badge-red")">
                                @Fallback(e.LogLevel, "Error")
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="SystemError" Property="Message" Title="Error Context">
                        <Template Context="e">
                            <div class="error-message-cell">
                                <strong>@BuildErrorSummary(e)</strong>
                                <span>@BuildContextLine(e)</span>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="SystemError" Title="Details" Width="130px" TextAlign="TextAlign.Center">
                        <Template Context="e">
                            <button type="button"
                                    class="btn small outline"
                                    @onclick="@(() => ToggleErrorDetail(e))">
                                @(HasStackTrace(e) ? "Stack Trace" : "Details")
                            </button>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </div>
    </section>
</div>

@code {
    private bool _busy;
    private HarnessResultDto? _result;
    private List<SystemError> _errors = new();
    private SystemError? _selectedError;

    protected override async Task OnInitializedAsync()
    {
        await RefreshErrorsAsync();
    }

    private async Task RefreshErrorsAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            _errors = await db.SystemErrors
                .OrderByDescending(e => e.Timestamp)
                .Take(500)
                .ToListAsync();

            if (_selectedError is not null)
            {
                _selectedError = _errors.FirstOrDefault(error => error.Id == _selectedError.Id);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load system-wide errors for the development diagnostics page.");
        }
    }

    private async Task ClearErrorsAsync()
    {
        if (!await Js.InvokeAsync<bool>("confirm", "Are you sure you want to clear all system errors?"))
        {
            return;
        }

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            await db.Database.ExecuteSqlRawAsync("TRUNCATE TABLE system_errors");
            _selectedError = null;
            await RefreshErrorsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to clear system-wide errors from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Failed to clear errors: {ex.Message}");
        }
    }

    private async Task RunHarnessAsync()
    {
        _busy = true;
        _result = null;
        StateHasChanged();

        try
        {
            await Task.Delay(500);
            _result = await Harness.RunAllAsync(default);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Harness execution failed from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Harness Execution Error: {ex.Message}");
        }
        finally
        {
            _busy = false;
            await RefreshErrorsAsync();
        }
    }

    private async Task ShowOutputAsync(WorkerHealthCheckResultDto r)
    {
        await Js.InvokeVoidAsync("alert", $"{r.WorkerName} Health Check Output:\n\n{r.Output}");
    }

    private void ToggleErrorDetail(SystemError e)
    {
        if (_selectedError?.Id == e.Id)
        {
            _selectedError = null;
            return;
        }

        _selectedError = e;
    }

    private void CloseErrorDetail()
    {
        _selectedError = null;
    }

    private static bool HasStackTrace(SystemError e)
    {
        return !string.IsNullOrWhiteSpace(e.Exception);
    }

    private static string BuildErrorSummary(SystemError e)
    {
        var message = Fallback(e.Message, "Error log entry did not include a message.");
        var exceptionHeadline = GetExceptionHeadline(e.Exception);

        if (!string.IsNullOrWhiteSpace(exceptionHeadline))
        {
            if (IsGenericErrorMessage(message))
            {
                return exceptionHeadline;
            }

            if (!message.Contains(exceptionHeadline, StringComparison.OrdinalIgnoreCase)
                && !message.Contains(exceptionHeadline.Split(':', 2)[^1].Trim(), StringComparison.OrdinalIgnoreCase))
            {
                return $"{message} — {exceptionHeadline}";
            }
        }

        return message;
    }

    private static string BuildContextLine(SystemError e)
    {
        var context = new List<string>
        {
            $"Logger: {Fallback(e.LoggerName, "unknown")}"
        };

        if (!string.IsNullOrWhiteSpace(e.MachineName))
        {
            context.Add($"Machine: {e.MachineName}");
        }

        var metadata = ParseMetadata(e.MetadataJson);

        if (metadata.TryGetValue("event_id", out var eventId) && !string.IsNullOrWhiteSpace(eventId))
        {
            context.Add($"EventId: {eventId}");
        }

        if (metadata.TryGetValue("event_name", out var eventName) && !string.IsNullOrWhiteSpace(eventName))
        {
            context.Add($"Event: {eventName}");
        }

        if (metadata.TryGetValue("trace_id", out var traceId) && !string.IsNullOrWhiteSpace(traceId))
        {
            context.Add($"Trace: {traceId}");
        }

        return string.Join(" • ", context);
    }

    private static string BuildFullErrorDetail(SystemError e)
    {
        var sb = new StringBuilder();

        sb.AppendLine($"Time:      {e.Timestamp.ToLocalTime():yyyy-MM-dd HH:mm:ss zzz}");
        sb.AppendLine($"Component: {Fallback(e.Component, "unknown")}");
        sb.AppendLine($"Level:     {Fallback(e.LogLevel, "Error")}");
        sb.AppendLine($"Logger:    {Fallback(e.LoggerName, "unknown")}");
        sb.AppendLine($"Machine:   {Fallback(e.MachineName, "unknown")}");
        sb.AppendLine();
        sb.AppendLine("Message:");
        sb.AppendLine(Fallback(e.Message, "Error log entry did not include a message."));

        if (!string.IsNullOrWhiteSpace(e.Exception))
        {
            sb.AppendLine();
            sb.AppendLine("Exception / stack trace:");
            sb.AppendLine(e.Exception.Trim());
        }

        if (!string.IsNullOrWhiteSpace(e.MetadataJson))
        {
            sb.AppendLine();
            sb.AppendLine("Metadata:");
            sb.AppendLine(FormatMetadata(e.MetadataJson));
        }

        return sb.ToString();
    }

    private static string? GetExceptionHeadline(string? exception)
    {
        if (string.IsNullOrWhiteSpace(exception))
        {
            return null;
        }

        var firstLine = exception
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .FirstOrDefault();

        return string.IsNullOrWhiteSpace(firstLine) ? null : firstLine;
    }

    private static bool IsGenericErrorMessage(string message)
    {
        var normalized = message.Trim().TrimEnd('.');

        return normalized.Equals("An error has occurred", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("An error has occured", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("An unhandled exception has occurred while executing the request", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("Unhandled exception rendering component", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("Circuit host terminated unexpectedly", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatMetadata(string metadataJson)
    {
        try
        {
            using var document = JsonDocument.Parse(metadataJson);

            return JsonSerializer.Serialize(
                document.RootElement,
                new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return metadataJson;
        }
    }

    private static IReadOnlyDictionary<string, string?> ParseMetadata(string? metadataJson)
    {
        if (string.IsNullOrWhiteSpace(metadataJson))
        {
            return new Dictionary<string, string?>();
        }

        try
        {
            using var document = JsonDocument.Parse(metadataJson);

            if (document.RootElement.ValueKind != JsonValueKind.Object)
            {
                return new Dictionary<string, string?>();
            }

            return document.RootElement
                .EnumerateObject()
                .ToDictionary(
                    property => property.Name,
                    property => property.Value.ValueKind == JsonValueKind.String
                        ? property.Value.GetString()
                        : property.Value.ToString());
        }
        catch
        {
            return new Dictionary<string, string?>();
        }
    }

    private static string Fallback(string? value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();
    }
}
