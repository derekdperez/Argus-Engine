@page "/development"
@using ArgusEngine.CommandCenter.Services.Updates
@using ArgusEngine.Domain.Entities
@using ArgusEngine.Harness.Core
@using ArgusEngine.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ArgusDbContext> DbFactory
@inject HarnessRunner Harness
@inject IComponentUpdateService ComponentUpdates
@inject IJSRuntime Js

<PageTitle>Development - Argus Engine</PageTitle>

<section class="development-page">
    <div class="page-header">
        <p class="eyebrow">Diagnostic Suite</p>
        <h1>Development & Diagnostics</h1>
        <p>Execute internal test harnesses, review system errors, and update deployed components from GitHub main.</p>
    </div>

    <section class="panel">
        <div class="panel-header">
            <div>
                <h2>Component Updates</h2>
                <p>Compare deployed components with the latest GitHub main revision and redeploy individual services.</p>
            </div>
            <button class="secondary" @onclick="RefreshComponentUpdatesAsync" disabled="@_componentBusy">
                @(_componentBusy ? "Refreshing..." : "Refresh")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_componentMessage))
        {
            <div class="@($"notice {(_componentError ? "error" : "info")}")">@_componentMessage</div>
        }

        @if (_components.Count == 0 && _componentBusy)
        {
            <div class="empty-state">Loading component status...</div>
        }
        else if (_components.Count == 0)
        {
            <div class="empty-state">No component status has been loaded yet.</div>
        }
        else
        {
            <div class="table-shell">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Component</th>
                            <th>Deployed</th>
                            <th>Latest GitHub main</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th>Update</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var component in _components)
                        {
                            <tr>
                                <td>
                                    <strong>@component.DisplayName</strong>
                                    <div class="muted">@component.ServiceName</div>
                                </td>
                                <td>
                                    <span>@component.DeployedVersion</span>
                                    <div class="muted">@component.DeployedRevision</div>
                                </td>
                                <td>
                                    <span>@component.LatestVersion</span>
                                    <div class="muted">@component.LatestRevision</div>
                                </td>
                                <td>@component.Location</td>
                                <td>
                                    <span class="@StatusClass(component)">@component.Status</span>
                                    <div class="muted">@component.Message</div>
                                </td>
                                <td>
                                    <button class="primary"
                                            disabled="@(!component.CanUpdate || _updatingComponentKey is not null)"
                                            @onclick="() => UpdateComponentAsync(component.Key)">
                                        @(_updatingComponentKey == component.Key ? "Updating..." : "Update")
                                    </button>
                                    <div class="muted">@component.UpdateState</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="panel-subheader">
            <div>
                <h3>Component Update Action Log</h3>
                <p>Saved to PostgreSQL table <code>component_update_logs</code>.</p>
            </div>
            <button class="secondary" @onclick="RefreshUpdateLogsAsync" disabled="@_componentBusy">Refresh Log</button>
        </div>

        @if (_updateLogs.Count == 0)
        {
            <div class="empty-state">No component update actions have been recorded.</div>
        }
        else
        {
            <div class="log-list">
                @foreach (var log in _updateLogs)
                {
                    <button class="log-entry" @onclick="() => ShowUpdateLogDetailAsync(log)">
                        <span class="timestamp">@log.CreatedAtUtc.ToLocalTime().ToString("MM/dd HH:mm:ss")</span>
                        <span class="component">@log.ComponentKey</span>
                        <span class="action">@log.Action</span>
                        <span class="@LogClass(log)">@LogStatus(log)</span>
                        <span class="message">@log.Message</span>
                    </button>
                }
            </div>
        }
    </section>

    <section class="panel">
        <div class="panel-header">
            <div>
                <h2>Worker Test Harness</h2>
                <p>Executes "Health Check" logic within each worker project to exercise core functionality.</p>
            </div>
            <button class="primary" disabled="@_busy" @onclick="RunHarnessAsync">
                @(_busy ? "Running Diagnostics..." : "Run Test Harness")
            </button>
        </div>

        @if (_result != null)
        {
            <div class="summary-grid">
                <div>
                    <span class="label">Executed At</span>
                    <strong>@_result.ExecutedAtUtc.ToLocalTime().ToString("HH:mm:ss")</strong>
                </div>
                <div>
                    <span class="label">Overall Status</span>
                    @if (_result.WorkerResults.All(r => r.Success))
                    {
                        <strong class="status-good">HEALTHY</strong>
                    }
                    else
                    {
                        <strong class="status-bad">DEGRADED</strong>
                    }
                </div>
                <div>
                    <span class="label">Success Rate</span>
                    <strong>@(_result.WorkerResults.Count(r => r.Success)) / @_result.WorkerResults.Count</strong>
                </div>
            </div>

            <div class="table-shell">
                <table class="data-table">
                    <tbody>
                        @foreach (var r in _result.WorkerResults)
                        {
                            <tr>
                                <td>@r.WorkerName</td>
                                <td>
                                    <span class="@(r.Success ? "status-pill good" : "status-pill bad")">
                                        @(r.Success ? "PASSED" : "FAILED")
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(r.Output))
                                    {
                                        <button class="link-button" @onclick="() => ShowOutputAsync(r)">View Output</button>
                                    }
                                    else
                                    {
                                        <span class="muted">No log available</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (!_busy)
        {
            <div class="empty-state">
                <h3>Ready to test</h3>
                <p>Click the button above to begin the automated worker health check suite.</p>
            </div>
        }
    </section>

    <section class="panel">
        <div class="panel-header">
            <div>
                <h2>System-Wide Error Log</h2>
                <p>Centralized collection of all Critical and Error level logs from all system components.</p>
            </div>
            <div class="button-row">
                <button class="secondary" @onclick="RefreshErrorsAsync">Refresh</button>
                <button class="danger" @onclick="ClearErrorsAsync">Clear All</button>
            </div>
        </div>

        @if (_errors.Count == 0)
        {
            <div class="empty-state">No system errors have been recorded.</div>
        }
        else
        {
            <div class="log-list">
                @foreach (var e in _errors)
                {
                    <button class="log-entry" @onclick="() => ShowErrorDetailAsync(e)">
                        <span class="timestamp">@e.Timestamp.ToLocalTime().ToString("MM/dd HH:mm:ss")</span>
                        <span class="component">@e.Component</span>
                        <span class="status-pill bad">@e.LogLevel</span>
                        <span class="message">@e.Message</span>
                        @if (!string.IsNullOrEmpty(e.Exception))
                        {
                            <span class="muted">Stack Trace</span>
                        }
                    </button>
                }
            </div>
        }
    </section>
</section>

@code {
    private bool _busy;
    private bool _componentBusy;
    private bool _componentError;
    private string? _componentMessage;
    private string? _updatingComponentKey;
    private HarnessResultDto? _result;
    private List<SystemError> _errors = [];
    private List<ComponentStatusDto> _components = [];
    private List<ComponentUpdateLogDto> _updateLogs = [];

    protected override async Task OnInitializedAsync()
    {
        await RefreshErrorsAsync();
        await RefreshComponentUpdatesAsync();
    }

    private async Task RefreshComponentUpdatesAsync()
    {
        _componentBusy = true;
        _componentError = false;
        _componentMessage = null;

        try
        {
            _components = (await ComponentUpdates.GetComponentsAsync()).ToList();
            await RefreshUpdateLogsAsync();
        }
        catch (Exception ex)
        {
            _componentError = true;
            _componentMessage = $"Failed to load component update status: {ex.Message}";
        }
        finally
        {
            _componentBusy = false;
        }
    }

    private async Task RefreshUpdateLogsAsync()
    {
        try
        {
            _updateLogs = (await ComponentUpdates.GetLogsAsync(200)).ToList();
        }
        catch (Exception ex)
        {
            _componentError = true;
            _componentMessage = $"Failed to load component update logs: {ex.Message}";
        }
    }

    private async Task UpdateComponentAsync(string componentKey)
    {
        var component = _components.FirstOrDefault(c => c.Key == componentKey);
        var name = component?.DisplayName ?? componentKey;

        if (!await Js.InvokeAsync<bool>("confirm", $"Update {name} from GitHub main and redeploy it?"))
        {
            return;
        }

        _updatingComponentKey = componentKey;
        _componentBusy = true;
        _componentError = false;
        _componentMessage = $"Updating {name}...";

        try
        {
            var result = await ComponentUpdates.UpdateComponentAsync(componentKey);
            _componentError = !result.Succeeded;
            _componentMessage = result.Message;
            await RefreshComponentUpdatesAsync();
        }
        catch (Exception ex)
        {
            _componentError = true;
            _componentMessage = $"Update failed: {ex.Message}";
            await RefreshUpdateLogsAsync();
        }
        finally
        {
            _componentBusy = false;
            _updatingComponentKey = null;
        }
    }

    private async Task RefreshErrorsAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _errors = await db.SystemErrors
                .OrderByDescending(e => e.Timestamp)
                .Take(500)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load errors: {ex.Message}");
        }
    }

    private async Task ClearErrorsAsync()
    {
        if (!await Js.InvokeAsync<bool>("confirm", "Are you sure you want to clear all system errors?"))
        {
            return;
        }

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            await db.Database.ExecuteSqlRawAsync("TRUNCATE TABLE system_errors");
            await RefreshErrorsAsync();
        }
        catch (Exception ex)
        {
            await Js.InvokeVoidAsync("alert", $"Failed to clear errors: {ex.Message}");
        }
    }

    private async Task RunHarnessAsync()
    {
        _busy = true;
        _result = null;
        StateHasChanged();

        try
        {
            await Task.Delay(500);
            _result = await Harness.RunAllAsync(default);
        }
        catch (Exception ex)
        {
            await Js.InvokeVoidAsync("alert", $"Harness Execution Error: {ex.Message}");
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ShowOutputAsync(WorkerHealthCheckResultDto r)
    {
        await Js.InvokeVoidAsync("alert", $"{r.WorkerName} Health Check Output:\n\n{r.Output}");
    }

    private async Task ShowErrorDetailAsync(SystemError e)
    {
        await Js.InvokeVoidAsync("alert", $"Error in {e.Component} ({e.LoggerName}):\n\n{e.Message}\n\n{e.Exception}");
    }

    private async Task ShowUpdateLogDetailAsync(ComponentUpdateLogDto log)
    {
        await Js.InvokeVoidAsync(
            "alert",
            $"{log.ComponentKey} / {log.Action}\n\n{log.Message}\n\n{log.Details}");
    }

    private static string StatusClass(ComponentStatusDto component)
    {
        if (!component.IsRunning)
        {
            return "status-pill bad";
        }

        return component.IsHealthy ? "status-pill good" : "status-pill warn";
    }

    private static string LogClass(ComponentUpdateLogDto log)
    {
        return log.Succeeded switch
        {
            true => "status-pill good",
            false => "status-pill bad",
            _ => "status-pill warn"
        };
    }

    private static string LogStatus(ComponentUpdateLogDto log)
    {
        return log.Succeeded switch
        {
            true => "OK",
            false => "FAILED",
            _ => "RUNNING"
        };
    }
}
