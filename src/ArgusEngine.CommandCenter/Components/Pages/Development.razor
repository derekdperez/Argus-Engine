@page "/development"

@using System.Text
@using System.Globalization
@using System.Text.Json
@using System.Net
@using System.Net.Sockets
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Hosting
@using ArgusEngine.Harness.Core
@using ArgusEngine.Domain.Entities
@using ArgusEngine.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@inject IDbContextFactory<ArgusDbContext> DbFactory
@inject HarnessRunner Harness
@inject IJSRuntime Js
@inject ILogger<Development> Logger
@inject IConfiguration Configuration
@inject IHostEnvironment HostEnvironment
@inject NavigationManager Navigation

<PageTitle>Development - Argus Engine</PageTitle>

<div class="dev-page">
    <div class="page-header">
        <div class="header-content">
            <p class="eyebrow">Diagnostic Suite</p>
            <h1>Development & Diagnostics</h1>
            <p class="description">Execute internal test harness to verify worker integrity and cross-component connectivity.</p>
        </div>
    </div>

    <section class="panel">
        <div class="section-heading">
            <div class="title-group">
                <h2>Worker Test Harness</h2>
                <p class="muted">Executes "Health Check" logic within each worker project to exercise core functionality.</p>
            </div>

            <button type="button" class="btn primary glow" disabled="@_busy" @onclick="RunHarnessAsync">
                @if (_busy)
                {
                    <span class="spinner"></span>
                    <span>Running Diagnostics...</span>
                }
                else
                {
                    <i class="ms-Icon ms-Icon--TestBeaker"></i>
                    <span>Run Test Harness</span>
                }
            </button>
        </div>

        @if (_result != null)
        {
            <div class="harness-summary-card">
                <div class="summary-stat">
                    <span class="label">Executed At</span>
                    <span class="value">@_result.ExecutedAtUtc.ToLocalTime().ToString("HH:mm:ss")</span>
                </div>

                <div class="summary-stat">
                    <span class="label">Overall Status</span>
                    @if (_result.WorkerResults.All(r => r.Success))
                    {
                        <span class="value success">HEALTHY</span>
                    }
                    else
                    {
                        <span class="value danger">DEGRADED</span>
                    }
                </div>

                <div class="summary-stat">
                    <span class="label">Success Rate</span>
                    <span class="value">@(_result.WorkerResults.Count(r => r.Success)) / @(_result.WorkerResults.Count)</span>
                </div>
            </div>

            <div class="grid-container">
                <RadzenDataGrid TItem="WorkerHealthCheckResultDto"
                                Data="@_result.WorkerResults"
                                AllowSorting="true"
                                class="dev-grid">
                    <Columns>
                        <RadzenDataGridColumn TItem="WorkerHealthCheckResultDto" Property="WorkerName" Title="Worker Component" Width="220px">
                            <Template Context="r">
                                <div class="worker-name-cell">
                                    <span class="kind-indicator"></span>
                                    <strong>@r.WorkerName</strong>
                                </div>
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="WorkerHealthCheckResultDto" Property="Success" Title="Result" Width="120px">
                            <Template Context="r">
                                <span class="badge @(r.Success ? "badge-green" : "badge-red")">
                                    @(r.Success ? "PASSED" : "FAILED")
                                </span>
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="WorkerHealthCheckResultDto" Property="Message" Title="Diagnostic Message" />

                        <RadzenDataGridColumn TItem="WorkerHealthCheckResultDto" Title="Detailed Log" Width="140px" TextAlign="TextAlign.Center">
                            <Template Context="r">
                                @if (!string.IsNullOrEmpty(r.Output))
                                {
                                    <button type="button" class="btn small outline" @onclick="@(() => ShowOutputAsync(r))">View Output</button>
                                }
                                else
                                {
                                    <span class="muted small">No log available</span>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
        else if (!_busy)
        {
            <div class="harness-empty">
                <div class="empty-icon"></div>
                <h3>Ready to test</h3>
                <p>Click the button above to begin the automated worker health check suite.</p>
            </div>
        }
    </section>

    <section class="panel error-log-panel">
        <div class="section-heading">
            <div class="title-group">
                <h2>System-Wide Error Log</h2>
                <p class="muted">Centralized collection of all Critical and Error level logs from all system components.</p>
            </div>

            <div class="actions">
                <button type="button" class="btn small outline" @onclick="RefreshErrorsAsync">
                    <i class="ms-Icon ms-Icon--Refresh"></i>
                    <span>Refresh</span>
                </button>

                <button type="button" class="btn small primary" disabled="@_generatingBugFixPrompt" @onclick="GenerateBugFixPromptAsync">
                    @if (_generatingBugFixPrompt)
                    {
                        <span class="spinner"></span>
                        <span>Generating...</span>
                    }
                    else
                    {
                        <i class="ms-Icon ms-Icon--Robot"></i>
                        <span>Generate Bug Fix Prompt</span>
                    }
                </button>

                <button type="button" class="btn small danger-outline" @onclick="ClearErrorsAsync">
                    <i class="ms-Icon ms-Icon--Delete"></i>
                    <span>Clear All</span>
                </button>
            </div>
        </div>

        @if (_selectedError != null)
        {
            <div class="error-detail-card">
                <div class="error-detail-header">
                    <div>
                        <p class="eyebrow">Selected Error</p>
                        <h3>@BuildErrorSummary(_selectedError)</h3>
                        <p class="muted">@BuildContextLine(_selectedError)</p>
                    </div>

                    <button type="button" class="btn small outline" @onclick="CloseErrorDetail">Close</button>
                </div>

                <div class="error-detail-meta">
                    <div>
                        <span class="label">Time</span>
                        <strong>@_selectedError.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz")</strong>
                    </div>
                    <div>
                        <span class="label">Component</span>
                        <strong>@Fallback(_selectedError.Component, "unknown")</strong>
                    </div>
                    <div>
                        <span class="label">Logger</span>
                        <strong>@Fallback(_selectedError.LoggerName, "unknown")</strong>
                    </div>
                    <div>
                        <span class="label">Machine</span>
                        <strong>@Fallback(_selectedError.MachineName, "unknown")</strong>
                    </div>
                </div>

                <pre class="stack-trace">@BuildFullErrorDetail(_selectedError)</pre>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_bugFixPrompt))
        {
            <div class="bug-fix-prompt-card">
                <div class="bug-fix-prompt-header">
                    <div>
                        <p class="eyebrow">Generated AI Agent Prompt</p>
                        <h3>Investigate System-Wide Errors and Create a PR</h3>
                        <p class="muted">
                            Generated @(_bugFixPromptGeneratedAtUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz") ?? "unknown").
                            Credential values are intentionally redacted; the agent must obtain them through approved secure channels.
                        </p>
                    </div>

                    <div class="actions">
                        <button type="button" class="btn small outline" @onclick="CopyBugFixPromptAsync">
                            <i class="ms-Icon ms-Icon--Copy"></i>
                            <span>Copy Prompt</span>
                        </button>
                        <button type="button" class="btn small outline" @onclick="CloseBugFixPrompt">
                            <span>Close</span>
                        </button>
                    </div>
                </div>

                <textarea class="bug-fix-prompt-textarea" readonly>@_bugFixPrompt</textarea>
            </div>
        }

        <div class="grid-container">
            <RadzenDataGrid TItem="SystemError"
                            Data="@_errors"
                            AllowPaging="true"
                            PageSize="10"
                            AllowSorting="true"
                            class="dev-grid error-grid">
                <Columns>
                    <RadzenDataGridColumn TItem="SystemError" Property="Timestamp" Title="Time" Width="160px">
                        <Template Context="e">
                            @e.Timestamp.ToLocalTime().ToString("MM/dd HH:mm:ss")
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="SystemError" Property="Component" Title="Component" Width="140px">
                        <Template Context="e">
                            <span class="badge badge-component">@Fallback(e.Component, "unknown")</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="SystemError" Property="LogLevel" Title="Level" Width="100px">
                        <Template Context="e">
                            <span class="badge @(e.LogLevel == "Critical" ? "badge-critical" : "badge-red")">
                                @Fallback(e.LogLevel, "Error")
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="SystemError" Property="Message" Title="Error Context">
                        <Template Context="e">
                            <div class="error-message-cell">
                                <strong>@BuildErrorSummary(e)</strong>
                                <span>@BuildContextLine(e)</span>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="SystemError" Title="Details" Width="130px" TextAlign="TextAlign.Center">
                        <Template Context="e">
                            <button type="button"
                                    class="btn small outline"
                                    @onclick="@(() => ToggleErrorDetail(e))">
                                @(HasStackTrace(e) ? "Stack Trace" : "Details")
                            </button>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </div>
    </section>
</div>

@code {
    private bool _busy;
    private bool _generatingBugFixPrompt;
    private HarnessResultDto? _result;
    private List<SystemError> _errors = new();
    private SystemError? _selectedError;
    private string? _bugFixPrompt;
    private DateTimeOffset? _bugFixPromptGeneratedAtUtc;

    protected override async Task OnInitializedAsync()
    {
        await RefreshErrorsAsync();
    }

    private async Task RefreshErrorsAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            _errors = await db.SystemErrors
                .OrderByDescending(e => e.Timestamp)
                .Take(500)
                .ToListAsync();

            if (_selectedError is not null)
            {
                _selectedError = _errors.FirstOrDefault(error => error.Id == _selectedError.Id);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load system-wide errors for the development diagnostics page.");
        }
    }

    private async Task ClearErrorsAsync()
    {
        if (!await Js.InvokeAsync<bool>("confirm", "Are you sure you want to clear all system errors?"))
        {
            return;
        }

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            await db.Database.ExecuteSqlRawAsync("TRUNCATE TABLE system_errors");
            _selectedError = null;
            await RefreshErrorsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to clear system-wide errors from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Failed to clear errors: {ex.Message}");
        }
    }

    private async Task RunHarnessAsync()
    {
        _busy = true;
        _result = null;
        StateHasChanged();

        try
        {
            await Task.Delay(500);
            _result = await Harness.RunAllAsync(default);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Harness execution failed from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Harness Execution Error: {ex.Message}");
        }
        finally
        {
            _busy = false;
            await RefreshErrorsAsync();
        }
    }

    private async Task GenerateBugFixPromptAsync()
    {
        _generatingBugFixPrompt = true;
        StateHasChanged();

        try
        {
            await RefreshErrorsAsync();

            _bugFixPromptGeneratedAtUtc = DateTimeOffset.UtcNow;
            _bugFixPrompt = BuildBugFixPrompt(_errors, _bugFixPromptGeneratedAtUtc.Value);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to generate the bug-fix prompt from the development diagnostics page.");
            await Js.InvokeVoidAsync("alert", $"Failed to generate bug fix prompt: {ex.Message}");
        }
        finally
        {
            _generatingBugFixPrompt = false;
        }
    }

    private async Task CopyBugFixPromptAsync()
    {
        if (string.IsNullOrWhiteSpace(_bugFixPrompt))
        {
            return;
        }

        try
        {
            await Js.InvokeVoidAsync("navigator.clipboard.writeText", _bugFixPrompt);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Clipboard copy failed for the generated bug-fix prompt.");
            await Js.InvokeVoidAsync("alert", "The browser blocked clipboard access. Select the prompt text and copy it manually.");
        }
    }

    private void CloseBugFixPrompt()
    {
        _bugFixPrompt = null;
        _bugFixPromptGeneratedAtUtc = null;
    }

    private string BuildBugFixPrompt(IReadOnlyCollection<SystemError> errors, DateTimeOffset generatedAtUtc)
    {
        var orderedErrors = errors
            .OrderByDescending(error => error.Timestamp)
            .ToList();

        var sb = new StringBuilder();

        sb.AppendLine("# Argus Engine System-Wide Error Bug Fix Task");
        sb.AppendLine();
        sb.AppendLine("You are an AI software engineering agent working on the Argus Engine repository.");
        sb.AppendLine("Your job is to investigate every error listed below, identify shared root causes, implement fixes, add or update regression coverage, run the relevant validation commands, and create a pull request for a developer to review and merge.");
        sb.AppendLine();
        sb.AppendLine("## Repository and PR instructions");
        sb.AppendLine("- Repository: https://github.com/derekdperez/Argus-Engine");
        sb.AppendLine("- Create a new branch with a descriptive name, for example `fix/development-system-error-log-failures`.");
        sb.AppendLine("- Do not clear or mutate production diagnostics data as part of the fix.");
        sb.AppendLine("- Preserve existing behavior unless it is clearly broken by one of the logged failures.");
        sb.AppendLine("- Add targeted tests for each root cause whenever practical.");
        sb.AppendLine("- Run `dotnet build ArgusEngine.slnx` and the relevant `dotnet test` commands before opening the PR.");
        sb.AppendLine("- Open a PR that summarizes root causes, fixes, tests, deployment notes, and any follow-up work for the developer approver.");
        sb.AppendLine();
        sb.AppendLine("## Security and access rules");
        sb.AppendLine("- Credential values are intentionally not embedded in this prompt.");
        sb.AppendLine("- Use the credential references below only to determine what access is required.");
        sb.AppendLine("- Obtain secrets through the project's approved secret manager, CI/CD secrets, deployment environment, or a human maintainer.");
        sb.AppendLine("- Never paste secrets into the PR, logs, generated code, screenshots, or comments.");
        sb.AppendLine("- Redact tokens, passwords, private keys, connection strings, cookies, and authorization headers from all investigation notes.");
        sb.AppendLine();
        sb.AppendLine("## Runtime context captured from the Development page");
        sb.AppendLine($"- Generated at UTC: {generatedAtUtc:yyyy-MM-dd HH:mm:ss zzz}");
        sb.AppendLine($"- Generated at local server time: {generatedAtUtc.ToLocalTime():yyyy-MM-dd HH:mm:ss zzz}");
        sb.AppendLine($"- ASP.NET Core environment: {Fallback(HostEnvironment.EnvironmentName, "unknown")}");
        sb.AppendLine($"- Application name: {Fallback(HostEnvironment.ApplicationName, "unknown")}");
        sb.AppendLine($"- Content root: {Fallback(HostEnvironment.ContentRootPath, "unknown")}");
        sb.AppendLine($"- Server machine name: {Environment.MachineName}");
        sb.AppendLine($"- Server process id: {Environment.ProcessId.ToString(CultureInfo.InvariantCulture)}");
        sb.AppendLine($"- Server OS: {Environment.OSVersion}");
        sb.AppendLine($"- Server IP address(es): {BuildServerIpAddressList()}");
        sb.AppendLine($"- Command Center URL visible to this browser: {Fallback(Navigation.Uri, "unknown")}");
        sb.AppendLine();
        sb.AppendLine("## Credentials, secrets, and service access likely required");
        sb.AppendLine("The following entries identify required or relevant credentials/configuration without exposing their values:");
        sb.AppendLine();

        var credentialReferences = BuildCredentialReferenceLines();

        if (credentialReferences.Count == 0)
        {
            sb.AppendLine("- No credential-like configuration keys were visible to the Development page configuration provider.");
            sb.AppendLine("- The agent will still likely need GitHub write access to create a branch/PR and read-only access to deployment logs, database diagnostics, message broker diagnostics, and service secrets through approved channels.");
        }
        else
        {
            foreach (var reference in credentialReferences)
            {
                sb.AppendLine($"- {reference}");
            }
        }

        sb.AppendLine();
        sb.AppendLine("## Error inventory");
        sb.AppendLine($"Total errors currently loaded on the Development page: {orderedErrors.Count.ToString(CultureInfo.InvariantCulture)}");
        sb.AppendLine();

        if (orderedErrors.Count == 0)
        {
            sb.AppendLine("No errors were present when this prompt was generated. Confirm whether the diagnostics page is loading the system-wide error log correctly before making code changes.");
        }

        var index = 1;

        foreach (var error in orderedErrors)
        {
            sb.AppendLine($"### Error {index.ToString(CultureInfo.InvariantCulture)}");
            sb.AppendLine($"- Id: {error.Id}");
            sb.AppendLine($"- Timestamp UTC: {error.Timestamp.UtcDateTime:yyyy-MM-dd HH:mm:ss}Z");
            sb.AppendLine($"- Timestamp local: {error.Timestamp.ToLocalTime():yyyy-MM-dd HH:mm:ss zzz}");
            sb.AppendLine($"- Component: {Fallback(error.Component, "unknown")}");
            sb.AppendLine($"- Level: {Fallback(error.LogLevel, "Error")}");
            sb.AppendLine($"- Logger: {Fallback(error.LoggerName, "unknown")}");
            sb.AppendLine($"- Machine: {Fallback(error.MachineName, "unknown")}");
            sb.AppendLine($"- Summary: {BuildErrorSummary(error)}");
            sb.AppendLine($"- Context: {BuildContextLine(error)}");
            sb.AppendLine();
            sb.AppendLine("Message:");
            sb.AppendLine("```text");
            sb.AppendLine(Fallback(error.Message, "Error log entry did not include a message."));
            sb.AppendLine("```");

            if (!string.IsNullOrWhiteSpace(error.Exception))
            {
                sb.AppendLine();
                sb.AppendLine("Exception / stack trace:");
                sb.AppendLine("```text");
                sb.AppendLine(error.Exception.Trim());
                sb.AppendLine("```");
            }

            if (!string.IsNullOrWhiteSpace(error.MetadataJson))
            {
                sb.AppendLine();
                sb.AppendLine("Metadata:");
                sb.AppendLine("```json");
                sb.AppendLine(FormatMetadata(error.MetadataJson));
                sb.AppendLine("```");
            }

            sb.AppendLine();
            index++;
        }

        sb.AppendLine("## Expected investigation workflow");
        sb.AppendLine("1. Group errors by component, logger, exception type, trace ID, and likely root cause.");
        sb.AppendLine("2. Reproduce failures locally or in a safe staging environment using the redacted credential references above.");
        sb.AppendLine("3. Fix root causes, not just symptoms. Prefer small, reviewable commits.");
        sb.AppendLine("4. Add regression coverage for the affected service/component boundaries.");
        sb.AppendLine("5. Validate the Development page still shows contextual error messages and working stack-trace/details behavior.");
        sb.AppendLine("6. Create the PR and include exact build/test commands run, remaining risks, and deployment notes.");

        return sb.ToString();
    }

    private List<string> BuildCredentialReferenceLines()
    {
        var references = Configuration
            .AsEnumerable()
            .Where(entry => IsCredentialOrServiceAccessKey(entry.Key))
            .Select(entry =>
            {
                var status = string.IsNullOrWhiteSpace(entry.Value)
                    ? "not configured or empty"
                    : "configured; value redacted";

                return $"{NormalizeConfigurationKey(entry.Key)}: [{status}]";
            })
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(line => line, StringComparer.OrdinalIgnoreCase)
            .Take(75)
            .ToList();

        references.Add("GitHub repository write access or an approved automation token: [required for branch and PR creation; value not available to the application]");
        references.Add("Deployment/runtime log access: [required for correlation with the system-wide error log; obtain through approved operations tooling]");

        return references
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static bool IsCredentialOrServiceAccessKey(string? key)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return false;
        }

        var normalized = NormalizeConfigurationKey(key);

        return normalized.StartsWith("ConnectionStrings:", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":ConnectionString", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":Password", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":Pwd", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":Secret", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":Token", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":ApiKey", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":ClientSecret", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":AccessKey", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":PrivateKey", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains(":Credential", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("AWS:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("RabbitMQ:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("RabbitMq:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("Postgres:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("Npgsql:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("Database:", StringComparison.OrdinalIgnoreCase)
            || normalized.StartsWith("OpenTelemetry:", StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizeConfigurationKey(string key)
    {
        return key.Replace("__", ":", StringComparison.Ordinal);
    }

    private static string BuildServerIpAddressList()
    {
        try
        {
            var hostName = Dns.GetHostName();
            var addresses = Dns.GetHostAddresses(hostName)
                .Where(address =>
                    address.AddressFamily is AddressFamily.InterNetwork or AddressFamily.InterNetworkV6
                    && !IPAddress.IsLoopback(address))
                .Select(address => address.ToString())
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(address => address, StringComparer.OrdinalIgnoreCase)
                .ToList();

            return addresses.Count == 0
                ? "none detected"
                : string.Join(", ", addresses);
        }
        catch (Exception ex)
        {
            return $"unavailable ({ex.GetType().Name}: {ex.Message})";
        }
    }

    private async Task ShowOutputAsync(WorkerHealthCheckResultDto r)
    {
        await Js.InvokeVoidAsync("alert", $"{r.WorkerName} Health Check Output:\n\n{r.Output}");
    }

    private void ToggleErrorDetail(SystemError e)
    {
        if (_selectedError?.Id == e.Id)
        {
            _selectedError = null;
            return;
        }

        _selectedError = e;
    }

    private void CloseErrorDetail()
    {
        _selectedError = null;
    }

    private static bool HasStackTrace(SystemError e)
    {
        return !string.IsNullOrWhiteSpace(e.Exception);
    }

    private static string BuildErrorSummary(SystemError e)
    {
        var message = Fallback(e.Message, "Error log entry did not include a message.");
        var exceptionHeadline = GetExceptionHeadline(e.Exception);

        if (!string.IsNullOrWhiteSpace(exceptionHeadline))
        {
            if (IsGenericErrorMessage(message))
            {
                return exceptionHeadline;
            }

            if (!message.Contains(exceptionHeadline, StringComparison.OrdinalIgnoreCase)
                && !message.Contains(exceptionHeadline.Split(':', 2)[^1].Trim(), StringComparison.OrdinalIgnoreCase))
            {
                return $"{message} — {exceptionHeadline}";
            }
        }

        return message;
    }

    private static string BuildContextLine(SystemError e)
    {
        var context = new List<string>
        {
            $"Logger: {Fallback(e.LoggerName, "unknown")}"
        };

        if (!string.IsNullOrWhiteSpace(e.MachineName))
        {
            context.Add($"Machine: {e.MachineName}");
        }

        var metadata = ParseMetadata(e.MetadataJson);

        if (metadata.TryGetValue("event_id", out var eventId) && !string.IsNullOrWhiteSpace(eventId))
        {
            context.Add($"EventId: {eventId}");
        }

        if (metadata.TryGetValue("event_name", out var eventName) && !string.IsNullOrWhiteSpace(eventName))
        {
            context.Add($"Event: {eventName}");
        }

        if (metadata.TryGetValue("trace_id", out var traceId) && !string.IsNullOrWhiteSpace(traceId))
        {
            context.Add($"Trace: {traceId}");
        }

        return string.Join(" • ", context);
    }

    private static string BuildFullErrorDetail(SystemError e)
    {
        var sb = new StringBuilder();

        sb.AppendLine($"Time:      {e.Timestamp.ToLocalTime():yyyy-MM-dd HH:mm:ss zzz}");
        sb.AppendLine($"Component: {Fallback(e.Component, "unknown")}");
        sb.AppendLine($"Level:     {Fallback(e.LogLevel, "Error")}");
        sb.AppendLine($"Logger:    {Fallback(e.LoggerName, "unknown")}");
        sb.AppendLine($"Machine:   {Fallback(e.MachineName, "unknown")}");
        sb.AppendLine();
        sb.AppendLine("Message:");
        sb.AppendLine(Fallback(e.Message, "Error log entry did not include a message."));

        if (!string.IsNullOrWhiteSpace(e.Exception))
        {
            sb.AppendLine();
            sb.AppendLine("Exception / stack trace:");
            sb.AppendLine(e.Exception.Trim());
        }

        if (!string.IsNullOrWhiteSpace(e.MetadataJson))
        {
            sb.AppendLine();
            sb.AppendLine("Metadata:");
            sb.AppendLine(FormatMetadata(e.MetadataJson));
        }

        return sb.ToString();
    }

    private static string? GetExceptionHeadline(string? exception)
    {
        if (string.IsNullOrWhiteSpace(exception))
        {
            return null;
        }

        var firstLine = exception
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .FirstOrDefault();

        return string.IsNullOrWhiteSpace(firstLine) ? null : firstLine;
    }

    private static bool IsGenericErrorMessage(string message)
    {
        var normalized = message.Trim().TrimEnd('.');

        return normalized.Equals("An error has occurred", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("An error has occured", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("An unhandled exception has occurred while executing the request", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("Unhandled exception rendering component", StringComparison.OrdinalIgnoreCase)
            || normalized.Equals("Circuit host terminated unexpectedly", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatMetadata(string metadataJson)
    {
        try
        {
            using var document = JsonDocument.Parse(metadataJson);

            return JsonSerializer.Serialize(
                document.RootElement,
                new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return metadataJson;
        }
    }

    private static IReadOnlyDictionary<string, string?> ParseMetadata(string? metadataJson)
    {
        if (string.IsNullOrWhiteSpace(metadataJson))
        {
            return new Dictionary<string, string?>();
        }

        try
        {
            using var document = JsonDocument.Parse(metadataJson);

            if (document.RootElement.ValueKind != JsonValueKind.Object)
            {
                return new Dictionary<string, string?>();
            }

            return document.RootElement
                .EnumerateObject()
                .ToDictionary(
                    property => property.Name,
                    property => property.Value.ValueKind == JsonValueKind.String
                        ? property.Value.GetString()
                        : property.Value.ToString());
        }
        catch
        {
            return new Dictionary<string, string?>();
        }
    }

    private static string Fallback(string? value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();
    }
}
