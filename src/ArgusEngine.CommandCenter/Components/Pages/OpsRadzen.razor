@page "/"
@page "/ops"
@rendermode InteractiveServer

@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web.Virtualization
@inject HttpClient Http

<PageTitle>Operations - Argus Engine</PageTitle>

<div class="page-shell ops-page ops-page-lite">
    <section class="page-hero ops-hero">
        <div>
            <p class="eyebrow">Command center</p>
            <h1>Operations</h1>
            <p class="hero-copy">Command-center workspace for target scope, confirmed asset inventory, HTTP request queue, and worker runtime health.</p>
        </div>

        <button type="button" class="btn primary" @onclick="ReloadAllAsync" disabled="@_loading">
            @(_loading ? "Refreshing..." : "Refresh")
        </button>
    </section>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="ops-alert">@_statusMessage</div>
    }

    <section class="metrics-grid">
        <article class="metric-card">
            <span>Targets</span>
            <strong>@FormatNumber(TargetCount)</strong>
        </article>
        <article class="metric-card">
            <span>Confirmed assets</span>
            <strong>@FormatNumber(OverviewLong("totalAssetsConfirmed"))</strong>
        </article>
        <article class="metric-card">
            <span>Subdomains confirmed</span>
            <strong>@FormatNumber(SubdomainsConfirmed)</strong>
        </article>
        <article class="metric-card">
            <span>HTTP queue</span>
            <strong>@FormatNumber(HttpQueueCount)</strong>
        </article>
        <article class="metric-card wide">
            <span>Top domain</span>
            <strong>@TopDomainLabel</strong>
        </article>
    </section>

    <section class="panel">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Scope</p>
                <h2>Targets</h2>
            </div>
            <span class="muted">@FormatNumber(TargetCount) configured targets</span>
        </div>

        <div class="ops-table-wrap compact">
            <table class="ops-table targets-table">
                <thead>
                    <tr>
                        <th>Root domain</th>
                        <th>Max depth</th>
                        <th>Confirmed subdomains</th>
                        <th>Confirmed assets</th>
                        <th>Confirmed URLs</th>
                        <th>Last run</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _targets)
                    {
                        <tr>
                            <td class="clip" title="@Text(t, "rootDomain", "RootDomain")">@Text(t, "rootDomain", "RootDomain")</td>
                            <td>@DisplayOrDash(Text(t, "globalMaxDepth", "GlobalMaxDepth"))</td>
                            <td>@FormatNumber(Long(t, "subdomainCount", "SubdomainCount"))</td>
                            <td>@FormatNumber(Long(t, "confirmedAssetCount", "ConfirmedAssetCount"))</td>
                            <td>@FormatNumber(Long(t, "confirmedUrlCount", "ConfirmedUrlCount"))</td>
                            <td>@FormatTime(Text(t, "lastRunAtUtc", "LastRunAtUtc"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="panel">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Inventory</p>
                <h2>Assets</h2>
            </div>
            <span class="muted">@FormatNumber(FilteredAssetRows.Count) visible assets</span>
        </div>

        <div class="ops-rz-toolbar simple">
            <label class="wide-search">
                <span>Search</span>
                <input type="search" class="ops-filter" @bind="_assetSearch" @bind:event="oninput" placeholder="Search kind, category, final URL, canonical key, pipeline, or discovery context…" />
            </label>
            <button type="button" class="btn" @onclick="ReloadAssetsAsync" disabled="@_assetsLoading">
                @(_assetsLoading ? "Loading..." : "Reload assets")
            </button>
        </div>

        <div class="ops-table-wrap asset-table-wrap">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th>Discovered</th>
                        <th>Last seen</th>
                        <th>Kind</th>
                        <th>Category</th>
                        <th>Confidence</th>
                        <th>Display name</th>
                        <th>Final URL</th>
                        <th>Canonical</th>
                        <th>Pipeline</th>
                        <th>How found</th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize Items="FilteredAssetRows" Context="a" ItemSize="48" OverscanCount="12" SpacerElement="tr">
                        <tr @key="AssetKey(a)">
                            @{
                                var finalUrl = Text(a, "finalUrl", "FinalUrl");
                                var href = TryHttpHref(finalUrl);
                            }
                            <td>@FormatTime(Text(a, "discoveredAtUtc", "DiscoveredAtUtc"))</td>
                            <td>@FormatTime(Text(a, "lastSeenAtUtc", "LastSeenAtUtc"))</td>
                            <td>@Text(a, "kind", "Kind")</td>
                            <td>@Text(a, "category", "Category")</td>
                            <td>@Text(a, "confidence", "Confidence")</td>
                            <td class="clip" title="@Text(a, "displayName", "DisplayName")">@Text(a, "displayName", "DisplayName")</td>
                            <td class="clip" title="@finalUrl">
                                @if (href is null)
                                {
                                    <span>@DisplayOrDash(finalUrl)</span>
                                }
                                else
                                {
                                    <a href="@href" target="_blank" rel="noopener noreferrer">@finalUrl</a>
                                }
                            </td>
                            <td class="clip" title="@Text(a, "canonicalKey", "CanonicalKey")">@Text(a, "canonicalKey", "CanonicalKey")</td>
                            <td>@Text(a, "discoveredBy", "DiscoveredBy")</td>
                            <td class="clip" title="@Text(a, "discoveryContext", "DiscoveryContext")">@Text(a, "discoveryContext", "DiscoveryContext")</td>
                        </tr>
                    </Virtualize>
                </tbody>
            </table>
        </div>
    </section>

    <section class="panel">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Workers</p>
                <h2>@WorkerHealthTitle</h2>
            </div>
            <span class="muted">@WorkerHealthSubtitle</span>
        </div>

        @if (UsingEcsWorkers)
        {
            <div class="worker-health-grid">
                @foreach (var scale in _workerScaleTargets)
                {
                    var workerKey = Text(scale, "workerKey", "WorkerKey", "scaleKey", "ScaleKey");
                    <article class="worker-card">
                        <h3>@DisplayOrDash(workerKey)</h3>
                        <dl>
                            <dt>Desired</dt>
                            <dd>@DisplayOrDash(Text(scale, "desiredCount", "DesiredCount"))</dd>
                            <dt>Running</dt>
                            <dd>@DisplayOrDash(Text(scale, "runningCount", "RunningCount"))</dd>
                            <dt>Pending</dt>
                            <dd>@DisplayOrDash(Text(scale, "pendingCount", "PendingCount"))</dd>
                            <dt>Manual desired</dt>
                            <dd>@DisplayOrDash(Text(scale, "manualDesiredCount", "ManualDesiredCount"))</dd>
                        </dl>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="worker-health-grid">
                @foreach (var worker in _workerSummaries)
                {
                    var workerKey = Text(worker, "workerKey", "WorkerKey");
                    <article class="worker-card">
                        <h3>@DisplayOrDash(workerKey)</h3>
                        <dl>
                            <dt>Enabled</dt>
                            <dd>@DisplayOrDash(Text(worker, "toggleEnabled", "ToggleEnabled"))</dd>
                            <dt>Instances</dt>
                            <dd>@DisplayOrDash(Text(worker, "instanceCount", "InstanceCount"))</dd>
                            <dt>Last activity</dt>
                            <dd>@FormatTime(Text(worker, "lastActivityUtc", "LastActivityUtc"))</dd>
                            <dt>Rollup</dt>
                            <dd>@DisplayOrDash(Text(worker, "rollupActivityLabel", "RollupActivityLabel"))</dd>
                        </dl>
                    </article>
                }
            </div>
        }

        <h3 class="subsection-title">Live worker instances</h3>
        <div class="ops-table-wrap compact">
            <table class="ops-table">
                <thead>
                    <tr>
                        <th>Host</th>
                        <th>Worker</th>
                        <th>Consumer</th>
                        <th>Health</th>
                        <th>Last active</th>
                        <th>Message</th>
                        <th>Duration</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var i in _workerInstances)
                    {
                        <tr>
                            <td>@Text(i, "hostName", "HostName")</td>
                            <td>@Text(i, "workerKind", "WorkerKind")</td>
                            <td>@Text(i, "consumerShortName", "ConsumerShortName")</td>
                            <td>@DisplayOrDash(Text(i, "status", "Status", "activityLabel", "ActivityLabel"))</td>
                            <td>@FormatTime(Text(i, "lastCompletedAtUtc", "LastCompletedAtUtc"))</td>
                            <td class="clip" title="@Text(i, "messageType", "MessageType")">@Text(i, "messageType", "MessageType")</td>
                            <td>@DurationLabel(i)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@code {
    private JsonElement? _overview;
    private readonly List<JsonElement> _targets = [];
    private readonly List<JsonElement> _assets = [];
    private readonly List<JsonElement> _queue = [];
    private readonly List<JsonElement> _workerSummaries = [];
    private readonly List<JsonElement> _workerInstances = [];
    private readonly List<JsonElement> _workerScaleTargets = [];

    private bool _loading;
    private bool _assetsLoading;
    private string _assetSearch = "";
    private string _statusMessage = "";

    private int TargetCount => _targets.Count;
    private int HttpQueueCount => _queue.Count;
    private bool UsingEcsWorkers => _workerScaleTargets.Count > 0;

    private string WorkerHealthTitle => UsingEcsWorkers ? "ECS worker health" : "Local / EC2 worker health";
    private string WorkerHealthSubtitle => UsingEcsWorkers
        ? "ECS service scale targets and live worker activity"
        : "Workers running with the local or EC2 deployment";

    private long SubdomainsConfirmed =>
        _targets.Sum(t => Long(t, "subdomainCount", "SubdomainCount"));

    private string TopDomainLabel
    {
        get
        {
            var top = _targets
                .Select(t => new
                {
                    RootDomain = Text(t, "rootDomain", "RootDomain"),
                    Count = Long(t, "confirmedAssetCount", "ConfirmedAssetCount")
                })
                .Where(t => !string.IsNullOrWhiteSpace(t.RootDomain))
                .OrderByDescending(t => t.Count)
                .ThenBy(t => t.RootDomain, StringComparer.OrdinalIgnoreCase)
                .FirstOrDefault();

            return top is null ? "-" : $"{top.RootDomain} ({FormatNumber(top.Count)} confirmed assets)";
        }
    }

    private IReadOnlyList<JsonElement> FilteredAssetRows => string.IsNullOrWhiteSpace(_assetSearch)
        ? _assets
        : _assets.Where(a => Matches(a, _assetSearch)).ToArray();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAllAsync();
    }

    private async Task ReloadAllAsync()
    {
        _loading = true;
        _statusMessage = "";

        try
        {
            await Task.WhenAll(
                ReloadOverviewAsync(),
                ReloadTargetsAsync(),
                ReloadAssetsAsync(),
                ReloadHttpQueueAsync(),
                ReloadWorkersAsync(),
                ReloadWorkerScaleAsync());
        }
        catch (Exception ex)
        {
            _statusMessage = $"Operations refresh failed: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReloadOverviewAsync()
    {
        try
        {
            _overview = await GetObjectAsync("/api/ops/overview");
        }
        catch
        {
            _overview = null;
        }
    }

    private async Task ReloadTargetsAsync()
    {
        Replace(_targets, await GetArrayAsync("/api/targets"));
    }

    private async Task ReloadAssetsAsync()
    {
        _assetsLoading = true;

        try
        {
            Replace(_assets, await GetArrayAsync("/api/assets"));
        }
        finally
        {
            _assetsLoading = false;
        }
    }

    private async Task ReloadHttpQueueAsync()
    {
        Replace(_queue, await GetArrayAsync("/api/http-request-queue?state=Queued"));
    }

    private async Task ReloadWorkersAsync()
    {
        try
        {
            var activity = await GetObjectAsync("/api/workers/activity");
            if (activity is JsonElement root)
            {
                Replace(_workerSummaries, ArrayProperty(root, "workerSummaries", "WorkerSummaries"));
                Replace(_workerInstances, ArrayProperty(root, "instances", "Instances"));
                return;
            }
        }
        catch
        {
            // Fall back to worker switches below.
        }

        try
        {
            Replace(_workerSummaries, await GetArrayAsync("/api/workers"));
        }
        catch
        {
            _workerSummaries.Clear();
        }
    }

    private async Task ReloadWorkerScaleAsync()
    {
        try
        {
            Replace(_workerScaleTargets, await GetArrayAsync("/api/workers/scale"));
        }
        catch
        {
            _workerScaleTargets.Clear();
        }
    }

    private long OverviewLong(params string[] names)
    {
        if (_overview is null)
        {
            return 0;
        }

        return Long(_overview.Value, names);
    }

    private static void Replace(List<JsonElement> target, IEnumerable<JsonElement> values)
    {
        target.Clear();
        target.AddRange(values.Select(v => v.Clone()));
    }

    private async Task<JsonElement?> GetObjectAsync(string uri)
    {
        using var response = await Http.GetAsync(uri);
        if (!response.IsSuccessStatusCode)
        {
            return null;
        }

        var json = await response.Content.ReadAsStringAsync();
        using var doc = JsonDocument.Parse(json);

        return doc.RootElement.ValueKind == JsonValueKind.Object
            ? doc.RootElement.Clone()
            : null;
    }

    private async Task<List<JsonElement>> GetArrayAsync(string uri)
    {
        using var response = await Http.GetAsync(uri);
        if (!response.IsSuccessStatusCode)
        {
            return [];
        }

        var json = await response.Content.ReadAsStringAsync();
        using var doc = JsonDocument.Parse(json);

        return doc.RootElement.ValueKind == JsonValueKind.Array
            ? doc.RootElement.EnumerateArray().Select(x => x.Clone()).ToList()
            : [];
    }

    private static IEnumerable<JsonElement> ArrayProperty(JsonElement element, params string[] names)
    {
        var property = Property(element, names);

        return property is { ValueKind: JsonValueKind.Array }
            ? property.Value.EnumerateArray().Select(x => x.Clone()).ToArray()
            : [];
    }

    private static JsonElement? Property(JsonElement element, params string[] names)
    {
        if (element.ValueKind != JsonValueKind.Object)
        {
            return null;
        }

        foreach (var name in names)
        {
            if (element.TryGetProperty(name, out var value))
            {
                return value;
            }

            var camel = char.ToLowerInvariant(name[0]) + name[1..];
            if (element.TryGetProperty(camel, out value))
            {
                return value;
            }

            var pascal = char.ToUpperInvariant(name[0]) + name[1..];
            if (element.TryGetProperty(pascal, out value))
            {
                return value;
            }
        }

        return null;
    }

    private static string Text(JsonElement element, params string[] names)
    {
        var value = Property(element, names);

        if (value is null)
        {
            return "";
        }

        return value.Value.ValueKind switch
        {
            JsonValueKind.String => value.Value.GetString() ?? "",
            JsonValueKind.Number => value.Value.ToString(),
            JsonValueKind.True => "true",
            JsonValueKind.False => "false",
            JsonValueKind.Null => "",
            _ => value.Value.ToString()
        };
    }

    private static long Long(JsonElement element, params string[] names)
    {
        var value = Property(element, names);
        if (value is null)
        {
            return 0;
        }

        if (value.Value.ValueKind == JsonValueKind.Number && value.Value.TryGetInt64(out var number))
        {
            return number;
        }

        return long.TryParse(Text(element, names), NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : 0;
    }

    private static bool Matches(JsonElement element, string search)
    {
        var terms = new[]
        {
            Text(element, "kind", "Kind"),
            Text(element, "category", "Category"),
            Text(element, "displayName", "DisplayName"),
            Text(element, "finalUrl", "FinalUrl"),
            Text(element, "canonicalKey", "CanonicalKey"),
            Text(element, "discoveredBy", "DiscoveredBy"),
            Text(element, "discoveryContext", "DiscoveryContext")
        };

        return terms.Any(value => value.Contains(search, StringComparison.OrdinalIgnoreCase));
    }

    private static string FormatNumber(long value) =>
        value.ToString("N0", CultureInfo.InvariantCulture);

    private static string DisplayOrDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatTime(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        return DateTimeOffset.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var parsed)
            ? parsed.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)
            : value;
    }

    private static string? TryHttpHref(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return Uri.TryCreate(value.Trim(), UriKind.Absolute, out var uri) && uri.Scheme is "http" or "https"
            ? uri.ToString()
            : null;
    }

    private static string DurationLabel(JsonElement element)
    {
        var value = Text(element, "durationMs", "DurationMs");
        return string.IsNullOrWhiteSpace(value) ? "-" : $"{value}ms";
    }

    private static string AssetKey(JsonElement element) =>
        DisplayOrDash(Text(element, "id", "Id", "canonicalKey", "CanonicalKey", "finalUrl", "FinalUrl"));
}
