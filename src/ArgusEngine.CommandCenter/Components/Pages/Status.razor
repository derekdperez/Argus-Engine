@using ArgusEngine.CommandCenter.Models
@using ArgusEngine.CommandCenter
@page "/status"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using ArgusEngine.CommandCenter.Realtime
@inject HttpClient Http
@inject DiscoveryRealtimeClient Realtime
@implements IDisposable

<PageTitle>System Status - Nightmare v2</PageTitle>

<h1>System Status</h1>

<div class="toolbar">
    @if (_snapshot is not null)
    {
        <span class="muted">Updated @AppTimeFormat.Format(_snapshot.AtUtc)</span>
        <span class="badge @ToBadgeClass(_snapshot.Color)">@_snapshot.Status</span>
    }
    @if (_ecsSnapshot is not null)
    {
        <span class="badge @ToBadgeClass(_ecsSnapshot.Color)">ECS @_ecsSnapshot.Status</span>
    }
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <p class="error">@_error</p>
}

@if (_loading && _snapshot is null)
{
    <p>Loading status...</p>
}
else if (_snapshot is null)
{
    <p>Status unavailable.</p>
}
else
{
    <section class="panel">
        <h2>Components</h2>
        <table>
            <thead>
            <tr>
                <th>Component</th>
                <th>Version</th>
                <th>First Released</th>
                <th>Status</th>
                <th>Reason</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var c in _snapshot.Components)
            {
                <tr>
                    <td>@c.DisplayName</td>
                    <td class="mono">@c.Version</td>
                    <td>@AppTimeFormat.Format(c.FirstReleasedAtUtc)</td>
                    <td><span class="badge @ToBadgeClass(c.Color)">@c.Status</span></td>
                    <td>@c.Reason</td>
                </tr>
            }
            </tbody>
        </table>
    </section>

    <section class="panel">
        <h2>Images</h2>
        <table>
            <thead>
            <tr>
                <th>Image</th>
                <th>Version</th>
                <th>First Released</th>
                <th>Containers</th>
                <th>Healthy</th>
                <th>Degraded</th>
                <th>Critical</th>
                <th>Status</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var image in _snapshot.Images)
            {
                <tr>
                    <td class="mono">@image.Image</td>
                    <td class="mono">@image.Version</td>
                    <td>@AppTimeFormat.Format(image.FirstReleasedAtUtc)</td>
                    <td>@image.ContainerCount</td>
                    <td>@image.HealthyContainers</td>
                    <td>@image.DegradedContainers</td>
                    <td>@image.CriticalContainers</td>
                    <td><span class="badge @ToBadgeClass(image.Color)">@image.Status</span></td>
                </tr>
            }
            </tbody>
        </table>
    </section>

    <section class="panel">
        <h2>ECS Services</h2>
        @if (_ecsSnapshot is null)
        {
            <p class="muted">Loading ECS state...</p>
        }
        else if (!_ecsSnapshot.EcsAvailable)
        {
            <p class="muted">@_ecsSnapshot.Error</p>
        }
        else
        {
            <table>
                <thead>
                <tr>
                    <th>Worker</th>
                    <th>Service</th>
                    <th>Version</th>
                    <th>First Released</th>
                    <th>Desired</th>
                    <th>Running</th>
                    <th>Pending</th>
                    <th>Status</th>
                    <th>Deployment</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var service in _ecsSnapshot.Services)
                {
                    <tr>
                        <td>@service.WorkerKey</td>
                        <td class="mono">@service.ServiceName</td>
                        <td class="mono">@service.Version</td>
                        <td>@AppTimeFormat.Format(service.FirstReleasedAtUtc)</td>
                        <td>@service.DesiredCount</td>
                        <td>@service.RunningCount</td>
                        <td>@service.PendingCount</td>
                        <td><span class="badge @ToBadgeClass(service.Color)">@service.ServiceStatus</span></td>
                        <td>@service.DeploymentStatus</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>

    <section class="panel">
        <h2>Containers + Last 300 Log Lines</h2>
        @foreach (var container in _snapshot.Containers)
        {
            <details>
                <summary>
                    <span class="badge @ToBadgeClass(container.Color)">@container.Status</span>
                    <strong>@container.Name</strong>
                    <span class="muted">@container.Image</span>
                    <span class="muted">version: @container.Version</span>
                    <span class="muted">docker: @container.DockerStatusText</span>
                    <span class="muted">health: @container.HealthCheckStatus</span>
                </summary>
                <pre>@string.Join(Environment.NewLine, container.LogTail)</pre>
            </details>
        }
    </section>
}

@code {
    private DockerRuntimeStatusDto? _snapshot;
    private EcsRuntimeStatusDto? _ecsSnapshot;
    private string _error = string.Empty;
    private bool _initialLoadStarted;
    private bool _loading = true;
    private readonly CancellationTokenSource _pollCts = new();

    protected override Task OnInitializedAsync()
    {
        Realtime.DomainEventReceived += OnRealtimeEvent;
        return Task.CompletedTask;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialLoadStarted)
        {
            _initialLoadStarted = true;
            _ = InvokeAsync(LoadInitialAsync);
        }

        return Task.CompletedTask;
    }

    private async Task LoadInitialAsync()
    {
        await ReloadAsync().ConfigureAwait(false);
        await StartRealtimeAsync().ConfigureAwait(false);
        _ = PollAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task StartRealtimeAsync()
    {
        try
        {
            await Realtime.EnsureStartedAsync(_pollCts.Token).ConfigureAwait(false);
        }
        catch
        {
            // Status remains available via manual refresh and fallback refresh.
        }
    }

    private void OnRealtimeEvent(object? sender, LiveUiEventDto evt)
    {
        if (evt.Scope is not ("workers" or "http" or "assets"))
            return;

        _ = InvokeAsync(async () =>
        {
            await ReloadAsync();
            StateHasChanged();
        });
    }

    private async Task PollAsync()
    {
        try
        {
            while (!_pollCts.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(30), _pollCts.Token).ConfigureAwait(false);
                if (Realtime.IsConnected)
                    continue;

                await ReloadAsync().ConfigureAwait(false);
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
            // shutdown
        }
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = string.Empty;
        try
        {
            _snapshot = await Http.GetFromJsonAsync<DockerRuntimeStatusDto>("/api/ops/docker-status").ConfigureAwait(false);
            _ecsSnapshot = await Http.GetFromJsonAsync<EcsRuntimeStatusDto>("/api/ops/ecs-status").ConfigureAwait(false);
            if (_snapshot is null)
                _error = "Status payload was empty.";
            else if (!string.IsNullOrWhiteSpace(_snapshot.Error))
                _error = _snapshot.Error;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string ToBadgeClass(string color) =>
        color.ToLowerInvariant() switch
        {
            "green" => "badge-green",
            "yellow" => "badge-yellow",
            "red" => "badge-red",
            _ => "badge-gray",
        };

    public void Dispose()
    {
        Realtime.DomainEventReceived -= OnRealtimeEvent;
        _pollCts.Cancel();
        _pollCts.Dispose();
    }
}
