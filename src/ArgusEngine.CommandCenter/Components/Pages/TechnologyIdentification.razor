@page "/technology-identification"
@rendermode InteractiveServer

@using System.Globalization
@using System.Net.Http.Json
@using ArgusEngine.CommandCenter.Models
@using Microsoft.AspNetCore.Components.Web.Virtualization
@inject HttpClient Http

<PageTitle>Technology Identification - Argus Engine</PageTitle>

<div class="page-shell ops-page ops-page-lite tech-id-page">
    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="ops-alert">@_statusMessage</div>
    }

    <section class="metrics-grid tech-id-summary">
        <article class="metric-card">
            <span>Targets</span>
            <strong>@FormatNumber(FilteredTargets.Count)</strong>
        </article>
        <article class="metric-card">
            <span>Subdomains</span>
            <strong>@FormatNumber(FilteredSubdomains.Count)</strong>
        </article>
        <article class="metric-card">
            <span>Technologies</span>
            <strong>@FormatNumber(TechnologyCount)</strong>
        </article>
        <article class="metric-card">
            <span>Observations</span>
            <strong>@FormatNumber(FilteredTechnologies.Count)</strong>
        </article>
    </section>

    <section class="ops-scope-grid tech-id-scope">
        <section class="panel tech-id-panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Inventory</p>
                    <h2>Targets</h2>
                    @if (_targetsLoading)
                    {
                        <span class="loading-inline"><span class="spinner"></span> Loading...</span>
                    }
                </div>
                <button type="button" class="btn" @onclick="ReloadAsync" disabled="@_loading">@(_loading ? "Loading..." : "Reload")</button>
            </div>

            <div class="ops-rz-toolbar simple dense-toolbar">
                <label class="wide-search">
                    <span>Search</span>
                    <input type="search" class="ops-filter" @bind="_targetSearch" @bind:event="oninput" placeholder="Search targets..." />
                </label>
                <label>
                    <span>Filter</span>
                    <select class="ops-filter compact-filter" @bind="_targetFilter">
                        <option value="">All</option>
                        <option value="with-tech">With technologies</option>
                        <option value="without-tech">Without technologies</option>
                    </select>
                </label>
            </div>

            <div class="ops-table-wrap tech-id-table-wrap">
                <table class="ops-table tech-id-targets-table">
                    <thead>
                        <tr>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetTargetSort("target"))">Target</button></th>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetTargetSort("subs"))">Subs</button></th>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetTargetSort("tech"))">Tech</button></th>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetTargetSort("seen"))">Last seen</button></th>
                        </tr>
                    </thead>
                    <tbody>
                        <Virtualize TItem="TechnologyIdentificationTargetDto" Items="FilteredTargets" Context="target" ItemSize="28" OverscanCount="18" SpacerElement="tr">
                            <tr class="selectable-row @(IsSelectedTarget(target.TargetId) ? "selected" : "")" @onclick="@(() => SelectTargetAsync(target.TargetId))">
                                <td class="clip" title="@target.TargetRootDomain">@target.TargetRootDomain</td>
                                <td>@FormatNumber(target.SubdomainCount)</td>
                                <td>@FormatNumber(target.TechnologyCount)</td>
                                <td>@FormatTime(target.LastObservedAtUtc)</td>
                            </tr>
                        </Virtualize>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="panel tech-id-panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Inventory</p>
                    <h2>Subdomains</h2>
                    @if (_subdomainsLoading)
                    {
                        <span class="loading-inline"><span class="spinner"></span> Loading...</span>
                    }
                </div>
                @if (_selectedTargetId is not null)
                {
                    <button type="button" class="btn ghost" @onclick="ClearTargetAsync">All targets</button>
                }
            </div>

            <div class="ops-rz-toolbar simple dense-toolbar">
                <label class="wide-search">
                    <span>Search</span>
                    <input type="search" class="ops-filter" @bind="_subdomainSearch" @bind:event="oninput" placeholder="Search subdomains..." />
                </label>
                <label>
                    <span>Filter</span>
                    <select class="ops-filter compact-filter" @bind="_subdomainFilter">
                        <option value="">All</option>
                        <option value="with-tech">With technologies</option>
                        <option value="without-tech">Without technologies</option>
                    </select>
                </label>
            </div>

            <div class="ops-table-wrap tech-id-table-wrap">
                <table class="ops-table tech-id-subdomains-table">
                    <thead>
                        <tr>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetSubdomainSort("subdomain"))">Subdomain</button></th>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetSubdomainSort("tech"))">Tech</button></th>
                            <th><button type="button" class="sort-header" @onclick="@(() => SetSubdomainSort("seen"))">Last seen</button></th>
                        </tr>
                    </thead>
                    <tbody>
                        <Virtualize TItem="TechnologyIdentificationSubdomainDto" Items="FilteredSubdomains" Context="subdomain" ItemSize="28" OverscanCount="18" SpacerElement="tr">
                            <tr class="selectable-row @(IsSelectedSubdomain(subdomain.Subdomain) ? "selected" : "")" @onclick="@(() => SelectSubdomainAsync(subdomain.Subdomain))">
                                <td class="clip" title="@subdomain.Subdomain">@subdomain.Subdomain</td>
                                <td>@FormatNumber(subdomain.TechnologyCount)</td>
                                <td>@FormatTime(subdomain.LastObservedAtUtc)</td>
                            </tr>
                        </Virtualize>
                    </tbody>
                </table>
            </div>
        </section>
    </section>

    <section class="panel">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Detection</p>
                <h2>Technologies</h2>
                @if (_technologiesLoading)
                {
                    <span class="loading-inline"><span class="spinner"></span> Loading...</span>
                }
            </div>
            <span class="muted">@ScopeLabel</span>
        </div>

        <div class="ops-rz-toolbar simple">
            <label class="wide-search">
                <span>Search</span>
                <input type="search" class="ops-filter" @bind="_technologySearch" @bind:event="oninput" placeholder="Search technologies, evidence, source..." />
            </label>
            <label>
                <span>Source</span>
                <select class="ops-filter compact-filter" @bind="_technologySourceFilter">
                    <option value="">All</option>
                    <option value="observation">Observations</option>
                </select>
            </label>
            @if (_selectedSubdomain is not null)
            {
                <button type="button" class="btn ghost" @onclick="ClearSubdomainAsync">Clear subdomain</button>
            }
        </div>

        <div class="ops-table-wrap tech-id-tech-table-wrap">
            <table class="ops-table tech-id-tech-table">
                <thead>
                    <tr>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetTechnologySort("seen"))">Last seen</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetTechnologySort("target"))">Target</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetTechnologySort("subdomain"))">Subdomain</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetTechnologySort("technology"))">Technology</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetTechnologySort("version"))">Version</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetTechnologySort("confidence"))">Confidence</button></th>
                        <th><button type="button" class="sort-header" @onclick="@(() => SetTechnologySort("source"))">Source</button></th>
                        <th>Evidence</th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize TItem="TechnologyIdentificationRowDto" Items="FilteredTechnologies" Context="row" ItemSize="28" OverscanCount="20" SpacerElement="tr">
                        <tr>
                            <td>@FormatTime(row.LastSeenUtc)</td>
                            <td class="clip" title="@row.TargetRootDomain">@row.TargetRootDomain</td>
                            <td class="clip" title="@row.Subdomain">@row.Subdomain</td>
                            <td class="clip strong" title="@TechnologyTitle(row)">@row.TechnologyName</td>
                            <td class="clip" title="@row.Version">@DisplayOrDash(row.Version)</td>
                            <td>@row.Confidence.ToString("P0", CultureInfo.InvariantCulture)</td>
                            <td>@DisplaySource(row)</td>
                            <td class="clip" title="@row.EvidenceSummary">@DisplayOrDash(row.EvidenceSummary)</td>
                        </tr>
                    </Virtualize>
                </tbody>
            </table>
        </div>
    </section>
</div>

@code {
    private readonly List<TechnologyIdentificationTargetDto> _targets = [];
    private readonly List<TechnologyIdentificationSubdomainDto> _subdomains = [];
    private readonly List<TechnologyIdentificationRowDto> _technologies = [];

    private bool _targetsLoading;
    private bool _subdomainsLoading;
    private bool _technologiesLoading;
    private bool _anyLoading => _targetsLoading || _subdomainsLoading || _technologiesLoading;
    private string? _statusMessage;
    private Guid? _selectedTargetId;
    private string? _selectedSubdomain;

    private string _targetSearch = "";
    private string _targetFilter = "";
    private string _targetSort = "target";
    private bool _targetSortDescending;

    private string _subdomainSearch = "";
    private string _subdomainFilter = "";
    private string _subdomainSort = "subdomain";
    private bool _subdomainSortDescending;

    private string _technologySearch = "";
    private string _technologySourceFilter = "";
    private string _technologySort = "seen";
    private bool _technologySortDescending = true;

    private List<TechnologyIdentificationTargetDto> FilteredTargets => SortTargets(_targets
        .Where(t => Matches(t.TargetRootDomain, _targetSearch))
        .Where(t => _targetFilter switch
        {
            "with-tech" => t.TechnologyCount > 0,
            "without-tech" => t.TechnologyCount == 0,
            _ => true,
        })).ToList();

    private List<TechnologyIdentificationSubdomainDto> FilteredSubdomains => SortSubdomains(_subdomains
        .Where(s => Matches(s.Subdomain, _subdomainSearch))
        .Where(s => _subdomainFilter switch
        {
            "with-tech" => s.TechnologyCount > 0,
            "without-tech" => s.TechnologyCount == 0,
            _ => true,
        })).ToList();

    private List<TechnologyIdentificationRowDto> FilteredTechnologies => SortTechnologies(_technologies
        .Where(t => MatchesTechnology(t, _technologySearch))
        .Where(t => string.IsNullOrWhiteSpace(_technologySourceFilter)
            || string.Equals(t.DataSource, _technologySourceFilter, StringComparison.OrdinalIgnoreCase)))
        .ToList();

    private long TechnologyCount => FilteredTechnologies
        .Select(t => string.IsNullOrWhiteSpace(t.Version) ? t.TechnologyName : $"{t.TechnologyName}|{t.Version}")
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .LongCount();

    private string ScopeLabel
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(_selectedSubdomain))
                return _selectedSubdomain;

            if (_selectedTargetId is { } targetId)
                return _targets.FirstOrDefault(t => t.TargetId == targetId)?.TargetRootDomain ?? "Selected target";

            return "All targets";
        }
    }

    private bool _initialLoadStarted;

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialLoadStarted)
        {
            _initialLoadStarted = true;
            _ = InvokeAsync(async () =>
            {
                await ReloadAsync().ConfigureAwait(false);
                StateHasChanged();
            });
        }

        return Task.CompletedTask;
    }

    private async Task ReloadAsync()
    {
        _statusMessage = null;
        await Task.WhenAll(ReloadTargetsAsync(), ReloadSubdomainsAsync(), ReloadTechnologiesAsync());
    }

    private async Task SelectTargetAsync(Guid targetId)
    {
        _selectedTargetId = targetId;
        _selectedSubdomain = null;
        _subdomainSearch = "";
        await ReloadSubdomainsAsync();
        await ReloadTechnologiesAsync();
    }

    private async Task ClearTargetAsync()
    {
        _selectedTargetId = null;
        _selectedSubdomain = null;
        await ReloadSubdomainsAsync();
        await ReloadTechnologiesAsync();
    }

    private async Task SelectSubdomainAsync(string subdomain)
    {
        _selectedSubdomain = subdomain;
        await ReloadTechnologiesAsync();
    }

    private async Task ClearSubdomainAsync()
    {
        _selectedSubdomain = null;
        await ReloadTechnologiesAsync();
    }

    private async Task ReloadTargetsAsync()
    {
        _targetsLoading = true;
        try
        {
            var targets = await Http.GetFromJsonAsync<List<TechnologyIdentificationTargetDto>>("/api/technology-identification/targets");
            _targets.Clear();
            if (targets is not null) _targets.AddRange(targets);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Failed to load targets: {ex.Message}";
        }
        finally
        {
            _targetsLoading = false;
        }
    }

    private async Task ReloadSubdomainsAsync()
    {
        _subdomainsLoading = true;
        try
        {
            var url = _selectedTargetId is { } targetId
                ? $"/api/technology-identification/subdomains?targetId={targetId}"
                : "/api/technology-identification/subdomains";

            var rows = await Http.GetFromJsonAsync<List<TechnologyIdentificationSubdomainDto>>(url);
            _subdomains.Clear();
            if (rows is not null)
                _subdomains.AddRange(rows);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Failed to load subdomains: {ex.Message}";
        }
        finally
        {
            _subdomainsLoading = false;
        }
    }

    private async Task ReloadTechnologiesAsync()
    {
        _technologiesLoading = true;
        try
        {
            var qs = BuildTechnologyQuery();
            var techs = await Http.GetFromJsonAsync<List<TechnologyIdentificationRowDto>>($"/api/technology-identification/technologies{qs}");
            _technologies.Clear();
            if (techs is not null) _technologies.AddRange(techs);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Failed to load technologies: {ex.Message}";
        }
        finally
        {
            _technologiesLoading = false;
        }
    }

    private string BuildTechnologyQuery()
    {
        var query = new List<string>();
        if (_selectedTargetId is { } targetId)
            query.Add($"targetId={targetId}");
        if (!string.IsNullOrWhiteSpace(_selectedSubdomain))
            query.Add($"subdomain={Uri.EscapeDataString(_selectedSubdomain)}");

        return query.Count > 0 ? "?" + string.Join("&", query) : "";
    }

    private void SetTargetSort(string key)
    {
        if (_targetSort == key)
            _targetSortDescending = !_targetSortDescending;
        else
        {
            _targetSort = key;
            _targetSortDescending = key is "tech" or "subs" or "seen";
        }
    }

    private void SetSubdomainSort(string key)
    {
        if (_subdomainSort == key)
            _subdomainSortDescending = !_subdomainSortDescending;
        else
        {
            _subdomainSort = key;
            _subdomainSortDescending = key is "tech" or "seen";
        }
    }

    private void SetTechnologySort(string key)
    {
        if (_technologySort == key)
            _technologySortDescending = !_technologySortDescending;
        else
        {
            _technologySort = key;
            _technologySortDescending = key is "seen" or "confidence";
        }
    }

    private IEnumerable<TechnologyIdentificationTargetDto> SortTargets(IEnumerable<TechnologyIdentificationTargetDto> rows) =>
        (_targetSort, _targetSortDescending) switch
        {
            ("subs", true) => rows.OrderByDescending(x => x.SubdomainCount),
            ("subs", false) => rows.OrderBy(x => x.SubdomainCount),
            ("tech", true) => rows.OrderByDescending(x => x.TechnologyCount),
            ("tech", false) => rows.OrderBy(x => x.TechnologyCount),
            ("seen", true) => rows.OrderByDescending(x => x.LastObservedAtUtc),
            ("seen", false) => rows.OrderBy(x => x.LastObservedAtUtc),
            ("target", true) => rows.OrderByDescending(x => x.TargetRootDomain, StringComparer.OrdinalIgnoreCase),
            _ => rows.OrderBy(x => x.TargetRootDomain, StringComparer.OrdinalIgnoreCase),
        };

    private IEnumerable<TechnologyIdentificationSubdomainDto> SortSubdomains(IEnumerable<TechnologyIdentificationSubdomainDto> rows) =>
        (_subdomainSort, _subdomainSortDescending) switch
        {
            ("tech", true) => rows.OrderByDescending(x => x.TechnologyCount),
            ("tech", false) => rows.OrderBy(x => x.TechnologyCount),
            ("seen", true) => rows.OrderByDescending(x => x.LastObservedAtUtc),
            ("seen", false) => rows.OrderBy(x => x.LastObservedAtUtc),
            ("subdomain", true) => rows.OrderByDescending(x => x.Subdomain, StringComparer.OrdinalIgnoreCase),
            _ => rows.OrderBy(x => x.Subdomain, StringComparer.OrdinalIgnoreCase),
        };

    private IEnumerable<TechnologyIdentificationRowDto> SortTechnologies(IEnumerable<TechnologyIdentificationRowDto> rows) =>
        (_technologySort, _technologySortDescending) switch
        {
            ("target", true) => rows.OrderByDescending(x => x.TargetRootDomain, StringComparer.OrdinalIgnoreCase),
            ("target", false) => rows.OrderBy(x => x.TargetRootDomain, StringComparer.OrdinalIgnoreCase),
            ("subdomain", true) => rows.OrderByDescending(x => x.Subdomain, StringComparer.OrdinalIgnoreCase),
            ("subdomain", false) => rows.OrderBy(x => x.Subdomain, StringComparer.OrdinalIgnoreCase),
            ("technology", true) => rows.OrderByDescending(x => x.TechnologyName, StringComparer.OrdinalIgnoreCase),
            ("technology", false) => rows.OrderBy(x => x.TechnologyName, StringComparer.OrdinalIgnoreCase),
            ("version", true) => rows.OrderByDescending(x => x.Version, StringComparer.OrdinalIgnoreCase),
            ("version", false) => rows.OrderBy(x => x.Version, StringComparer.OrdinalIgnoreCase),
            ("confidence", true) => rows.OrderByDescending(x => x.Confidence),
            ("confidence", false) => rows.OrderBy(x => x.Confidence),
            ("source", true) => rows.OrderByDescending(x => x.SourceType, StringComparer.OrdinalIgnoreCase),
            ("source", false) => rows.OrderBy(x => x.SourceType, StringComparer.OrdinalIgnoreCase),
            ("seen", false) => rows.OrderBy(x => x.LastSeenUtc),
            _ => rows.OrderByDescending(x => x.LastSeenUtc),
        };

    private bool IsSelectedTarget(Guid targetId) => _selectedTargetId == targetId;

    private bool IsSelectedSubdomain(string subdomain) =>
        string.Equals(_selectedSubdomain, subdomain, StringComparison.OrdinalIgnoreCase);

    private static bool MatchesTechnology(TechnologyIdentificationRowDto row, string search) =>
        string.IsNullOrWhiteSpace(search)
        || Matches(row.TargetRootDomain, search)
        || Matches(row.Subdomain, search)
        || Matches(row.AssetCanonicalKey, search)
        || Matches(row.TechnologyName, search)
        || Matches(row.Vendor, search)
        || Matches(row.Product, search)
        || Matches(row.Version, search)
        || Matches(row.SourceType, search)
        || Matches(row.DetectionMode, search)
        || Matches(row.FingerprintId, search)
        || Matches(row.EvidenceSummary, search);

    private static bool Matches(string? value, string? search) =>
        string.IsNullOrWhiteSpace(search)
        || (!string.IsNullOrWhiteSpace(value) && value.Contains(search.Trim(), StringComparison.OrdinalIgnoreCase));

    private static string FormatNumber(long value) => value.ToString("N0", CultureInfo.InvariantCulture);

    private static string FormatTime(DateTimeOffset? value) =>
        value is null ? "-" : value.Value.ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture);

    private static string DisplayOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string TechnologyTitle(TechnologyIdentificationRowDto row)
    {
        var vendor = string.IsNullOrWhiteSpace(row.Vendor) ? null : row.Vendor;
        var product = string.IsNullOrWhiteSpace(row.Product) ? null : row.Product;
        return string.Join(" / ", new[] { vendor, product, row.FingerprintId }.Where(x => !string.IsNullOrWhiteSpace(x)));
    }

    private static string DisplaySource(TechnologyIdentificationRowDto row) =>
        row.DetectionMode;
}
