{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=argus_engine;Username=argus;Password=argus",
    "Redis": "localhost:6379"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Username": "argus",
    "Password": "argus",
    "VirtualHost": "/"
  },
  "Argus": {
    "SkipStartupDatabase": true,
    "SubdomainEnumeration": {
      "Enabled": true,
      "Subfinder": {
        "Enabled": true,
        "BinaryPath": "subfinder"
      },
      "Amass": {
        "Enabled": true,
        "BinaryPath": "amass",
        "WordlistPath": "wordlists/subdomains-top1mil-5000.txt"
      }
    },
    "Spider": {
      "MaxConcurrency": 10,
      "PollIntervalSeconds": 2
    }
  }
}
