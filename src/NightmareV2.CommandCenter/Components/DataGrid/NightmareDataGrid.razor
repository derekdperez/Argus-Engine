@typeparam TGridItem
@using Microsoft.AspNetCore.Components.QuickGrid
@using NightmareV2.CommandCenter

<div @attributes="AdditionalAttributes"
     class="nightmare-dg @DensityCssClass @CssClass"
     aria-busy="@IsLoading"
     data-grid-key="@PersistKey">
    @if (ToolbarVisible)
    {
        <div class="nightmare-dg-toolbar">
            <div class="nightmare-dg-toolbar-main">
                @if (ShowSearch)
                {
                    <label class="nightmare-dg-search-wrap">
                        <span class="sr-only">@SearchPlaceholder</span>
                        <input type="search"
                               class="nightmare-dg-search ops-filter"
                               placeholder="@SearchPlaceholder"
                               value="@_searchInputText"
                               @oninput="OnSearchInput" />
                    </label>
                }

                @if (ShowPageSizePicker && CanPage)
                {
                    <label class="nightmare-dg-page-size">
                        <span>Rows</span>
                        <select value="@ActivePagination.ItemsPerPage" @onchange="OnPageSizeChanged">
                            @foreach (var option in NormalizedPageSizeOptions)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                    </label>
                }

                @if (ShowDensityPicker)
                {
                    <label class="nightmare-dg-page-size">
                        <span>Density</span>
                        <select value="@Density.ToString()" @onchange="OnDensityChanged">
                            <option value="@nameof(NightmareDataGridDensity.Compact)">Compact</option>
                            <option value="@nameof(NightmareDataGridDensity.Comfortable)">Comfortable</option>
                            <option value="@nameof(NightmareDataGridDensity.Relaxed)">Relaxed</option>
                        </select>
                    </label>
                }

                @ToolbarTemplate

                @if (HasConfiguration)
                {
                    <details class="nightmare-dg-config">
                        <summary>
                            Configure
                            @if (ActiveFilterCount > 0)
                            {
                                <span class="nightmare-dg-badge">@ActiveFilterCount</span>
                            }
                        </summary>
                        <div class="nightmare-dg-config-body">
                            @ConfigurationTemplate
                        </div>
                    </details>
                }

                @if (ShowClearFiltersButton && (HasAnyActiveFilter || ClearFiltersRequested.HasDelegate))
                {
                    <button type="button" class="btn ghost small" @onclick="ClearAllFiltersAsync" disabled="@IsLoading">
                        Reset filters
                    </button>
                }
            </div>

            <div class="nightmare-dg-toolbar-actions">
                @if (LastUpdatedUtc is not null)
                {
                    <span class="nightmare-dg-updated muted small">Updated @AppTimeFormat.Format(LastUpdatedUtc)</span>
                }

                @if (EnableCsvExport)
                {
                    <button type="button" class="btn small" @onclick="ExportCsvAsync" disabled="@(_visibleRowCount == 0 || IsLoading)">
                        Export CSV
                    </button>
                }

                @if (CanPage)
                {
                    <div class="nightmare-dg-pager">
                        <Paginator State="ActivePagination" />
                    </div>
                }
            </div>
        </div>
    }

    @if (ShowRowCount)
    {
        <div class="nightmare-dg-rowcount muted small" aria-live="polite">
            @if (_searchInputText != SearchText)
            {
                <span>Filtering…</span>
            }
            else if (_visibleRowCount == _totalRowCount)
            {
                <span>@_visibleRowCount.ToString("N0") rows</span>
            }
            else
            {
                <span>@_visibleRowCount.ToString("N0") of @_totalRowCount.ToString("N0") rows</span>
            }

            @if (HasAnyActiveFilter)
            {
                <span class="nightmare-dg-mode">@EffectiveActiveFilterCount active filter@(EffectiveActiveFilterCount == 1 ? "" : "s")</span>
            }
            @if (EffectiveVirtualize)
            {
                <span class="nightmare-dg-mode">virtualized</span>
            }
            else if (Pagination is not null && GroupKeySelector is null)
            {
                <span class="nightmare-dg-mode">paged</span>
            }
            @if (GroupKeySelector is not null)
            {
                <span class="nightmare-dg-mode">grouped</span>
            }
            @if (EnableCsvExport && _visibleRowCount > MaxExportRows)
            {
                <span class="nightmare-dg-mode">export caps at @MaxExportRows.ToString("N0")</span>
            }
        </div>
    }

    @if (IsLoading)
    {
        <div class="nightmare-dg-loading" role="status">
            @if (LoadingTemplate is null)
            {
                <span class="nightmare-dg-spinner" aria-hidden="true"></span>
                <span>@LoadingText</span>
            }
            else
            {
                @LoadingTemplate
            }
        </div>
    }

    @if (_visibleRowCount == 0 && !IsLoading)
    {
        <div class="@HostCssClasses nightmare-dg-empty" style="@EffectiveHostStyle" tabindex="@HostTabIndex">
            @if (EmptyTemplate is null)
            {
                @EmptyText
            }
            else
            {
                @EmptyTemplate
            }
        </div>
    }
    else if (GroupKeySelector is null)
    {
        <div class="@HostCssClasses" style="@EffectiveHostStyle" tabindex="@HostTabIndex">
            <QuickGrid Items="@EffectiveItems"
                       Class="@GridTableClass"
                       Theme="@Theme"
                       Virtualize="@EffectiveVirtualize"
                       ItemSize="@EffectiveItemSize"
                       ItemKey="@ItemKey"
                       OverscanCount="@OverscanCount"
                       Pagination="@EffectivePagination">
                @ChildContent
            </QuickGrid>
        </div>
    }
    else if (_groups is { Count: > 0 })
    {
        <div class="nightmare-dg-groups">
            @foreach (var group in _groups)
            {
                <details @key="group.Key" class="nightmare-dg-group" open="@GroupsInitiallyExpanded">
                    <summary class="nightmare-dg-group-summary">
                        <span>@group.Key</span>
                        <span class="muted">(@group.Items.Count.ToString("N0"))</span>
                    </summary>
                    <div class="@HostCssClasses" style="@EffectiveHostStyle">
                        <QuickGrid Items="@group.Query"
                                   Class="@GridTableClass"
                                   Theme="@Theme"
                                   Virtualize="false"
                                   ItemSize="@EffectiveItemSize"
                                   ItemKey="@ItemKey"
                                   OverscanCount="@OverscanCount">
                            @ChildContent
                        </QuickGrid>
                    </div>
                </details>
            }
        </div>
    }

    @if (CanPage && ShowBottomPager)
    {
        <div class="nightmare-dg-bottom-pager">
            <Paginator State="ActivePagination" />
        </div>
    }
</div>
