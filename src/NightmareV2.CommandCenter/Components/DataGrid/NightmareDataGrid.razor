@typeparam TGridItem
@using Microsoft.AspNetCore.Components.QuickGrid

<div @attributes="AdditionalAttributes" class="nightmare-dg @CssClass">
    @if (ToolbarVisible)
    {
        <div class="nightmare-dg-toolbar">
            <div class="nightmare-dg-toolbar-main">
                @if (ShowSearch)
                {
                    <label class="nightmare-dg-search-wrap">
                        <span class="sr-only">@SearchPlaceholder</span>
                        <input type="search"
                               class="nightmare-dg-search ops-filter"
                               placeholder="@SearchPlaceholder"
                               value="@SearchText"
                               @oninput="OnSearchInput" />
                    </label>
                }

                @if (ShowPageSizePicker && CanPage)
                {
                    <label class="nightmare-dg-page-size">
                        <span>Rows</span>
                        <select value="@Pagination.ItemsPerPage" @onchange="OnPageSizeChanged">
                            @foreach (var option in PageSizeOptions.Distinct().OrderBy(x => x))
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                    </label>
                }

                @ToolbarTemplate

                @if (HasConfiguration)
                {
                    <details class="nightmare-dg-config">
                        <summary>Configure</summary>
                        <div class="nightmare-dg-config-body">
                            @ConfigurationTemplate
                        </div>
                    </details>
                }
            </div>

            @if (CanPage)
            {
                <div class="nightmare-dg-pager">
                    <Paginator State="@Pagination" />
                </div>
            }
        </div>
    }

    @if (ShowRowCount)
    {
        <div class="nightmare-dg-rowcount muted small">
            @if (_visibleRowCount == _totalRowCount)
            {
                <text>@_visibleRowCount.ToString("N0") rows</text>
            }
            else
            {
                <text>@_visibleRowCount.ToString("N0") of @_totalRowCount.ToString("N0") rows</text>
            }
            @if (EffectiveVirtualize)
            {
                <span class="nightmare-dg-mode">virtualized</span>
            }
            else if (Pagination is not null && GroupKeySelector is null)
            {
                <span class="nightmare-dg-mode">paged</span>
            }
            @if (GroupKeySelector is not null)
            {
                <span class="nightmare-dg-mode">grouped</span>
            }
        </div>
    }

    @if (IsLoading)
    {
        <div class="nightmare-dg-loading">Loading rows…</div>
    }

    @if (_visibleRowCount == 0)
    {
        <div class="@HostCssClasses nightmare-dg-empty" style="@HostStyle" tabindex="@HostTabIndex">
            @EmptyText
        </div>
    }
    else if (GroupKeySelector is null)
    {
        <div class="@HostCssClasses" style="@HostStyle" tabindex="@HostTabIndex">
            <QuickGrid Items="@GetEffectiveItems()"
                       Class="@GridTableClass"
                       Theme="@Theme"
                       Virtualize="@EffectiveVirtualize"
                       ItemSize="@ItemSize"
                       ItemKey="@ItemKey"
                       OverscanCount="@OverscanCount"
                       Pagination="@EffectivePagination">
                @ChildContent
            </QuickGrid>
        </div>
    }
    else if (_groups is { Count: > 0 })
    {
        @foreach (var g in _groups)
        {
            <details class="nightmare-dg-group" open>
                <summary class="nightmare-dg-group-summary">@g.Key <span class="muted">(@g.Count().ToString("N0"))</span></summary>
                <div class="@HostCssClasses" style="@HostStyle">
                    <QuickGrid Items="@g.AsQueryable()"
                               Class="@GridTableClass"
                               Theme="@Theme"
                               Virtualize="false"
                               ItemSize="@ItemSize"
                               ItemKey="@ItemKey"
                               OverscanCount="@OverscanCount">
                        @ChildContent
                    </QuickGrid>
                </div>
            </details>
        }
    }
</div>
