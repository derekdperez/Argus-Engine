@inherits LayoutComponentBase

<header class="app-header">
    <a class="brand" href="/">
        <span class="brand-mark">N2</span>
        <span>
            <strong>Nightmare</strong>
            <small>Command Center</small>
        </span>
    </a>
    <nav class="app-nav" aria-label="Primary">
        <NavLink href="/" Match="NavLinkMatch.All">Home</NavLink>
        <NavLink href="/targets">Targets</NavLink>
        <NavLink href="/ops">Operations</NavLink>
        <NavLink href="/events">Events</NavLink>
        <NavLink href="/status">System status</NavLink>
        <NavLink href="/high-value-findings">High value findings</NavLink>
    </nav>
</header>

<main class="app-main">
    @Body
</main>

<RadzenComponents @rendermode="InteractiveServer" />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
