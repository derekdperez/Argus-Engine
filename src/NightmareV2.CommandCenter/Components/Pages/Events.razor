@page "/events"
@rendermode InteractiveServer
@using System.Globalization
@using NightmareV2.CommandCenter.Models
@using NightmareV2.CommandCenter.Realtime
@implements IDisposable
@inject HttpClient Http
@inject DiscoveryRealtimeClient Realtime

<PageTitle>Events - Nightmare v2</PageTitle>

<div class="page-shell events-page">
    <section class="page-hero events-hero">
        <div>
            <p class="eyebrow">Message bus</p>
            <h1>Events</h1>
            <p class="hero-copy">Live event trace with publish time, producer, payload, consumers, and immediate follow-up events.</p>
            <div class="hero-meta">
                <span class="live-pill @LiveStateCss">@Realtime.State</span>
                <span>@_rows.Count.ToString("N0") publishes loaded</span>
                @if (_lastLoadedAtUtc is not null)
                {
                    <span>Updated @_lastLoadedAtUtc.Value.ToLocalTime().ToString("T")</span>
                }
            </div>
        </div>
        <div class="hero-actions">
            <button type="button" class="btn primary" @onclick="ReloadAsync" disabled="@_loading">Refresh</button>
            <button type="button" class="btn" @onclick="StartRealtimeAsync">Reconnect</button>
            <label class="switch-row">
                <input type="checkbox" @bind="_autoRefresh" />
                <span>Live refresh</span>
            </label>
        </div>
    </section>

    <section class="stat-grid events-stat-grid" aria-label="Event summary">
        <div class="stat-card">
            <div class="stat-label">Publishes</div>
            <div class="stat-value">@_rows.Count.ToString("N0")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Consumes</div>
            <div class="stat-value">@_rows.Sum(r => r.ConsumerCount).ToString("N0")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Follow-ups</div>
            <div class="stat-value">@_rows.Sum(r => r.FollowUps.Count).ToString("N0")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Unconsumed</div>
            <div class="stat-value">@_rows.Count(r => r.ConsumerCount == 0).ToString("N0")</div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert">@_error</div>
    }

    <section class="panel">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Live trace</p>
                <h2>Published events</h2>
            </div>
            <span class="muted">Newest first</span>
        </div>

        <NightmareDataGrid TGridItem="EventTraceRowDto"
                           Items="FilteredEvents"
                           @bind-SearchText="_eventSearch"
                           SearchPlaceholder="Search event, producer, worker, payload, id..."
                           ScrollPreset="@(_virtualize && EventGroupKeySelector is null ? NightmareDataGridScrollPreset.Virtualized : NightmareDataGridScrollPreset.Tall)"
                           Virtualize="@(_virtualize && EventGroupKeySelector is null)"
                           Pagination="_pagination"
                           ItemSize="52"
                           ItemKey="@(r => r.JournalId)"
                           OverscanCount="8"
                           GroupKeySelector="EventGroupKeySelector"
                           RowMatches="@EventMatches"
                           IsLoading="@_loading"
                           EmptyText="No events match the current filters.">
            <ToolbarTemplate>
                <label class="compact-field">
                    <span>Window</span>
                    <input type="number" min="1" max="240" @bind="_minutes" @bind:after="ReloadAsync" />
                </label>
                <label class="compact-field">
                    <span>Load</span>
                    <input type="number" min="25" max="1000" step="25" @bind="_take" @bind:after="ReloadAsync" />
                </label>
            </ToolbarTemplate>
            <ConfigurationTemplate>
                <div class="grid-config compact">
                    <label>
                        <span>Event</span>
                        <input type="text" class="ops-filter" @bind="_eventNameFilter" />
                    </label>
                    <label>
                        <span>Producer</span>
                        <input type="text" class="ops-filter" @bind="_producerFilter" />
                    </label>
                    <label>
                        <span>Consumer</span>
                        <input type="text" class="ops-filter" @bind="_consumerFilter" />
                    </label>
                    <label>
                        <span>Group by</span>
                        <select @bind="_groupBy">
                            <option value="">No grouping</option>
                            <option value="Event">Event</option>
                            <option value="Producer">Producer</option>
                            <option value="ConsumerState">Consumer state</option>
                        </select>
                    </label>
                    <label class="switch-row">
                        <input type="checkbox" @bind="_unconsumedOnly" />
                        <span>Unconsumed only</span>
                    </label>
                    <label class="switch-row">
                        <input type="checkbox" @bind="_virtualize" />
                        <span>Virtualized rows</span>
                    </label>
                    <button type="button" class="btn ghost" @onclick="ClearFilters">Clear filters</button>
                </div>
            </ConfigurationTemplate>
            <ChildContent>
                <TemplateColumn Title="Time (UTC)" Context="row" SortBy="@SortPublishedAt">
                    <GridDateCell Value="@row.PublishedAtUtc" />
                </TemplateColumn>
                <TemplateColumn Title="Event" Context="row" SortBy="@SortEventName">
                    <div class="event-name-cell">
                        <GridCodeCell Text="@row.EventName" />
                        @if (row.EventId is not null)
                        {
                            <span class="event-id">@row.EventId</span>
                        }
                    </div>
                </TemplateColumn>
                <PropertyColumn Title="Producer" Property="@(row => row.Producer)" Sortable="true" />
                <TemplateColumn Title="Consumers" Context="row">
                    @if (row.Consumers.Count == 0)
                    {
                        <span class="badge badge-gray">pending</span>
                    }
                    else
                    {
                        <div class="event-stack">
                            @foreach (var consumer in row.Consumers.Take(4))
                            {
                                <span>
                                    <strong>@consumer.Worker</strong>
                                    <small>@consumer.ConsumedAtUtc.ToLocalTime().ToString("T") +@consumer.LatencyMs.ToString("N0", CultureInfo.InvariantCulture)ms on @consumer.HostName</small>
                                </span>
                            }
                            @if (row.Consumers.Count > 4)
                            {
                                <span class="muted">+@(row.Consumers.Count - 4) more</span>
                            }
                        </div>
                    }
                </TemplateColumn>
                <TemplateColumn Title="Next" Context="row">
                    @if (row.FollowUps.Count == 0)
                    {
                        <span class="muted">No follow-up publish in window</span>
                    }
                    else
                    {
                        <div class="event-stack">
                            @foreach (var next in row.FollowUps.Take(4))
                            {
                                <span>
                                    <strong>@next.EventName</strong>
                                    <small>@next.Producer at @next.PublishedAtUtc.ToLocalTime().ToString("T")</small>
                                </span>
                            }
                            @if (row.FollowUps.Count > 4)
                            {
                                <span class="muted">+@(row.FollowUps.Count - 4) more</span>
                            }
                        </div>
                    }
                </TemplateColumn>
                <TemplateColumn Title="Data" Context="row">
                    <details class="event-payload">
                        <summary>@row.PayloadPreview</summary>
                        <pre>@row.PayloadJson</pre>
                    </details>
                </TemplateColumn>
            </ChildContent>
        </NightmareDataGrid>
    </section>
</div>

@code {
    private readonly CancellationTokenSource _pollCts = new();
    private readonly PaginationState _pagination = new() { ItemsPerPage = 50 };
    private readonly List<EventTraceRowDto> _rows = [];
    private bool _autoRefresh = true;
    private bool _loading;
    private bool _virtualize = true;
    private bool _unconsumedOnly;
    private int _minutes = 15;
    private int _take = 250;
    private string _eventSearch = "";
    private string _eventNameFilter = "";
    private string _producerFilter = "";
    private string _consumerFilter = "";
    private string _groupBy = "";
    private string _error = "";
    private DateTimeOffset? _lastLoadedAtUtc;

    private string LiveStateCss => Realtime.IsConnected ? "connected" : "disconnected";

    private static readonly GridSort<EventTraceRowDto> SortPublishedAt =
        GridSort<EventTraceRowDto>.ByDescending(static r => r.PublishedAtUtc);

    private static readonly GridSort<EventTraceRowDto> SortEventName =
        GridSort<EventTraceRowDto>.ByAscending(static r => r.EventName);

    private IQueryable<EventTraceRowDto> FilteredEvents =>
        _rows.AsQueryable().Where(r =>
            (!_unconsumedOnly || r.ConsumerCount == 0)
            && GridTextFilter.Matches(r.EventName, _eventNameFilter)
            && GridTextFilter.Matches(r.Producer, _producerFilter)
            && (string.IsNullOrWhiteSpace(_consumerFilter)
                || r.Consumers.Any(c => GridTextFilter.Matches(c.Worker, _consumerFilter)
                    || GridTextFilter.Matches(c.ConsumerType, _consumerFilter)
                    || GridTextFilter.Matches(c.HostName, _consumerFilter))));

    private Func<EventTraceRowDto, string>? EventGroupKeySelector =>
        _groupBy switch
        {
            "Event" => static r => r.EventName,
            "Producer" => static r => string.IsNullOrWhiteSpace(r.Producer) ? "unknown" : r.Producer,
            "ConsumerState" => static r => r.ConsumerCount == 0 ? "Pending consume" : "Consumed",
            _ => null,
        };

    protected override async Task OnInitializedAsync()
    {
        Realtime.DomainEventReceived += OnRealtimeEvent;
        Realtime.ConnectionStateChanged += OnRealtimeConnectionChanged;
        await ReloadAsync().ConfigureAwait(false);
        await StartRealtimeAsync().ConfigureAwait(false);
        _ = PollAsync();
    }

    private async Task StartRealtimeAsync()
    {
        try
        {
            await Realtime.EnsureStartedAsync(_pollCts.Token).ConfigureAwait(false);
        }
        catch
        {
            // Polling remains the source of truth for this page.
        }
    }

    private void OnRealtimeConnectionChanged(object? sender, EventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnRealtimeEvent(object? sender, LiveUiEventDto evt)
    {
        if (!_autoRefresh)
            return;

        _ = InvokeAsync(async () =>
        {
            await Task.Delay(350, _pollCts.Token).ConfigureAwait(false);
            await ReloadAsync().ConfigureAwait(false);
            StateHasChanged();
        });
    }

    private async Task PollAsync()
    {
        try
        {
            while (!_pollCts.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(2), _pollCts.Token).ConfigureAwait(false);
                if (!_autoRefresh)
                    continue;

                await ReloadAsync().ConfigureAwait(false);
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ReloadAsync()
    {
        if (_loading)
            return;

        _loading = true;
        _error = "";
        try
        {
            _minutes = Math.Clamp(_minutes, 1, 240);
            _take = Math.Clamp(_take, 25, 1000);
            var list = await Http.GetFromJsonAsync<List<EventTraceRowDto>>($"/api/events/live?minutes={_minutes}&take={_take}")
                .ConfigureAwait(false);
            _rows.Clear();
            if (list is not null)
                _rows.AddRange(list);
            _lastLoadedAtUtc = DateTimeOffset.UtcNow;
        }
        catch (Exception ex)
        {
            _error = $"Could not load event trace: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ClearFilters()
    {
        _eventSearch = "";
        _eventNameFilter = "";
        _producerFilter = "";
        _consumerFilter = "";
        _groupBy = "";
        _unconsumedOnly = false;
    }

    private static bool EventMatches(EventTraceRowDto row, string q) =>
        GridTextFilter.Matches(row.EventName, q)
        || GridTextFilter.Matches(row.Producer, q)
        || GridTextFilter.Matches(row.HostName, q)
        || GridTextFilter.Matches(row.PayloadPreview, q)
        || GridTextFilter.Matches(row.PayloadJson, q)
        || GridTextFilter.Matches(row.EventId?.ToString(), q)
        || GridTextFilter.Matches(row.CorrelationId?.ToString(), q)
        || row.Consumers.Any(c => GridTextFilter.Matches(c.Worker, q)
            || GridTextFilter.Matches(c.ConsumerType, q)
            || GridTextFilter.Matches(c.HostName, q))
        || row.FollowUps.Any(f => GridTextFilter.Matches(f.EventName, q)
            || GridTextFilter.Matches(f.Producer, q)
            || GridTextFilter.Matches(f.PayloadPreview, q));

    public void Dispose()
    {
        Realtime.DomainEventReceived -= OnRealtimeEvent;
        Realtime.ConnectionStateChanged -= OnRealtimeConnectionChanged;
        _pollCts.Cancel();
        _pollCts.Dispose();
    }
}
