@page "/high-value-findings"
@rendermode InteractiveServer
@using NightmareV2.CommandCenter.Components.DataGrid
@using NightmareV2.CommandCenter.Components.DataGrid.Cells
@using NightmareV2.CommandCenter.Models
@using NightmareV2.CommandCenter.Realtime
@using static Microsoft.AspNetCore.Components.QuickGrid.SortDirection
@implements IDisposable
@inject HttpClient Http
@inject DiscoveryRealtimeClient Realtime

<PageTitle>High value findings · Nightmare v2</PageTitle>

<h1>High value findings</h1>
<p class="muted">Regex matches from stored HTTP responses and sensitive path confirmations. Path probes are queued by <code>HighValuePaths</code> and fetched by the normal Spider pipeline.</p>

<div class="row">
    <label>
        <input type="checkbox" @bind="_criticalOnly" @bind:after="ReloadAsync" />
        Critical only
    </label>
    <button type="button" @onclick="ReloadAsync">Refresh</button>
</div>

<section class="panel">
    <div class="row">
        <label>Column filters</label>
        <input type="text" class="ops-filter" placeholder="Severity" @bind="_findingSeverityFilter" />
        <input type="text" class="ops-filter" placeholder="Type" @bind="_findingTypeFilter" />
        <input type="text" class="ops-filter" placeholder="Pattern" @bind="_findingPatternFilter" />
        <input type="text" class="ops-filter" placeholder="Target" @bind="_findingTargetFilter" />
        <input type="text" class="ops-filter" placeholder="Worker" @bind="_findingWorkerFilter" />
        <button type="button" @onclick="ClearFindingFilters">Clear all filters</button>
    </div>
    <NightmareDataGrid TGridItem="HighValueFindingRowDto"
                       Items="FilteredFindings"
                       @bind-SearchText="_findingSearch"
                       SearchPlaceholder="Search severity, type, pattern, URL, worker, snippet…"
                       ScrollPreset="@(_findingVirtualize ? NightmareDataGridScrollPreset.Virtualized : NightmareDataGridScrollPreset.Tall)"
                       Virtualize="@_findingVirtualize"
                       Pagination="_findingPagination"
                       ItemSize="40"
                       ItemKey="@(r => r.Id)"
                       OverscanCount="6"
                       GroupKeySelector="FindingGroupKeySelector"
                       RowMatches="@FindingMatches"
                       HostTabIndex="@(-1)">
        <ConfigurationTemplate>
            <div class="grid-config compact">
                <label>
                    <span>Group by</span>
                    <select @bind="_findingGroupBy">
                        <option value="">No grouping</option>
                        <option value="Severity">Severity</option>
                        <option value="Type">Type</option>
                        <option value="Target">Target</option>
                        <option value="Worker">Worker</option>
                    </select>
                </label>
                <label class="switch-row">
                    <input type="checkbox" @bind="_findingVirtualize" />
                    <span>Virtualized rows</span>
                </label>
                <button type="button" class="btn ghost" @onclick="ClearFindingFilters">Clear filters</button>
            </div>
        </ConfigurationTemplate>
        <ChildContent>
            <PropertyColumn Title="Discovered (UTC)" Property="@(r => r.DiscoveredAtUtc)" Format="u" Sortable="true" IsDefaultSortColumn="true" InitialSortDirection="Descending" />
            <TemplateColumn Title="Severity" Context="r" SortBy="@SortFindingSeverity">
                <strong>@r.Severity</strong>
            </TemplateColumn>
            <PropertyColumn Title="Type" Property="@(r => r.FindingType)" Sortable="true" />
            <TemplateColumn Title="Pattern" Context="r" SortBy="@SortFindingPattern">
                <GridCodeCell Text="@r.PatternName" />
            </TemplateColumn>
            <PropertyColumn Title="Target" Property="@(r => r.TargetRootDomain ?? "")" Sortable="true" />
            <TemplateColumn Title="Source URL" Context="r" SortBy="@SortFindingUrl">
                <a href="@r.SourceUrl" target="_blank" rel="noopener noreferrer">
                    <GridEllipsisCell Text="@r.SourceUrl" Title="@r.SourceUrl" />
                </a>
            </TemplateColumn>
            <PropertyColumn Title="Worker" Property="@(r => r.WorkerName)" Sortable="true" />
            <TemplateColumn Title="Score" Context="r" SortBy="@SortFindingScore">
                <GridNumberCell Value="@r.ImportanceScore" />
            </TemplateColumn>
            <TemplateColumn Title="Snippet" Context="r">
                <GridEllipsisCell Text="@r.MatchedText" Title="@r.MatchedText" />
            </TemplateColumn>
        </ChildContent>
    </NightmareDataGrid>
</section>

@code {
    private readonly CancellationTokenSource _pollCts = new();
    private readonly List<HighValueFindingRowDto> _rows = [];
    private bool _criticalOnly;
    private string _findingSearch = "";
    private string _findingSeverityFilter = "";
    private string _findingTypeFilter = "";
    private string _findingPatternFilter = "";
    private string _findingTargetFilter = "";
    private string _findingWorkerFilter = "";
    private string _findingGroupBy = "Severity";
    private bool _findingVirtualize = true;
    private readonly PaginationState _findingPagination = new() { ItemsPerPage = 50 };

    private static readonly GridSort<HighValueFindingRowDto> SortFindingSeverity =
        GridSort<HighValueFindingRowDto>.ByAscending(static r => r.Severity);

    private static readonly GridSort<HighValueFindingRowDto> SortFindingPattern =
        GridSort<HighValueFindingRowDto>.ByAscending(static r => r.PatternName);

    private static readonly GridSort<HighValueFindingRowDto> SortFindingUrl =
        GridSort<HighValueFindingRowDto>.ByAscending(static r => r.SourceUrl);

    private static readonly GridSort<HighValueFindingRowDto> SortFindingScore =
        GridSort<HighValueFindingRowDto>.ByDescending(static r => r.ImportanceScore ?? int.MinValue);

    private static bool FindingMatches(HighValueFindingRowDto r, string q) =>
        GridTextFilter.Matches(r.Severity, q)
        || GridTextFilter.Matches(r.FindingType, q)
        || GridTextFilter.Matches(r.PatternName, q)
        || GridTextFilter.Matches(r.TargetRootDomain, q)
        || GridTextFilter.Matches(r.SourceUrl, q)
        || GridTextFilter.Matches(r.WorkerName, q)
        || GridTextFilter.Matches(r.MatchedText, q)
        || GridTextFilter.Matches(r.Category, q);

    private Func<HighValueFindingRowDto, string>? FindingGroupKeySelector =>
        _findingGroupBy switch
        {
            "Severity" => static r => r.Severity,
            "Type" => static r => r.FindingType,
            "Target" => static r => r.TargetRootDomain ?? "No target",
            "Worker" => static r => r.WorkerName,
            _ => null,
        };

    private IQueryable<HighValueFindingRowDto> FilteredFindings =>
        _rows.AsQueryable().Where(r =>
            GridTextFilter.Matches(r.Severity, _findingSeverityFilter)
            && GridTextFilter.Matches(r.FindingType, _findingTypeFilter)
            && GridTextFilter.Matches(r.PatternName, _findingPatternFilter)
            && GridTextFilter.Matches(r.TargetRootDomain, _findingTargetFilter)
            && GridTextFilter.Matches(r.WorkerName, _findingWorkerFilter));

    private void ClearFindingFilters()
    {
        _findingSearch = "";
        _findingSeverityFilter = "";
        _findingTypeFilter = "";
        _findingPatternFilter = "";
        _findingTargetFilter = "";
        _findingWorkerFilter = "";
        _findingGroupBy = "Severity";
    }

    protected override async Task OnInitializedAsync()
    {
        Realtime.DomainEventReceived += OnRealtimeEvent;
        await ReloadAsync().ConfigureAwait(false);
        await StartRealtimeAsync().ConfigureAwait(false);
        _ = PollAsync();
    }

    private async Task StartRealtimeAsync()
    {
        try
        {
            await Realtime.EnsureStartedAsync(_pollCts.Token).ConfigureAwait(false);
        }
        catch
        {
            // Manual refresh and fallback polling remain available.
        }
    }

    private void OnRealtimeEvent(object? sender, LiveUiEventDto evt)
    {
        if (evt.Scope is not ("findings" or "http"))
            return;

        _ = InvokeAsync(async () =>
        {
            await ReloadAsync();
            StateHasChanged();
        });
    }

    private async Task PollAsync()
    {
        try
        {
            while (!_pollCts.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(30), _pollCts.Token).ConfigureAwait(false);
                if (Realtime.IsConnected)
                    continue;

                await ReloadAsync().ConfigureAwait(false);
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ReloadAsync()
    {
        try
        {
            var qs = _criticalOnly ? "?criticalOnly=true&take=800" : "?take=800";
            var list = await Http.GetFromJsonAsync<List<HighValueFindingRowDto>>($"/api/high-value-findings{qs}")
                .ConfigureAwait(false);
            _rows.Clear();
            if (list is not null)
                _rows.AddRange(list);
        }
        catch
        {
            _rows.Clear();
        }
    }

    public void Dispose()
    {
        Realtime.DomainEventReceived -= OnRealtimeEvent;
        _pollCts.Cancel();
        _pollCts.Dispose();
    }
}
