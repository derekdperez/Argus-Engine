@using System.Net.Http.Json
@using NightmareV2.CommandCenter.Models
@using NightmareV2.CommandCenter.Realtime
@implements IDisposable
@inject HttpClient Http
@inject DiscoveryRealtimeClient Realtime

@page "/high-value-findings"
@rendermode InteractiveServer

<PageTitle>High value findings · Nightmare v2</PageTitle>

<div class="page-shell ops-page">
    <section class="page-hero ops-hero">
        <div>
            <p class="eyebrow">Detection</p>
            <h1>High value findings</h1>
            <p class="hero-copy">Regex matches and sensitive path confirmations from stored HTTP responses. URL findings use the final destination after redirects.</p>
            <div class="hero-meta">
                <span class="live-pill @LiveStateCss">@Realtime.State</span>
                <span>@(_lastLoadedAtUtc is null ? "Not loaded" : $"Last refresh {_lastLoadedAtUtc:yyyy-MM-dd HH:mm:ss} UTC")</span>
                <span>@FilteredFindings.Count().ToString("N0") rows</span>
            </div>
        </div>
        <div class="hero-actions">
            <label class="ops-inline-check">
                <input type="checkbox" @bind="_criticalOnly" @bind:after="ReloadAsync" />
                <span>Critical only</span>
            </label>
            <button type="button" class="btn" @onclick="ReloadAsync" disabled="@_loading">@(_loading ? "Refreshing..." : "Refresh")</button>
        </div>
    </section>

    <section class="panel ops-rz-panel">
        <div class="ops-grid-toolbar">
            <input type="text" class="ops-filter wide" placeholder="Search severity, pattern, final URL, original URL, worker, snippet..." @bind="_search" @bind:event="oninput" />
            <input type="text" class="ops-filter" placeholder="Severity" @bind="_severityFilter" @bind:event="oninput" />
            <input type="text" class="ops-filter" placeholder="Type" @bind="_typeFilter" @bind:event="oninput" />
            <input type="text" class="ops-filter" placeholder="Pattern" @bind="_patternFilter" @bind:event="oninput" />
            <input type="text" class="ops-filter" placeholder="Target" @bind="_targetFilter" @bind:event="oninput" />
            <button type="button" class="btn ghost" @onclick="ClearFilters">Clear filters</button>
        </div>

        <RadzenDataGrid TItem="HighValueFindingRowDto"
                        Data="@FilteredFindings"
                        Count="@FilteredFindings.Count()"
                        AllowSorting="true"
                        AllowFiltering="false"
                        AllowPaging="false"
                        AllowVirtualization="true"
                        Style="height: 860px"
                        Density="Density.Compact"
                        GridLines="DataGridGridLines.Both"
                        IsLoading="@_loading"
                        ColumnWidth="180px">
            <Columns>
                <RadzenDataGridColumn TItem="HighValueFindingRowDto" Property="DiscoveredAtUtc" Title="Discovered" Width="180px" SortOrder="SortOrder.Descending">
                    <Template Context="r">@r.DiscoveredAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="HighValueFindingRowDto" Property="Severity" Title="Severity" Width="120px">
                    <Template Context="r"><strong>@r.Severity</strong></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="HighValueFindingRowDto" Property="FindingType" Title="Type" Width="150px" />
                <RadzenDataGridColumn TItem="HighValueFindingRowDto" Property="PatternName" Title="Pattern" Width="240px">
                    <Template Context="r"><code>@r.PatternName</code></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="HighValueFindingRowDto" Property="TargetRootDomain" Title="Target" Width="220px" />
                <RadzenDataGridColumn TItem="HighValueFindingRowDto" Property="SourceUrl" Title="Final URL" Width="460px">
                    <Template Context="r">
                        @if (TryHttpHref(r.SourceUrl) is { } href)
                        {
                            <a href="@href" target="_blank" rel="noopener noreferrer"><span class="ops-rz-clip" title="@r.SourceUrl">@r.SourceUrl</span></a>
                        }
                        else
                        {
                            <span class="ops-rz-clip" title="@r.SourceUrl">@r.SourceUrl</span>
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="HighValueFindingRowDto" Property="OriginalSourceUrl" Title="Original URL" Width="460px">
                    <Template Context="r"><span class="ops-rz-clip" title="@r.OriginalSourceUrl">@r.OriginalSourceUrl</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="HighValueFindingRowDto" Property="RedirectCount" Title="Redirects" Width="120px" />
                <RadzenDataGridColumn TItem="HighValueFindingRowDto" Property="WorkerName" Title="Worker" Width="180px" />
                <RadzenDataGridColumn TItem="HighValueFindingRowDto" Property="ImportanceScore" Title="Score" Width="110px" />
                <RadzenDataGridColumn TItem="HighValueFindingRowDto" Property="MatchedText" Title="Snippet" Width="420px">
                    <Template Context="r"><span class="ops-rz-clip" title="@r.MatchedText">@r.MatchedText</span></Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </section>
</div>

@code {
    private readonly CancellationTokenSource _pollCts = new();
    private readonly List<HighValueFindingRowDto> _rows = [];
    private bool _criticalOnly;
    private bool _loading;
    private DateTimeOffset? _lastLoadedAtUtc;
    private string _search = "";
    private string _severityFilter = "";
    private string _typeFilter = "";
    private string _patternFilter = "";
    private string _targetFilter = "";

    private string LiveStateCss => Realtime.IsConnected ? "ok" : "warn";

    private IEnumerable<HighValueFindingRowDto> FilteredFindings => _rows.Where(r =>
        Matches(r.Severity, _severityFilter)
        && Matches(r.FindingType, _typeFilter)
        && Matches(r.PatternName, _patternFilter)
        && Matches(r.TargetRootDomain, _targetFilter)
        && (
            Matches(r.Severity, _search)
            || Matches(r.FindingType, _search)
            || Matches(r.PatternName, _search)
            || Matches(r.Category, _search)
            || Matches(r.TargetRootDomain, _search)
            || Matches(r.SourceUrl, _search)
            || Matches(r.OriginalSourceUrl, _search)
            || Matches(r.FinalSourceUrl, _search)
            || Matches(r.WorkerName, _search)
            || Matches(r.MatchedText, _search)));

    protected override async Task OnInitializedAsync()
    {
        Realtime.DomainEventReceived += OnRealtimeEvent;
        await ReloadAsync().ConfigureAwait(false);
        await StartRealtimeAsync().ConfigureAwait(false);
        _ = PollAsync();
    }

    private async Task StartRealtimeAsync()
    {
        try
        {
            await Realtime.EnsureStartedAsync(_pollCts.Token).ConfigureAwait(false);
        }
        catch
        {
            // Manual refresh and fallback polling remain available.
        }
    }

    private void OnRealtimeEvent(object? sender, LiveUiEventDto evt)
    {
        if (evt.Scope is not ("findings" or "assets" or "http"))
            return;

        _ = InvokeAsync(async () =>
        {
            await ReloadAsync();
            StateHasChanged();
        });
    }

    private async Task PollAsync()
    {
        try
        {
            while (!_pollCts.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(30), _pollCts.Token).ConfigureAwait(false);
                if (Realtime.IsConnected)
                    continue;

                await ReloadAsync().ConfigureAwait(false);
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ReloadAsync()
    {
        if (_loading)
            return;

        _loading = true;
        try
        {
            var qs = _criticalOnly ? "?criticalOnly=true" : "";
            var list = await Http.GetFromJsonAsync<List<HighValueFindingRowDto>>($"/api/high-value-findings{qs}")
                .ConfigureAwait(false);
            _rows.Clear();
            if (list is not null)
                _rows.AddRange(list);

            _lastLoadedAtUtc = DateTimeOffset.UtcNow;
        }
        catch
        {
            _rows.Clear();
        }
        finally
        {
            _loading = false;
        }
    }

    private void ClearFilters()
    {
        _search = "";
        _severityFilter = "";
        _typeFilter = "";
        _patternFilter = "";
        _targetFilter = "";
    }

    private static bool Matches(string? value, string? filter) =>
        string.IsNullOrWhiteSpace(filter)
        || (!string.IsNullOrWhiteSpace(value) && value.Contains(filter.Trim(), StringComparison.OrdinalIgnoreCase));

    private static string? TryHttpHref(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;
        return Uri.TryCreate(value.Trim(), UriKind.Absolute, out var uri) && uri.Scheme is "http" or "https"
            ? uri.ToString()
            : null;
    }

    public void Dispose()
    {
        Realtime.DomainEventReceived -= OnRealtimeEvent;
        _pollCts.Cancel();
        _pollCts.Dispose();
    }
}
