@using NightmareV2.CommandCenter.Models
@inject HttpClient Http

<PageTitle>Operations</PageTitle>

<div class="ops-header mb-4">
    <h3>Worker Operations</h3>
    <div class="card p-3 bg-light border-warning">
        <h5 class="text-warning"><i class="bi bi-exclamation-triangle"></i> Global Actions</h5>
        <p class="text-muted small">These actions will queue tasks for every active target in the database.</p>
        <div class="d-flex gap-2">
            <button class="btn btn-warning" @onclick="() => RestartEnum(true)">Restart Enum (All Targets)</button>
            <button class="btn btn-danger" @onclick="() => RestartSpider(true)">Restart Spidering (All Targets)</button>
        </div>
    </div>
</div>

<div class="mt-4">
    <h4>Target Specific Actions</h4>
    <div class="mb-3 d-flex align-items-center gap-2">
        <button class="btn btn-primary" @onclick="() => RestartEnum(false)" disabled="@(!SelectedTargetIds.Any())">
            <i class="bi bi-search"></i> Restart Enum (@SelectedTargetIds.Count)
        </button>
        <button class="btn btn-secondary" @onclick="() => RestartSpider(false)" disabled="@(!SelectedTargetIds.Any())">
            <i class="bi bi-spider"></i> Restart Spider (@SelectedTargetIds.Count)
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width: 40px;">Select</th>
                    <th>Target</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Targets == null)
                {
                    <tr><td colspan="3" class="text-center">Loading targets...</td></tr>
                }
                else
                {
                    @foreach (var target in Targets)
                    {
                        <tr>
                            <td>
                                <input type="checkbox" class="form-check-input" 
                                       @onchange="e => OnTargetToggled(target.Id, e)" />
                            </td>
                            <td><strong>@target.Name</strong></td>
                            <td><span class="badge bg-secondary">@target.Status</span></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
