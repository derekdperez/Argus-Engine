    private async Task UpdateTargetMaxDepthAsync(bool allTargets)
    {
        if (_targetBulkMaxDepth <= 0)
        {
            _statusMessage = "Max depth must be greater than zero.";
            return;
        }

        if (!allTargets && SelectedToolTargetCount == 0)
        {
            _statusMessage = "Select at least one target first.";
            return;
        }

        var targetCount = allTargets ? _targets.Count : SelectedToolTargetCount;
        var scope = allTargets ? "all targets" : $"{targetCount} selected targets";
        var ok = await Js.InvokeAsync<bool>("confirm", $"Set max depth to {_targetBulkMaxDepth} for {scope}?");
        if (!ok)
            return;

        _targetDepthBusy = true;
        _statusMessage = "";
        try
        {
            var ids = allTargets ? null : _selectedToolTargetIds.ToArray();
            var response = await Http.PutAsJsonAsync(
                    "/api/targets/max-depth",
                    new UpdateTargetMaxDepthRequest(_targetBulkMaxDepth, ids, allTargets))
                .ConfigureAwait(false);
            if (response.StatusCode == HttpStatusCode.BadRequest)
            {
                _statusMessage = await ReadResponseMessageAsync(response, "Max depth could not be updated.").ConfigureAwait(false);
                return;
            }

            response.EnsureSuccessStatusCode();
            var result = await response.Content.ReadFromJsonAsync<UpdateTargetMaxDepthResult>().ConfigureAwait(false);
            if (!allTargets)
                _selectedToolTargetIds.Clear();
            _statusMessage = result is null
                ? "Max depth updated."
                : $"Updated {result.Updated} targets to max depth {result.GlobalMaxDepth}.";
            await ReloadTargetsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Max depth update failed: {ex.Message}";
        }
        finally
        {
            _targetDepthBusy = false;
        }
    }

