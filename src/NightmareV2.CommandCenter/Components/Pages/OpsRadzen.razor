    private async Task ExportCsvAsync(string fileName, string[] headers, IEnumerable<string?[]> rows)
    {
        var csv = BuildCsv(headers, rows);
        await Js.InvokeVoidAsync("nightmareUi.downloadTextFile", fileName, csv, "text/csv;charset=utf-8");
    }

    private static string BuildCsv(string[] headers, IEnumerable<string?[]> rows)
    {
        var builder = new System.Text.StringBuilder();
        builder.AppendLine(string.Join(",", headers.Select(CsvEscape)));
        foreach (var row in rows)
            builder.AppendLine(string.Join(",", row.Select(CsvEscape)));
        return builder.ToString();
    }

    private static string CsvEscape(string? value)
    {
        var s = value ?? "";
        return s.IndexOfAny([',', '"', '\r', '\n']) < 0
            ? s
            : "\"" + s.Replace("\"", "\"\"", StringComparison.Ordinal) + "\"";
    }

    private static string FormatOpsTime(DateTimeOffset? value) =>
        AppTimeFormat.Format(value);

    private static string FormatOpsTime(DateTimeOffset value) =>
        AppTimeFormat.Format(value);

    private static string FormatMetricTriple(long? oneMinute, long? oneHour, long? oneDay) =>
        oneMinute is null || oneHour is null || oneDay is null
            ? "- / - / -"
            : $"{oneMinute.Value.ToString("N0", CultureInfo.InvariantCulture)} / {oneHour.Value.ToString("N0", CultureInfo.InvariantCulture)} / {oneDay.Value.ToString("N0", CultureInfo.InvariantCulture)}";

    private static string RootDomainHref(string rootDomain)
    {
        var host = rootDomain.Trim();
        return host.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
            || host.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
            ? host
            : $"https://{host}";
    }

    private static string? ToLiveHref(AssetGridRowDto asset) =>
        TryHttpHref(asset.FinalUrl) ?? TryHttpHref(asset.RawValue) ?? TryHttpHref(asset.CanonicalKey);

    private static string? ToLiveHref(HttpRequestQueueRowDto row) =>
        TryHttpHref(row.FinalUrl) ?? TryHttpHref(row.RequestUrl);

    private static string? TryHttpHref(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;
        return Uri.TryCreate(value.Trim(), UriKind.Absolute, out var uri) && uri.Scheme is "http" or "https"
            ? uri.ToString()
            : null;
    }

