    private async Task RestartToolAsync(string endpoint, bool allTargets, string successMessage)
    {
        if (_toolRestartBusy)
            return;
        if (!allTargets && SelectedToolTargetCount == 0)
            return;

        _toolRestartBusy = true;
        try
        {
            var ids = allTargets ? null : _selectedToolTargetIds.Select(id => id.ToString()).ToArray();
            var response = await Http.PostAsJsonAsync(endpoint, new RestartToolRequest(ids, allTargets)).ConfigureAwait(false);
            if (response.IsSuccessStatusCode)
            {
                if (!allTargets)
                    _selectedToolTargetIds.Clear();
                _statusMessage = successMessage;
                await ReloadVolatileAsync().ConfigureAwait(false);
            }
            else
            {
                _statusMessage = $"Tool restart failed: {(int)response.StatusCode} {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            _statusMessage = $"Tool restart failed: {ex.Message}";
        }
        finally
        {
            _toolRestartBusy = false;
        }
    }

