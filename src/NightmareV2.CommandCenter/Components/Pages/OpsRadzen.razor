    private async Task ReloadVolatileAsync()
    {
        _snapshotLoading = true;
        try
        {
            try
            {
                var overview = await Http.GetFromJsonAsync<OpsOverviewDto>("/api/ops/overview");
                if (overview is not null)
                    _overview = overview;
            }
            catch
            {
                // keep last good overview
            }

            try
            {
                _snapshot = await Http.GetFromJsonAsync<OpsSnapshotDto>("/api/ops/snapshot");
                ApplySnapshotRows();
            }
            catch
            {
                // Keep the last good snapshot and fall back to focused endpoints.
            }

            await ReloadWorkerRowsAsync();
            await ReloadWorkerScaleAsync();
            await ReloadHttpQueueMetricsAsync();
            _snapshotLoadedAtUtc = DateTimeOffset.UtcNow;
        }
        finally
        {
            _snapshotLoading = false;
        }
    }

    private void ApplySnapshotRows()
    {
        if (_snapshot is null)
            return;

        _workerSummaries.Clear();
        _workerSummaries.AddRange(_snapshot.Activity.WorkerSummaries);

    }

    private async Task ReloadWorkerRowsAsync()
    {
        if (_workerSummaries.Count > 0)
            return;

        try
        {
            var activity = await Http.GetFromJsonAsync<WorkerActivitySnapshotDto>("/api/workers/activity");
            if (activity is not null)
            {
                _workerSummaries.Clear();
                _workerSummaries.AddRange(activity.WorkerSummaries);
                return;
            }
        }
        catch
        {
            // Fall back to configured worker switches below.
        }

        try
        {
            var switches = await Http.GetFromJsonAsync<List<WorkerSwitchDto>>("/api/workers");
            if (switches is not null)
            {
                _workerSummaries.Clear();
                _workerSummaries.AddRange(
                    switches.Select(w => new WorkerKindSummaryDto(
                        w.WorkerKey,
                        w.IsEnabled,
                        0,
                        null,
                        "No journal data loaded")));
            }
        }
        catch
        {
            // Keep last good rows.
        }
    }

    private async Task ReloadWorkerScaleAsync()
    {
        try
        {
            var scale = await Http.GetFromJsonAsync<List<WorkerScaleTargetDto>>("/api/workers/scale").ConfigureAwait(false);
            _workerScaleTargets.Clear();
            if (scale is not null)
            {
                _workerScaleTargets.AddRange(scale);
                foreach (var row in scale)
                    _workerScaleInputs[row.WorkerKey] = Math.Max(0, row.ManualDesiredCount ?? row.DesiredCount ?? row.RunningCount ?? 0);
            }
        }
        catch
        {
            _workerScaleTargets.Clear();
        }
    }

