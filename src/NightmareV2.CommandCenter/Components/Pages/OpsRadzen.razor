            </RadzenDataGrid>
        </section>

        <section class="panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Workers</p>
                    <h2>Activity + controls</h2>
                </div>
                <span class="muted">Updated by live events</span>
            </div>

            <div class="ops-rz-toolbar">
                <label>
                    <span>Search</span>
                    <input type="search" class="ops-filter" @bind="_workerSearch" placeholder="Worker, rollup, timestamp…" />
                </label>
                <details class="ops-rz-column-toggles column-title-editor">
                    <summary>Display names</summary>
                    @foreach (var col in WorkerColumnTitleOptions)
                    {
                        <label>
                            <span>@col.Label</span>
                            <input type="text"
                                   class="ops-filter"
                                   value="@ColumnTitle(col.Key, col.DefaultTitle)"
                                   @oninput="@((ChangeEventArgs e) => SetColumnTitle(col.Key, e.Value?.ToString()))" />
                        </label>
                    }
                </details>
                <button type="button" class="btn" @onclick="ExportWorkersCsvAsync">Export CSV</button>
            </div>

            <RadzenDataGrid TItem="WorkerKindSummaryDto"
                            Data="@RadzenWorkers"
                            IsLoading="@_snapshotLoading"
                            AllowFiltering="true"
                            FilterMode="FilterMode.Advanced"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            AllowPaging="false"
                            AllowVirtualization="true"
                            VirtualizationOverscanCount="24"
                            Style="height: 860px"
                            AllowSorting="true"
                            AllowMultiColumnSorting="true"
                            AllowColumnResize="true"
                            AllowColumnReorder="true"
                            AllowColumnPicking="true"
                            AllowGrouping="true"
                            GroupPanelText="Drag a column header here to group workers"
                            Density="@_radzenDensity"
                            EmptyText="Worker activity has not loaded yet."
                            class="ops-rz-grid">
                <Columns>
                    <RadzenDataGridColumn TItem="WorkerKindSummaryDto" Property="WorkerKey" Title='@ColumnTitle("worker.WorkerKey", "Worker")' Width="180px">
                        <Template Context="w"><strong>@w.WorkerKey</strong></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="WorkerKindSummaryDto" Property="ToggleEnabled" Title='@ColumnTitle("worker.ToggleEnabled", "Enabled")' Width="130px">
                        <Template Context="w"><span class="@WorkerBadgeClass(w)">@(w.ToggleEnabled ? "Enabled" : "Paused")</span></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="WorkerKindSummaryDto" Property="InstanceCount" Title='@ColumnTitle("worker.InstanceCount", "Instances")' Width="120px" />
                    <RadzenDataGridColumn TItem="WorkerKindSummaryDto" Title='@ColumnTitle("worker.DesiredCount", "Desired")' Width="260px" Filterable="false" Sortable="false" Groupable="false">
                        <Template Context="w">
                            @if (WorkerScaleFor(w.WorkerKey) is { } scale)
                            {
                                <div class="worker-scale-control">
                                    <button type="button" class="btn small" disabled="@WorkerScaleBusy(w.WorkerKey)" @onclick="@(() => ChangeWorkerScaleAsync(w.WorkerKey, -1))">-1</button>
                                    <input type="number"
                                           min="0"
                                           class="ops-filter worker-scale-input"
                                           value="@WorkerScaleInput(w.WorkerKey)"
                                           @oninput="@((ChangeEventArgs e) => SetWorkerScaleInput(w.WorkerKey, e.Value?.ToString()))" />
                                    <button type="button" class="btn small" disabled="@WorkerScaleBusy(w.WorkerKey)" @onclick="@(() => ApplyWorkerScaleInputAsync(w.WorkerKey))">Set</button>
                                    <button type="button" class="btn small" disabled="@WorkerScaleBusy(w.WorkerKey)" @onclick="@(() => ChangeWorkerScaleAsync(w.WorkerKey, 1))">+1</button>
                                </div>
                                <small class="muted">@WorkerScaleSummary(scale)</small>
                            }
                            else
                            {
                                <span class="muted">Not scalable</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="WorkerKindSummaryDto" Property="LastActivityUtc" Title='@ColumnTitle("worker.LastActivityUtc", "Last activity")' Width="180px">
                        <Template Context="w">@FormatOpsTime(w.LastActivityUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="WorkerKindSummaryDto" Property="RollupActivityLabel" Title='@ColumnTitle("worker.RollupActivityLabel", "Rollup")' Width="280px">
                        <Template Context="w"><span class="ops-rz-clip" title="@w.RollupActivityLabel">@w.RollupActivityLabel</span></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="WorkerKindSummaryDto" Title="Actions" Width="120px" Filterable="false" Sortable="false" Groupable="false">
                        <Template Context="w">
                            <button type="button" class="btn small" disabled="@(_workerBusyKey == w.WorkerKey)" @onclick="@(() => SetWorkerEnabledAsync(w.WorkerKey, !w.ToggleEnabled))">
                                @(w.ToggleEnabled ? "Pause" : "Resume")
                            </button>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>


        </section>
    </section>
</div>

@code {
    private const string OpsTargetCreateFormName = "ops-target-create";
    private const string OpsTargetEditFormName = "ops-target-edit";

    private readonly CancellationTokenSource _pollCts = new();
    private CancellationTokenSource? _liveReloadCts;

    private readonly List<TargetSummary> _targets = [];
    private readonly List<AssetGridRowDto> _assets = [];
    private readonly List<HttpRequestQueueRowDto> _requestQueue = [];
    private readonly List<WorkerKindSummaryDto> _workerSummaries = [];
    private readonly List<WorkerScaleTargetDto> _workerScaleTargets = [];
    private readonly HashSet<Guid> _selectedToolTargetIds = [];
    private int SelectedToolTargetCount => _selectedToolTargetIds.Count;
    private readonly Dictionary<string, int> _workerScaleInputs = new(StringComparer.Ordinal);
    private readonly Dictionary<string, string> _columnTitles = new(StringComparer.Ordinal);
    private static readonly (string Key, string Label, string DefaultTitle)[] TargetColumnTitleOptions =
    [
        ("target.Id", "Id", "Id"),
        ("target.CreatedAtUtc", "Created", "Created"),
        ("target.RootDomain", "Root Domain", "Root Domain"),
        ("target.SubdomainCount", "Number of Subdomains", "Number of Subdomains"),
        ("target.ConfirmedAssetCount", "Number of Confirmed Assets", "Number of Confirmed Assets"),
        ("target.QueuedAssetCount", "Number of Queued Assets", "Number of Queued Assets"),
        ("target.GlobalMaxDepth", "Max Depth", "Max Depth"),
        ("target.LastRunAtUtc", "Last Run Time", "Last Run Time"),
    ];

    private static readonly (string Key, string Label, string DefaultTitle)[] AssetColumnTitleOptions =
    [
        ("asset.Id", "Id", "Id"),
        ("asset.TargetId", "Target Id", "Target Id"),
        ("asset.DiscoveredAtUtc", "Discovered", "Discovered"),
        ("asset.LastSeenAtUtc", "Last Seen", "Last Seen"),
        ("asset.Kind", "Kind", "Kind"),
        ("asset.Category", "Category", "Category"),
        ("asset.LifecycleStatus", "Status", "Status"),
        ("asset.Depth", "Depth", "Depth"),
        ("asset.Confidence", "Confidence", "Confidence"),
        ("asset.DisplayName", "Display Name", "Display Name"),
        ("asset.RawValue", "Raw", "Raw"),
        ("asset.FinalUrl", "Final URL", "Final URL"),
        ("asset.RedirectCount", "Redirects", "Redirects"),
        ("asset.CanonicalKey", "Canonical", "Canonical"),
        ("asset.DiscoveredBy", "Pipeline", "Pipeline"),
        ("asset.DiscoveryContext", "How found", "How found"),
        ("asset.TypeDetailsJson", "Type Details JSON", "Type Details JSON"),
    ];
    private static readonly (string Key, string Label, string DefaultTitle)[] QueueColumnTitleOptions =
    [
        ("queue.Id", "Id", "Id"),
        ("queue.AssetId", "Asset Id", "Asset Id"),
        ("queue.TargetId", "Target Id", "Target Id"),
        ("queue.CreatedAtUtc", "Created", "Created"),
        ("queue.UpdatedAtUtc", "Updated", "Updated"),
        ("queue.State", "State", "State"),
        ("queue.AssetKind", "Kind", "Kind"),
        ("queue.Method", "Method", "Method"),
        ("queue.RequestUrl", "Request URL", "Request URL"),
        ("queue.DomainKey", "Domain", "Domain"),
        ("queue.AttemptCount", "Attempts", "Attempts"),
        ("queue.MaxAttempts", "Max Attempts", "Max Attempts"),
        ("queue.Priority", "Priority", "Priority"),
        ("queue.NextAttemptAtUtc", "Next Attempt", "Next Attempt"),
        ("queue.StartedAtUtc", "Started", "Started"),
        ("queue.CompletedAtUtc", "Completed", "Completed"),
        ("queue.LockedBy", "Locked By", "Locked By"),
        ("queue.LockedUntilUtc", "Locked Until", "Locked Until"),
        ("queue.LastHttpStatus", "HTTP", "HTTP"),
        ("queue.DurationMs", "Duration ms", "Duration ms"),
        ("queue.RequestHeadersJson", "Request Headers JSON", "Request Headers JSON"),
        ("queue.RequestBody", "Request Body", "Request Body"),
        ("queue.ResponseHeadersJson", "Response Headers JSON", "Response Headers JSON"),
        ("queue.ResponseBody", "Response Body", "Response Body"),
        ("queue.ResponseContentType", "Response Content Type", "Response Content Type"),
        ("queue.ResponseContentLength", "Response Length", "Response Length"),
        ("queue.FinalUrl", "Final URL", "Final URL"),
        ("queue.RedirectCount", "Redirects", "Redirects"),
        ("queue.LastError", "Last error", "Last error"),
    ];


    private static readonly (string Key, string Label, string DefaultTitle)[] WorkerColumnTitleOptions =
    [
        ("worker.WorkerKey", "Worker", "Worker"),
        ("worker.ToggleEnabled", "Enabled", "Enabled"),
        ("worker.InstanceCount", "Instances", "Instances"),
        ("worker.DesiredCount", "Desired", "Desired"),
        ("worker.LastActivityUtc", "Last activity", "Last activity"),
        ("worker.RollupActivityLabel", "Rollup", "Rollup"),
    ];

    private RadzenDataGrid<AssetGridRowDto>? _assetGrid;
    private RadzenDataGrid<HttpRequestQueueRowDto>? _queueGrid;
    private int _assetGridVersion;
    private int _queueGridVersion;

    private OpsOverviewDto? _overview;
    private OpsSnapshotDto? _snapshot;
    private HttpRequestQueueMetricsDto? _queueMetrics;
    private HttpRequestQueueSettingsDto? _queueSettings;
    private MaintenanceStatusDto? _maintenanceStatus;

    [SupplyParameterFromForm(FormName = OpsTargetCreateFormName)]
    private TargetForm? _targetCreateForm { get; set; }
    private TargetForm TargetCreateForm => _targetCreateForm ??= new();

    private TargetEditForm? _targetEditing;
    private string _targetSearch = "";
    private string _targetFilter = "";

    private string _filterAssets = "";
    private string _filterKindCol = "";
    private string _filterStatusCol = "";
    private string _filterRawCol = "";
    private string _filterPipelineCol = "";
    private string _filterHowFoundCol = "";
    private bool _showAssetDepth = true;
    private bool _showAssetCanonical;
    private bool _showAssetPipeline = true;
    private bool _showAssetHowFound = true;

    private string _filterQueueSearch = "";
    private string _filterQueueKindCol = "";
    private string _filterQueueRawCol = "";
    private string _filterQueuePipelineCol = "";
    private bool _showQueueDomain = true;
    private bool _showQueueAttempts = true;
    private bool _showQueueTiming;
    private bool _showQueueErrors = true;

    private string _workerSearch = "";
    private string? _workerBusyKey;
    private string? _workerScaleBusyKey;

    private string _maintenanceApiKey = "";
    private string _phraseClearTargets = "";
    private string _phraseClearAssets = "";
    private string _phraseClearDomain = "";
    private string _phraseClearDomainRoot = "";
    private string _phraseClearFiltered = "";
    private string _filterDeleteKind = "";
    private string _filterDeleteStatus = "";
    private string _filterDeleteDiscoveredBy = "";
    private string _maintenanceMessage = "";
    private bool _maintenanceBusy;

    private bool _loadingAll;
    private bool _targetsLoading;
    private bool _assetsLoading;
    private bool _queueLoading;
    private bool _snapshotLoading;
    private bool _targetCreateBusy;
    private bool _targetDepthBusy;
    private bool _toolRestartBusy;
    private bool _queueSettingsBusy;
    private string _statusMessage = "";
    private string _queueSettingsMessage = "";
    private DateTimeOffset? _lastLiveEventUtc;
    private DateTimeOffset? _targetsLoadedAtUtc;
    private DateTimeOffset? _assetsLoadedAtUtc;
    private DateTimeOffset? _queueLoadedAtUtc;
    private DateTimeOffset? _snapshotLoadedAtUtc;

    private int _queueGlobalRequestsPerMinute = 120;
    private int _queuePerDomainRequestsPerMinute = 6;
    private int _queueMaxConcurrency = 8;
    private int _queueRequestTimeoutSeconds = 30;
    private int _targetBulkMaxDepth = 12;

    private Density _radzenDensity = Density.Compact;

    private IEnumerable<TargetSummary> RadzenTargets =>
        _targets.Where(t =>
            GridTextFilter.Matches(t.RootDomain, _targetSearch)
            || GridTextFilter.Matches(t.Id.ToString(), _targetSearch)
            || GridTextFilter.Matches(t.GlobalMaxDepth.ToString(CultureInfo.InvariantCulture), _targetSearch)
            || GridTextFilter.Matches(t.SubdomainCount.ToString(CultureInfo.InvariantCulture), _targetSearch)
            || GridTextFilter.Matches(t.ConfirmedAssetCount.ToString(CultureInfo.InvariantCulture), _targetSearch)
            || GridTextFilter.Matches(t.QueuedAssetCount.ToString(CultureInfo.InvariantCulture), _targetSearch)
            || GridTextFilter.Matches(FormatOpsTime(t.LastRunAtUtc), _targetSearch));

    private IEnumerable<AssetGridRowDto> RadzenAssets =>
        _assets.Where(a =>
            GridTextFilter.Matches(a.Kind, _filterAssets)
            || GridTextFilter.Matches(a.LifecycleStatus, _filterAssets)
            || GridTextFilter.Matches(a.RawValue, _filterAssets)
            || GridTextFilter.Matches(a.FinalUrl, _filterAssets)
            || GridTextFilter.Matches(a.CanonicalKey, _filterAssets)
            || GridTextFilter.Matches(a.DisplayName, _filterAssets)
            || GridTextFilter.Matches(a.Category, _filterAssets)
            || GridTextFilter.Matches(a.DiscoveredBy, _filterAssets)
            || GridTextFilter.Matches(a.DiscoveryContext, _filterAssets))
        .Where(a => GridTextFilter.Matches(a.Kind, _filterKindCol))
        .Where(a => GridTextFilter.Matches(a.LifecycleStatus, _filterStatusCol))
        .Where(a => GridTextFilter.Matches(a.RawValue, _filterRawCol) || GridTextFilter.Matches(a.FinalUrl, _filterRawCol) || GridTextFilter.Matches(a.CanonicalKey, _filterRawCol))
        .Where(a => GridTextFilter.Matches(a.DiscoveredBy, _filterPipelineCol))
        .Where(a => GridTextFilter.Matches(a.DiscoveryContext, _filterHowFoundCol));

    private IEnumerable<HttpRequestQueueRowDto> RadzenRequestQueue =>
        _requestQueue.Where(q =>
            GridTextFilter.Matches(q.RequestUrl, _filterQueueSearch)
            || GridTextFilter.Matches(q.DomainKey, _filterQueueSearch)
            || GridTextFilter.Matches(q.State, _filterQueueSearch)
            || GridTextFilter.Matches(q.FinalUrl, _filterQueueSearch)
            || GridTextFilter.Matches(q.LockedBy, _filterQueueSearch)
            || GridTextFilter.Matches(q.RequestHeadersJson, _filterQueueSearch)
            || GridTextFilter.Matches(q.RequestBody, _filterQueueSearch)
            || GridTextFilter.Matches(q.ResponseHeadersJson, _filterQueueSearch)
            || GridTextFilter.Matches(q.ResponseBody, _filterQueueSearch)
            || GridTextFilter.Matches(q.LastHttpStatus?.ToString(CultureInfo.InvariantCulture), _filterQueueSearch)
            || GridTextFilter.Matches(q.LastError, _filterQueueSearch))
        .Where(q => GridTextFilter.Matches(q.AssetKind, _filterQueueKindCol))
        .Where(q => GridTextFilter.Matches(q.RequestUrl, _filterQueueRawCol) || GridTextFilter.Matches(q.DomainKey, _filterQueueRawCol))
        .Where(q => GridTextFilter.Matches(q.State, _filterQueuePipelineCol));

    private IEnumerable<WorkerKindSummaryDto> RadzenWorkers =>
        _workerSummaries
            .Where(w =>
                GridTextFilter.Matches(w.WorkerKey, _workerSearch)
                || GridTextFilter.Matches(w.RollupActivityLabel, _workerSearch)
                || GridTextFilter.Matches(FormatOpsTime(w.LastActivityUtc), _workerSearch));

    private string LiveStateCss => Realtime.IsConnected ? "connected" : "disconnected";
    private string LiveStatusText => Realtime.IsConnected
        ? "Subscribed to command-center events"
        : "Live updates disconnected";

    private string QueueToggleButtonClass => _queueSettings?.Enabled == true ? "btn danger" : "btn primary";

    private string ColumnTitle(string key, string defaultTitle) =>
        _columnTitles.TryGetValue(key, out var title) && !string.IsNullOrWhiteSpace(title)
            ? title
            : defaultTitle;

    private void SetColumnTitle(string key, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            _columnTitles.Remove(key);
        else
            _columnTitles[key] = value.Trim();

        StateHasChanged();
    }

    private static string WorkerBadgeClass(WorkerKindSummaryDto worker) =>
        worker.ToggleEnabled ? "badge badge-green" : "badge badge-gray";

    private WorkerScaleTargetDto? WorkerScaleFor(string workerKey) =>
        _workerScaleTargets.FirstOrDefault(s => string.Equals(s.WorkerKey, workerKey, StringComparison.Ordinal));

    private int WorkerScaleInput(string workerKey)
    {
        if (_workerScaleInputs.TryGetValue(workerKey, out var value))
            return value;

        var scale = WorkerScaleFor(workerKey);
        return Math.Max(0, scale?.ManualDesiredCount ?? scale?.DesiredCount ?? scale?.RunningCount ?? 0);
    }

    private bool WorkerScaleBusy(string workerKey)
    {
        var scale = WorkerScaleFor(workerKey);
        return string.Equals(_workerScaleBusyKey, workerKey, StringComparison.Ordinal)
            || (scale is not null && string.Equals(_workerScaleBusyKey, scale.ScaleKey, StringComparison.Ordinal));
    }

    private static string WorkerScaleSummary(WorkerScaleTargetDto scale)
    {
        var desired = scale.DesiredCount?.ToString(CultureInfo.InvariantCulture) ?? "?";
        var running = scale.RunningCount?.ToString(CultureInfo.InvariantCulture) ?? "?";
        var pending = scale.PendingCount?.ToString(CultureInfo.InvariantCulture) ?? "?";
        var manual = scale.ManualDesiredCount is null
            ? "auto"
            : $"manual {scale.ManualDesiredCount.Value.ToString(CultureInfo.InvariantCulture)}";
        return $"{manual}; ECS desired {desired}, running {running}, pending {pending}";
    }

    protected override async Task OnInitializedAsync()
    {
        Realtime.DomainEventReceived += OnRealtimeEvent;
        Realtime.ConnectionStateChanged += OnRealtimeConnectionChanged;

        await ReloadAllAsync();
        await StartRealtimeAsync();
    }

    private async Task StartRealtimeAsync()
    {
        try
        {
            await Realtime.EnsureStartedAsync(_pollCts.Token);
            if (Guid.TryParse(_targetFilter, out var targetId))
                await Realtime.SubscribeTargetAsync(targetId, _pollCts.Token);
            _statusMessage = "";
        }
        catch (Exception ex)
        {
