@using NightmareV2.CommandCenter.Models
@using NightmareV2.CommandCenter
@page "/"
@page "/ops"
@rendermode InteractiveServer
@using System.Globalization
@using System.Net
@using System.Net.Http.Json
@using NightmareV2.CommandCenter.DataMaintenance
@using NightmareV2.CommandCenter.Realtime
@using NightmareV2.CommandCenter.Components.DataGrid.Cells
@using static Microsoft.AspNetCore.Components.QuickGrid.SortDirection
@implements IDisposable
@inject HttpClient Http
@inject IJSRuntime Js
@inject DiscoveryRealtimeClient Realtime

<PageTitle>Operations - Nightmare v2</PageTitle>

<div class="page-shell ops-page">
    <section class="page-hero ops-hero">
        <div>
            <p class="eyebrow">Command center</p>
            <h1>Operations</h1>
            <p class="hero-copy">Command-center workspace for target scope, asset inventory, HTTP request queue, and worker activity.</p>
            <div class="hero-meta">
                <span class="live-pill @LiveStateCss">@Realtime.State</span>
                <span>@LiveStatusText</span>
                @if (_lastLiveEventUtc is not null)
                {
                    <span>Last event @FormatOpsTime(_lastLiveEventUtc)</span>
                }
            </div>
        </div>
        <div class="hero-actions">
            <span class="muted">@(_loadingAll ? "Refreshing workspace..." : "Live event updates enabled")</span>
        </div>
    </section>

    <section class="stat-grid ops-stat-grid compact-stats" aria-label="Operations summary">
        @if (_overview is null)
        {
            <div class="stat-card wide">
                <div class="stat-label">Summary</div>
                <div class="stat-value small">Loading operational snapshot…</div>
            </div>
        }
        else
        {
            <div class="stat-card">
                <div class="stat-label">Targets</div>
                <div class="stat-value">@_overview.TotalTargets.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Confirmed assets</div>
                <div class="stat-value">@_overview.TotalAssetsConfirmed.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Subdomains discovered</div>
                <div class="stat-value">@_overview.SubdomainsDiscovered.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">HTTP Queue</div>
                <div class="stat-value">@_overview.HttpQueueQueuedAssetCount.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Last asset created</div>
                <div class="stat-value small">@FormatOpsTime(_overview.LastAssetCreatedAtUtc)</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Last worker event</div>
                <div class="stat-value small">@FormatOpsTime(_overview.LastWorkerEventPublishedAtUtc)</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">HTTP failed 1m / 1h / 24h</div>
                <div class="stat-value small">@FormatMetricTriple(_queueMetrics?.FailedLastMinuteCount, _queueMetrics?.FailedLastHourCount, _queueMetrics?.FailedLast24HoursCount)</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">HTTP sent 1m / 1h / 24h</div>
                <div class="stat-value small">@FormatMetricTriple(_queueMetrics?.SentLastMinuteCount, _queueMetrics?.SentLastHourCount, _queueMetrics?.SentLast24HoursCount)</div>
            </div>
            <div class="stat-card wide">
                <div class="stat-label">Top domain</div>
                <div class="stat-value small">@(_overview.TopDomainByAssets ?? "-") (@_overview.TopDomainAssetCount.ToString("N0") assets)</div>
            </div>
        }
    </section>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="alert">@_statusMessage</div>
    }


    <section class="panel ops-tool-actions">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Tool controls</p>
                <h2>Restart enumeration or spidering</h2>
            </div>
            <span class="muted">@SelectedToolTargetCount.ToString("N0") selected</span>
        </div>
        <p class="muted">Use the checkboxes in the Targets grid to restart tools for selected targets, or queue the restart globally for every active target.</p>
        <div class="ops-rz-toolbar">
            <button type="button" class="btn primary" disabled="@_toolRestartBusy" @onclick="@(() => RestartEnumAsync(true))">Restart enum for all targets</button>
            <button type="button" class="btn danger" disabled="@_toolRestartBusy" @onclick="@(() => RestartSpiderAsync(true))">Restart spidering for all targets</button>
            <button type="button" class="btn" disabled="@(_toolRestartBusy || SelectedToolTargetCount == 0)" @onclick="@(() => RestartEnumAsync(false))">Restart enum for selected (@SelectedToolTargetCount)</button>
            <button type="button" class="btn" disabled="@(_toolRestartBusy || SelectedToolTargetCount == 0)" @onclick="@(() => RestartSpiderAsync(false))">Restart spidering for selected (@SelectedToolTargetCount)</button>
            <button type="button" class="btn ghost" disabled="@(SelectedToolTargetCount == 0)" @onclick="ClearToolTargetSelection">Clear selection</button>
        </div>
    </section>
    <section class="ops-layout-grid">
        <section class="panel ops-primary-panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Scope</p>
                    <h2>Targets</h2>
                </div>
                <span class="muted">@_targets.Count.ToString("N0") loaded</span>
            </div>

            <div class="ops-card-row">
                <EditForm Model="TargetCreateForm" OnValidSubmit="CreateTargetAsync" FormName="@OpsTargetCreateFormName" method="post" class="inline-form">
                    <label>
                        <span>Root domain</span>
                        <InputText @bind-Value="TargetCreateForm.RootDomain" placeholder="example.com" />
                    </label>
                    <label class="short-field">
                        <span>Depth</span>
                        <InputNumber @bind-Value="TargetCreateForm.GlobalMaxDepth" />
                    </label>
                    <button type="submit" class="btn primary" disabled="@_targetCreateBusy">@(_targetCreateBusy ? "Queueing…" : "Queue target")</button>
                </EditForm>

                <div class="filter-cluster">
                    <label>
                        <span>Active target filter</span>
                        <select @bind="_targetFilter" @bind:after="ReloadTargetScopedAsync">
                            <option value="">All targets</option>
                            @foreach (var t in _targets.OrderBy(t => t.RootDomain, StringComparer.OrdinalIgnoreCase))
                            {
                                <option value="@t.Id.ToString()">@t.RootDomain</option>
                            }
                        </select>
                    </label>
                </div>
            </div>

            @if (_targetEditing is not null)
            {
                <div class="edit-drawer">
                    <EditForm Model="_targetEditing" OnValidSubmit="SaveTargetEditAsync" FormName="@OpsTargetEditFormName" method="post" class="inline-form">
                        <label>
                            <span>Edit root domain</span>
                            <InputText @bind-Value="_targetEditing.RootDomain" />
                        </label>
                        <label class="short-field">
                            <span>Depth</span>
                            <InputNumber @bind-Value="_targetEditing.GlobalMaxDepth" />
                        </label>
                        <button type="submit" class="btn primary">Save target</button>
                        <button type="button" class="btn ghost" @onclick="CancelTargetEdit">Cancel</button>
                    </EditForm>
                </div>
            }

            <div class="ops-rz-toolbar">
                <label>
                    <span>Search</span>
                    <input type="search" class="ops-filter" @bind="_targetSearch" placeholder="Domain, id, depth…" />
                </label>
                <details class="ops-rz-column-toggles column-title-editor">
                    <summary>Display names</summary>
                    @foreach (var col in TargetColumnTitleOptions)
                    {
                        <label>
                            <span>@col.Label</span>
                            <input type="text"
                                   class="ops-filter"
                                   value="@ColumnTitle(col.Key, col.DefaultTitle)"
                                   @oninput="@((ChangeEventArgs e) => SetColumnTitle(col.Key, e.Value?.ToString()))" />
                        </label>
                    }
                </details>
                <button type="button" class="btn ghost" @onclick="ClearTargetFilters">Clear filters</button>
                <button type="button" class="btn" @onclick="ExportTargetsCsvAsync">Export CSV</button>
            </div>
            <div class="ops-rz-toolbar">
                <label class="short-field">
                    <span>Set max depth</span>
                    <InputNumber @bind-Value="_targetBulkMaxDepth" />
                </label>
                <button type="button" class="btn" disabled="@(_targetDepthBusy || SelectedToolTargetCount == 0)" @onclick="@(() => UpdateTargetMaxDepthAsync(false))">Apply to selected (@SelectedToolTargetCount)</button>
                <button type="button" class="btn danger" disabled="@(_targetDepthBusy || _targets.Count == 0)" @onclick="@(() => UpdateTargetMaxDepthAsync(true))">Apply to all (@_targets.Count)</button>
            </div>

            <RadzenDataGrid TItem="TargetSummary"
                            Data="@RadzenTargets"
                            IsLoading="@_targetsLoading"
                            AllowFiltering="true"
                            FilterMode="FilterMode.Advanced"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            AllowPaging="false"
                            AllowSorting="true"
                            AllowMultiColumnSorting="true"
                            AllowColumnResize="true"
                            AllowColumnReorder="true"
                            AllowColumnPicking="true"
                            AllowGrouping="true"
                            GroupPanelText="Drag a column header here to group targets"
                            AllowVirtualization="true"
                            VirtualizationOverscanCount="24"
                            Density="@_radzenDensity"
                            EmptyText="No targets match the current filters."
                            Style="height: 860px"
                            class="ops-rz-grid">
                <Columns>
                    <RadzenDataGridColumn TItem="TargetSummary" Title="Select" Width="90px" Filterable="false" Sortable="false" Groupable="false">
                        <Template Context="row">
                            <input @key="row.Id" type="checkbox" checked="@_selectedToolTargetIds.Contains(row.Id)" @onchange="@((ChangeEventArgs e) => ToggleToolTarget(row.Id, e))" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TargetSummary" Property="Id" Title='@ColumnTitle("target.Id", "Id")' Width="280px" Visible="false" />
                    <RadzenDataGridColumn TItem="TargetSummary" Property="CreatedAtUtc" Title='@ColumnTitle("target.CreatedAtUtc", "Created")' Width="180px" SortOrder="SortOrder.Descending">
                        <Template Context="row">@FormatOpsTime(row.CreatedAtUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TargetSummary" Property="RootDomain" Title='@ColumnTitle("target.RootDomain", "Root Domain")' Width="260px" Frozen="true">
                        <Template Context="row">
                            <a class="mono" href="@RootDomainHref(row.RootDomain)" target="_blank" rel="noopener noreferrer">@row.RootDomain</a>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TargetSummary" Property="SubdomainCount" Title='@ColumnTitle("target.SubdomainCount", "Number of Subdomains")' Width="190px" />
                    <RadzenDataGridColumn TItem="TargetSummary" Property="ConfirmedAssetCount" Title='@ColumnTitle("target.ConfirmedAssetCount", "Number of Confirmed Assets")' Width="230px" />
                    <RadzenDataGridColumn TItem="TargetSummary" Property="QueuedAssetCount" Title='@ColumnTitle("target.QueuedAssetCount", "Number of Queued Assets")' Width="210px" />
                    <RadzenDataGridColumn TItem="TargetSummary" Property="GlobalMaxDepth" Title='@ColumnTitle("target.GlobalMaxDepth", "Max Depth")' Width="130px" />
                    <RadzenDataGridColumn TItem="TargetSummary" Property="LastRunAtUtc" Title='@ColumnTitle("target.LastRunAtUtc", "Last Run Time")' Width="180px">
                        <Template Context="row">@FormatOpsTime(row.LastRunAtUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TargetSummary" Title="Actions" Width="150px" Filterable="false" Sortable="false" Groupable="false">
                        <Template Context="row">
                            <div class="row-actions">
                                <button type="button" class="btn small" @onclick="@(() => StartTargetEdit(row))">Edit</button>
                                <button type="button" class="btn small danger" @onclick="@(() => DeleteTargetAsync(row))">Delete</button>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </section>
</section>

    <section class="panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Inventory</p>
                    <h2>Assets</h2>
                </div>
                <span class="muted">Updated by live events</span>
            </div>

        @if (_maintenanceStatus is { Enabled: true })
        {
            <details class="danger-zone">
                <summary>Maintenance danger zone</summary>
                <div class="danger-zone-body">
                    @if (_maintenanceStatus.ApiKeyConfigured)
                    {
                        <label>
                            <span>Maintenance API key</span>
                            <input type="password" class="ops-filter" @bind="_maintenanceApiKey" autocomplete="off" />
                        </label>
                    }
                    <label>
                        <span>Confirm all-target delete phrase</span>
                        <input type="text" class="ops-filter" @bind="_phraseClearTargets" placeholder="@DataMaintenanceEndpoints.PhraseClearAllTargets" />
                    </label>
                    <button type="button" class="btn danger" disabled="@_maintenanceBusy" @onclick="ClearAllTargetsAsync">Delete all targets</button>
                    <label>
                        <span>Confirm all-assets delete phrase</span>
                        <input type="text" class="ops-filter" @bind="_phraseClearAssets" placeholder="@DataMaintenanceEndpoints.PhraseClearAllAssets" />
                    </label>
                    <button type="button" class="btn danger" disabled="@_maintenanceBusy" @onclick="ClearAllAssetsAsync">Delete all assets</button>
                    <label>
                        <span>Domain root</span>
                        <input type="text" class="ops-filter" @bind="_phraseClearDomainRoot" placeholder="example.com" />
                    </label>
                    <label>
                        <span>Confirm domain delete phrase</span>
                        <input type="text" class="ops-filter" @bind="_phraseClearDomain" placeholder="@DataMaintenanceEndpoints.PhraseClearAssetsForDomain" />
                    </label>
                    <button type="button" class="btn danger" disabled="@_maintenanceBusy" @onclick="ClearAssetsForDomainAsync">Delete domain assets</button>
                    <label>
                        <span>Delete kind</span>
                        <input type="text" class="ops-filter" @bind="_filterDeleteKind" placeholder="Url" />
                    </label>
                    <label>
                        <span>Delete status</span>
                        <input type="text" class="ops-filter" @bind="_filterDeleteStatus" placeholder="Queued/Confirmed/NonExistent" />
                    </label>
                    <label>
                        <span>Found by contains</span>
                        <input type="text" class="ops-filter" @bind="_filterDeleteDiscoveredBy" />
                    </label>
                    <label>
                        <span>Confirm filtered delete phrase</span>
                        <input type="text" class="ops-filter" @bind="_phraseClearFiltered" placeholder="@DataMaintenanceEndpoints.PhraseClearAssetsFiltered" />
                    </label>
                    <button type="button" class="btn danger" disabled="@_maintenanceBusy" @onclick="ClearAssetsFilteredAsync">Delete filtered assets</button>
                    @if (!string.IsNullOrWhiteSpace(_maintenanceMessage))
                    {
                        <p class="muted full-row">@_maintenanceMessage</p>
                    }
                </div>
            </details>
        }

        <div class="ops-rz-toolbar">
            <label>
                <span>Search</span>
                <input type="search" class="ops-filter" @bind="_filterAssets" placeholder="Kind, status, URL, pipeline, canonical key…" />
            </label>
            <label>
                <span>Kind</span>
                <input type="text" class="ops-filter" @bind="_filterKindCol" />
            </label>
            <label>
                <span>Status</span>
                <input type="text" class="ops-filter" @bind="_filterStatusCol" />
            </label>
            <label>
                <span>Raw/canonical</span>
                <input type="text" class="ops-filter" @bind="_filterRawCol" />
            </label>
            <details class="ops-rz-column-toggles">
                <summary>Columns</summary>
                <label class="switch-row"><input type="checkbox" @bind="_showAssetDepth" /><span>Depth</span></label>
                <label class="switch-row"><input type="checkbox" @bind="_showAssetCanonical" /><span>Canonical key</span></label>
                <label class="switch-row"><input type="checkbox" @bind="_showAssetPipeline" /><span>Pipeline</span></label>
                <label class="switch-row"><input type="checkbox" @bind="_showAssetHowFound" /><span>How found</span></label>
            </details>
            <details class="ops-rz-column-toggles column-title-editor">
                <summary>Display names</summary>
                @foreach (var col in AssetColumnTitleOptions)
                {
                    <label>
                        <span>@col.Label</span>
                        <input type="text"
                               class="ops-filter"
                               value="@ColumnTitle(col.Key, col.DefaultTitle)"
                               @oninput="@((ChangeEventArgs e) => SetColumnTitle(col.Key, e.Value?.ToString()))" />
                    </label>
                }
            </details>
            <button type="button" class="btn ghost" @onclick="ClearAssetFilters">Clear filters</button>
            <button type="button" class="btn" @onclick="ExportAssetsCsvAsync">Export CSV</button>
        </div>

        <RadzenDataGrid @ref="_assetGrid"
                        @key="_assetGridVersion"
                        TItem="AssetGridRowDto"
                        Data="@RadzenAssets"
                        IsLoading="@_assetsLoading"
                        AllowFiltering="true"
                        FilterMode="FilterMode.Advanced"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        AllowPaging="false"
                        AllowSorting="true"
                        AllowMultiColumnSorting="true"
                        AllowColumnResize="true"
                        AllowColumnReorder="true"
                        AllowColumnPicking="true"
                        AllowGrouping="true"
                        GroupPanelText="Drag a column header here to group assets"
                        AllowVirtualization="true"
                        VirtualizationOverscanCount="24"
                        Density="@_radzenDensity"
                        EmptyText="No assets match the current filters."
                        Style="height: 860px"
                        class="ops-rz-grid">
            <Columns>
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="Id" Title='@ColumnTitle("asset.Id", "Id")' Width="280px" Visible="false" />
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="TargetId" Title='@ColumnTitle("asset.TargetId", "Target Id")' Width="280px" Visible="false" />
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="DiscoveredAtUtc" Title='@ColumnTitle("asset.DiscoveredAtUtc", "Discovered")' Width="180px">
                    <Template Context="a">@FormatOpsTime(a.DiscoveredAtUtc)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="LastSeenAtUtc" Title='@ColumnTitle("asset.LastSeenAtUtc", "Last Seen")' Width="180px" Visible="false">
                    <Template Context="a">@FormatOpsTime(a.LastSeenAtUtc)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="Kind" Title='@ColumnTitle("asset.Kind", "Kind")' Width="130px" />
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="Category" Title='@ColumnTitle("asset.Category", "Category")' Width="150px" Visible="false" />
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="LifecycleStatus" Title='@ColumnTitle("asset.LifecycleStatus", "Status")' Width="150px" />
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="Depth" Title='@ColumnTitle("asset.Depth", "Depth")' Width="110px" Visible="@_showAssetDepth" />
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="Confidence" Title='@ColumnTitle("asset.Confidence", "Confidence")' Width="130px" Visible="false" />
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="DisplayName" Title='@ColumnTitle("asset.DisplayName", "Display Name")' Width="220px" Visible="false" />
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="RawValue" Title='@ColumnTitle("asset.RawValue", "Raw")' Width="380px" Frozen="true">
                    <Template Context="a">
                        @{
                            var href = ToLiveHref(a);
                        }
                        @if (string.IsNullOrEmpty(href))
                        {
                            <span class="ops-rz-clip" title="@a.RawValue">@a.RawValue</span>
                        }
                        else
                        {
                            <a href="@href" target="_blank" rel="noopener noreferrer"><span class="ops-rz-clip" title="@a.RawValue">@a.RawValue</span></a>
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="FinalUrl" Title='@ColumnTitle("asset.FinalUrl", "Final URL")' Width="380px">
                    <Template Context="a"><span class="ops-rz-clip" title="@a.FinalUrl">@a.FinalUrl</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="RedirectCount" Title='@ColumnTitle("asset.RedirectCount", "Redirects")' Width="120px" />
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="CanonicalKey" Title='@ColumnTitle("asset.CanonicalKey", "Canonical")' Width="320px" Visible="@_showAssetCanonical">
                    <Template Context="a"><span class="mono ops-rz-clip" title="@a.CanonicalKey">@a.CanonicalKey</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="DiscoveredBy" Title='@ColumnTitle("asset.DiscoveredBy", "Pipeline")' Width="180px" Visible="@_showAssetPipeline" />
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="DiscoveryContext" Title='@ColumnTitle("asset.DiscoveryContext", "How found")' Width="360px" Visible="@_showAssetHowFound">
                    <Template Context="a"><span class="ops-rz-clip" title="@a.DiscoveryContext">@a.DiscoveryContext</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AssetGridRowDto" Property="TypeDetailsJson" Title='@ColumnTitle("asset.TypeDetailsJson", "Type Details JSON")' Width="420px" Visible="false">
                    <Template Context="a"><span class="ops-rz-clip" title="@a.TypeDetailsJson">@a.TypeDetailsJson</span></Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </section>

    <section class="ops-stack-grid">
        <section class="panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">HTTP</p>
                    <h2>Request queue</h2>
                </div>
                <span class="muted">Updated by live events</span>
            </div>

            @if (_queueSettings is not null)
            {
                <div class="settings-strip">
                    <button type="button" class="@QueueToggleButtonClass" disabled="@_queueSettingsBusy" @onclick="ToggleHttpQueueAsync">
                        @(_queueSettings.Enabled ? "Pause new requests" : "Resume new requests")
                    </button>
                    <label>
                        <span>Global req/min</span>
                        <input type="number" min="1" @bind="_queueGlobalRequestsPerMinute" />
                    </label>
                    <label>
                        <span>Per-domain req/min</span>
                        <input type="number" min="1" @bind="_queuePerDomainRequestsPerMinute" />
                    </label>
                    <label>
                        <span>Max concurrency</span>
                        <input type="number" min="1" @bind="_queueMaxConcurrency" />
                    </label>
                    <label>
                        <span>Timeout sec</span>
                        <input type="number" min="5" max="300" @bind="_queueRequestTimeoutSeconds" />
                    </label>
                    <button type="button" class="btn primary" disabled="@_queueSettingsBusy" @onclick="SaveHttpQueueSettingsAsync">Save</button>
                </div>
                <p class="muted">Queue is @(_queueSettings.Enabled ? "enabled" : "disabled"); updated @FormatOpsTime(_queueSettings.UpdatedAtUtc). @_queueSettingsMessage</p>
            }

            <div class="mini-metrics">
                <span>Backlog <strong>@(_queueMetrics?.BacklogCount.ToString("N0") ?? "-")</strong></span>
                <span>In flight <strong>@(_queueMetrics?.InFlightCount.ToString("N0") ?? "-")</strong></span>
                <span>Failed <strong>@(_queueMetrics?.FailedCount.ToString("N0") ?? "-")</strong></span>
                <span>Completed/hour <strong>@(_queueMetrics?.CompletedLastHourCount.ToString("N0") ?? "-")</strong></span>
            </div>

            <div class="ops-rz-toolbar">
                <label>
                    <span>Search</span>
                    <input type="search" class="ops-filter" @bind="_filterQueueSearch" placeholder="URL, domain, state, HTTP status, error…" />
                </label>
                <label>
                    <span>Kind</span>
                    <input type="text" class="ops-filter" @bind="_filterQueueKindCol" />
                </label>
                <label>
                    <span>URL/domain</span>
                    <input type="text" class="ops-filter" @bind="_filterQueueRawCol" />
                </label>
                <label>
                    <span>State</span>
                    <input type="text" class="ops-filter" @bind="_filterQueuePipelineCol" />
                </label>
                <details class="ops-rz-column-toggles">
                    <summary>Columns</summary>
                    <label class="switch-row"><input type="checkbox" @bind="_showQueueDomain" /><span>Domain</span></label>
                    <label class="switch-row"><input type="checkbox" @bind="_showQueueAttempts" /><span>Attempts</span></label>
                    <label class="switch-row"><input type="checkbox" @bind="_showQueueTiming" /><span>Timing</span></label>
                    <label class="switch-row"><input type="checkbox" @bind="_showQueueErrors" /><span>Errors</span></label>
                </details>
                <details class="ops-rz-column-toggles column-title-editor">
                    <summary>Display names</summary>
                    @foreach (var col in QueueColumnTitleOptions)
                    {
                        <label>
                            <span>@col.Label</span>
                            <input type="text"
                                   class="ops-filter"
                                   value="@ColumnTitle(col.Key, col.DefaultTitle)"
                                   @oninput="@((ChangeEventArgs e) => SetColumnTitle(col.Key, e.Value?.ToString()))" />
                        </label>
                    }
                </details>
                <button type="button" class="btn ghost" @onclick="ClearQueueFilters">Clear filters</button>
                <button type="button" class="btn" @onclick="ExportQueueCsvAsync">Export CSV</button>
            </div>

            <RadzenDataGrid @ref="_queueGrid"
                            @key="_queueGridVersion"
                            TItem="HttpRequestQueueRowDto"
                            Data="@RadzenRequestQueue"
                            IsLoading="@_queueLoading"
                            AllowFiltering="true"
                            FilterMode="FilterMode.Advanced"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            AllowPaging="false"
                            AllowSorting="true"
                            AllowMultiColumnSorting="true"
                            AllowColumnResize="true"
                            AllowColumnReorder="true"
                            AllowColumnPicking="true"
                            AllowGrouping="true"
                            GroupPanelText="Drag a column header here to group queue rows"
                            AllowVirtualization="true"
