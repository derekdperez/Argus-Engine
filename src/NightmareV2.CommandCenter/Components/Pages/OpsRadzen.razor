                            Density="@_radzenDensity"
                            EmptyText="No queue rows match the current filters."
                            Style="height: 860px"
                            class="ops-rz-grid">
                <Columns>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="Id" Title='@ColumnTitle("queue.Id", "Id")' Width="280px" Visible="false" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="AssetId" Title='@ColumnTitle("queue.AssetId", "Asset Id")' Width="280px" Visible="false" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="TargetId" Title='@ColumnTitle("queue.TargetId", "Target Id")' Width="280px" Visible="false" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="CreatedAtUtc" Title='@ColumnTitle("queue.CreatedAtUtc", "Created")' Width="180px">
                        <Template Context="q">@FormatOpsTime(q.CreatedAtUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="UpdatedAtUtc" Title='@ColumnTitle("queue.UpdatedAtUtc", "Updated")' Width="180px" Visible="@_showQueueTiming">
                        <Template Context="q">@FormatOpsTime(q.UpdatedAtUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="State" Title='@ColumnTitle("queue.State", "State")' Width="130px" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="AssetKind" Title='@ColumnTitle("queue.AssetKind", "Kind")' Width="130px" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="Method" Title='@ColumnTitle("queue.Method", "Method")' Width="100px" Visible="false" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="RequestUrl" Title='@ColumnTitle("queue.RequestUrl", "Request URL")' Width="420px" Frozen="true">
                        <Template Context="q">
                            @{
                                var href = ToLiveHref(q);
                            }
                            @if (string.IsNullOrEmpty(href))
                            {
                                <span class="ops-rz-clip" title="@q.RequestUrl">@q.RequestUrl</span>
                            }
                            else
                            {
                                <a href="@href" target="_blank" rel="noopener noreferrer"><span class="ops-rz-clip" title="@q.RequestUrl">@q.RequestUrl</span></a>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="DomainKey" Title='@ColumnTitle("queue.DomainKey", "Domain")' Width="220px" Visible="@_showQueueDomain" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="AttemptCount" Title='@ColumnTitle("queue.AttemptCount", "Attempts")' Width="120px" Visible="@_showQueueAttempts" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="MaxAttempts" Title='@ColumnTitle("queue.MaxAttempts", "Max Attempts")' Width="140px" Visible="false" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="Priority" Title='@ColumnTitle("queue.Priority", "Priority")' Width="110px" Visible="@_showQueueAttempts" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="NextAttemptAtUtc" Title='@ColumnTitle("queue.NextAttemptAtUtc", "Next Attempt")' Width="180px" Visible="false">
                        <Template Context="q">@FormatOpsTime(q.NextAttemptAtUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="StartedAtUtc" Title='@ColumnTitle("queue.StartedAtUtc", "Started")' Width="180px" Visible="false">
                        <Template Context="q">@FormatOpsTime(q.StartedAtUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="CompletedAtUtc" Title='@ColumnTitle("queue.CompletedAtUtc", "Completed")' Width="180px" Visible="false">
                        <Template Context="q">@FormatOpsTime(q.CompletedAtUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="LockedBy" Title='@ColumnTitle("queue.LockedBy", "Locked By")' Width="220px" Visible="false" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="LockedUntilUtc" Title='@ColumnTitle("queue.LockedUntilUtc", "Locked Until")' Width="180px" Visible="false">
                        <Template Context="q">@FormatOpsTime(q.LockedUntilUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="LastHttpStatus" Title='@ColumnTitle("queue.LastHttpStatus", "HTTP")' Width="110px" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="DurationMs" Title='@ColumnTitle("queue.DurationMs", "Duration ms")' Width="140px" Visible="@_showQueueTiming" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="RequestHeadersJson" Title='@ColumnTitle("queue.RequestHeadersJson", "Request Headers JSON")' Width="420px" Visible="false">
                        <Template Context="q"><GridEllipsisCell Text="@q.RequestHeadersJson" Title="@q.RequestHeadersJson" /></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="RequestBody" Title='@ColumnTitle("queue.RequestBody", "Request Body")' Width="360px" Visible="false">
                        <Template Context="q"><GridEllipsisCell Text="@q.RequestBody" Title="@q.RequestBody" /></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="ResponseHeadersJson" Title='@ColumnTitle("queue.ResponseHeadersJson", "Response Headers JSON")' Width="420px" Visible="false">
                        <Template Context="q"><GridEllipsisCell Text="@q.ResponseHeadersJson" Title="@q.ResponseHeadersJson" /></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="ResponseBody" Title='@ColumnTitle("queue.ResponseBody", "Response Body")' Width="420px" Visible="false">
                        <Template Context="q"><GridEllipsisCell Text="@q.ResponseBody" Title="@q.ResponseBody" /></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="ResponseContentType" Title='@ColumnTitle("queue.ResponseContentType", "Response Content Type")' Width="220px" Visible="false" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="ResponseContentLength" Title='@ColumnTitle("queue.ResponseContentLength", "Response Length")' Width="150px" Visible="false" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="FinalUrl" Title='@ColumnTitle("queue.FinalUrl", "Final URL")' Width="420px">
                        <Template Context="q"><span class="ops-rz-clip" title="@q.FinalUrl">@q.FinalUrl</span></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="RedirectCount" Title='@ColumnTitle("queue.RedirectCount", "Redirects")' Width="120px" />
                    <RadzenDataGridColumn TItem="HttpRequestQueueRowDto" Property="LastError" Title='@ColumnTitle("queue.LastError", "Last error")' Width="360px" Visible="@_showQueueErrors">
                        <Template Context="q"><span class="ops-rz-clip" title="@q.LastError">@q.LastError</span></Template>
