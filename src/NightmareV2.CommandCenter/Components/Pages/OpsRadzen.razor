    private void SetWorkerScaleInput(string workerKey, string? raw)
    {
        if (!int.TryParse(raw, NumberStyles.Integer, CultureInfo.InvariantCulture, out var desired))
            return;

        _workerScaleInputs[workerKey] = Math.Max(0, desired);
    }

    private Task ChangeWorkerScaleAsync(string workerKey, int delta)
    {
        var desired = Math.Max(0, WorkerScaleInput(workerKey) + delta);
        _workerScaleInputs[workerKey] = desired;
        return SetWorkerScaleAsync(workerKey, desired);
    }

    private Task ApplyWorkerScaleInputAsync(string workerKey) =>
        SetWorkerScaleAsync(workerKey, WorkerScaleInput(workerKey));

    private async Task SetWorkerScaleAsync(string workerKey, int desiredCount)
    {
        var scale = WorkerScaleFor(workerKey);
        if (scale is null)
        {
            _statusMessage = $"{workerKey} does not map to a scalable ECS worker service.";
            return;
        }

        _workerScaleBusyKey = scale.ScaleKey;
        _statusMessage = "";
        try
        {
            var response = await Http.PutAsJsonAsync(
                    $"/api/workers/{Uri.EscapeDataString(workerKey)}/scale",
                    new WorkerScalePatchRequest(Math.Max(0, desiredCount)))
                .ConfigureAwait(false);
            response.EnsureSuccessStatusCode();
            var result = await response.Content.ReadFromJsonAsync<WorkerScaleUpdateResult>().ConfigureAwait(false);
            _statusMessage = result?.Message ?? $"{scale.ScaleKey} desired count updated.";
            await ReloadWorkerScaleAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
        finally
        {
            _workerScaleBusyKey = null;
        }
    }

