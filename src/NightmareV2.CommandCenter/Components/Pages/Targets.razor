@page "/targets"
@rendermode InteractiveServer
@using System.Net
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.AspNetCore.Components.QuickGrid
@using NightmareV2.CommandCenter.Components.DataGrid
@using NightmareV2.CommandCenter.Components.DataGrid.Cells
@using NightmareV2.CommandCenter.Models
@using NightmareV2.CommandCenter.Realtime
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime Js
@inject DiscoveryRealtimeClient Realtime
@implements IDisposable

<PageTitle>Targets · Nightmare v2</PageTitle>

<h1>Recon targets</h1>

<section class="panel">
    <h2>Add target</h2>
    <EditForm Model="Form" OnValidSubmit="CreateAsync" FormName="@AddTargetFormName" method="post">
        <div>
            <label>Root domain</label>
            <InputText @bind-Value="Form.RootDomain" placeholder="example.com" />
        </div>
        <div>
            <label>Max depth</label>
            <InputNumber @bind-Value="Form.GlobalMaxDepth" />
        </div>
        <button type="submit" disabled="@_createBusy">@(_createBusy ? "Publishing…" : "Publish TargetCreated")</button>
    </EditForm>
    @if (!string.IsNullOrEmpty(_status))
    {
        <p role="status">@_status</p>
    }
</section>

<section class="panel">
    <h2>Bulk import</h2>
    <p class="muted">Plain text file: one root domain per line. Blank lines are ignored. Duplicates in the file or already in the database are skipped.</p>
    <form method="post" action="/api/targets/bulk" enctype="multipart/form-data">
        <div class="row">
            <label>
                Max depth
                <input type="number" name="globalMaxDepth" min="1" value="@(Form.GlobalMaxDepth > 0 ? Form.GlobalMaxDepth : 12)" />
            </label>
            <label>
                Target file
                <input type="file" name="file" accept=".txt,text/plain" required />
            </label>
            <button type="submit">Import file</button>
        </div>
    </form>
    @if (!string.IsNullOrEmpty(_bulkStatus))
    {
        <p role="status">@_bulkStatus</p>
    }
</section>

@if (_editing is not null)
{
    <section class="panel">
        <h2>Edit target</h2>
        <EditForm Model="_editing" OnValidSubmit="SaveEditAsync" FormName="@EditTargetFormName" method="post">
            <div>
                <label>Root domain</label>
                <InputText @bind-Value="_editing.RootDomain" />
            </div>
            <div>
                <label>Max depth</label>
                <InputNumber @bind-Value="_editing.GlobalMaxDepth" />
            </div>
            <div class="row">
                <button type="submit">Save</button>
                <button type="button" @onclick="CancelEdit">Cancel</button>
            </div>
        </EditForm>
    </section>
}

<section class="panel">
    <h2>Update max depth</h2>
    <div class="row">
        <label>
            Max depth
            <InputNumber @bind-Value="_bulkMaxDepth" />
        </label>
        <button type="button" disabled="@(_bulkDepthBusy || FilteredTargetCount == 0)" @onclick="@(() => UpdateBulkDepthAsync(false))">
            Apply to filtered (@FilteredTargetCount)
        </button>
        <button type="button" disabled="@(_bulkDepthBusy || _rows.Count == 0)" @onclick="@(() => UpdateBulkDepthAsync(true))">
            Apply to all (@_rows.Count)
        </button>
    </div>
    @if (!string.IsNullOrEmpty(_bulkDepthStatus))
    {
        <p role="status">@_bulkDepthStatus</p>
    }
</section>

<h2>Recent targets</h2>
@if (_rows.Count == 0)
{
    <p>No targets yet.</p>
}
else
{
    <section class="panel">
        <NightmareDataGrid TGridItem="TargetSummary"
                           Items="FilteredTargets"
                           @bind-SearchText="_targetSearch"
                           SearchPlaceholder="Search root domain or id…"
                           ScrollPreset="NightmareDataGridScrollPreset.Virtualized"
                           Virtualize="true"
                           VirtualizedHeightPixels="860"
                           ItemSize="44"
                           ItemKey="@(r => r.Id)"
                           OverscanCount="8"
                           RowMatches="@TargetRowMatches"
                           HostTabIndex="@(-1)"
                           ShowDensityPicker="true"
                           RefreshRequested="ReloadAsync"
                           LastUpdatedUtc="_lastLoadedAtUtc"
                           ClearFiltersRequested="ClearTargetFilters"
                           ActiveFilterCount="@TargetActiveFilterCount"
                           EnableCsvExport="true"
                           ExportFileName="nightmare-targets.csv"
                           PersistKey="targets"
                           StickyFirstColumn="true">
            <ConfigurationTemplate>
                <div class="grid-config compact">
                    <button type="button" class="btn ghost" @onclick="ClearTargetFilters">Clear filters</button>
                </div>
            </ConfigurationTemplate>
            <ChildContent>
                <TemplateColumn Title="Root domain" Context="row" SortBy="@SortTargetRoot">
                    <strong><GridCodeCell Text="@row.RootDomain" /></strong>
                </TemplateColumn>
                <PropertyColumn Title="Max depth" Property="@(row => row.GlobalMaxDepth)" Sortable="true" />
                <TemplateColumn Title="Created" Context="row" SortBy="@SortTargetCreated">
                    <GridDateCell Value="@row.CreatedAtUtc" />
                </TemplateColumn>
                <TemplateColumn Title="Actions" Context="row">
                    <button type="button" @onclick="@(() => StartEdit(row))">Edit</button>
                    <button type="button" @onclick="@(() => DeleteAsync(row))">Delete</button>
                </TemplateColumn>
            </ChildContent>
        </NightmareDataGrid>
    </section>
}

@code {
    private const string AddTargetFormName = "add-target";
    private const string EditTargetFormName = "edit-target";

    [SupplyParameterFromForm(FormName = AddTargetFormName)]
    private TargetForm? _form { get; set; }
    private TargetForm Form => _form ??= new();
    private readonly List<TargetSummary> _rows = new();
    private string _targetSearch = "";
    private string? _status;
    private string? _bulkStatus;
    private string? _bulkDepthStatus;
    private bool _createBusy;
    private bool _bulkDepthBusy;
    private int _bulkMaxDepth = 12;
    private TargetEditForm? _editing;
    private DateTimeOffset? _lastLoadedAtUtc;

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("bulkStatus", out var bulkStatus))
            _bulkStatus = bulkStatus.ToString();

        Realtime.DomainEventReceived += OnRealtimeEvent;
        await ReloadAsync();
        await StartRealtimeAsync();
    }

    private async Task StartRealtimeAsync()
    {
        try
        {
            await Realtime.EnsureStartedAsync();
        }
        catch
        {
            // The page still works with manual refresh/CRUD if the live hub is unavailable.
        }
    }

    private void OnRealtimeEvent(object? sender, LiveUiEventDto evt)
    {
        if (evt.Scope != "targets")
            return;

        _ = InvokeAsync(async () =>
        {
            await ReloadAsync();
            StateHasChanged();
        });
    }

    private async Task ReloadAsync()
    {
        try
        {
            var list = await Http.GetFromJsonAsync<List<TargetSummary>>("/api/targets");
            _rows.Clear();
            if (list is not null)
                _rows.AddRange(list);

            _lastLoadedAtUtc = DateTimeOffset.UtcNow;
        }
        catch
        {
            _status = "Could not load targets (is the API running?)";
        }
    }

    private async Task CreateAsync()
    {
        if (_createBusy)
            return;

        _status = null;
        _createBusy = true;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/targets", new CreateTargetRequest(Form.RootDomain, Form.GlobalMaxDepth));
            if (response.StatusCode == HttpStatusCode.BadRequest || response.StatusCode == HttpStatusCode.Conflict)
            {
                _status = await ReadResponseMessageAsync(response, "Target could not be created.");
                return;
            }

            response.EnsureSuccessStatusCode();
            _status = "Target queued.";
            _form = new TargetForm { GlobalMaxDepth = Form.GlobalMaxDepth > 0 ? Form.GlobalMaxDepth : 12 };
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _status = ex.Message;
        }
        finally
        {
            _createBusy = false;
        }
    }

    private void StartEdit(TargetSummary row)
    {
        _editing = new TargetEditForm(row.Id, row.RootDomain, row.GlobalMaxDepth);
        _status = null;
    }

    private void CancelEdit()
    {
        _editing = null;
    }

    private async Task SaveEditAsync()
    {
        if (_editing is null)
            return;
        _status = null;
        try
        {
            var response = await Http.PutAsJsonAsync($"/api/targets/{_editing.Id}", new UpdateTargetRequest(_editing.RootDomain, _editing.GlobalMaxDepth));
            if (response.StatusCode == HttpStatusCode.Conflict)
            {
                _status = await ReadResponseMessageAsync(response, "Root domain is already in use.");
                return;
            }

            response.EnsureSuccessStatusCode();
            _editing = null;
            _status = "Target updated.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _status = ex.Message;
        }
    }

    private async Task DeleteAsync(TargetSummary row)
    {
        var ok = await Js.InvokeAsync<bool>("confirm", $"Delete target {row.RootDomain}? Related assets and findings are removed with the target.");
        if (!ok)
            return;
        _status = null;
        try
        {
            var response = await Http.DeleteAsync($"/api/targets/{row.Id}");
            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                _status = "Target was already removed.";
                await ReloadAsync();
                return;
            }

            response.EnsureSuccessStatusCode();
            _status = "Target deleted.";
            if (_editing?.Id == row.Id)
                _editing = null;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _status = ex.Message;
        }
    }

    private async Task UpdateBulkDepthAsync(bool allTargets)
    {
        _bulkDepthStatus = null;
        if (_bulkMaxDepth <= 0)
        {
            _bulkDepthStatus = "Max depth must be greater than zero.";
            return;
        }

        var targetIds = allTargets
            ? null
            : FilteredTargets.Select(t => t.Id).Distinct().ToArray();
        var targetCount = allTargets ? _rows.Count : targetIds?.Length ?? 0;
        if (targetCount == 0)
        {
            _bulkDepthStatus = "No targets match the current filters.";
            return;
        }

        var scope = allTargets ? "all targets" : $"{targetCount} filtered targets";
        var ok = await Js.InvokeAsync<bool>("confirm", $"Set max depth to {_bulkMaxDepth} for {scope}?");
        if (!ok)
            return;

        _bulkDepthBusy = true;
        try
        {
            var response = await Http.PutAsJsonAsync(
                "/api/targets/max-depth",
                new UpdateTargetMaxDepthRequest(_bulkMaxDepth, targetIds, allTargets));
            if (response.StatusCode == HttpStatusCode.BadRequest)
            {
                _bulkDepthStatus = await ReadResponseMessageAsync(response, "Max depth could not be updated.");
                return;
            }

            response.EnsureSuccessStatusCode();
            var result = await response.Content.ReadFromJsonAsync<UpdateTargetMaxDepthResult>();
            _bulkDepthStatus = result is null
                ? "Max depth updated."
                : $"Updated {result.Updated} targets to max depth {result.GlobalMaxDepth}.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _bulkDepthStatus = ex.Message;
        }
        finally
        {
            _bulkDepthBusy = false;
        }
    }

    private async Task BulkImportAsync(InputFileChangeEventArgs e)
    {
        _bulkStatus = null;
        var file = e.File;
        if (file is null)
            return;
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 5_000_000);
            using var reader = new StreamReader(stream);
            var text = await reader.ReadToEndAsync();
            var lines = TargetRootNormalization.SplitLines(text).ToList();
            var response = await Http.PostAsJsonAsync("/api/targets/bulk", new BulkImportRequest(lines, Form.GlobalMaxDepth));
            if (response.StatusCode == HttpStatusCode.BadRequest)
            {
                _bulkStatus = await response.Content.ReadAsStringAsync();
                return;
            }

            response.EnsureSuccessStatusCode();
            var result = await response.Content.ReadFromJsonAsync<BulkImportResult>();
            if (result is not null)
            {
                _bulkStatus =
                    $"Created {result.Created}, skipped {result.SkippedAlreadyExist} already in DB, {result.SkippedDuplicateInBatch} duplicate lines in file, {result.SkippedEmptyOrInvalid} empty or invalid lines.";
            }
            else
            {
                _bulkStatus = "Import finished.";
            }

            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _bulkStatus = ex.Message;
        }
    }

    private static async Task<string> ReadResponseMessageAsync(HttpResponseMessage response, string fallback)
    {
        var message = await response.Content.ReadAsStringAsync();
        return string.IsNullOrWhiteSpace(message) ? fallback : message;
    }

    public sealed class TargetForm
    {
        public string RootDomain { get; set; } = "example.com";
        public int GlobalMaxDepth { get; set; } = 12;
    }

    private static readonly GridSort<TargetSummary> SortTargetRoot =
        GridSort<TargetSummary>.ByAscending(static r => r.RootDomain);

    private static readonly GridSort<TargetSummary> SortTargetCreated =
        GridSort<TargetSummary>.ByDescending(static r => r.CreatedAtUtc);

    private static bool TargetRowMatches(TargetSummary r, string q) =>
        GridTextFilter.Matches(r.RootDomain, q)
        || GridTextFilter.Matches(r.Id.ToString(), q);

    private IQueryable<TargetSummary> FilteredTargets => _rows.AsQueryable();

    private int FilteredTargetCount => _rows.Count;

    private int TargetActiveFilterCount => 0;

    private void ClearTargetFilters()
    {
        _targetSearch = "";
    }

    private sealed class TargetEditForm
    {
        public TargetEditForm(Guid id, string rootDomain, int globalMaxDepth)
        {
            Id = id;
            RootDomain = rootDomain;
            GlobalMaxDepth = globalMaxDepth;
        }

        public Guid Id { get; }
        public string RootDomain { get; set; }
        public int GlobalMaxDepth { get; set; }
    }

    public void Dispose()
    {
        Realtime.DomainEventReceived -= OnRealtimeEvent;
    }

}
