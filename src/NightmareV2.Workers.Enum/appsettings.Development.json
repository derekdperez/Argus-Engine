{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Enumeration": {
    "UseSubfinder": true,
    "SubfinderPath": "subfinder",
    "SubfinderAllSources": true,
    "SubfinderRecursive": true,
    "SubfinderTimeoutSeconds": 180,
    "UseAmass": true,
    "AmassPath": "amass",
    "AmassActive": true,
    "AmassBruteForce": true,
    "AmassTimeoutSeconds": 900,
    "UseDnsFallback": true,
    "DnsFallbackMaxCandidates": 300,
    "SubdomainWordlistPath": "deploy/wordlists/subdomains.txt"
  }
}
