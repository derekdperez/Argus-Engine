      "PHP"
    ]
  },
  "WordPress": {
    "description": "WordPress content management system",
    "website": "https://wordpress.org/",
    "html": [
      "wp-content",
      "wp-includes",
      "<meta[^>]+name=[\\\"']generator[\\\"'][^>]+WordPress"
    ],
    "meta": {
      "generator": "WordPress(?: ([\\d.]+))?\\;version:\\1"
    },
    "scripts": [
      "wp-(?:includes|content)/"
    ],
    "implies": [
      "PHP"
    ]
  },
  "Drupal": {
    "description": "Drupal content management system",
    "website": "https://www.drupal.org/",
    "headers": {
      "x-generator": "Drupal(?: ([\\d.]+))?\\;version:\\1"
    },
    "html": [
      "drupal-settings-json",
      "content=[\\\"']Drupal"
    ],
    "meta": {
      "generator": "Drupal(?: ([\\d.]+))?\\;version:\\1"
    },
    "implies": [
      "PHP"
    ]
  },
  "Joomla": {
    "description": "Joomla content management system",
