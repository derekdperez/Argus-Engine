    "headers": {
      "x-aspnet-version": "",
      "x-powered-by": "ASP\\.NET"
    },
    "html": [
      "__VIEWSTATE",
      "WebResource\\.axd"
    ],
    "implies": [
      "Microsoft"
    ]
  },
  "ASP.NET Core": {
    "description": "Microsoft ASP.NET Core web framework",
